{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name
  assign fallback_share_image = 'prime-og-share.jpg' | asset_url
  assign fallback_share_image_prefix = fallback_share_image | slice: 0, 2
  if fallback_share_image_prefix == '//'
    assign fallback_share_image = 'https:' | append: fallback_share_image
  elsif fallback_share_image contains 'http'
    assign fallback_share_image = fallback_share_image
  else
    assign fallback_share_image = request.origin | append: fallback_share_image
  endif

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">

{%- if page_image -%}
  <meta property="og:image" content="http:{{ page_image | image_url }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url }}">
  <meta property="og:image:width" content="{{ page_image.width }}">
  <meta property="og:image:height" content="{{ page_image.height }}">
  <meta property="og:image:alt" content="{{ og_title | escape }}">
  <meta name="twitter:image" content="https:{{ page_image | image_url }}">
  <meta name="twitter:image:alt" content="{{ og_title | escape }}">
{%- else -%}
  <meta property="og:image" content="{{ fallback_share_image }}">
  <meta property="og:image:secure_url" content="{{ fallback_share_image }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="675">
  <meta property="og:image:alt" content="Prime Pet Food Himalayan yak cheese dog chews">
  <meta name="twitter:image" content="{{ fallback_share_image }}">
  <meta name="twitter:image:alt" content="Prime Pet Food Himalayan yak cheese dog chews">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- if settings.social_x_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_x_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">

<meta name="theme:name" content="Ignite">
<meta name="theme:version" content="2.5.0">
<meta name="theme:preset" content="{% if settings.color_overlay == '#010101' %}tech{% elsif settings.color_overlay == '#020202' %}fashion{% elsif settings.color_overlay == '#030303' %}toys{% elsif settings.color_overlay == '#040404' %}pets{% elsif settings.color_overlay == '#050505' %}automotive{% elsif settings.color_overlay == '#060606' %}food{% else %}unknown{% endif %}">
{% if request.design_mode %}<meta name="theme:contact" content="{{ shop.email | escape }}">{% endif %}

{%- if request.page_type == 'product' and product != blank -%}
  {%- liquid
    assign product_description = product.description | strip_html | default: product.title | truncate: 500
    assign product_schema_image = product.featured_media | image_url: width: 1200 | prepend: 'https:'
  -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product_description | json }},
      "url": {{ canonical_url | json }},
      "brand": {
        "@type": "Brand",
        "name": {{ shop.name | json }}
      },
      {%- if product.featured_media -%}
        "image": [{{ product_schema_image | json }}],
      {%- endif -%}
      "category": {{ product.type | default: 'Dog Chews' | json }},
      "sku": {{ product.selected_or_first_available_variant.sku | default: product.selected_or_first_available_variant.id | json }},
      {%- if product.selected_or_first_available_variant.barcode != blank -%}
        "gtin": {{ product.selected_or_first_available_variant.barcode | json }},
      {%- endif -%}
      "offers": [
        {%- for variant in product.variants -%}
          {
            "@type": "Offer",
            "name": {{ variant.title | json }},
            "sku": {{ variant.sku | default: variant.id | json }},
            {%- if variant.barcode != blank -%}
              "gtin": {{ variant.barcode | json }},
            {%- endif -%}
            "priceCurrency": {{ cart.currency.iso_code | json }},
            "price": {{ variant.price | divided_by: 100.0 | json }},
            "availability": "https://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
            "itemCondition": "https://schema.org/NewCondition",
            "url": {{ request.origin | append: variant.url | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "2400"
      }
    }
  </script>
{%- endif -%}

{%- unless request.page_type == 'index' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ request.origin | append: routes.root_url | json }}
        }
        {%- if request.page_type == 'product' and product != blank -%}
          {%- if collection != blank -%}
            ,{
              "@type": "ListItem",
              "position": 2,
              "name": {{ collection.title | json }},
              "item": {{ request.origin | append: collection.url | json }}
            }
            ,{
              "@type": "ListItem",
              "position": 3,
              "name": {{ product.title | json }},
              "item": {{ canonical_url | json }}
            }
          {%- else -%}
            ,{
              "@type": "ListItem",
              "position": 2,
              "name": {{ product.title | json }},
              "item": {{ canonical_url | json }}
            }
          {%- endif -%}
        {%- elsif request.page_type == 'collection' and collection != blank -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }},
            "item": {{ canonical_url | json }}
          }
        {%- elsif page_title != blank -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ page_title | json }},
            "item": {{ canonical_url | json }}
          }
        {%- endif -%}
      ]
    }
  </script>
{%- endunless -%}
