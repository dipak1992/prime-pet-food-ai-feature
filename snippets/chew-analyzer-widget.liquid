{% comment %}
  Prime Pet Food - Chew Analyzer Widget
  Place this snippet on product pages to show the "How Long Will This Last" analyzer.
  Usage: {% render 'chew-analyzer-widget' %}
{% endcomment %}

<div
  class="ca-widget-container"
  id="chew-analyzer-widget"
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-url="{% if product %}{{ product.url }}{% else %}/products/himalayan-yak-chews-for-dogs{% endif %}"
  data-placement="{% if product %}product_page{% else %}content_page{% endif %}"
>
  <!-- Widget renders via JavaScript -->
</div>

{{ 'chew-analyzer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'chew-analyzer.js' | asset_url }}" defer></script>
