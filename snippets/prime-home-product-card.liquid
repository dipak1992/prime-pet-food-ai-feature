<article class="ph-product-card">
  {% if image != blank %}
    <div class="ph-product-card__media">
      <img src="{{ image }}" alt="{{ image_alt | escape }}" loading="lazy" width="1024" height="1024">
      {% if label != blank %}
        <span class="ph-product-card__label">{{ label }}</span>
      {% endif %}
    </div>
  {% endif %}

  <div class="ph-product-card__body">
    <span class="ph-product-card__badge">{{ badge }}</span>
    <h3>{{ title }}</h3>
    <span class="ph-product-card__fit">{{ fit }}</span>
    {% if best_for != blank %}
      <span class="ph-product-card__best">Best for {{ best_for }}</span>
    {% endif %}
    <p>{{ text }}</p>
  </div>

  <div class="ph-product-card__footer">
    {% if variant != blank %}
      <div class="ph-product-card__buy-meta">
        <span class="ph-product-card__price">From {{ variant.price | money }}</span>
        <span class="ph-product-card__note">Ships fast from Prime Pet Food</span>
      </div>
      <form method="post" action="/cart/add">
        <input type="hidden" name="id" value="{{ variant.id }}">
        <button type="submit"{% unless variant.available %} disabled{% endunless %}>
          {% if variant.available %}Add to cart{% else %}Sold out{% endif %}
        </button>
      </form>
    {% elsif product != blank %}
      <a href="{{ product.url }}" class="ph-product-card__link">View product</a>
    {% else %}
      <a href="/collections/all" class="ph-product-card__link">Shop chews</a>
    {% endif %}
  </div>
</article>
