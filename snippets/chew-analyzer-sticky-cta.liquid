{% comment %}
  Prime Pet Food - Chew Analyzer Mobile Sticky CTA
  Renders a fixed bottom CTA on mobile that scrolls user to the analyzer widget.
  Include in theme.liquid before </body>
{% endcomment %}

<style>
  .ca-sticky-cta {
    position: fixed;
    bottom: -80px;
    left: 0;
    right: 0;
    z-index: 9999;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid #e5e7eb;
    transition: bottom 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: none;
  }
  .ca-sticky-cta--visible { bottom: 0; }
  .ca-sticky-cta__btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 24px;
    background: linear-gradient(135deg, #2d5016, #4a7c28);
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    transition: all 0.3s ease;
  }
  .ca-sticky-cta__btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(45, 80, 22, 0.4);
  }
  @media (max-width: 768px) {
    .ca-sticky-cta { display: block; }
  }
</style>
