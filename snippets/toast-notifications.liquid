<script>
  // Demo setup for the updated 2-toast stack system
  document.addEventListener('DOMContentLoaded', () => {
    // Small delay to ensure scripts are loaded
    setTimeout(() => {
      if (window.Toast) {
        // Trigger two initial notifications with image, title, and description
        window.Toast.show(
          'Someone from London', 
          'Just purchased a Premium Dog Food pack 2 minutes ago', 
          'https://cdn.shopify.com/s/files/1/0615/6353/5553/files/dog-food-placeholder.png?v=1645454545',
          'sale'
        );
        
        setTimeout(() => {
          window.Toast.show(
            'Live Visitors', 
            '12 people are currently viewing this product', 
            'https://cdn.shopify.com/s/files/1/0615/6353/5553/files/visitor-placeholder.png?v=1645454545',
            'visit'
          );
        }, 1500);

        // A 3rd one to show queueing and 6s FIFO dismiss
        setTimeout(() => {
          window.Toast.show(
            'New Sale', 
            'A customer from New York just bought a cat toy!', 
            'https://cdn.shopify.com/s/files/1/0615/6353/5553/files/cat-toy-placeholder.png?v=1645454545',
            'sale'
          );
        }, 3000);
      }
    }, 2000);
  });
</script>

<style>
  /* Custom background colors for different types if needed */
  .toast-notification--visit { border-left: 4px solid #4caf50; }
  .toast-notification--sale { border-left: 4px solid #2196f3; }
  .toast-notification--info { border-left: 4px solid #ff9800; }
</style>
