{% comment %}
  Free Shipping Progress Bar
  Shows progress toward free shipping threshold.
  Usage: {% render 'free-shipping-bar' %}
  Configure threshold in cart theme settings.
{% endcomment %}

{% liquid
  assign free_shipping_threshold = settings.cart_shipping_bar_threshold | default: 30 | times: 100
  assign cart_total = cart.total_price
  assign remaining = free_shipping_threshold | minus: cart_total
  assign progress = cart_total | times: 100 | divided_by: free_shipping_threshold
  if progress > 100
    assign progress = 100
  endif
%}

<div class="fsb" data-threshold="{{ free_shipping_threshold }}">
  {% if remaining <= 0 %}
    <div class="fsb__message fsb__message--success">
      <svg class="fsb__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
        <polyline points="22 4 12 14.01 9 11.01"/>
      </svg>
      <span>You've unlocked <strong>FREE shipping!</strong> 🎉</span>
    </div>
  {% else %}
    <div class="fsb__message">
      <svg class="fsb__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="1" y="3" width="15" height="13"/>
        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
        <circle cx="5.5" cy="18.5" r="2.5"/>
        <circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
      <span>Add <strong>{{ remaining | money }}</strong> more for <strong>FREE shipping</strong></span>
    </div>
  {% endif %}
  <div class="fsb__bar">
    <div class="fsb__bar-fill" style="width: {{ progress }}%"></div>
  </div>
</div>

<style>
  .fsb {
    padding: 12px 16px 14px;
    background: #fafafa;
    border-bottom: 1px solid #e5e7eb;
  }
  .fsb__message {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: #374151;
    margin-bottom: 8px;
    line-height: 1.4;
  }
  .fsb__message strong {
    font-weight: 700;
    color: #1a1a1a;
  }
  .fsb__message--success {
    color: #166534;
  }
  .fsb__message--success strong {
    color: #166534;
  }
  .fsb__icon {
    flex-shrink: 0;
    color: #2d5016;
  }
  .fsb__bar {
    height: 6px;
    background: #e5e7eb;
    border-radius: 3px;
    overflow: hidden;
  }
  .fsb__bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #2d5016, #4a7c28);
    border-radius: 3px;
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    min-width: 4px;
  }
</style>
