ative", "show_vet_badge": true, "vet_badge_text": "VET RECOMMENDED", "show_reviews": true, "review_stars": "★★★★★", "review_text": "4.7/5.0 Based on 10,000+ reviews", "show_info_line": true, "per_chew_prefix": "$10.00 per chew", "shipping_text": "Free shipping over $49", "subscribe_label": "Subscribe & save", "cta_text": "ADD TO CART", "size_guide_label": "Size Guide", "show_review_cards": true, "review_card_1": "“My dog’s obsessed — he won’t let go of his yak chew for hours on end!”", "review_card_2": "“Super long-lasting and no mess. My pup stays busy and happy chewing every single day.”", "review_card_3": "“Natural, durable, and totally addictive for my dog. He gets excited every time I open the bag!”"}}, "ypc_product_tab_QnMPYB": {"type": "ypc-product-tab", "blocks": {"recommended_product_XJJNQN": {"type": "recommended_product", "settings": {"product": "himalayan-yak-chews-for-dogs"}}, "recommended_product_cqJkJp": {"type": "recommended_product", "settings": {"product": "2-lb-bulk-yak-cheese-dog-chews-natural-long-lasting-treats-small-to-jumbo-copy"}}}, "block_order": ["recommended_product_XJJNQN", "recommended_product_cqJkJp"], "name": "YPC Product Tabs", "settings": {"tab_1_label": "Description", "tab_2_label": "Safe Feeding Guidelines", "tab_3_label": "Shipping", "tab_4_label": "Ingredients", "description_heading": "The Chew That Calms and Cleans", "change_heading": "Safe Feeding Guidelines for Yak Chews", "sizing_heading": "Shipping", "ingredients_heading": "Simple Ingredients", "description_fallback": "<p>Mighty Paw Yak Chews are more than a treat, they’re a long-lasting chew that supports your dog’s well-being. Designed to help reduce stress and anxiety, these chews provide satisfying mental stimulation while naturally cleaning teeth to reduce plaque and tartar.</p><ul><li><strong>Pure, Simple Ingredients</strong><br/>Handcrafted in Nepal and made with just a few simple ingredients.</li><li><strong>Healthy Snacking</strong><br/>A natural alternative to rawhide and a great option for dogs with sensitive stomachs.</li><li><strong>Bite-Sized Benefits</strong><br/>Rich in protein and calcium to support muscles, bones, and dental health.</li></ul>", "change_fallback": "<p><strong>Supervised Chewing</strong><br/><br/>Always supervise your dog while enjoying Himalayan yak chews. Make sure fresh drinking water is available during every chewing session for a safe and comfortable experience.</p><p><strong>Introducing Yak Chews to Sensitive Dogs</strong><br/><br/>Our protein-rich yak chews are natural and highly satisfying, but dogs with sensitive stomachs should start slowly. For first-time use, we recommend limiting intake to less than one chew per day to help avoid digestive discomfort.</p><p><strong>Naturally Hard, Gradually Softer</strong><br/><br/>Yak chews begin as a dense, long-lasting chew and naturally soften over time as your dog chews, making them ideal for strong chewers and extended chewing sessions.</p><p><strong>Helpful Tip for First-Time Chewers</strong><br/><br/>If your dog is used to softer processed treats or you have concerns about sensitive teeth, soak the yak chew in warm water for about 10 minutes before giving it to your dog. This helps soften the chew slightly while maintaining its durability.</p><p><strong>Safe & Enjoyable Chewing Experience</strong><br/><br/>By following these simple feeding recommendations, you can help your dog enjoy a safer, cleaner, and more satisfying natural chewing experience with Himalayan yak chews.</p>", "sizing_fallback": "<p>Orders are typically processed and shipped within 24–48 hours after purchase using trusted carriers such as UPS, FedEx, DHL, or USPS, depending on your location and the fastest available shipping option.</p><p>Most customers receive their orders within 2–5 business days, and in many cases, packages arrive even sooner.</p><p>Every order includes a tracking number so you can monitor your shipment from dispatch to delivery.</p><p>Please note that occasional shipping delays caused by customs processing, weather conditions, or postal carrier issues may occur and are outside our control.</p>", "ingredients_fallback": "<p>Yak milk, cow milk, lime juice, and salt.</p>", "reco_heading": "You may also like...", "product_link_label": "Quick view", "bg_color": "#f6f1e9", "text_color": "#2b1408", "muted_color": "#6d7478", "accent_color": "#e16610", "heading_size": 31, "body_size": 16, "tab_size": 13, "reco_heading_size": 16, "product_title_size": 17, "product_price_size": 16}}, "two_treats_in_one_C8mxDb": {"type": "two-treats-in-one", "blocks": {"step_Ui7QzJ": {"type": "step", "settings": {"step_number": "1", "text": "<p>Your dog enjoys a <strong>long-lasting yak chew</strong>.</p>"}}, "step_GLJY9L": {"type": "step", "settings": {"step_number": "2", "text": "<p>It becomes a <strong>small nub</strong> that can be a choking risk.</p>"}}, "step_nADYVx": {"type": "step", "settings": {"step_number": "3", "text": "<p>Microwave the nub for <strong>60 seconds</strong> on a microwave-safe plate.</p>"}}, "step_pKREhN": {"type": "step", "settings": {"step_number": "4", "text": "<p>It puffs up <strong>3-4x bigger</strong> into a light crunchy treat.</p>"}}}, "block_order": ["step_Ui7QzJ", "step_GLJY9L", "step_nADYVx", "step_pKREhN"], "custom_css": ["h2 {font-size: 42px;}"], "name": "Bonus treat image steps", "settings": {"eyebrow": "Zero waste treat hack", "heading": "Turn Leftover Yak Nubs Into A Second Crunchy Treat", "description": "", "image": "shopify://shop_images/add_process_with_line_in_202605082321.jpg", "badge_text": "", "button_label": "Shop Yak Chews", "button_link": "", "max_width": 1260, "padding_top": 80, "padding_bottom": 80, "bg_color": "#ffffff", "surface_color": "#f8f5f1", "border_color": "#ede5dd", "heading_color": "#24130d", "text_color": "#3d2a22", "muted_color": "#7b675e", "accent_color": "#d2632e", "button_text_color": "#ffffff"}}, "video_carousel_6EkF8r": {"type": "video-carousel", "blocks": {"video_6DMLLj": {"t