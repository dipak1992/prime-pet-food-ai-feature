 "rgba(0,0,0,0)", "check_icon_color": "#3d2a18", "cross_icon_bg": "rgba(0,0,0,0)", "cross_icon_color": "#3d2a18", "dash_icon_bg": "rgba(0,0,0,0)", "dash_icon_color": "#777777", "button_bg": "#d2632e", "button_hover_bg": "#ba5626", "button_text": "#ffffff", "eyebrow_size": 14, "heading_size": 42, "mobile_heading_size": 34, "subtext_size": 22, "mobile_subtext_size": 17, "column_heading_size": 22, "body_size": 20, "badge_size": 11, "button_size": 17, "icon_size": 38, "table_radius": 22, "featured_column_radius": 16, "padding_top": 84, "padding_bottom": 84, "mobile_padding_top": 48, "mobile_padding_bottom": 48}}, "faqs_tVaRYD": {"type": "faqs", "blocks": {"faq_item_ApMt4r": {"type": "faq_item", "settings": {"question": "What is a yak chew?", "answer": "<p>Yak chews are natural long-lasting dog chews inspired by traditional Himalayan recipes. They are high in protein, durable, and designed to keep dogs mentally engaged while chewing.</p>"}}, "faq_item_K7RCbk": {"type": "faq_item", "settings": {"question": "What are yak chews made from?", "answer": "<p>Just 3 ingredients: yak milk, lime juice, and a pinch of salt. No chemicals, preservatives, or artificial flavors.</p>"}}, "faq_item_nUazy7": {"type": "faq_item", "settings": {"question": "Are yak chews safe for dogs?", "answer": "<p>Yes, high-quality yak chews are generally safe and digestible for dogs when given in the correct size and under supervision.</p>"}}, "faq_item_KxqTWx": {"type": "faq_item", "settings": {"question": "How are yak chews made?", "answer": "<p>Yak chews are traditionally made by boiling milk, separating curds, compressing them into blocks, and slowly drying them for several weeks</p>"}}, "faq_item_kMyAkX": {"type": "faq_item", "settings": {"question": "What size yak chew should I get for my dog?", "answer": "<p>Choose a chew size based on your dog’s weight and chewing style. Larger dogs and aggressive chewers should use bigger sizes for safety.</p><ul><li><strong>Small</strong>: for dogs up to 15 lbs</li><li><strong>Medium</strong>: for dogs up to 35 lbs</li><li><strong>Large</strong>: for dogs up to 55 lbs</li><li><strong>Extra Large</strong>: for dogs up to 85 lbs</li><li><strong>Jumbo</strong>: for dogs above 85<br/></li></ul>"}}, "faq_item_C3irtd": {"type": "faq_item", "settings": {"question": "Are yak chews good for dogs’ teeth?", "answer": "<p>Yes, chewing yak chews may help reduce plaque and tartar buildup while supporting healthier chewing habits.</p>"}}, "faq_item_EVBFGx": {"type": "faq_item", "settings": {"question": "Yak chew vs bully stick — which is better?", "answer": "<p>Yak chews are generally longer-lasting, lower odor, and less greasy, while bully sticks are softer and easier to chew for some dogs.</p>"}}, "faq_item_JPDiP9": {"type": "faq_item", "settings": {"question": "What do I do with the end piece of a yak chew?", "answer": "<p>Small leftover pieces can be microwaved for about 30–60 seconds to turn them into a crunchy puff treat after cooling.</p>"}}, "faq_item_zCPr6g": {"type": "faq_item", "settings": {"question": "How long do they last?", "answer": "<p>Depending on your dog's chewing intensity, a single chew can last anywhere from 3 days to 2+ weeks.</p>"}}, "faq_item_iqwipL": {"type": "faq_item", "settings": {"question": "Are they safe for puppies?", "answer": "<p>We recommend yak chews for puppies 4+ months old who have started teething. Always supervise chewing.</p>"}}, "faq_item_nkxPPQ": {"type": "faq_item", "settings": {"question": "What do I do with the small end piece?", "answer": "<p>Soak it in hot water for 5 minutes, then microwave for 45–60 seconds. It puffs up into a delicious cheesy treat.</p>"}}}, "block_order": ["faq_item_ApMt4r", "faq_item_K7RCbk", "faq_item_nUazy7", "faq_item_KxqTWx", "faq_item_kMyAkX", "faq_item_C3irtd", "faq_item_EVBFGx", "faq_item_JPDiP9", "faq_item_zCPr6g", "faq_item_iqwipL", "faq_item_nkxPPQ"], "name": "Accordion FAQ", "settings": {"eyebrow": "Common Questions", "heading": "Everything You Need to 