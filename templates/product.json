s:</strong> Our clear return, refund, and shipping policies provide peace of mind, knowing we stand behind our products.</p><p><strong>7. Customer Support:</strong> Our dedicated customer support team is ready to assist with any concerns or questions you may have.</p><p>Shop confidently at our Shopify store, where your safety and satisfaction are our top priorities.</p>", "page": ""}}, "chew_analyzer_inline": {"type": "custom_liquid", "settings": {"custom_liquid": "{% render 'chew-analyzer-widget' %}"}}, "duration_badge": {"type": "custom_liquid", "settings": {"custom_liquid": "{% render 'duration-badge' %}"}}, "subscription_toggle": {"type": "custom_liquid", "settings": {"custom_liquid": "{% render 'subscription-toggle', product: product %}"}}, "breed_messaging": {"type": "custom_liquid", "settings": {"custom_liquid": "{% render 'breed-messaging' %}"}}}, "block_order": ["title_3qyCbh", "inventory_9DtJ9J", "spacer_p7PC6z", "variant_picker_Aj9Pcg", "spacer_XCjAkL", "price", "duration_badge", "breed_messaging", "chew_analyzer_inline", "subscription_toggle", "buy_buttons", "spacer_Ktgzch", "icon_with_text_9WUrL6", "spacer_mx7trQ", "richtext_tHQW4k", "countdown_pCrdBx", "panel_KaqEVk", "enquiry_back_in_stock_TAdjDn", "panel_ax4TPn", "complementary_V7Ew3r", "panel_wRqAxH", "enquiry_product_4iRP68", "panel_EbDytj", "product_badges_nGN6yi", "product_icons_KVzAJB", "description_VVj7PD", "spacer_PnJ9Jr", "score_yrQXg7", "spacer_KfGaz7", "score_AWfUai", "spacer_L8Cbjf", "table_xGKgbK", "collapsible-row-0", "collapsible-row-2", "collapsible-row-3", "share_NUaity", "panel_bWz9dJ", "text_hReqDJ", "payment_icons_rt8Ubr", "spacer_PKVqBG", "popup_ahUmtQ"], "disabled": true, "settings": {"gallery_layout": "slider", "info_fullwidth_mob": true, "scroll_to_active_variant": true, "sticky_panel_enable": true, "sticky_panel": "", "page_title_enabled": false, "page_title_vendor": false, "page_title_price": true, "page_title_review_stars": false, "page_title_size": "h2", "page_title_visibil