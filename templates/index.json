    "faqs_KDWjwK": {
      "type": "faqs",
      "blocks": {
        "faq_item_hxgjjh": {
          "type": "faq_item",
          "settings": {
            "question": "What are Himalayan Yak Chews?",
            "answer": "<p>Prime Pet Food Yak Chews are traditional Himalayan dog treats made from yak and cow milk. They are completely natural, free from chemicals and preservatives, and crafted using time-tested methods from the Himalayan region. Their hard texture makes them long-lasting and highly satisfying for dogs.</p>"
          }
        },
        "faq_item_Qprh7Q": {
          "type": "faq_item",
          "settings": {
            "question": "Where do your chews come from?",
            "answer": "<p>Our chews are inspired by an ancient Himalayan recipe, originally made for human consumption. Today, we bring this authentic process to your dogs—using high-quality milk sourced from free-grazing animals and crafted into a safe, nutritious chew.</p>"
          }
        },
        "faq_item_hkEemN": {
          "type": "faq_item",
          "settings": {
            "question": "How are Prime Pet Food chews made?",
            "answer": "<p>Our chews go through a careful process:</p><ol><li>Fresh milk is collected and pasteurized</li><li>It is turned into dense cheese</li><li>Naturally aged for hardness and durability</li><li>Cut, cleaned, and inspected</li><li>Slowly dried for long shelf life</li></ol><p><br/>This process creates a healthy, long-lasting chew your dog will love.</p>"
          }
        },
        "faq_item_JAEqRG": {
          "type": "faq_item",
          "settings": {
            "question": "Are yak chews safe for dogs?",
            "answer": "<p>Yes — they are safe and digestible. Unlike raw milk, the cheese-making process removes most lactose and fats, making it easier on your dog’s stomach. As with any chew, supervision is recommended.</p>"
          }
        },
        "faq_item_EcLKzx": {
          "type": "faq_item",
          "settings": {
            "question": "Do yak chews cause weight gain?",
            "answer": "<p>Yak chews are high in protein and nutrients like calcium and vitamins. While they are not inherently fattening, moderation is key. They are a healthier alternative to many processed treats.</p>"
          }
        },
        "faq_item_Ffeqk7": {
          "type": "faq_item",
          "settings": {
            "question": "How do I choose the right size for my dog?",
            "answer": "<ul><li><strong>Small</strong>: for dogs up to 15 lbs</li><li><strong>Medium</strong>: for dogs up to 35 lbs</li><li><strong>Large</strong>: for dogs up to 55 lbs</li><li><strong>Extra Large</strong>: for dogs up to 85 lbs</li><li><strong>Jumbo</strong>: for dogs above 85<br/><br/>Choosing the right size ensures safety and longer chew time.</li></ul>"
          }
        }
      },
