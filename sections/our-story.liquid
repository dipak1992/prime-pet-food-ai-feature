{% assign section_id = 'story-split' | append: section.id %}

<section id="{{ section_id }}" class="story-split-section">
  <div class="story-split-section__grid">
    
    <div class="story-split-section__left">
      <div class="story-split-section__media">
        {% if section.settings.left_image != blank %}
          {{
            section.settings.left_image
            | image_url: width: 1400
            | image_tag:
              class: 'story-split-section__image',
              loading: 'lazy',
              alt: section.settings.left_image.alt | escape
          }}
        {% else %}
          <div class="story-split-section__image story-split-section__image--placeholder">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endif %}

        {% if section.settings.left_overlay_enable %}
          <div class="story-split-section__overlay"></div>
        {% endif %}

        <div class="story-split-section__left-content">
          {% if section.settings.left_top_text != blank %}
            <div class="story-split-section__left-top">
              {{ section.settings.left_top_text }}
            </div>
          {% endif %}

          {% if section.settings.center_icon != blank %}
            <div class="story-split-section__left-icon">
              {{
                section.settings.center_icon
                | image_url: width: 160
                | image_tag:
                  class: 'story-split-section__icon-image',
                  loading: 'lazy',
                  alt: section.settings.center_icon.alt | escape
              }}
            </div>
          {% elsif section.settings.center_icon_text != blank %}
            <div class="story-split-section__left-icon story-split-section__left-icon--text">
              {{ section.settings.center_icon_text }}
            </div>
          {% endif %}

          {% if section.settings.left_bottom_text != blank %}
            <div class="story-split-section__left-bottom">
              {{ section.settings.left_bottom_text }}
            </div>
          {% endif %}
        </div>
      </div>

      {% if section.settings.quote_text != blank %}
        <div class="story-split-section__quote-bar">
          <div class="story-split-section__quote-text">
            {{ section.settings.quote_text }}
          </div>

          {% if section.settings.quote_author != blank %}
            <div class="story-split-section__quote-author">
              {{ section.settings.quote_author }}
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="story-split-section__right">
      {% if section.settings.eyebrow != blank %}
        <div class="story-split-section__eyebrow">
          {{ section.settings.eyebrow }}
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="story-split-section__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="story-split-section__description rte">
          {{ section.settings.description }}
        </div>
      {% endif %}

      <div class="story-split-section__cards">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'stat_card' %}
              <div class="story-split-section__card" {{ block.shopify_attributes }}>
                {% if block.settings.card_number != blank %}
                  <div class="story-split-section__card-number">
                    {{ block.settings.card_number }}
                  </div>
                {% endif %}
                {% if block.settings.card_label != blank %}
                  <div class="story-split-section__card-label">
                    {{ block.settings.card_label }}
                  </div>
                {% endif %}
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </div>

  </div>
</section>

<style>
  #{{ section_id }} {
    --section-bg: {{ section.settings.section_bg }};
    --right-bg: {{ section.settings.right_bg }};
    --left-text-color: {{ section.settings.left_text_color }};
    --right-text-color: {{ section.settings.right_text_color }};
    --eyebrow-color: {{ section.settings.eyebrow_color }};
    --heading-color: {{ section.settings.heading_color }};
    --body-color: {{ section.settings.body_color }};
    --quote-bg: {{ section.settings.quote_bg }};
    --quote-text-color: {{ section.settings.quote_text_color }};
    --card-bg: {{ section.settings.card_bg }};
    --card-number-color: {{ section.settings.card_number_color }};
    --card-label-color: {{ section.settings.card_label_color }};
    --overlay-color: {{ section.settings.overlay_color }};
    --border-radius: {{ section.settings.border_radius }}px;
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --content-padding: {{ section.settings.content_padding }}px;
    --card-gap: {{ section.settings.card_gap }}px;
    --grid-gap: {{ section.settings.grid_gap }}px;
    --left-height: {{ section.settings.left_height }}px;
    --quote-min-height: {{ section.settings.quote_height }}px;
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }

  #{{ section_id }} {
    background: var(--section-bg);
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  #{{ section_id }} .story-split-section__grid {
    max-width: {{ section.settings.page_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--grid-gap);
    align-items: stretch;
  }

  #{{ section_id }} .story-split-section__left {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  #{{ section_id }} .story-split-section__media {
    position: relative;
    min-height: var(--left-height);
    overflow: hidden;
    border-radius: var(--border-radius) var(--border-radius) 0 0;
    background: #d97b3c;
  }

  #{{ section_id }} .story-split-section__image,
  #{{ section_id }} .story-split-section__image--placeholder,
  #{{ section_id }} .story-split-section__image--placeholder svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  #{{ section_id }} .story-split-section__image {
    object-fit: cover;
  }

  #{{ section_id }} .story-split-section__image--placeholder {
    height: 100%;
    background: #e7e1d5;
  }

  #{{ section_id }} .story-split-section__overlay {
    position: absolute;
    inset: 0;
    background: var(--overlay-color);
    opacity: var(--overlay-opacity);
    pointer-events: none;
  }

  #{{ section_id }} .story-split-section__left-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    color: var(--left-text-color);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 44px;
    text-align: center;
    padding: 36px;
  }

  #{{ section_id }} .story-split-section__left-top,
  #{{ section_id }} .story-split-section__left-bottom {
    max-width: 78%;
    font-size: {{ section.settings.left_text_size }}px;
    line-height: 1.3;
    font-style: italic;
    font-weight: 600;
  }

  #{{ section_id }} .story-split-section__left-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ section.settings.icon_text_size }}px;
    line-height: 1;
  }

  #{{ section_id }} .story-split-section__icon-image {
    width: {{ section.settings.icon_size }}px;
    max-width: 100%;
    height: auto;
    display: block;
  }

  #{{ section_id }} .story-split-section__quote-bar {
    background: var(--quote-bg);
    color: var(--quote-text-color);
    padding: 18px 36px;
    min-height: var(--quote-min-height);
    border-radius: 0 0 var(--border-radius) var(--border-radius);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #{{ section_id }} .story-split-section__quote-text {
    font-size: {{ section.settings.quote_size }}px;
    line-height: 1.35;
    font-style: italic;
    font-weight: 700;
  }

  #{{ section_id }} .story-split-section__quote-author {
    font-size: {{ section.settings.quote_author_size }}px;
    opacity: 0.9;
  }

  #{{ section_id }} .story-split-section__right {
    background: var(--right-bg);
    border-radius: var(--border-radius);
    padding: var(--content-padding);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #{{ section_id }} .story-split-section__eyebrow {
    color: var(--eyebrow-color);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: 700;
    margin-bottom: 20px;
  }

  #{{ section_id }} .story-split-section__heading {
    margin: 0 0 24px;
    color: var(--heading-color);
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.05;
    font-weight: 700;
  }

  #{{ section_id }} .story-split-section__description {
    color: var(--body-color);
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.7;
    margin-bottom: 34px;
  }

  #{{ section_id }} .story-split-section__description p {
    margin: 0 0 22px;
  }

  #{{ section_id }} .story-split-section__description p:last-child {
    margin-bottom: 0;
  }

  #{{ section_id }} .story-split-section__cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--card-gap);
    margin-top: 6px;
  }

  #{{ section_id }} .story-split-section__card {
    background: var(--card-bg);
    border-radius: {{ section.settings.card_radius }}px;
    padding: 34px 22px;
    text-align: center;
  }

  #{{ section_id }} .story-split-section__card-number {
    color: var(--card-number-color);
    font-size: {{ section.settings.card_number_size }}px;
    line-height: 1;
    font-weight: 700;
    margin-bottom: 16px;
  }

  #{{ section_id }} .story-split-section__card-label {
    color: var(--card-label-color);
    font-size: {{ section.settings.card_label_size }}px;
    line-height: 1.4;
  }

  @media screen and (max-width: 1100px) {
    #{{ section_id }} .story-split-section__grid {
      grid-template-columns: 1fr;
    }

    #{{ section_id }} .story-split-section__right {
      padding: 40px 28px;
    }
  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} .story-split-section__media {
      min-height: 440px;
    }

    #{{ section_id }} .story-split-section__left-content {
      gap: 26px;
      padding: 24px;
    }

    #{{ section_id }} .story-split-section__left-top,
    #{{ section_id }} .story-split-section__left-bottom {
      max-width: 90%;
      font-size: calc({{ section.settings.left_text_size }}px * 0.82);
    }

    #{{ section_id }} .story-split-section__quote-bar {
      padding: 22px 20px;
    }

    #{{ section_id }} .story-split-section__quote-text {
      font-size: calc({{ section.settings.quote_size }}px * 0.82);
    }

    #{{ section_id }} .story-split-section__right {
      padding: 30px 20px;
    }

    #{{ section_id }} .story-split-section__heading {
      font-size: calc({{ section.settings.heading_size }}px * 0.72);
    }

    #{{ section_id }} .story-split-section__description {
      font-size: calc({{ section.settings.body_size }}px * 0.95);
    }

    #{{ section_id }} .story-split-section__cards {
      grid-template-columns: 1fr;
    }

    #{{ section_id }} .story-split-section__card {
      padding: 26px 18px;
    }
  }
</style>

{% schema %}
