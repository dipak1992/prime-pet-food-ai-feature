<div class="pptb" aria-label="Product trust signals">
  <div class="pptb__inner page-width">

    <div class="pptb__item">
      <div class="pptb__icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <div class="pptb__text">
        <strong>{{ section.settings.stat1_value | default: '67 min' }}</strong>
        <span>{{ section.settings.stat1_label | default: 'Average chew time' }}</span>
      </div>
    </div>

    <div class="pptb__divider" aria-hidden="true"></div>

    <div class="pptb__item">
      <div class="pptb__icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <polyline points="9 12 11 14 15 10"/>
        </svg>
      </div>
      <div class="pptb__text">
        <strong>{{ section.settings.stat2_value | default: '4' }}</strong>
        <span>{{ section.settings.stat2_label | default: 'Natural ingredients' }}</span>
      </div>
    </div>

    <div class="pptb__divider" aria-hidden="true"></div>

    <div class="pptb__item">
      <div class="pptb__icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      </div>
      <div class="pptb__text">
        <strong>{{ section.settings.stat3_value | default: '4.9★' }}</strong>
        <span>{{ section.settings.stat3_label | default: 'From 2,400+ reviews' }}</span>
      </div>
    </div>

    <div class="pptb__divider" aria-hidden="true"></div>

    <div class="pptb__item">
      <div class="pptb__icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <polyline points="23 4 23 10 17 10"/>
          <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
        </svg>
      </div>
      <div class="pptb__text">
        <strong>{{ section.settings.stat4_value | default: '30-day' }}</strong>
        <span>{{ section.settings.stat4_label | default: 'Satisfaction guarantee' }}</span>
      </div>
    </div>

    <div class="pptb__divider" aria-hidden="true"></div>

    <div class="pptb__item">
      <div class="pptb__icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <rect x="1" y="3" width="15" height="13"/>
          <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
          <circle cx="5.5" cy="18.5" r="2.5"/>
          <circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
      </div>
      <div class="pptb__text">
        <strong>{{ section.settings.stat5_value | default: 'Free' }}</strong>
        <span>{{ section.settings.stat5_label | default: 'Shipping over $30' }}</span>
      </div>
    </div>

  </div>
</div>

<style>
  .pptb {
    background: #fff;
    border-top: 1px solid rgba(55, 43, 31, 0.1);
    border-bottom: 1px solid rgba(55, 43, 31, 0.1);
    padding: 16px 0;
    font-family: var(--prime-font-sans, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif);
  }

  .pptb * { box-sizing: border-box; }

  .pptb__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
  }

  .pptb__item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 20px;
    flex-shrink: 0;
  }

  .pptb__icon {
    color: #b85f32;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .pptb__text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .pptb__text strong {
    display: block;
    color: #171512;
    font-size: 15px;
    font-weight: 780;
    line-height: 1.2;
  }

  .pptb__text span {
    display: block;
    color: #5f574e;
    font-size: 12px;
    line-height: 1.3;
  }

  .pptb__divider {
    width: 1px;
    height: 32px;
    background: rgba(55, 43, 31, 0.12);
    flex-shrink: 0;
  }

  @media (max-width: 860px) {
    .pptb__inner {
      justify-content: flex-start;
      gap: 0;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      flex-wrap: nowrap;
      padding-bottom: 2px;
    }

    .pptb__inner::-webkit-scrollbar {
      display: none;
    }

    .pptb__item {
      padding: 6px 16px;
      flex-shrink: 0;
    }

    .pptb__divider {
      height: 24px;
    }
  }

  @media (max-width: 560px) {
    .pptb__item {
      padding: 6px 12px;
    }

    .pptb__text strong {
      font-size: 14px;
    }

    .pptb__text span {
      font-size: 11px;
    }

    .pptb__icon svg {
      width: 18px;
      height: 18px;
    }
  }
</style>

