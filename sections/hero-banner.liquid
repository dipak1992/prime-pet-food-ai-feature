{% comment %}
  Section: Hero Banner
  File: sections/hero-banner.liquid
  Description: Full background image hero with scrolling feature ticker + trust bar
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
  :root {
    --forest: #e36611;
    --forest-deep: #1A3409;
    --sage: #7A8B6A;
    --sage-light: #A3B18A;
    --cream: #FEFAE0;
    --cream-warm: #F5F0DC;
    --sand: #E9E0C8;
    --ember: #e46711;
    --ember-bright: #e46711;
    --warm-white: #FDFCF7;
    --text-primary: #1A1A1A;
    --text-secondary: #5A5A4F;
    --text-muted: #8B8B7A;
    --gold: #C9A84C;
    --red-sale: #e46711;
    --radius-full: 999px;
    --radius-xl: 28px;
    --radius-md: 12px;
    --shadow-xl: 0 16px 48px rgba(0,0,0,0.12);
    --shadow-lg: 0 8px 32px rgba(0,0,0,0.10);
    --font-display: 'DM Serif Display', Georgia, serif;
    --font-body: 'Plus Jakarta Sans', -apple-system, sans-serif;
  }

  /* ===== HERO — FULL BG IMAGE ===== */
  .pp-hero {
    position: relative;
    min-height: {{ section.settings.min_height }}vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #1A1A1A;
  }

  /* Background image layer */
  .pp-hero-bg-img {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .pp-hero-bg-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_position }};
    display: block;
  }

  /* Dark overlay */
  .pp-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to right,
      rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }}) 0%,
      rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 | times: 0.55 }}) 55%,
      rgba(0,0,0,0.08) 100%
    );
  }

  /* Dot pattern */
  .pp-hero-bg-pattern {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.03;
    background-image: radial-gradient(circle, white 1px, transparent 1px);
    background-size: 40px 40px;
  }

  /* Content wrapper */
  .pp-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 80px 48px;
    position: relative;
    z-index: 3;
    width: 100%;
  }

  /* Content block */
  .pp-hero-content {
    max-width: 640px;
    animation: ppFadeUp 0.8s ease-out;
  }

  @keyframes ppFadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Sale Badge */
  .pp-sale-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--red-sale);
    color: white;
    padding: 8px 18px;
    border-radius: var(--radius-full);
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 24px;
    letter-spacing: 0.5px;
    animation: ppFadeUp 0.8s 0.1s ease-out both;
    font-family: var(--font-body);
  }
  .pp-sale-badge svg { width: 14px; height: 14px; flex-shrink: 0; }

  /* Heading */
  .pp-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(38px, 5vw, 68px);
    line-height: 1.08;
    color: white;
    margin-bottom: 20px;
    animation: ppFadeUp 0.8s 0.2s ease-out both;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }
  .pp-hero h1 em {
    color: #d4770b;
    font-style: italic;
  }

  .pp-hero-subtitle {
    font-size: 18px;
    color: rgba(255,255,255,0.85);
    margin-bottom: 36px;
    font-weight: 400;
    animation: ppFadeUp 0.8s 0.3s ease-out both;
    font-family: var(--font-body);
    text-shadow: 0 1px 8px rgba(0,0,0,0.3);
  }

  /* CTA Buttons */
  .pp-hero-ctas {
    display: flex;
    gap: 16px;
    align-items: center;
    animation: ppFadeUp 0.8s 0.4s ease-out both;
    flex-wrap: wrap;
  }
  .pp-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--ember);
    color: white;
    padding: 16px 36px;
    border-radius: var(--radius-full);
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    font-family: var(--font-body);
    box-shadow: 0 4px 20px rgba(212,119,11,0.45);
  }
  .pp-btn-primary:hover {
    background: var(--ember-bright);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(212,119,11,0.5);
    color: white;
  }
  .pp-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(8px);
    color: white;
    padding: 16px 28px;
    border-radius: var(--radius-full);
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    border: 2px solid rgba(255,255,255,0.5);
    transition: all 0.3s;
    font-family: var(--font-body);
  }
  .pp-btn-secondary:hover {
    background: rgba(255,255,255,0.28);
    border-color: white;
    color: white;
  }

  /* ===== FEATURE BADGES (static, under subtitle) ===== */
  .pp-hero-features {
    display: flex;
    gap: 20px;
    margin: 24px 0 36px;
    flex-wrap: wrap;
    animation: ppFadeUp 0.8s 0.4s ease-out both;
  }
  .pp-hero-feature {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 500;
    color: rgba(255,255,255,0.9);
    font-family: var(--font-body);
  }
  .pp-check {
    width: 22px;
    height: 22px;
    background: #d4770b;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 11px;
    flex-shrink: 0;
  }

  /* CTA buttons animation delay pushed */
  .pp-hero-ctas {
    animation: ppFadeUp 0.8s 0.5s ease-out both;
  }

  /* ===== TRUST BAR — SCROLLING MARQUEE ===== */
  .pp-trust-bar {
    background: var(--forest-deep);
    padding: 20px 0;
    overflow: hidden;
  }

  .pp-trust-track {
    display: flex;
    width: max-content;
    animation: ppTrustScroll {{ section.settings.trust_scroll_speed }}s linear infinite;
  }

  .pp-trust-bar:hover .pp-trust-track {
    animation-play-state: paused;
  }

  @keyframes ppTrustScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .pp-trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    color: var(--cream);
    padding: 0 48px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .pp-trust-icon {
    width: 44px;
    height: 44px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }

  .pp-trust-text-wrap { display: flex; flex-direction: column; }
  .pp-trust-text    { font-size: 13px; font-weight: 600; letter-spacing: 0.3px; font-family: var(--font-body); }
  .pp-trust-subtext { font-size: 11px; opacity: 0.7; font-weight: 400; font-family: var(--font-body); }

  /* Separator dot between badges */
  .pp-trust-sep {
    width: 5px;
    height: 5px;
    background: rgba(255,255,255,0.2);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .pp-hero { min-height: 75vh; }
    .pp-hero-inner { padding: 48px 24px 100px; }
    .pp-hero h1 { font-size: 34px; }
    .pp-hero-subtitle { font-size: 16px; }
  }
  @media (max-width: 480px) {
    .pp-hero-inner { padding: 36px 20px 90px; }
    .pp-hero h1 { font-size: 28px; }
    .pp-btn-primary, .pp-btn-secondary { padding: 13px 22px; font-size: 14px; }
  }
</style>

<!-- ===== HERO SECTION ===== -->
<section class="pp-hero" id="pp-hero-{{ section.id }}">

  <!-- Background Image -->
  <div class="pp-hero-bg-img">
    {% if section.settings.hero_image != blank %}
      {{ section.settings.hero_image | image_url: width: 1800 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        alt: section.settings.hero_image_alt | default: 'Hero background'
      }}
    {% endif %}
  </div>

  <!-- Overlays -->
  <div class="pp-hero-overlay"></div>
  <div class="pp-hero-bg-pattern"></div>

  <!-- Main Content -->
  <div class="pp-hero-inner">
    <div class="pp-hero-content">

      {% if section.settings.show_sale_badge and section.settings.sale_badge_text != blank %}
        <div class="pp-sale-badge">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>
          {{ section.settings.sale_badge_text }}
        </div>
      {% endif %}

      <h1>
        {{ section.settings.heading_line1 }}
        {% if section.settings.heading_italic != blank %}
          <em>{{ section.settings.heading_italic }}</em>
        {% endif %}
        {{ section.settings.heading_line2 }}
      </h1>

      {% if section.settings.subtitle != blank %}
        <p class="pp-hero-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}

      <!-- Feature Badges (static ✓ list) -->
      {% assign feature_blocks = section.blocks | where: "type", "feature" %}
      {% if feature_blocks.size > 0 %}
        <div class="pp-hero-features">
          {% for block in feature_blocks %}
            <div class="pp-hero-feature" {{ block.shopify_attributes }}>
              <span class="pp-check">✓</span>
              {{ block.settings.feature_text }}
            </div>
          {% endfor %}
        </div>
      {% endif %}

      <div class="pp-hero-ctas">
        {% if section.settings.primary_btn_label != blank %}
          <a href="{{ section.settings.primary_btn_link }}" class="pp-btn-primary">
            {{ section.settings.primary_btn_label }} →
          </a>
        {% endif %}
        {% if section.settings.secondary_btn_label != blank %}
          <a href="{{ section.settings.secondary_btn_link }}" class="pp-btn-secondary">
            {{ section.settings.secondary_btn_label }}
          </a>
        {% endif %}
      </div>

    </div>
  </div>

</section>

<!-- ===== TRUST BAR ===== -->
{% if section.settings.show_trust_bar %}
  {% assign trust_blocks = section.blocks | where: "type", "trust_badge" %}
  {% if trust_blocks.size > 0 %}
    <div class="pp-trust-bar">
      <div class="pp-trust-track">
        {%- comment -%} Doubled for seamless infinite loop {%- endcomment -%}
        {% for n in (1..2) %}
          {% for block in trust_blocks %}
            <div class="pp-trust-badge" {{ block.shopify_attributes }}>
              <div class="pp-trust-icon">{{ block.settings.trust_icon }}</div>
              <div class="pp-trust-text-wrap">
                <span class="pp-trust-text">{{ block.settings.trust_title }}</span>
                <span class="pp-trust-subtext">{{ block.settings.trust_subtitle }}</span>
              </div>
            </div>
            <span class="pp-trust-sep"></span>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  {% endif %}
{% endif %}


{% schema %}
{
  "name": "Hero Banner",
  "tag": "div",
  "class": "hero-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero Layout"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Section Min Height",
      "default": 85
    },
    {
      "type": "header",
      "content": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Image Alt Text",
      "default": "Happy dog enjoying Premium Himalayan Yak Cheese Chew"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Focus Position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "top center",    "label": "Top" },
        { "value": "bottom center", "label": "Bottom" },
        { "value": "center left",   "label": "Left" },
        { "value": "center right",  "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Dark Overlay Strength",
      "default": 50,
      "info": "Higher = darker, text more readable"
    },
    {
      "type": "header",
      "content": "Sale Badge"
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show Sale Badge",
      "default": true
    },
    {
      "type": "text",
      "id": "sale_badge_text",
      "label": "Sale Badge Text",
      "default": "UP TO 65% OFF — MARCH SALE"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading — Line 1 (before italic)",
      "default": "Premium Himalayan Yak Chews for"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading — Italic/Highlighted Word(s)",
      "default": "Happy, Healthy",
      "info": "This part shows in golden italic style"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading — Line 2 (after italic)",
      "default": "Dogs"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Handcrafted in Nepal. Loved by dogs everywhere."
    },
    {
      "type": "header",
      "content": "CTA Buttons"
    },
    {
      "type": "text",
      "id": "primary_btn_label",
      "label": "Primary Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "primary_btn_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_btn_label",
      "label": "Secondary Button Label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "secondary_btn_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "header",
      "content": "Trust Bar"
    },
    {
      "type": "checkbox",
      "id": "show_trust_bar",
      "label": "Show Trust Bar below Hero",
      "default": true
    },
    {
      "type": "range",
      "id": "trust_scroll_speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Trust Bar Scroll Speed",
      "default": 30,
      "info": "Lower = faster, Higher = slower"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Badge (Ticker)",
      "settings": [
        {
          "type": "text",
          "id": "feature_text",
          "label": "Feature Text",
          "default": "100% Natural"
        }
      ]
    },
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "text",
          "id": "trust_icon",
          "label": "Icon (Emoji)",
          "default": "🩺"
        },
        {
          "type": "text",
          "id": "trust_title",
          "label": "Title",
          "default": "Vet Approved"
        },
        {
          "type": "text",
          "id": "trust_subtitle",
          "label": "Subtitle",
          "default": "Recommended by vets"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "feature", "settings": { "feature_text": "100% Natural" } },
        { "type": "feature", "settings": { "feature_text": "High Protein" } },
        { "type": "feature", "settings": { "feature_text": "Long-Lasting" } },
        { "type": "feature", "settings": { "feature_text": "Grain Free" } },
        { "type": "feature", "settings": { "feature_text": "Vet Approved" } },
        { "type": "feature", "settings": { "feature_text": "No Additives" } },
        { "type": "feature", "settings": { "feature_text": "Handcrafted in Nepal" } },
        { "type": "trust_badge", "settings": { "trust_icon": "🩺", "trust_title": "Vet Approved", "trust_subtitle": "Recommended by vets" } },
        { "type": "trust_badge", "settings": { "trust_icon": "🌿", "trust_title": "100% Natural", "trust_subtitle": "No artificial anything" } },
        { "type": "trust_badge", "settings": { "trust_icon": "🌾", "trust_title": "Grain Free", "trust_subtitle": "Safe for allergies" } },
        { "type": "trust_badge", "settings": { "trust_icon": "🚫", "trust_title": "No Additives", "trust_subtitle": "Pure ingredients only" } },
        { "type": "trust_badge", "settings": { "trust_icon": "🤲", "trust_title": "Handcrafted", "trust_subtitle": "By Nepalese farmers" } }
      ]
    }
  ]
}
{% endschema %}
<style>
  .pp-trust-bar{
    background: #d4770b;
  }
  .pp-trust-sep{
        background: rgb(255 255 255 / 0%);
  }
</style>