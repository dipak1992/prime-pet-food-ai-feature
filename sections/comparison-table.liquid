{% liquid
  assign section_id = 'yak-comparison-' | append: section.id
%}

<section id="{{ section_id }}" class="yak-comparison-section">
  <div class="page-width">
    <div class="yak-comparison__header">
      {% if section.settings.eyebrow != blank %}
        <p class="yak-comparison__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="yak-comparison__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subtext != blank %}
        <div class="yak-comparison__subtext rte">
          {{ section.settings.subtext }}
        </div>
      {% endif %}
    </div>

    <div class="yak-comparison__table-wrap">
      <div class="yak-comparison__table">
        <div class="yak-comparison__row yak-comparison__row--head">
          <div class="yak-comparison__cell yak-comparison__cell--feature">
            {{ section.settings.feature_column_label }}
          </div>

          <div class="yak-comparison__cell yak-comparison__cell--competitor">
            {{ section.settings.left_title }}
          </div>

          <div class="yak-comparison__cell yak-comparison__cell--brand">
            {% if section.settings.center_badge != blank %}
              <span class="yak-comparison__badge">{{ section.settings.center_badge }}</span>
            {% endif %}
            <span>{{ section.settings.center_title }}</span>
          </div>

          <div class="yak-comparison__cell yak-comparison__cell--competitor">
            {{ section.settings.right_title }}
          </div>
        </div>

        {% for block in section.blocks %}
          {% if block.type == 'comparison_row' %}
            <div class="yak-comparison__row" {{ block.shopify_attributes }}>
              <div class="yak-comparison__cell yak-comparison__cell--feature">
                {{ block.settings.feature }}
              </div>

              <div class="yak-comparison__cell yak-comparison__cell--icon">
                {% if block.settings.left_status == 'check' %}
                  <span class="yak-comparison__icon yak-comparison__icon--check">✓</span>
                {% elsif block.settings.left_status == 'cross' %}
                  <span class="yak-comparison__icon yak-comparison__icon--cross">×</span>
                {% else %}
                  <span class="yak-comparison__icon yak-comparison__icon--dash">—</span>
                {% endif %}
              </div>

              <div class="yak-comparison__cell yak-comparison__cell--icon yak-comparison__cell--brand-body">
                {% if block.settings.center_status == 'check' %}
                  <span class="yak-comparison__icon yak-comparison__icon--brand-check">✓</span>
                {% elsif block.settings.center_status == 'cross' %}
                  <span class="yak-comparison__icon yak-comparison__icon--cross">×</span>
                {% else %}
                  <span class="yak-comparison__icon yak-comparison__icon--dash">—</span>
                {% endif %}
              </div>

              <div class="yak-comparison__cell yak-comparison__cell--icon">
                {% if block.settings.right_status == 'check' %}
                  <span class="yak-comparison__icon yak-comparison__icon--check">✓</span>
                {% elsif block.settings.right_status == 'cross' %}
                  <span class="yak-comparison__icon yak-comparison__icon--cross">×</span>
                {% else %}
                  <span class="yak-comparison__icon yak-comparison__icon--dash">—</span>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% if section.settings.button_label != blank %}
      <div class="yak-comparison__actions">
        <a
          {% if section.settings.button_link != blank %}
            href="{{ section.settings.button_link }}"
          {% else %}
            role="link" aria-disabled="true"
          {% endif %}
          class="yak-comparison__button"
        >
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>

  <style>
    #{{ section_id }} {
      background: {{ section.settings.section_bg }};
      padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
      min-height: 80vh;
      display: flex;
      align-items: center;
    }

    #{{ section_id }} .page-width {
      width: 100%;
      max-width: 1280px;
    }

    #{{ section_id }} .yak-comparison__header {
      max-width: 820px;
      margin: 0 auto 24px;
      text-align: center;
    }

    #{{ section_id }} .yak-comparison__eyebrow {
      margin: 0 0 10px;
      font-size: {{ section.settings.eyebrow_size }}px;
      line-height: 1;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-weight: 700;
      color: {{ section.settings.eyebrow_color }};
    }

    #{{ section_id }} .yak-comparison__heading {
      margin: 0;
      color: {{ section.settings.heading_color }};
      font-size: clamp({{ section.settings.mobile_heading_size }}px, 4vw, {{ section.settings.heading_size }}px);
      line-height: 1;
      letter-spacing: -0.03em;
      font-weight: 700;
    }

    #{{ section_id }} .yak-comparison__subtext {
      margin-top: 10px;
      color: {{ section.settings.subtext_color }};
      font-size: {{ section.settings.subtext_size }}px;
      line-height: 1.4;
      max-width: 680px;
      margin-left: auto;
      margin-right: auto;
    }

    #{{ section_id }} .yak-comparison__subtext p {
      margin: 0;
    }

    #{{ section_id }} .yak-comparison__table-wrap {
      overflow-x: auto;
      padding: 2px;
    }

    #{{ section_id }} .yak-comparison__table {
      min-width: 820px;
      border: 1px solid {{ section.settings.table_border }};
      border-radius: {{ section.settings.table_radius }}px;
      overflow: hidden;
      background: {{ section.settings.table_bg }};
      box-shadow: 0 10px 28px rgba(0,0,0,0.04);
    }

    #{{ section_id }} .yak-comparison__row {
      display: grid;
      grid-template-columns: 1.45fr 0.9fr 1fr 0.9fr;
      border-bottom: 1px solid {{ section.settings.row_border }};
    }

    #{{ section_id }} .yak-comparison__row:last-child {
      border-bottom: 0;
    }

    #{{ section_id }} .yak-comparison__row--head {
      min-height: 70px;
    }

    #{{ section_id }} .yak-comparison__cell {
      display: flex;
      align-items: center;
      padding: 13px 18px;
      color: {{ section.settings.body_color }};
      font-size: {{ section.settings.body_size }}px;
      line-height: 1.2;
      font-weight: 600;
    }

    #{{ section_id }} .yak-comparison__row--head .yak-comparison__cell {
      justify-content: center;
      text-align: center;
      color: {{ section.settings.heading_color }};
      font-size: {{ section.settings.column_heading_size }}px;
      font-weight: 700;
    }

    #{{ section_id }} .yak-comparison__cell--feature {
      justify-content: flex-start;
      text-align: left;
    }

    #{{ section_id }} .yak-comparison__cell--icon {
      justify-content: center;
      text-align: center;
    }

    #{{ section_id }} .yak-comparison__cell--brand,
    #{{ section_id }} .yak-comparison__cell--brand-body {
      background: {{ section.settings.featured_column_bg }};
    }

    #{{ section_id }} .yak-comparison__cell--brand {
      flex-direction: column;
      gap: 8px;
      border-radius: {{ section.settings.featured_column_radius }}px {{ section.settings.featured_column_radius }}px 0 0;
    }

    #{{ section_id }} .yak-comparison__row:last-child .yak-comparison__cell--brand-body {
      border-radius: 0 0 {{ section.settings.featured_column_radius }}px {{ section.settings.featured_column_radius }}px;
    }

    #{{ section_id }} .yak-comparison__badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 6px 12px;
      border-radius: 999px;
      background: {{ section.settings.badge_bg }};
      color: {{ section.settings.badge_text }};
      font-size: {{ section.settings.badge_size }}px;
      line-height: 1;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-weight: 700;
    }

    #{{ section_id }} .yak-comparison__icon {
      width: {{ section.settings.icon_size }}px;
      height: {{ section.settings.icon_size }}px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: calc({{ section.settings.icon_size }}px * 0.55);
      line-height: 1;
      font-weight: 800;
    }

    #{{ section_id }} .yak-comparison__icon--brand-check {
      background: {{ section.settings.brand_icon_bg }};
      color: {{ section.settings.brand_icon_color }};
    }

    #{{ section_id }} .yak-comparison__icon--check {
      background: {{ section.settings.check_icon_bg }};
      color: {{ section.settings.check_icon_color }};
    }

    #{{ section_id }} .yak-comparison__icon--cross {
      background: {{ section.settings.cross_icon_bg }};
      color: {{ section.settings.cross_icon_color }};
    }

    #{{ section_id }} .yak-comparison__icon--dash {
      background: {{ section.settings.dash_icon_bg }};
      color: {{ section.settings.dash_icon_color }};
    }

    #{{ section_id }} .yak-comparison__actions {
      margin-top: 24px;
      display: flex;
      justify-content: center;
    }

    #{{ section_id }} .yak-comparison__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 26px;
      border-radius: 999px;
      background: {{ section.settings.button_bg }};
      color: {{ section.settings.button_text }};
      text-decoration: none;
      font-size: {{ section.settings.button_size }}px;
      line-height: 1;
      font-weight: 700;
      transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
      box-shadow: 0 10px 24px rgba(210, 99, 46, 0.18);
    }

    #{{ section_id }} .yak-comparison__button:hover {
      transform: translateY(-1px);
      background: {{ section.settings.button_hover_bg }};
      box-shadow: 0 14px 30px rgba(210, 99, 46, 0.24);
    }

    @media screen and (max-width: 749px) {
      #{{ section_id }} {
        padding: {{ section.settings.mobile_padding_top }}px 0 {{ section.settings.mobile_padding_bottom }}px;
        min-height: auto;
      }

      #{{ section_id }} .yak-comparison__header {
        margin-bottom: 24px;
      }

      #{{ section_id }} .yak-comparison__subtext {
        font-size: {{ section.settings.mobile_subtext_size }}px;
      }

      #{{ section_id }} .yak-comparison__table-wrap {
        margin-left: -16px;
        margin-right: -16px;
        padding-left: 16px;
        padding-right: 16px;
      }

      #{{ section_id }} .yak-comparison__table {
        min-width: 720px;
      }

      #{{ section_id }} .yak-comparison__cell {
        padding: 14px 14px;
      }

      #{{ section_id }} .yak-comparison__actions {
        margin-top: 22px;
      }

      #{{ section_id }} .yak-comparison__button {
        width: 100%;
      }
    }
  </style>
</section>

