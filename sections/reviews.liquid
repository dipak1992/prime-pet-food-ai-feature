{% comment %}
  Section: Reviews / Social Proof
  File: sections/reviews.liquid
  Description: Compact 3-column review cards grid with rating summary header — fully color customizable
{% endcomment %}

<style>
  /* REVIEW GRID / SLIDER WRAPPERS */
  #pp-reviews-wrapper-{{ section.id }} .pp-reviews-grid,
  #pp-reviews-wrapper-{{ section.id }} .swiper-wrapper,
  #pp-reviews-wrapper-{{ section.id }} .slick-track,
  #pp-reviews-wrapper-{{ section.id }} .embla__container {
    align-items: flex-start !important;
  }

  /* EACH SLIDE / ITEM */
  #pp-reviews-wrapper-{{ section.id }} .pp-reviews-grid > *,
  #pp-reviews-wrapper-{{ section.id }} .swiper-slide,
  #pp-reviews-wrapper-{{ section.id }} .slick-slide,
  #pp-reviews-wrapper-{{ section.id }} .embla__slide {
    height: auto !important;
    min-height: 0 !important;
    display: block !important;
    padding: 10px 0
  }

  /* MAIN CARD */
  #pp-reviews-wrapper-{{ section.id }} .pp-review-card {
    background: {{ section.settings.card_bg_color }};
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: 18px;
    padding: 12px !important;

    height: auto !important;
    min-height: 0 !important;
    max-height: none !important;
    display: inline-block !important;
    width: 100%;
    box-sizing: border-box;
    vertical-align: top;
    align-self: flex-start !important;
  }

  /* REMOVE FORCED HEIGHT FROM ANY INNER BLOCK */
  #pp-reviews-wrapper-{{ section.id }} .pp-review-card *,
  #pp-reviews-wrapper-{{ section.id }} .pp-review-card *::before,
  #pp-reviews-wrapper-{{ section.id }} .pp-review-card *::after {
    box-sizing: border-box;
  }

  /* IMAGE */
  #pp-reviews-wrapper-{{ section.id }} .pp-review-card img,
  #pp-reviews-wrapper-{{ section.id }} .pp-review-image {
    width: 100%;
    height: auto !important;
    min-height: 0 !important;
    max-height: none !important;
    object-fit: cover;
    display: block;
    margin: 0 0 12px !important;
    border-radius: 18px;
  }

  /* STARS */
  #pp-reviews-wrapper-{{ section.id }} .pp-review-stars {
    margin: 0 0 8px !important;
    line-height: 1 !important;
  }

  /* TEXT */
  #pp-reviews-wrapper-{{ section.id }} .pp-review-text {
    margin: 0 0 10px !important;
    line-height: 1.45 !important;
  }

  /* DIVIDER */
  #pp-reviews-wrapper-{{ section.id }} .pp-divider,
  #pp-reviews-wrapper-{{ section.id }} .divider,
  #pp-reviews-wrapper-{{ section.id }} hr {
    margin: 8px 0 10px !important;
  }

  /* NAME / LOCATION BLOCK */
  #pp-reviews-wrapper-{{ section.id }} .pp-review-name {
    margin: 0 0 2px !important;
    line-height: 1.2 !important;
  }

  #pp-reviews-wrapper-{{ section.id }} .pp-review-location {
    margin: 0 !important;
    line-height: 1.2 !important;
  }

  /* KILL EXTRA SPACE FROM LAST ELEMENTS */
  #pp-reviews-wrapper-{{ section.id }} .pp-review-card > :last-child {
    margin-bottom: 0 !important;
  }

  /* VERY IMPORTANT: if parent card wrapper exists */
  #pp-reviews-wrapper-{{ section.id }} .card,
  #pp-reviews-wrapper-{{ section.id }} .Card,
  #pp-reviews-wrapper-{{ section.id }} [class*="card"],
  #pp-reviews-wrapper-{{ section.id }} [class*="Card"] {
    min-height: 0 !important;
    height: auto !important;
    max-height: none !important;
  }
</style>

<div id="pp-reviews-wrapper-{{ section.id }}">
  <section class="pp-reviews-section" id="pp-reviews-{{ section.id }}">
    <div class="pp-reviews-inner">

      <div class="pp-reviews-header">
        <div>
          {% if section.settings.section_label != blank %}
            <div class="pp-section-label">{{ section.settings.section_label }}</div>
          {% endif %}
          {% if section.settings.section_title != blank %}
            <h2 class="pp-section-title">{{ section.settings.section_title }}</h2>
          {% endif %}
        </div>

        {% if section.settings.show_rating_summary %}
          <div class="pp-reviews-summary">
            <div class="pp-reviews-big-number">{{ section.settings.rating_number }}</div>
            <div class="pp-reviews-meta">
              <span class="pp-stars">★★★★★</span>
              <span>{{ section.settings.rating_label }}</span>
            </div>
          </div>
        {% endif %}
      </div>

      <div class="pp-reviews-grid" id="pp-reviews-grid-{{ section.id }}">
        {% for block in section.blocks %}
          {% if block.type == 'review_card' %}
            {% assign avatar_initial = block.settings.reviewer_name | slice: 0 %}
            <div class="pp-review-card" {{ block.shopify_attributes }}>
              <div class="pp-review-card-header">
                <div class="pp-review-avatar" style="background: {{ block.settings.avatar_color }};">
                  {{ avatar_initial | upcase }}
                </div>
                <div>
                  <div class="pp-review-name">{{ block.settings.reviewer_name }}</div>
                  {% if block.settings.reviewer_location != blank %}
                    <div class="pp-review-location">{{ block.settings.reviewer_location }}</div>
                  {% endif %}
                </div>
              </div>

              <div class="pp-review-stars">
                {% assign star_count = block.settings.star_rating | plus: 0 %}
                {% for i in (1..5) %}
                  {% if i <= star_count %}★{% else %}☆{% endif %}
                {% endfor %}
              </div>

              <div class="pp-review-text">{{ block.settings.review_text }}</div>

              {% if block.settings.show_verified %}
                <div class="pp-review-verified">✓ Customer note</div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

    </div>
  </section>
</div>

<script>
(function() {
  var grid = document.getElementById('pp-reviews-grid-{{ section.id }}');
  if (!grid) return;
  var cards = grid.querySelectorAll('.pp-review-card');

  cards.forEach(function(card, i) {
    card.style.transition = 'all 0.45s ease-out';
    card.style.transitionDelay = (i * 0.08) + 's';
  });

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -30px 0px' });

  cards.forEach(function(card) {
    observer.observe(card);
  });
})();
</script>

