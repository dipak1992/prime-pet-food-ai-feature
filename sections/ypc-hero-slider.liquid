{% liquid
  assign autoplay = section.settings.autoplay
  assign autoplay_speed = section.settings.autoplay_speed | times: 1000
%}

<section id="ypc-hero-slider-{{ section.id }}" class="ypc-hero-slider" data-autoplay="{{ autoplay }}" data-speed="{{ autoplay_speed }}">
  <div class="ypc-hero-slider__track-wrap">
    <div class="ypc-hero-slider__track">
      {% for block in section.blocks %}
        <div class="ypc-hero-slide {% if forloop.first %}is-active{% endif %}" {{ block.shopify_attributes }}>
          <div class="ypc-hero-slide__media">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 2400
                | image_tag:
                  loading: 'lazy',
                  class: 'ypc-hero-slide__image',
                  alt: block.settings.heading | escape
              }}
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'ypc-hero-slide__image ypc-hero-slide__image--placeholder' }}
            {% endif %}
          </div>

          <div class="page-width">
            <div class="ypc-hero-slide__content ypc-hero-slide__content--{{ block.settings.content_alignment }}">
              {% if block.settings.eyebrow != blank %}
                <p class="ypc-hero-slide__eyebrow">
                  <span class="ypc-hero-slide__eyebrow-line"></span>
                  {{ block.settings.eyebrow }}
                </p>
              {% endif %}

              {% if block.settings.heading != blank %}
                <h2 class="ypc-hero-slide__heading">{{ block.settings.heading }}</h2>
              {% endif %}

              {% if block.settings.text != blank %}
                <div class="ypc-hero-slide__text">{{ block.settings.text }}</div>
              {% endif %}

              <div class="ypc-hero-slide__buttons">
                {% if block.settings.button_1_label != blank %}
                  <a
                    {% if block.settings.button_1_link != blank %}
                      href="{{ block.settings.button_1_link }}"
                    {% else %}
                      role="link" aria-disabled="true"
                    {% endif %}
                    class="ypc-hero-slide__button ypc-hero-slide__button--primary"
                  >
                    {{ block.settings.button_1_label }}
                  </a>
                {% endif %}

                {% if block.settings.button_2_label != blank %}
                  <a
                    {% if block.settings.button_2_link != blank %}
                      href="{{ block.settings.button_2_link }}"
                    {% else %}
                      role="link" aria-disabled="true"
                    {% endif %}
                    class="ypc-hero-slide__button ypc-hero-slide__button--secondary"
                  >
                    {{ block.settings.button_2_label }}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.blocks.size > 1 %}
      <button class="ypc-hero-slider__arrow ypc-hero-slider__arrow--prev" type="button" aria-label="Previous slide">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="ypc-hero-slider__arrow ypc-hero-slider__arrow--next" type="button" aria-label="Next slide">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="ypc-hero-slider__dots">
        {% for block in section.blocks %}
          <button
            class="ypc-hero-slider__dot {% if forloop.first %}is-active{% endif %}"
            type="button"
            aria-label="Go to slide {{ forloop.index }}"
            data-index="{{ forloop.index0 }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <style>
    #ypc-hero-slider-{{ section.id }} {
      position: relative;
      overflow: hidden;
      background: #111;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slider__track-wrap {
      position: relative;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slider__track {
      position: relative;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide {
      position: relative;
      min-height: {{ section.settings.desktop_height }}px;
      display: none;
      align-items: center;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide.is-active {
      display: flex;
    }

    /* ── Media layer ── */
    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__media {
      position: absolute;
      inset: 0;
      z-index: 1;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__image,
    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__image--placeholder {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* Single reliable gradient overlay via ::after — same technique as the reference HTML.
       Stacked as: dark-left-to-transparent-right (for text legibility) 
       + a base dark tint on top. No separate divs = no z-index stacking bugs. */
    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__media::after {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 2;
      background:
        linear-gradient(
          to bottom,
          rgba(10, 4, 0, 0.18) 0%,
          rgba(10, 4, 0, 0.10) 100%
        ),
        linear-gradient(
          to right,
          rgba(10, 4, 0, 0.82) 0%,
          rgba(10, 4, 0, 0.65) 35%,
          rgba(10, 4, 0, 0.22) 65%,
          rgba(10, 4, 0, 0.05) 100%
        );
    }

    /* ── Content ── */
    #ypc-hero-slider-{{ section.id }} .page-width {
      position: relative;
      z-index: 3;
      width: 100%;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__content {
      max-width: 600px;
      color: #fff;
      padding: 60px 0;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__content--left {
      text-align: left;
      margin-right: auto;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__content--center {
      text-align: center;
      margin-left: auto;
      margin-right: auto;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__content--right {
      text-align: right;
      margin-left: auto;
    }

    /* ── Eyebrow ── */
    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__eyebrow {
      margin: 0 0 14px;
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 600;
      color: #d4711e;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__content--center .ypc-hero-slide__eyebrow {
      justify-content: center;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__content--right .ypc-hero-slide__eyebrow {
      justify-content: flex-end;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__eyebrow-line {
      display: inline-block;
      width: 28px;
      height: 2px;
      background: #d4711e;
      flex-shrink: 0;
    }

    /* ── Heading ── */
    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__heading {
      margin: 0 0 18px;
      font-size: 52px;
      line-height: 1.06;
      font-weight: 700;
      color: #fff;
      text-shadow: 0 2px 20px rgba(0,0,0,0.45);
      letter-spacing: -0.01em;
    }

    /* ── Body text ── */
    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__text {
      margin: 0 0 28px;
      font-size: 16px;
      line-height: 1.65;
      max-width: 520px;
      color: rgba(255, 255, 255, 0.88);
      text-shadow: 0 1px 8px rgba(0,0,0,0.5);
    }

    /* ── Buttons ── */
    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__buttons {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__content--center .ypc-hero-slide__buttons {
      justify-content: center;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__content--right .ypc-hero-slide__buttons {
      justify-content: flex-end;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 50px;
      padding: 0 28px;
      border-radius: 999px;
      text-decoration: none;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.02em;
      transition: all 0.25s ease;
      cursor: pointer;
    }

    /* Primary — solid brand colour */
    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__button--primary {
      background: #d4711e;
      color: #fff;
      border: 2px solid #d4711e;
      box-shadow: 0 4px 18px rgba(212, 113, 30, 0.40);
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__button--primary:hover {
      background: #bf6318;
      border-color: #bf6318;
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(212, 113, 30, 0.50);
    }

    /* Secondary — white ghost */
    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__button--secondary {
      background: transparent;
      color: #fff;
      border: 2px solid rgba(255, 255, 255, 0.75);
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__button--secondary:hover {
      background: rgba(255, 255, 255, 0.12);
      border-color: #fff;
      transform: translateY(-2px);
    }

    /* ── Arrows ── */
    #ypc-hero-slider-{{ section.id }} .ypc-hero-slider__arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 6;
      width: 46px;
      height: 46px;
      border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.5);
      cursor: pointer;
      background: rgba(0,0,0,0.30);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.22s ease;
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slider__arrow:hover {
      background: #d4711e;
      border-color: #d4711e;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slider__arrow--prev {
      left: 24px;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slider__arrow--next {
      right: 24px;
    }

    /* ── Dots ── */
    #ypc-hero-slider-{{ section.id }} .ypc-hero-slider__dots {
      position: absolute;
      left: 50%;
      bottom: 24px;
      transform: translateX(-50%);
      z-index: 6;
      display: flex;
      gap: 8px;
      align-items: center;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slider__dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      border: none;
      background: rgba(255,255,255,0.40);
      cursor: pointer;
      padding: 0;
      transition: all 0.25s ease;
    }

    #ypc-hero-slider-{{ section.id }} .ypc-hero-slider__dot.is-active {
      background: #d4711e;
      width: 24px;
      border-radius: 4px;
    }

    /* ── Responsive ── */
    @media screen and (max-width: 989px) {
      #ypc-hero-slider-{{ section.id }} .ypc-hero-slide {
        min-height: {{ section.settings.mobile_height }}px;
      }

      #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__content {
        max-width: 100%;
        padding: 40px 0 72px;
      }

      #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__heading {
        font-size: 36px;
      }

      /* On mobile switch to a bottom-up gradient since content stacks lower */
      #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__media::after {
        background:
          linear-gradient(
            to top,
            rgba(10, 4, 0, 0.88) 0%,
            rgba(10, 4, 0, 0.60) 45%,
            rgba(10, 4, 0, 0.15) 100%
          );
      }

      #ypc-hero-slider-{{ section.id }} .ypc-hero-slider__arrow {
        width: 38px;
        height: 38px;
      }
    }

    @media screen and (max-width: 749px) {
      #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__heading {
        font-size: 28px;
      }

      #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__text {
        font-size: 14px;
      }

      #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__buttons {
        gap: 10px;
      }

      #ypc-hero-slider-{{ section.id }} .ypc-hero-slide__button {
        min-height: 44px;
        padding: 0 20px;
        font-size: 13px;
      }

      #ypc-hero-slider-{{ section.id }} .ypc-hero-slider__arrow--prev {
        left: 12px;
      }

      #ypc-hero-slider-{{ section.id }} .ypc-hero-slider__arrow--next {
        right: 12px;
      }
    }
  </style>

  <script>
    (function() {
      const section = document.getElementById('ypc-hero-slider-{{ section.id }}');
      if (!section) return;

      const slides = section.querySelectorAll('.ypc-hero-slide');
      const dots = section.querySelectorAll('.ypc-hero-slider__dot');
      const prevBtn = section.querySelector('.ypc-hero-slider__arrow--prev');
      const nextBtn = section.querySelector('.ypc-hero-slider__arrow--next');

      if (slides.length <= 1) return;

      let currentIndex = 0;
      let interval;
      const autoplayEnabled = section.dataset.autoplay === 'true';
      const speed = parseInt(section.dataset.speed || 5000, 10);

      function showSlide(index) {
        slides.forEach((slide, i) => {
          slide.classList.toggle('is-active', i === index);
        });
        dots.forEach((dot, i) => {
          dot.classList.toggle('is-active', i === index);
        });
        currentIndex = index;
      }

      function nextSlide() {
        showSlide((currentIndex + 1) % slides.length);
      }

      function prevSlide() {
        showSlide((currentIndex - 1 + slides.length) % slides.length);
      }

      function startAutoplay() {
        if (!autoplayEnabled) return;
        stopAutoplay();
        interval = setInterval(nextSlide, speed);
      }

      function stopAutoplay() {
        if (interval) clearInterval(interval);
      }

      if (nextBtn) nextBtn.addEventListener('click', () => { nextSlide(); startAutoplay(); });
      if (prevBtn) prevBtn.addEventListener('click', () => { prevSlide(); startAutoplay(); });

      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => { showSlide(index); startAutoplay(); });
      });

      section.addEventListener('mouseenter', stopAutoplay);
      section.addEventListener('mouseleave', startAutoplay);

      startAutoplay();
    })();
  </script>
</section>

{% schema %}
{
  "name": "YPC Hero Slider",
  "settings": [
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed (seconds)",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop height",
      "min": 500,
      "max": 900,
      "step": 20,
      "default": 720
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 420,
      "max": 800,
      "step": 20,
      "default": 560
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Small label",
          "default": "Authentic Himalayan Source"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Made from pure Himalayan yak milk"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Short description",
          "default": "Crafted from traditional Himalayan yak cheese to bring a natural, long-lasting chew your dog will love."
        },
        {
          "type": "select",
          "id": "content_alignment",
          "label": "Content alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "button_1_label",
          "label": "Primary button label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "button_1_link",
          "label": "Primary button link"
        },
        {
          "type": "text",
          "id": "button_2_label",
          "label": "Secondary button label",
          "default": "Know the process"
        },
        {
          "type": "url",
          "id": "button_2_link",
          "label": "Secondary button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "YPC Hero Slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Authentic Himalayan Source",
            "heading": "Made from pure Himalayan yak milk",
            "text": "Rooted in Himalayan tradition, our chews begin with natural yak milk and a slow-crafted process for true authenticity.",
            "button_1_label": "Shop now",
            "button_2_label": "Know the process",
            "content_alignment": "left"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Loved by Dogs in the USA",
            "heading": "A chew dogs keep coming back to",
            "text": "Long-lasting, natural, and satisfying — made for dogs who love to chew and parents who want better ingredients.",
            "button_1_label": "Shop now",
            "button_2_label": "Why dogs love it",
            "content_alignment": "left"
          }
        }
      ]
    }
  ]
}
{% endschema %}
