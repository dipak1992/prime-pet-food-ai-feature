    .ypd-puff-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .ypd-puff-card {
      position: relative;
      background: #fff;
      border-radius: 22px;
      padding: 34px 24px 28px;
      text-align: center;
      box-shadow: 0 10px 30px rgba(17,38,28,0.08);
    }
    .ypd-puff-num {
      position: absolute;
      top: -16px;
      left: 50%;
      transform: translateX(-50%);
      width: 38px;
      height: 38px;
      border-radius: 999px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #d5b067;
      color: #173b2b;
      font: 800 15px/1 system-ui, sans-serif;
    }
    .ypd-puff-icon { font-size: 46px; margin: 10px 0 14px; }
    .ypd-puff-card h4 {
      margin: 0 0 8px;
      font: 700 20px/1.2 Georgia, serif;
      color: #173b2b;
    }
    .ypd-puff-card p {
      margin: 0;
      color: #6a6660;
      font: 500 14px/1.7 system-ui, sans-serif;
    }

    .ypd-review-card {
      background: #fff;
      box-shadow: 0 10px 28px rgba(17,38,28,0.08);
    }
    .ypd-review-stars {
      margin-bottom: 12px;
      color: #d5a72c;
      letter-spacing: 2px;
      font-size: 16px;
    }
    .ypd-review-card p {
      margin: 0 0 14px;
      color: #55514a;
      font: italic 500 15px/1.8 system-ui, sans-serif;
    }
    .ypd-review-card strong {
      color: #173b2b;
      font: 700 14px/1.3 system-ui, sans-serif;
    }

    .ypd-promise-card {
      text-align: center;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
    }
    .ypd-promise-icon { font-size: 42px; margin-bottom: 14px; }
    .ypd-promise-card h4 {
      margin: 0 0 8px;
      color: #f8f1e4;
      font: 700 18px/1.2 Georgia, serif;
    }
    .ypd-promise-card p {
      margin: 0;
      color: rgba(248,241,228,0.72);
      font: 500 13px/1.7 system-ui, sans-serif;
    }

    .ypd-faq { display: grid; gap: 12px; }
    .ypd-faq-item {
      border: 1px solid #e7decf;
      border-radius: 18px;
      background: #fff;
      overflow: hidden;
    }
    .ypd-faq-question {
      width: 100%;
      background: none;
      border: 0;
      padding: 22px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      cursor: pointer;
      color: #173b2b;
      text-align: left;
      font: 700 17px/1.4 system-ui, sans-serif;
    }
    .ypd-faq-question span {
      width: 32px;
      height: 32px;
      min-width: 32px;
      border-radius: 999px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #f3ece0;
      color: #173b2b;
      font-size: 22px;
      line-height: 1;
    }
    .ypd-faq-answer {
      display: none;
      padding: 0 24px 22px;
      color: #6d6963;
      font: 500 15px/1.8 system-ui, sans-serif;
    }
    .ypd-faq-item.is-open .ypd-faq-answer { display: block; }
    .ypd-faq-item.is-open .ypd-faq-question span {
      background: #173b2b;
      color: #fff;
      transform: rotate(45deg);
    }

    .ypd-final-title {
      margin: 0 0 16px;
      color: #f8f1e4;
      font: 700 clamp(38px, 5vw, 62px)/1.06 Georgia, serif;
    }
    .ypd-final-subtitle {
      max-width: 760px;
      margin: 0 auto 30px;
      color: rgba(248,241,228,0.76);
      font: 500 18px/1.8 system-ui, sans-serif;
    }
    .ypd-final-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 320px;
      padding: 20px 32px;
      border-radius: 16px;
      background: #d5a75a;
      color: #13241b;
      text-decoration: none;
      font: 800 17px/1.2 system-ui, sans-serif;
      letter-spacing: 0.6px;
      text-transform: uppercase;
    }
    .ypd-table-wrap {
    overflow-x: auto;
    border-radius: 16px;
    box-shadow: 0 10px 28px rgba(17,38,28,0.08);
  }

  .ypd-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-family: system-ui, sans-serif;
  }

  .ypd-table thead th {
    background: #173b2b;
    color: #f8f1e4;
    padding: 16px 20px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-align: left;
  }

  .ypd-table tbody td {
    padding: 16px 20px;
    border-bottom: 1px solid #e7decf;
    font-size: 15px;
    color: #4b4b4b;
    background: #fffdf9;
  }

  .ypd-table tbody tr:nth-child(even) td {
    background: #f8f2e9;
  }

  .ypd-table tbody tr:last-child td {
    border-bottom: none;
  }

  .ypd-pill {
    display: inline-block;
    background: #173b2b;
    color: #fff;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    margin-left: 8px;
  }

    @media (max-width: 991px) {
      .ypd-size-card,
      .ypd-story-grid { grid-template-columns: 1fr; }
      .ypd-compare-grid,
      .ypd-benefits-grid,
      .ypd-puff-grid,
      .ypd-promise-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 767px) {
      .ypd-wrap, .ypd-final { padding: 60px 0; }
      .ypd-title { font-size: 30px; }
      .ypd-compare-grid,
      .ypd-benefits-grid,
      .ypd-review-grid,
      .ypd-puff-grid,
      .ypd-promise-grid { grid-template-columns: 1fr; }
      .ypd-final-btn { min-width: 0; width: 100%; }
    }
</style>

