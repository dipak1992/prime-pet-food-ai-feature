<section class="ypd-wrap">
  <div class="ypd-container">
    <div class="ypd-section-header">
      <span class="ypd-eyebrow">{{ section.settings.size_eyebrow }}</span>
      <h2 class="ypd-title">{{ section.settings.size_title }}</h2>
      <p class="ypd-subtitle">{{ section.settings.size_subtitle }}</p>
    </div>

    <div class="ypd-table-wrap">
      <table class="ypd-table">
        <thead>
          <tr>
            <th>Size</th>
            <th>Dog Weight</th>
            <th>Chew Weight</th>
            <th>Best For</th>
            <th>Lasts</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>🐕 <strong>Small</strong></td>
            <td>Under 15 lbs</td>
            <td>~1.5 oz</td>
            <td>Toy breeds, puppies</td>
            <td>2–4 days</td>
          </tr>
          <tr>
            <td>🐕 <strong>Medium</strong></td>
            <td>15–35 lbs</td>
            <td>~2.5 oz</td>
            <td>Beagles, Corgis, Cockers</td>
            <td>3–7 days</td>
          </tr>
          <tr>
            <td>🐕‍🦺 <strong>Large</strong> <span class="ypd-pill">Popular</span></td>
            <td>35–55 lbs</td>
            <td>~4 oz</td>
            <td>Labs, Goldens, Huskies</td>
            <td>5–10 days</td>
          </tr>
          <tr>
            <td>🐕‍🦺 <strong>Extra Large</strong></td>
            <td>55–85 lbs</td>
            <td>~6 oz</td>
            <td>German Shepherds, Boxers</td>
            <td>1–2 weeks</td>
          </tr>
          <tr>
            <td>🦮 <strong>Jumbo</strong></td>
            <td>85+ lbs</td>
            <td>~8 oz</td>
            <td>Great Danes, Mastiffs, Saint Bernards</td>
            <td>2–3 weeks</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="ypd-wrap ypd-wrap--white">
  <div class="ypd-container">
    <div class="ypd-section-header">
      <span class="ypd-eyebrow">{{ section.settings.compare_eyebrow }}</span>
      <h2 class="ypd-title">{{ section.settings.compare_title }}</h2>
      <p class="ypd-subtitle">{{ section.settings.compare_subtitle }}</p>
    </div>

    <div class="ypd-compare-grid">
      <div class="ypd-compare-card">
        <div class="ypd-compare-media">
          {% if section.settings.compare_image_1 != blank %}
            {{
              section.settings.compare_image_1
              | image_url: width: 300
              | image_tag: loading: 'lazy', widths: '150, 200, 300', class: 'ypd-compare-img', alt: 'Rawhide'
            }}
          {% else %}
            <div class="ypd-compare-fallback">Rawhide</div>
          {% endif %}
        </div>

        <h3>Rawhide</h3>
        <ul class="ypd-compare-list">
          <li><span class="ypd-compare-bullet ypd-compare-bullet--bad">✕</span><span>Bleached and processed</span></li>
          <li><span class="ypd-compare-bullet ypd-compare-bullet--bad">✕</span><span>Not fully digestible</span></li>
          <li><span class="ypd-compare-bullet ypd-compare-bullet--bad">✕</span><span>Higher blockage risk</span></li>
          <li><span class="ypd-compare-bullet ypd-compare-bullet--bad">✕</span><span>Low nutritional value</span></li>
          <li><span class="ypd-compare-bullet ypd-compare-bullet--bad">✕</span><span>Unclear sourcing</span></li>
        </ul>
      </div>

      <div class="ypd-compare-card ypd-compare-card--best">
        <div class="ypd-compare-media">
          {% if section.settings.compare_image_2 != blank %}
            {{
              section.settings.compare_image_2
              | image_url: width: 300
              | image_tag: loading: 'lazy', widths: '150, 200, 300', class: 'ypd-compare-img', alt: product.title
            }}
          {% elsif product.featured_image %}
            {{
              product.featured_image
              | image_url: width: 300
              | image_tag: loading: 'lazy', widths: '150, 200, 300', class: 'ypd-compare-img', alt: product.title
            }}
          {% else %}
            <div class="ypd-compare-fallback">{{ product.title }}</div>
          {% endif %}
        </div>

        <h3>{{ product.title }}</h3>
        <ul class="ypd-compare-list">
          <li>
            <span class="ypd-compare-bullet ypd-compare-bullet--good">✓</span><span>100% natural ingredients</span>
          </li>
          <li><span class="ypd-compare-bullet ypd-compare-bullet--good">✓</span><span>Dense and long-lasting</span></li>
          <li>
            <span class="ypd-compare-bullet ypd-compare-bullet--good">✓</span><span>High protein &amp; calcium</span>
          </li>
          <li><span class="ypd-compare-bullet ypd-compare-bullet--good">✓</span><span>Cleaner indoor chew</span></li>
          <li>
            <span class="ypd-compare-bullet ypd-compare-bullet--good">✓</span><span>Traditional Himalayan process</span>
          </li>
        </ul>
      </div>

      <div class="ypd-compare-card">
        <div class="ypd-compare-media">
          {% if section.settings.compare_image_3 != blank %}
            {{
              section.settings.compare_image_3
              | image_url: width: 300
              | image_tag: loading: 'lazy', widths: '150, 200, 300', class: 'ypd-compare-img', alt: 'Bully sticks'
            }}
          {% else %}
            <div class="ypd-compare-fallback">Bully Sticks</div>
          {% endif %}
        </div>

        <h3>Bully Sticks</h3>
        <ul class="ypd-compare-list">
          <li><span class="ypd-compare-bullet ypd-compare-bullet--bad">✕</span><span>Strong odor indoors</span></li>
          <li><span class="ypd-compare-bullet ypd-compare-bullet--bad">✕</span><span>Often short-lasting</span></li>
          <li>
            <span class="ypd-compare-bullet ypd-compare-bullet--bad">✕</span><span>Can leave greasy residue</span>
          </li>
          <li><span class="ypd-compare-bullet ypd-compare-bullet--bad">✕</span><span>Higher calorie chew</span></li>
          <li>
            <span class="ypd-compare-bullet ypd-compare-bullet--bad">✕</span><span>Messier overall experience</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

