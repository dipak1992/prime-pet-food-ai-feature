  </div>
</section>

<script>
  (function () {
    document.querySelectorAll('.ypd-faq-question').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item = btn.closest('.ypd-faq-item');
        var isOpen = item.classList.contains('is-open');

        document.querySelectorAll('.ypd-faq-item').forEach(function (el) {
          el.classList.remove('is-open');
        });

        if (!isOpen) item.classList.add('is-open');
      });
    });
  })();
</script>

