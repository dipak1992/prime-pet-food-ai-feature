{% liquid
  assign founder_image_url = 'prime-founder.png' | asset_url
%}

<section class="prime-founder-about" aria-labelledby="PrimeFounderAboutTitle">
  <div class="pfa-hero">
    <div class="pfa-hero__media">
      <img
        src="{{ founder_image_url }}"
        alt="Prime Pet Food founder representing Himalayan yak chew sourcing and dog enrichment"
        width="941"
        height="1672"
        loading="eager"
        class="pfa-hero__image"
      >
    </div>

    <div class="pfa-hero__overlay"></div>

    <div class="pfa-shell pfa-hero__content">
      <p class="pfa-kicker">Founder-led Himalayan dog enrichment</p>
      <h1 id="PrimeFounderAboutTitle">From Nepal's Himalayan tradition to calmer modern dog homes.</h1>
      <p>
        Prime Pet Food began with a simple belief: a dog chew should feel trustworthy, purposeful,
        and rooted in real ingredients, not mystery fillers or throwaway treats.
      </p>
      <div class="pfa-hero__actions" aria-label="About page actions">
        <a href="/collections/all" class="pfa-button pfa-button--primary">Shop yak chews</a>
        <a href="#founder-story" class="pfa-button pfa-button--secondary">Read the story</a>
      </div>
    </div>
  </div>

  <div class="pfa-origin" id="founder-story">
    <div class="pfa-shell pfa-origin__grid">
      <div class="pfa-origin__intro">
        <p class="pfa-kicker">The founder story</p>
        <h2>Built by a dog lover carrying Himalayan roots into a modern pet brand.</h2>
      </div>

      <div class="pfa-story">
        <p>
          I was born and raised in Nepal, where Himalayan products were not a marketing idea.
          They were part of everyday life: simple, practical, and made with respect for the land
          and the people behind them.
        </p>
        <p>
          After moving to the United States in 2019, I began seeing dog care through a new lens.
          As a dog lover and software engineer, I naturally paid attention to the systems behind
          products: the ingredients, the sourcing, the user experience, and the level of trust a
          family has to place in a brand before giving something to their dog.
        </p>
        <p>
          Too many chew options felt low quality, short lived, or hard to trust. Prime Pet Food was
          created to bring something better forward: authentic Himalayan yak cheese chews with a
          calm, long-lasting purpose for dogs and the people who love them.
        </p>
      </div>
    </div>
  </div>

  <div class="pfa-editorial">
    <div class="pfa-shell pfa-editorial__grid">
      <div class="pfa-founder-card">
        <img
          src="{{ founder_image_url }}"
          alt="Founder of Prime Pet Food"
          width="941"
          height="1672"
          loading="lazy"
          class="pfa-founder-card__image"
        >
        <div class="pfa-founder-card__caption">
          <strong>Prime Pet Food founder</strong>
          <span>Nepali roots. Modern dog care. Purposeful enrichment.</span>
        </div>
      </div>

      <div class="pfa-editorial__copy">
        <p class="pfa-kicker">Why this matters</p>
        <h2>Dogs do not need more noise. They need better rituals.</h2>
        <p>
          A great chew is not just a snack. It gives dogs something meaningful to do, supports a
          calmer household, and helps modern dog parents turn restless moments into focused,
          satisfying enrichment.
        </p>
        <p>
          That is the standard behind Prime Pet Food: culturally authentic Himalayan inspiration,
          careful product thinking, and a deep respect for the trust customers place in us.
        </p>
      </div>
    </div>
  </div>

  <div class="pfa-beliefs">
    <div class="pfa-shell">
      <div class="pfa-section-head">
        <p class="pfa-kicker">Our product philosophy</p>
        <h2>Real ingredients, real purpose, calmer routines.</h2>
      </div>

      <div class="pfa-beliefs__grid">
        <article class="pfa-belief">
          <span>01</span>
          <h3>Authentic Himalayan heritage</h3>
          <p>
            Inspired by traditional yak cheese practices from the Himalayan region and built for
            today's quality-conscious dog parents.
          </p>
        </article>

        <article class="pfa-belief">
          <span>02</span>
          <h3>Long-lasting enrichment</h3>
          <p>
            Designed to keep dogs engaged longer, reduce boredom, and support more peaceful
            everyday routines at home.
          </p>
        </article>

        <article class="pfa-belief">
          <span>03</span>
          <h3>Dog-first trust</h3>
          <p>
            Simple, purposeful chews selected with the mindset that every ingredient should earn
            its place.
          </p>
        </article>
      </div>
    </div>
  </div>

  <div class="pfa-promise">
    <div class="pfa-shell pfa-promise__grid">
      <div>
        <p class="pfa-kicker">Our promise</p>
        <h2>Premium care should feel calm, honest, and easy to trust.</h2>
      </div>

      <div class="pfa-promise__list" aria-label="Prime Pet Food promises">
        <div>
          <strong>Safer chewing mindset</strong>
          <span>Built around supervised, satisfying chew time instead of cheap, questionable fillers.</span>
        </div>
        <div>
          <strong>Modern dog parenting</strong>
          <span>Products and guidance that help make daily enrichment feel simple and confident.</span>
        </div>
        <div>
          <strong>Cultural authenticity</strong>
          <span>A brand shaped by Nepali roots without turning heritage into a costume.</span>
        </div>
      </div>
    </div>
  </div>

  <div class="pfa-cta">
    <div class="pfa-shell pfa-cta__inner">
      <p class="pfa-kicker">For dogs who need more than a treat</p>
      <h2>Bring home a calmer, longer-lasting chew ritual.</h2>
      <p>
        Explore authentic Himalayan yak cheese chews made for enrichment, focus, and everyday
        moments of calm.
      </p>
      <a href="/collections/all" class="pfa-button pfa-button--primary">Shop Prime Pet Food</a>
    </div>
  </div>
</section>

<style>
  .prime-founder-about {
    --pfa-ink: #171512;
    --pfa-muted: #5f574e;
    --pfa-soft: #f8f1e7;
    --pfa-cream: #fffaf2;
    --pfa-clay: #b85f32;
    --pfa-clay-dark: #94451f;
    --pfa-forest: #243c2d;
    --pfa-line: rgba(51, 40, 29, 0.14);
    --pfa-card: #ffffff;
    color: var(--pfa-ink);
    background: var(--pfa-cream);
    font-family: var(--prime-font-sans, "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  .prime-founder-about * {
    box-sizing: border-box;
  }

  .pfa-shell {
    width: min(1180px, calc(100% - 32px));
    margin-inline: auto;
  }

  .pfa-kicker {
    margin: 0 0 14px;
    color: var(--pfa-clay);
    font-size: 12px;
    line-height: 1.25;
    letter-spacing: 0;
    text-transform: uppercase;
    font-weight: 780;
  }

  .prime-founder-about h1,
  .prime-founder-about h2,
  .prime-founder-about h3 {
    margin: 0;
    font-family: var(--prime-font-display, var(--prime-font-sans, inherit));
    letter-spacing: 0;
    color: inherit;
  }

  .prime-founder-about h1 {
    max-width: 820px;
    font-size: 88px;
    line-height: 0.98;
    font-weight: 760;
  }

  .prime-founder-about h2 {
    font-size: 58px;
    line-height: 1.04;
    font-weight: 735;
  }

  .prime-founder-about h3 {
    font-size: 25px;
    line-height: 1.16;
    font-weight: 735;
  }

  .prime-founder-about p {
    margin: 0;
    color: var(--pfa-muted);
    font-size: 19px;
    line-height: 1.72;
  }

  .pfa-hero {
    position: relative;
    min-height: clamp(680px, 92vh, 900px);
    display: grid;
    align-items: end;
    overflow: hidden;
    isolation: isolate;
    background: #1e1a15;
  }

  .pfa-hero__media,
  .pfa-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .pfa-hero__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(19, 16, 12, 0.88) 0%, rgba(19, 16, 12, 0.58) 42%, rgba(19, 16, 12, 0.08) 100%);
  }

  .pfa-hero__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: 64% 34%;
  }

  .pfa-hero__overlay {
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.06) 0%, rgba(0, 0, 0, 0.24) 100%),
      radial-gradient(circle at 18% 28%, rgba(184, 95, 50, 0.28), transparent 32%);
  }

  .pfa-hero__content {
    padding-block: clamp(92px, 14vh, 156px) clamp(72px, 10vh, 120px);
  }

  .pfa-hero .pfa-kicker,
  .pfa-hero h1,
  .pfa-hero p {
    color: #fffaf2;
    text-shadow: 0 2px 28px rgba(0, 0, 0, 0.26);
  }

  .pfa-hero p {
    max-width: 640px;
    margin-top: 24px;
    color: rgba(255, 250, 242, 0.86);
  }

  .pfa-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  .pfa-button {
    display: inline-flex;
    min-height: 52px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 15px 26px;
    font-size: 13px;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
    font-weight: 780;
    text-decoration: none;
    transition: transform 180ms ease, background 180ms ease, border-color 180ms ease, color 180ms ease;
  }

  .pfa-button:hover {
    transform: translateY(-1px);
  }

  .pfa-button--primary {
    background: var(--pfa-clay);
    color: #fff;
    box-shadow: 0 18px 36px rgba(77, 36, 16, 0.26);
  }

  .pfa-button--primary:hover {
    background: var(--pfa-clay-dark);
    color: #fff;
  }

  .pfa-button--secondary {
    border: 1px solid rgba(255, 250, 242, 0.42);
    color: #fffaf2;
    background: rgba(255, 250, 242, 0.08);
    backdrop-filter: blur(12px);
  }

  .pfa-origin,
  .pfa-editorial,
  .pfa-beliefs,
  .pfa-promise,
  .pfa-cta {
    padding-block: clamp(72px, 10vw, 132px);
  }

  .pfa-origin {
    background: var(--pfa-cream);
  }

  .pfa-origin__grid,
  .pfa-editorial__grid,
  .pfa-promise__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(36px, 6vw, 86px);
    align-items: start;
  }

  .pfa-origin__intro {
    position: sticky;
    top: 120px;
  }

  .pfa-story {
    display: grid;
    gap: 24px;
  }

  .pfa-story p {
    font-size: 24px;
    line-height: 1.62;
    color: #3d352e;
  }

  .pfa-editorial {
    background: var(--pfa-soft);
  }

  .pfa-founder-card {
    position: relative;
    overflow: hidden;
    min-height: 620px;
    border-radius: 8px;
    background: #e8dfd3;
    box-shadow: 0 28px 80px rgba(52, 42, 32, 0.12);
  }

  .pfa-founder-card__image {
    width: 100%;
    height: 100%;
    min-height: 620px;
    display: block;
    object-fit: cover;
    object-position: center 22%;
  }

  .pfa-founder-card__caption {
    position: absolute;
    right: 18px;
    bottom: 18px;
    left: 18px;
    display: grid;
    gap: 4px;
    padding: 18px;
    border: 1px solid rgba(255, 255, 255, 0.26);
    border-radius: 8px;
    background: rgba(24, 21, 17, 0.64);
    color: #fffaf2;
    backdrop-filter: blur(16px);
  }

  .pfa-founder-card__caption strong {
    font-size: 15px;
    line-height: 1.2;
  }

  .pfa-founder-card__caption span {
    font-size: 13px;
    line-height: 1.45;
    color: rgba(255, 250, 242, 0.78);
  }

  .pfa-editorial__copy {
    align-self: center;
    max-width: 620px;
  }

  .pfa-editorial__copy p {
    margin-top: 22px;
  }

  .pfa-beliefs {
    background: #fbf7ef;
  }

  .pfa-section-head {
    max-width: 780px;
    margin-bottom: clamp(34px, 5vw, 56px);
  }

  .pfa-beliefs__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .pfa-belief {
    display: grid;
    gap: 18px;
    min-height: 330px;
    align-content: start;
    padding: clamp(24px, 3vw, 34px);
    border: 1px solid var(--pfa-line);
    border-radius: 8px;
    background: var(--pfa-card);
  }

  .pfa-belief span {
    color: var(--pfa-clay);
    font-size: 13px;
    font-weight: 820;
    letter-spacing: 0;
  }

  .pfa-belief p {
    font-size: 16px;
    line-height: 1.68;
  }

  .pfa-promise {
    color: #fffaf2;
    background:
      radial-gradient(circle at 80% 20%, rgba(184, 95, 50, 0.26), transparent 34%),
      linear-gradient(135deg, #1f3427 0%, #17241d 100%);
  }

  .pfa-promise .pfa-kicker,
  .pfa-promise h2 {
    color: #fffaf2;
  }

  .pfa-promise__list {
    display: grid;
    gap: 14px;
  }

  .pfa-promise__list div {
    padding: 22px;
    border: 1px solid rgba(255, 250, 242, 0.14);
    border-radius: 8px;
    background: rgba(255, 250, 242, 0.07);
  }

  .pfa-promise__list strong,
  .pfa-promise__list span {
    display: block;
  }

  .pfa-promise__list strong {
    color: #fffaf2;
    font-size: 18px;
    line-height: 1.24;
    font-weight: 760;
  }

  .pfa-promise__list span {
    margin-top: 8px;
    color: rgba(255, 250, 242, 0.74);
    font-size: 15px;
    line-height: 1.58;
  }

  .pfa-cta {
    text-align: center;
    background: var(--pfa-cream);
  }

  .pfa-cta__inner {
    max-width: 760px;
  }

  .pfa-cta p:not(.pfa-kicker) {
    margin: 20px auto 30px;
    max-width: 620px;
  }

  .pfa-cta .pfa-button {
    color: #fff;
  }

  @media (max-width: 900px) {
    .prime-founder-about h1 {
      font-size: 64px;
    }

    .prime-founder-about h2 {
      font-size: 44px;
    }

    .prime-founder-about h3 {
      font-size: 23px;
    }

    .prime-founder-about p {
      font-size: 18px;
    }

    .pfa-hero {
      min-height: 760px;
      align-items: end;
    }

    .pfa-hero__media::after {
      background: linear-gradient(180deg, rgba(19, 16, 12, 0.18) 0%, rgba(19, 16, 12, 0.48) 38%, rgba(19, 16, 12, 0.92) 100%);
    }

    .pfa-hero__image {
      height: 64%;
      object-position: center 18%;
    }

    .pfa-origin__grid,
    .pfa-editorial__grid,
    .pfa-promise__grid,
    .pfa-beliefs__grid {
      grid-template-columns: 1fr;
    }

    .pfa-origin__intro {
      position: static;
    }

    .pfa-founder-card,
    .pfa-founder-card__image {
      min-height: 560px;
    }
  }

  @media (max-width: 640px) {
    .pfa-shell {
      width: min(100% - 24px, 1180px);
    }

    .prime-founder-about h1 {
      font-size: 46px;
      line-height: 1.02;
    }

    .prime-founder-about h2 {
      font-size: 36px;
      line-height: 1.06;
    }

    .prime-founder-about h3 {
      font-size: 21px;
    }

    .pfa-hero {
      min-height: 720px;
    }

    .pfa-hero__content {
      padding-block: 260px 54px;
    }

    .pfa-hero p {
      font-size: 16px;
      line-height: 1.65;
    }

    .pfa-hero__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .pfa-button {
      width: 100%;
      min-height: 54px;
      padding-inline: 18px;
    }

    .pfa-origin,
    .pfa-editorial,
    .pfa-beliefs,
    .pfa-promise,
    .pfa-cta {
      padding-block: 62px;
    }

    .pfa-story p {
      font-size: 18px;
      line-height: 1.62;
    }

    .pfa-founder-card,
    .pfa-founder-card__image {
      min-height: 500px;
    }

    .pfa-founder-card__caption {
      right: 12px;
      bottom: 12px;
      left: 12px;
    }

    .pfa-belief {
      min-height: 0;
    }
  }
</style>

{% schema %}
{
  "name": "Prime founder about",
  "settings": [],
  "presets": [
    {
      "name": "Prime founder about"
    }
  ]
}
{% endschema %}
