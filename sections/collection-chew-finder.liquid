<section class="collection-chew-finder">
  <div class="collection-chew-finder__inner page-width">
    <div class="collection-chew-finder__copy">
      <p>{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.title }}</h2>
      <span>{{ section.settings.subtitle }}</span>

      <div class="collection-chew-finder__note" role="note">
        <strong>Quick rule:</strong>
        choose the largest size your dog can safely carry and chew under supervision. Remove the final small piece before it becomes a choking risk.
      </div>
    </div>

    <div class="collection-chew-finder__panel" aria-label="Collection shopping guide">
      <div class="collection-chew-finder__steps" role="list">
        <div class="collection-chew-finder__step" role="listitem">
          <span>1</span>
          <strong>Start with weight</strong>
          <small>Use the size guide below to match your dog's current weight range.</small>
        </div>
        <div class="collection-chew-finder__step" role="listitem">
          <span>2</span>
          <strong>Adjust for intensity</strong>
          <small>Strong chewers usually do better sizing up when they are between ranges.</small>
        </div>
        <div class="collection-chew-finder__step" role="listitem">
          <span>3</span>
          <strong>Pick the job</strong>
          <small>Choose calmer crate time, boredom relief, or a rawhide-free swap.</small>
        </div>
      </div>

      <div class="collection-chew-finder__routes" aria-label="Shop by dog need">
        <a href="/pages/how-long-will-this-last-for-my-dog?intent=aggressive-chewer">
          <strong>Aggressive chewer</strong>
          <span>Needs more lasting resistance</span>
        </a>
        <a href="/pages/how-long-will-this-last-for-my-dog?intent=bored-dog">
          <strong>Bored dog</strong>
          <span>Needs focused enrichment</span>
        </a>
        <a href="/pages/how-long-will-this-last-for-my-dog?intent=crate-training">
          <strong>Crate calming</strong>
          <span>Needs a settled routine</span>
        </a>
        <a href="/blogs/dog-behavior/best-rawhide-alternative">
          <strong>Rawhide alternative</strong>
          <span>Needs a simpler chew</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .collection-chew-finder {
    background: #2b1408;
    color: #fff8ef;
    padding: 30px 0;
  }

  .collection-chew-finder__inner {
    align-items: start;
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
  }

  .collection-chew-finder__copy p {
    color: #f3b27d;
    font-size: 11px;
    font-weight: 850;
    letter-spacing: 0.12em;
    margin: 0 0 8px;
    text-transform: uppercase;
  }

  .collection-chew-finder__copy h2 {
    font-size: clamp(24px, 3vw, 38px);
    line-height: 1.05;
    margin: 0 0 10px;
  }

  .collection-chew-finder__copy span {
    color: rgba(255, 248, 239, 0.72);
    display: block;
    line-height: 1.55;
    max-width: 560px;
  }

  .collection-chew-finder__note {
    background: rgba(255, 248, 239, 0.08);
    border: 1px solid rgba(255, 248, 239, 0.16);
    border-radius: 8px;
    color: rgba(255, 248, 239, 0.8);
    font-size: 13px;
    line-height: 1.55;
    margin-top: 18px;
    max-width: 560px;
    padding: 14px 16px;
  }

  .collection-chew-finder__note strong {
    color: #fff8ef;
  }

  .collection-chew-finder__panel {
    display: grid;
    gap: 14px;
  }

  .collection-chew-finder__steps {
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .collection-chew-finder__step {
    background: #fff8ef;
    border-radius: 8px;
    color: #24130d;
    display: grid;
    gap: 7px;
    min-height: 138px;
    padding: 16px;
  }

  .collection-chew-finder__step > span {
    align-items: center;
    background: #d2632e;
    border-radius: 999px;
    color: #ffffff;
    display: inline-flex;
    font-size: 12px;
    font-weight: 900;
    height: 26px;
    justify-content: center;
    width: 26px;
  }

  .collection-chew-finder__step strong {
    font-size: 14px;
    line-height: 1.2;
  }

  .collection-chew-finder__step small {
    color: #6f5a50;
    font-size: 12px;
    line-height: 1.45;
  }

  .collection-chew-finder__routes {
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .collection-chew-finder__routes a {
    background: rgba(255, 248, 239, 0.1);
    border: 1px solid rgba(255, 248, 239, 0.18);
    border-radius: 8px;
    color: #fff8ef;
    display: grid;
    gap: 4px;
    min-height: 76px;
    padding: 14px 16px;
    text-decoration: none;
  }

  .collection-chew-finder__routes a:first-child {
    background: #d2632e;
    border-color: #d2632e;
  }

  .collection-chew-finder__routes strong {
    font-size: 14px;
    line-height: 1.2;
  }

  .collection-chew-finder__routes span {
    color: rgba(255, 248, 239, 0.68);
    font-size: 12px;
    line-height: 1.35;
  }

  @media (max-width: 749px) {
    .collection-chew-finder__inner {
      grid-template-columns: 1fr;
    }

    .collection-chew-finder__steps,
    .collection-chew-finder__routes {
      grid-template-columns: 1fr;
    }

    .collection-chew-finder__routes a {
      min-height: 0;
    }
  }
</style>

{% schema %}
{
  "name": "Collection chew finder",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop by dog need"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Start with your dog's chewing problem"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The fastest path to the right chew is not flavor. It is dog size, chewing intensity, and the calm-time job you need the chew to do."
    }
  ],
  "presets": [
    {
      "name": "Collection chew finder"
    }
  ]
}
{% endschema %}
