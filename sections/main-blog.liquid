    {
      "type": "paragraph",
      "content": "Change excerpts by editing your blog posts. [Learn more](https://help.shopify.com/manual/online-store/blogs/writing-blogs#display-an-excerpt-from-a-blog-post)"
    },
    {
      "type": "header",
      "content": "Featured posts"
    },
    {
