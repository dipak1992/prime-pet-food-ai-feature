{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_manual_featured = false
  assign show_blog_filters = false
  assign show_blog_toolbar = false

  if section.settings.blog_card_featured_1 != blank or section.settings.blog_card_featured_2 != blank or section.settings.blog_card_featured_3 != blank
    assign has_manual_featured = true
  endif

  if section.settings.show_tag_filter and blog.all_tags.size > 0
    assign show_blog_filters = true
  endif

  if show_blog_filters or section.settings.show_socials
    assign show_blog_toolbar = true
  endif
-%}

<style>
  #shopify-section-{{ section.id }} .main-blog {
    display: grid;
    gap: 2.4rem;
  }

  #shopify-section-{{ section.id }} .main-blog__toolbar {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.2rem;
    margin-top: 2rem;
    padding: 1.2rem 1.4rem;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    border-radius: 2rem;
    background: rgb(var(--color-background));
  }

  #shopify-section-{{ section.id }} .main-blog__tabs {
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .main-blog__tabs .horizontal-scroll {
    padding-bottom: 0.2rem;
  }

  #shopify-section-{{ section.id }} .main-blog__tabs .custom-tabs {
    display: inline-flex;
    flex-wrap: nowrap;
    gap: 0.8rem;
  }

  #shopify-section-{{ section.id }} .main-blog__tabs .custom-tab {
    border-radius: 999px;
    border: 1px solid rgba(var(--color-foreground), 0.1);
    background: rgba(var(--color-foreground), 0.04);
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .main-blog__share {
    display: flex;
    order: 2;
    justify-content: flex-start;
  }

  #shopify-section-{{ section.id }} .main-blog__share .social-share {
    gap: 0.6rem;
  }

  #shopify-section-{{ section.id }} .main-blog__share .share-button__social {
    width: 4rem;
    height: 4rem;
    border-radius: 999px;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    background: rgba(var(--color-background), 0.75);
  }

  #shopify-section-{{ section.id }} .main-blog__tabs {
    order: 1;
    margin-inline-end: 1.2rem;
  }

  #shopify-section-{{ section.id }} .main-blog__grid {
    display: grid;
    gap: 2rem;
    align-items: stretch;
    grid-template-columns: minmax(0, 1fr);
  }

  #shopify-section-{{ section.id }} .main-blog__post,
  #shopify-section-{{ section.id }} .main-blog__post .article-card-wrapper {
    height: 100%;
  }

  #shopify-section-{{ section.id }} .main-blog__post {
    width: auto;
    max-width: none;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .pagination-wrapper {
    margin-top: 1rem;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .main-blog__toolbar {
      align-items: center;
      column-gap: 1.6rem;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: flex-start;
    }

    #shopify-section-{{ section.id }} .main-blog__share {
      order: 3;
    }

    #shopify-section-{{ section.id }} .main-blog__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .main-blog__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749.98px) {
    #shopify-section-{{ section.id }} .main-blog__toolbar {
      width: 100%;
    }
  }
</style>

<div class="main-blog page-width section__inner {{ section.settings.top_padding }} {{ section.settings.bottom_padding }}">
  {%- if show_blog_toolbar -%}
    {{ 'component-section-tabs.css' | asset_url | stylesheet_tag }}

    <div class="main-blog__toolbar mb-3">
      {%- if section.settings.show_socials -%}
        <div class="main-blog__share">
          {%- render 'share-button', share_link: blog.url, share_title: blog.title -%}
        </div>
      {%- endif -%}

      {%- if show_blog_filters -%}
      <div class="main-blog__tabs flex justify-{{ section.settings.tab_alignment }}">
        <div class="horizontal-scroll">
          <div class="block custom-tabs custom-tabs--{{ section.settings.tab_style }} custom-tabs--divided {{ section.settings.tab_text_size }}">
            <a href="{{ blog.url }}" class="custom-tab{% unless current_tags %} custom-tab--active{% endunless %}">
              {{- 'blogs.filter.all' | t -}}
            </a>

            {% for tag in blog.all_tags %}
              <a  href="{{ tag | link_to_tag: tag | split: 'href="' | last | split: '"' | first }}" class="custom-tab{% if current_tags contains tag %} custom-tab--active{% endif %}">
                {{- tag -}}
              </a>
            {% endfor %}
          </div>
        </div>
      </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- paginate blog.articles by section.settings.items_per_page -%}
    <infinite-scroll data-infinite-scroll-enabled="{% if settings.pagination_style == 'infinite' %}true{% else %}false{% endif %}">
      <div class="blog-articles main-blog__grid section-grid grid articles-wrapper contains-card contains-card--article
        {% if settings.blog_card_style == 'standard' %} contains-card--standard{% endif %}
        grid--{{ section.settings.columns_desktop }}-col-desktop
        grid--scaled
        grid--1-col-tablet-down"
     >
        {%- for article in blog.articles -%}
          {%- if section.settings.blog_card_omit == blank or article.id != section.settings.blog_card_omit.id -%}
            {%- liquid
              if article.id == section.settings.blog_card_featured_1.id or article.id == section.settings.blog_card_featured_2.id or article.id == section.settings.blog_card_featured_3.id
                assign is_featured = true
              else
                assign is_featured = false
              endif
            -%}
            <div
              class="blog__post main-blog__post grid__item article js-pagination__item{% if is_featured %} main-blog__post--featured{% endif %}
                {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
            >
              {%- render 'article-card',
                article: article,
                show_image: section.settings.show_image,
                show_date: section.settings.show_date,
                show_author: section.settings.show_author,
                excerpt_mode: section.settings.excerpt_mode,
                show_reading_estimate: section.settings.show_reading_estimate,
                show_first_tag: section.settings.show_first_tag,
                is_featured: is_featured,
                featured_excerpt_mode: section.settings.featured_excerpt_mode,
                columns_desktop: section.settings.columns_desktop
              -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        {%- render 'pagination', paginate: paginate -%}
      {%- endif -%}
    </infinite-scroll>
  {%- endpaginate -%}
</div>
{% schema %}
{
  "name": "Blog posts",
  "tag": "section",
  "class": "section section-main-blog",
  "settings": [
    {
      "type": "range",
      "id": "items_per_page",
      "label": "Posts per page",
      "min": 4,
      "max": 64,
      "step": 1,
      "default": 16
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "options": [
        {
          "value": "5",
          "label": "S"
        },
        {
          "value": "4",
          "label": "M"
        },
        {
          "value": "3",
          "label": "L"
        },
        {
          "value": "2",
          "label": "XL"
        }
      ],
      "default": "4",
      "label": "Card size on desktop"
    },
    {
      "type": "header",
      "content": "Filter"
    },
    {
      "type": "checkbox",
      "id": "show_tag_filter",
      "default": true,
      "label": "Show tag filter"
    },
    {
      "type": "text_alignment",
      "id": "tab_alignment",
      "default": "left",
      "label": "Filter alignment"
    },
    {
      "type": "select",
      "id": "tab_style",
      "options": [
        {
          "value": "simple",
          "label": "Simple"
        },
        {
          "value": "switch",
          "label": "Switch"
        }
      ],
      "default": "switch",
      "label": "Tag style"
    },
    {
      "type": "select",
      "id": "tab_text_size",
      "options": [
        {
          "value": "t4",
          "label": "S"
        },
        {
          "value": "t3",
          "label": "M"
        },
        {
          "value": "t2",
          "label": "L"
        },
        {
          "value": "t1",
          "label": "XL"
        },
        {
          "value": "t0",
          "label": "2XL"
        }
      ],
      "default": "t4",
      "label": "Tag size"
    },
    {
      "type": "checkbox",
      "id": "show_socials",
