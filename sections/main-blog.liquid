      "info": "These can be customized in [Social theme settings](/editor?context=theme&category=socials)"
    },
    {
      "type": "header",
      "content": "Blog posts"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "Show article image"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "Show date"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": false,
      "label": "Show author"
    },
    {
      "type": "checkbox",
      "id": "show_reading_estimate",
      "default": true,
      "label": "Show reading estimate"
    },
    {
      "type": "checkbox",
      "id": "show_first_tag",
      "default": true,
      "label": "Show first tag"
    },
    {
      "type": "select",
      "id": "excerpt_mode",
      "default": "short",
      "info": "Article content will be used if the excerpt is empty.",
      "label": "Excerpt",
      "options": [
        {
          "value": "none",
          "label": "Hide"
        },
        {
          "value": "short",
          "label": "Short"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "long",
          "label": "Long"
        },
        {
          "value": "show",
          "label": "All"
        }
