<section
  id="shopify-section-{{ section.id }}"
  class="mpt-section mpt-layout--{{ section.settings.layout }}"
  style="
    --mpt-bg: {{ section.settings.bg_color }};
    --mpt-heading: {{ section.settings.heading_color }};
    --mpt-text: {{ section.settings.text_color }};
    --mpt-accent: {{ section.settings.accent_color }};
    --mpt-soft: {{ section.settings.soft_color }};
    --mpt-card-bg: {{ section.settings.card_color }};
    --mpt-max-width: {{ section.settings.max_width }}px;
    --mpt-padding-top: {{ section.settings.padding_top }}px;
    --mpt-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="mpt-container">
    <div class="mpt-header">
      {% if section.settings.eyebrow != blank %}
        <p class="mpt-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="mpt-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="mpt-description rte">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      {% if section.settings.layout == 'zigzag' %}
        <div class="mpt-desktop-timeline mpt-zigzag">
          <div class="mpt-zigzag-spine"></div>
          {% for block in section.blocks %}
            <div class="mpt-zigzag-step {% cycle 'is-left', 'is-right' %}" {{ block.shopify_attributes }}>
              <div class="mpt-zigzag-media">
                <div class="mpt-zigzag-image-wrap">
                  {% if block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 600
                      | image_tag:
                        loading: 'lazy',
                        widths: '240,360,480,600',
                        class: 'mpt-zigzag-image',
                        alt: block.settings.title
                    }}
                  {% else %}
                    <div class="mpt-fallback-icon mpt-fallback-icon--lg">
                      {% case block.settings.icon %}
                        {% when 'collection' %}<span>🏔️</span>
                        {% when 'pasteurization' %}<span>🥛</span>
                        {% when 'aging' %}<span>🧀</span>
                        {% when 'cut' %}<span>📏</span>
                        {% when 'dry' %}<span>☀️</span>
                        {% else %}<span>✨</span>
                      {% endcase %}
                    </div>
                  {% endif %}
                </div>
              </div>

              <div class="mpt-zigzag-dot">
                <span class="mpt-zigzag-dot-inner"></span>
              </div>

              <div class="mpt-zigzag-content">
                <span class="mpt-zigzag-number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                {% if block.settings.title != blank %}
                  <h3 class="mpt-zigzag-title">{{ block.settings.title }}</h3>
                {% endif %}
                {% if block.settings.text != blank %}
                  <p class="mpt-zigzag-text">{{ block.settings.text }}</p>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="mpt-desktop-timeline mpt-horizontal">
          <div class="mpt-steps-row">
            {% for block in section.blocks %}
              <div class="mpt-step" {{ block.shopify_attributes }}>
                <div class="mpt-step-media">
                  <span class="mpt-step-number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                  <div class="mpt-image-wrap">
                    {% if block.settings.image != blank %}
                      {{
                        block.settings.image
                        | image_url: width: 360
                        | image_tag:
                          loading: 'lazy',
                          widths: '160,240,320,360',
                          class: 'mpt-icon-image',
                          alt: block.settings.title
                      }}
                    {% else %}
                      <div class="mpt-fallback-icon">
                        {% case block.settings.icon %}
                          {% when 'collection' %}<span>🏔️</span>
                          {% when 'pasteurization' %}<span>🥛</span>
                          {% when 'aging' %}<span>🧀</span>
                          {% when 'cut' %}<span>📏</span>
                          {% when 'dry' %}<span>☀️</span>
                          {% else %}<span>✨</span>
                        {% endcase %}
                      </div>
                    {% endif %}
                  </div>
                </div>

                {% if block.settings.title != blank %}
                  <h3 class="mpt-step-title">{{ block.settings.title }}</h3>
                {% endif %}

                <div class="mpt-line-wrap">
                  <div class="mpt-dot">
                    <span class="mpt-dot-inner"></span>
                  </div>
                </div>

                {% if block.settings.text != blank %}
                  <div class="mpt-bubble">
                    <p>{{ block.settings.text }}</p>
                  </div>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        </div>
      {% endif %}

      <div class="mpt-mobile-timeline">
        {% for block in section.blocks %}
          <div class="mpt-mobile-step" {{ block.shopify_attributes }}>
            <div class="mpt-mobile-top">
              <div class="mpt-mobile-line"></div>
              <div class="mpt-mobile-dot">
                <span class="mpt-mobile-dot-inner"></span>
              </div>
            </div>

            <div class="mpt-mobile-content">
              <div class="mpt-top-card">
                <div class="mpt-image-wrap">
                  {% if block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 360
                      | image_tag:
                        loading: 'lazy',
                        widths: '160,240,320,360',
                        class: 'mpt-icon-image',
                        alt: block.settings.title
                    }}
                  {% else %}
                    <div class="mpt-fallback-icon">
                      {% case block.settings.icon %}
                        {% when 'collection' %}
                          <span>🏔️</span>
                        {% when 'pasteurization' %}
                          <span>🥛</span>
                        {% when 'aging' %}
                          <span>🧀</span>
                        {% when 'cut' %}
                          <span>📏</span>
                        {% when 'dry' %}
                          <span>☀️</span>
                        {% else %}
                          <span>✨</span>
                      {% endcase %}
                    </div>
                  {% endif %}
                </div>

                {% if block.settings.title != blank %}
                  <h3 class="mpt-step-title">{{ block.settings.title }}</h3>
                {% endif %}
              </div>

              {% if block.settings.text != blank %}
                <div class="mpt-bubble">
                  <p>{{ block.settings.text }}</p>
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <div class="mpt-footer">
        <a href="{{ section.settings.button_link }}" class="mpt-button">
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>

  <style>
    .mpt-section {
      background: var(--mpt-bg);
      padding-top: var(--mpt-padding-top);
      padding-bottom: var(--mpt-padding-bottom);
    }

    .mpt-section .mpt-container {
      width: min(calc(100% - 40px), var(--mpt-max-width));
      margin: 0 auto;
    }

    .mpt-section .mpt-header {
      text-align: center;
      max-width: 980px;
      margin: 0 auto 42px;
    }

    .mpt-section .mpt-eyebrow {
      margin: 0 0 12px;
      color: var(--mpt-accent);
      font-size: 13px;
      line-height: 1.2;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .mpt-section .mpt-heading {
      margin: 0;
      color: var(--mpt-heading);
      font-size: clamp(32px, 4vw, 62px);
      line-height: 1.05;
      letter-spacing: -0.035em;
      font-weight: 850;
    }

    .mpt-section .mpt-description {
      margin-top: 16px;
      color: var(--mpt-text);
      font-size: clamp(15px, 1.4vw, 18px);
      line-height: 1.75;
      width: 70%;
      margin-left: auto;
      margin-right: auto;
    }

    .mpt-section .mpt-description p {
      margin: 0;
    }

    .mpt-desktop-timeline {
      display: block;
    }

    .mpt-mobile-timeline {
      display: none;
    }

    /* ─────── HORIZONTAL LAYOUT ─────── */
    .mpt-horizontal .mpt-steps-row {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      column-gap: 28px;
      row-gap: 24px;
      align-items: start;
      position: relative;
    }

    .mpt-horizontal .mpt-step {
      display: grid;
      grid-template-rows: auto auto auto 1fr;
      gap: 18px;
      align-items: start;
      justify-items: center;
      position: relative;
    }

    /* Image area with watermark number */
    .mpt-horizontal .mpt-step-media {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding-top: 32px;
    }

    .mpt-horizontal .mpt-step-number {
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      font-size: 88px;
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.04em;
      color: var(--mpt-accent);
      opacity: 0.10;
      pointer-events: none;
      user-select: none;
      z-index: 0;
    }

    .mpt-horizontal .mpt-image-wrap {
      width: 140px;
      height: 140px;
      border-radius: 999px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      z-index: 1;
      overflow: hidden;
      background: var(--mpt-card-bg);
      box-shadow: 0 12px 32px rgba(36, 19, 13, 0.10);
      border: 6px solid #ffffff;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .mpt-horizontal .mpt-step:hover .mpt-image-wrap {
      transform: translateY(-4px);
      box-shadow: 0 18px 40px rgba(36, 19, 13, 0.14);
    }

    .mpt-horizontal .mpt-icon-image {
      width: 100%;
      height: 100%;
      border-radius: 999px;
      object-fit: cover;
      object-position: center;
      display: block;
    }

    .mpt-horizontal .mpt-fallback-icon {
      width: 100%;
      height: 100%;
      border-radius: 999px;
      background: rgba(210, 99, 46, 0.10);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 48px;
      line-height: 1;
    }

    .mpt-horizontal .mpt-step-title {
      margin: 0;
      color: var(--mpt-heading);
      text-align: center;
      font-size: 19px;
      line-height: 1.2;
      font-weight: 800;
      max-width: 220px;
      min-height: 46px;
      display: flex;
      align-items: flex-start;
      justify-content: center;
    }

    /* Continuous connector line + centered dot */
    .mpt-horizontal .mpt-line-wrap {
      width: 100%;
      height: 28px;
      position: relative;
    }

    .mpt-horizontal .mpt-line-wrap::before {
      content: "";
      position: absolute;
      left: -50%;
      right: -50%;
      top: 50%;
      transform: translateY(-50%);
      height: 2px;
      background: var(--mpt-accent);
      opacity: 0.45;
      z-index: 0;
    }

    .mpt-horizontal .mpt-step:first-child .mpt-line-wrap::before { left: 50%; }
    .mpt-horizontal .mpt-step:last-child .mpt-line-wrap::before { right: 50%; }

    .mpt-horizontal .mpt-dot {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: #ffffff;
      border: 3px solid var(--mpt-accent);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 2;
      box-sizing: border-box;
      box-shadow: 0 4px 10px rgba(36, 19, 13, 0.12);
    }

    .mpt-horizontal .mpt-dot-inner {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--mpt-accent);
      display: block;
    }

    .mpt-horizontal .mpt-bubble {
      width: 100%;
      max-width: 260px;
      min-height: 130px;
      background: transparent;
      border-radius: 18px;
      padding: 18px 16px;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      text-align: center;
      box-sizing: border-box;
      border: 1px solid rgba(36, 19, 13, 0.10);
      transition: border-color 0.25s ease, background 0.25s ease;
    }

    .mpt-horizontal .mpt-step:hover .mpt-bubble {
      border-color: var(--mpt-accent);
      background: var(--mpt-soft);
    }

    .mpt-horizontal .mpt-bubble p {
      margin: 0;
      color: var(--mpt-text);
      font-size: 14.5px;
      line-height: 1.6;
      font-weight: 500;
    }

    /* ─────── ZIGZAG LAYOUT ─────── */
    .mpt-zigzag {
      position: relative;
      padding: 20px 0;
    }

    .mpt-zigzag-spine {
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      transform: translateX(-50%);
      width: 3px;
      background: linear-gradient(
        to bottom,
        transparent 0%,
        var(--mpt-accent) 8%,
        var(--mpt-accent) 92%,
        transparent 100%
      );
      opacity: 0.55;
      z-index: 0;
    }

    .mpt-zigzag-step {
      position: relative;
      display: grid;
      grid-template-columns: 1fr 60px 1fr;
      align-items: center;
      column-gap: 0;
      padding: 36px 0;
      z-index: 1;
    }

    .mpt-zigzag-step.is-left .mpt-zigzag-media {
      grid-column: 1;
      justify-self: end;
      padding-right: 50px;
    }

    .mpt-zigzag-step.is-left .mpt-zigzag-content {
      grid-column: 3;
      justify-self: start;
      padding-left: 50px;
      text-align: left;
    }

    .mpt-zigzag-step.is-right .mpt-zigzag-media {
      grid-column: 3;
      justify-self: start;
      padding-left: 50px;
      order: 1;
    }

    .mpt-zigzag-step.is-right .mpt-zigzag-content {
      grid-column: 1;
      justify-self: end;
      padding-right: 50px;
      text-align: right;
    }

    .mpt-zigzag-media {
      width: 100%;
      max-width: 340px;
    }

    .mpt-zigzag-image-wrap {
      width: 100%;
      aspect-ratio: 1 / 1;
      border-radius: 28px;
      overflow: hidden;
      background: var(--mpt-card-bg);
      box-shadow: 0 20px 50px rgba(36, 19, 13, 0.14);
      border: 8px solid #ffffff;
      transition: transform 0.35s ease, box-shadow 0.35s ease;
    }

    .mpt-zigzag-step:hover .mpt-zigzag-image-wrap {
      transform: translateY(-6px);
      box-shadow: 0 28px 60px rgba(36, 19, 13, 0.18);
    }

    .mpt-zigzag-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .mpt-fallback-icon--lg {
      width: 100%;
      height: 100%;
      border-radius: 0;
      background: rgba(210, 99, 46, 0.10);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 96px;
      line-height: 1;
    }

    .mpt-zigzag-dot {
      grid-column: 2;
      justify-self: center;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: #ffffff;
      border: 5px solid var(--mpt-accent);
      display: flex;
      align-items: center;
      justify-content: center;
      box-sizing: border-box;
      box-shadow: 0 6px 16px rgba(36, 19, 13, 0.18);
      position: relative;
      z-index: 2;
    }

    .mpt-zigzag-dot-inner {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--mpt-accent);
    }

    .mpt-zigzag-content {
      max-width: 420px;
    }

    .mpt-zigzag-number {
      display: inline-block;
      font-size: 72px;
      font-weight: 900;
      line-height: 0.9;
      letter-spacing: -0.04em;
      color: var(--mpt-accent);
      opacity: 0.18;
      margin-bottom: 4px;
    }

    .mpt-zigzag-title {
      margin: 0 0 12px;
      color: var(--mpt-heading);
      font-size: clamp(24px, 2.2vw, 32px);
      line-height: 1.1;
      font-weight: 850;
      letter-spacing: -0.01em;
    }

    .mpt-zigzag-text {
      margin: 0;
      color: var(--mpt-text);
      font-size: 16px;
      line-height: 1.7;
      font-weight: 500;
    }

    .mpt-section .mpt-footer {
      margin-top: 38px;
      text-align: center;
    }

    .mpt-section .mpt-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      padding: 14px 26px;
      border-radius: 999px;
      background: var(--mpt-accent);
      color: #ffffff;
      text-decoration: none;
      font-size: 15px;
      font-weight: 800;
      transition: transform 0.2s ease, opacity 0.2s ease, box-shadow 0.2s ease;
      box-shadow: 0 12px 24px rgba(210, 99, 46, 0.24);
    }

    .mpt-section .mpt-button:hover {
      transform: translateY(-2px);
      opacity: 0.95;
      box-shadow: 0 16px 32px rgba(210, 99, 46, 0.28);
    }

    .mpt-mobile-step {
      display: grid;
      grid-template-columns: 28px minmax(0, 1fr);
      column-gap: 14px;
      align-items: start;
    }

    .mpt-mobile-top {
      position: relative;
      min-height: 100%;
    }

    .mpt-mobile-line {
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      transform: translateX(-50%);
      width: 4px;
      background: var(--mpt-accent);
    }

    .mpt-mobile-dot {
      position: relative;
      z-index: 2;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: #ffffff;
      border: 4px solid var(--mpt-accent);
      display: flex;
      align-items: center;
      justify-content: center;
      box-sizing: border-box;
      margin-top: 42px;
      box-shadow: 0 8px 18px rgba(36, 19, 13, 0.12);
    }

    .mpt-mobile-dot-inner {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--mpt-accent);
      display: block;
    }

    .mpt-mobile-content {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .mpt-mobile-content .mpt-top-card {
      width: 100%;
      background: var(--mpt-card-bg);
      border-radius: 24px;
      padding: 18px 16px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      border: 1px solid rgba(36, 19, 13, 0.08);
      box-shadow: 0 10px 24px rgba(36, 19, 13, 0.06);
      box-sizing: border-box;
    }

    .mpt-mobile-content .mpt-image-wrap {
      width: 108px;
      height: 108px;
      border-radius: 999px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      background: transparent;
    }

    .mpt-mobile-content .mpt-icon-image {
      width: 100%;
      height: 100%;
      border-radius: 999px;
      object-fit: cover;
      display: block;
    }

    .mpt-mobile-content .mpt-fallback-icon {
      width: 108px;
      height: 108px;
      border-radius: 999px;
      background: rgba(210, 99, 46, 0.10);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 42px;
    }

    .mpt-mobile-content .mpt-step-title {
      margin: 0;
      color: var(--mpt-heading);
      text-align: center;
      font-size: 18px;
      line-height: 1.2;
      font-weight: 800;
    }

    .mpt-mobile-content .mpt-bubble {
      width: 100%;
      background: var(--mpt-soft);
      border-radius: 18px;
      padding: 16px 18px;
      border: 1px solid rgba(36, 19, 13, 0.06);
      box-sizing: border-box;
    }

    .mpt-mobile-content .mpt-bubble p {
      margin: 0;
      color: var(--mpt-heading);
      font-size: 14.5px;
      line-height: 1.55;
      font-weight: 500;
    }

    @media screen and (max-width: 1200px) {
      .mpt-horizontal .mpt-steps-row {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        row-gap: 40px;
      }

      .mpt-horizontal .mpt-line-wrap::before {
        display: none;
      }
    }

    @media screen and (max-width: 900px) {
      .mpt-desktop-timeline {
        display: none;
      }

      .mpt-mobile-timeline {
        display: grid;
        row-gap: 22px;
      }
    }

    @media screen and (max-width: 749px) {
      .mpt-section .mpt-container {
        width: min(calc(100% - 24px), var(--mpt-max-width));
      }

      .mpt-section .mpt-header {
        margin-bottom: 28px;
      }

      .mpt-section .mpt-heading {
        font-size: clamp(28px, 8vw, 42px);
      }

      .mpt-section .mpt-description {
        width: 100%;
      }

      .mpt-section .mpt-top-card,
      .mpt-section .mpt-bubble {
        max-width: 100%;
      }

      .mpt-section .mpt-image-wrap,
      .mpt-section .mpt-icon-image,
      .mpt-section .mpt-fallback-icon {
        width: 108px;
        height: 108px;
      }

      .mpt-section .mpt-bubble {
        min-height: auto;
        padding: 18px 16px;
      }
    }
  </style>
</section>

{% schema %}
{
  "name": "Manufacturing timeline",
  "tag": "section",
  "class": "section-manufacturing-timeline",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop layout style",
      "options": [
        { "value": "horizontal", "label": "Numbered horizontal" },
        { "value": "zigzag", "label": "Vertical zig-zag" }
      ],
      "default": "horizontal",
      "info": "Mobile uses vertical timeline regardless"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Authentic Himalayan process"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From the Himalayas to Your Dog"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Each chew begins with authentic Himalayan milk and moves through a careful traditional process to create the dense, long-lasting texture dogs love.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Know the process"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Section max width",
      "min": 1000,
      "max": 1800,
      "step": 20,
      "default": 1600
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 20,
      "max": 140,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 20,
      "max": 140,
