    }

    .mpt-section .mpt-eyebrow {
      margin: 0 0 12px;
      color: var(--mpt-accent);
      font-size: 13px;
      line-height: 1.2;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .mpt-section .mpt-heading {
      margin: 0;
      color: var(--mpt-heading);
      font-size: clamp(32px, 4vw, 62px);
      line-height: 1.05;
      letter-spacing: -0.035em;
      font-weight: 850;
    }

    .mpt-section .mpt-description {
      margin-top: 16px;
      color: var(--mpt-text);
      font-size: clamp(15px, 1.4vw, 18px);
      line-height: 1.75;
      width: 70%;
      margin-left: auto;
      margin-right: auto;
    }

    .mpt-section .mpt-description p {
      margin: 0;
    }

    .mpt-desktop-timeline {
      display: block;
    }

    .mpt-mobile-timeline {
      display: none;
    }

    .mpt-section .mpt-steps-row {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      column-gap: 14px;
      row-gap: 24px;
      align-items: start;
    }

    .mpt-section .mpt-step {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .mpt-section .mpt-top-card {
      width: 100%;
      max-width: 250px;
      min-height: 164px;
      background: var(--mpt-card-bg);
      border-radius: 34px;
      padding: 20px 16px 22px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      box-sizing: border-box;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      border: 1px solid rgba(36, 19, 13, 0.08);
      box-shadow: 0 14px 34px rgba(36, 19, 13, 0.07);
      overflow: hidden;
    }

    .mpt-section .mpt-top-card::before {
      content: "";
      position: absolute;
      inset: 10px;
      border-radius: 28px;
      border: 1px solid rgba(210, 99, 46, 0.12);
      pointer-events: none;
    }

    .mpt-section .mpt-step:hover .mpt-top-card {
      transform: translateY(-4px);
      box-shadow: 0 18px 44px rgba(36, 19, 13, 0.11);
    }

    .mpt-section .mpt-image-wrap {
      width: 116px;
      height: 116px;
      border-radius: 999px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      z-index: 1;
      overflow: hidden;
      background: transparent;
      box-shadow: none;
      border: none;
    }

    .mpt-section .mpt-icon-image {
      width: 116px;
      height: 116px;
      border-radius: 999px;
      object-fit: cover;
      object-position: center;
      display: block;
      background: transparent;
      border: none;
      box-shadow: none;
    }

    .mpt-section .mpt-fallback-icon {
      width: 116px;
      height: 116px;
      border-radius: 999px;
      background: rgba(210, 99, 46, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 42px;
      line-height: 1;
    }

    .mpt-section .mpt-step-title {
      margin: 14px 0 0;
      position: relative;
      z-index: 1;
      color: var(--mpt-heading);
      text-align: center;
      font-size: clamp(18px, 1.5vw, 22px);
      line-height: 1.08;
      font-weight: 850;
      max-width: 190px;
    }

    .mpt-section .mpt-line-wrap {
      width: 100%;
      height: 72px;
      position: relative;
      margin-top: 0;
    }

    .mpt-section .mpt-line {
      position: absolute;
      left: 0;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
      height: 5px;
      background: var(--mpt-accent);
      opacity: 0.9;
    }

    .mpt-section .mpt-dot {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      width: 34px;
      height: 34px;
      border-radius: 50%;
      background: #ffffff;
      border: 5px solid var(--mpt-accent);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 2;
      box-sizing: border-box;
      box-shadow: 0 8px 18px rgba(36, 19, 13, 0.12);
    }

    .mpt-section .mpt-dot-inner {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--mpt-accent);
      display: block;
    }

    .mpt-section .mpt-arrow-up,
    .mpt-section .mpt-arrow-down {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      width: 4px;
      background: var(--mpt-accent);
      z-index: 1;
    }

    .mpt-section .mpt-arrow-up {
      top: 10px;
      height: 22px;
    }

    .mpt-section .mpt-arrow-down {
      bottom: 10px;
      height: 22px;
    }

    .mpt-section .mpt-arrow-up::before,
    .mpt-section .mpt-arrow-down::after {
      content: "";
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      border-left: 7px solid transparent;
      border-right: 7px solid transparent;
    }

    .mpt-section .mpt-arrow-up::before {
      top: -8px;
      border-bottom: 10px solid var(--mpt-accent);
    }

    .mpt-section .mpt-arrow-down::after {
      bottom: -8px;
      border-top: 10px solid var(--mpt-accent);
    }

    .mpt-section .mpt-bubble {
      width: 100%;
      max-width: 250px;
      min-height: 112px;
      background: var(--mpt-soft);
      border-radius: 26px;
      padding: 18px 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      box-sizing: border-box;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      border: 1px solid rgba(36, 19, 13, 0.07);
    }

    .mpt-section .mpt-step:hover .mpt-bubble {
      transform: translateY(4px);
      box-shadow: 0 12px 26px rgba(36, 19, 13, 0.07);
    }

    .mpt-section .mpt-bubble p {
      margin: 0;
      color: var(--mpt-heading);
      font-size: 15px;
      line-height: 1.55;
      font-weight: 500;
    }

    .mpt-section .mpt-footer {
      margin-top: 38px;
      text-align: center;
    }

    .mpt-section .mpt-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      padding: 14px 26px;
      border-radius: 999px;
      background: var(--mpt-accent);
      color: #ffffff;
      text-decoration: none;
      font-size: 15px;
      font-weight: 800;
      transition: transform 0.2s ease, opacity 0.2s ease, box-shadow 0.2s ease;
      box-shadow: 0 12px 24px rgba(210, 99, 46, 0.24);
    }

    .mpt-section .mpt-button:hover {
      transform: translateY(-2px);
      opacity: 0.95;
      box-shadow: 0 16px 32px rgba(210, 99, 46, 0.28);
    }

    .mpt-mobile-step {
      display: grid;
      grid-template-columns: 28px minmax(0, 1fr);
      column-gap: 14px;
      align-items: start;
    }

    .mpt-mobile-top {
      position: relative;
      min-height: 100%;
    }

    .mpt-mobile-line {
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      transform: translateX(-50%);
      width: 4px;
      background: var(--mpt-accent);
    }

    .mpt-mobile-dot {
      position: relative;
      z-index: 2;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: #ffffff;
      border: 4px solid var(--mpt-accent);
      display: flex;
      align-items: center;
      justify-content: center;
      box-sizing: border-box;
      margin-top: 42px;
      box-shadow: 0 8px 18px rgba(36, 19, 13, 0.12);
    }

    .mpt-mobile-dot-inner {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--mpt-accent);
      display: block;
    }

    .mpt-mobile-content {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    @media screen and (max-width: 1200px) {
      .mpt-section .mpt-steps-row {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        row-gap: 28px;
      }
    }

    @media screen and (max-width: 900px) {
      .mpt-desktop-timeline {
        display: none;
      }

      .mpt-mobile-timeline {
        display: grid;
        row-gap: 22px;
      }
    }

    @media screen and (max-width: 749px) {
      .mpt-section .mpt-container {
        width: min(calc(100% - 24px), var(--mpt-max-width));
      }

      .mpt-section .mpt-header {
        margin-bottom: 28px;
      }

      .mpt-section .mpt-heading {
        font-size: clamp(28px, 8vw, 42px);
      }

      .mpt-section .mpt-description {
        width: 100%;
      }

      .mpt-section .mpt-top-card,
      .mpt-section .mpt-bubble {
        max-width: 100%;
      }

      .mpt-section .mpt-top-card {
        min-height: 168px;
        padding: 18px 14px 22px;
      }

      .mpt-section .mpt-image-wrap,
      .mpt-section .mpt-icon-image,
      .mpt-section .mpt-fallback-icon {
        width: 108px;
        height: 108px;
      }

      .mpt-section .mpt-bubble {
        min-height: auto;
        padding: 18px 16px;
      }
    }
  </style>
</section>

