{% comment %} <section
  id="shopify-section-{{ section.id }}"
  class="mpt-section"
  style="
    --mpt-bg: {{ section.settings.bg_color }};
    --mpt-heading: {{ section.settings.heading_color }};
    --mpt-text: {{ section.settings.text_color }};
    --mpt-accent: {{ section.settings.accent_color }};
    --mpt-soft: {{ section.settings.soft_color }};
    --mpt-max-width: {{ section.settings.max_width }}px;
    --mpt-padding-top: {{ section.settings.padding_top }}px;
    --mpt-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="mpt-container">
    <div class="mpt-header">
      {% if section.settings.eyebrow != blank %}
        <p class="mpt-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="mpt-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="mpt-description rte">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="mpt-desktop-timeline">
        <div class="mpt-steps-row">
          {% for block in section.blocks %}
            <div class="mpt-step" {{ block.shopify_attributes }}>
              <div class="mpt-top-card">
                <div class="mpt-icon-circle">
                  {% if block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 240
                      | image_tag:
                        loading: 'lazy',
                        widths: '120,180,240',
                        class: 'mpt-icon-image',
                        alt: block.settings.title
                    }}
                  {% else %}
                    <div class="mpt-fallback-icon">
                      {% case block.settings.icon %}
                        {% when 'collection' %}
                          <span>🏔️</span>
                        {% when 'pasteurization' %}
                          <span>🥛</span>
                        {% when 'aging' %}
                          <span>🧀</span>
                        {% when 'cut' %}
                          <span>📏</span>
                        {% when 'dry' %}
                          <span>☀️</span>
                        {% else %}
                          <span>✨</span>
                      {% endcase %}
                    </div>
                  {% endif %}
                </div>

                {% if block.settings.title != blank %}
                  <h3 class="mpt-step-title">{{ block.settings.title }}</h3>
                {% endif %}
              </div>

              <div class="mpt-line-wrap">
                <div class="mpt-line"></div>
                <div class="mpt-dot">
                  <span class="mpt-dot-inner"></span>
                </div>
                <div class="mpt-arrow-up"></div>
                <div class="mpt-arrow-down"></div>
              </div>

              {% if block.settings.text != blank %}
                <div class="mpt-bubble">
                  <p>{{ block.settings.text }}</p>
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>

      <div class="mpt-mobile-timeline">
        {% for block in section.blocks %}
          <div class="mpt-mobile-step" {{ block.shopify_attributes }}>
            <div class="mpt-mobile-top">
              <div class="mpt-mobile-line"></div>
              <div class="mpt-mobile-dot">
                <span class="mpt-mobile-dot-inner"></span>
              </div>
            </div>

            <div class="mpt-mobile-content">
              <div class="mpt-top-card">
                <div class="mpt-icon-circle">
                  {% if block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 240
                      | image_tag:
                        loading: 'lazy',
                        widths: '120,180,240',
                        class: 'mpt-icon-image',
                        alt: block.settings.title
                    }}
                  {% else %}
                    <div class="mpt-fallback-icon">
                      {% case block.settings.icon %}
                        {% when 'collection' %}
                          <span>🏔️</span>
                        {% when 'pasteurization' %}
                          <span>🥛</span>
                        {% when 'aging' %}
                          <span>🧀</span>
                        {% when 'cut' %}
                          <span>📏</span>
                        {% when 'dry' %}
                          <span>☀️</span>
                        {% else %}
                          <span>✨</span>
                      {% endcase %}
                    </div>
                  {% endif %}
                </div>

                {% if block.settings.title != blank %}
                  <h3 class="mpt-step-title">{{ block.settings.title }}</h3>
                {% endif %}
              </div>

              {% if block.settings.text != blank %}
                <div class="mpt-bubble">
                  <p>{{ block.settings.text }}</p>
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <div class="mpt-footer">
        <a href="{{ section.settings.button_link }}" class="mpt-button">
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>

<style>
  .mpt-section {
    background: var(--mpt-bg);
    padding-top: var(--mpt-padding-top);
    padding-bottom: var(--mpt-padding-bottom);
  }

  .mpt-section .mpt-container {
    width: min(calc(100% - 40px), var(--mpt-max-width));
    margin: 0 auto;
  }

  .mpt-section .mpt-header {
    text-align: center;
    max-width: 980px;
    margin: 0 auto 42px;
  }

  .mpt-section .mpt-eyebrow {
    margin: 0 0 12px;
    color: var(--mpt-accent);
    font-size: 13px;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .mpt-section .mpt-heading {
    margin: 0;
    color: var(--mpt-heading);
    font-size: clamp(32px, 4vw, 62px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 800;
  }

  .mpt-section .mpt-description {
    margin-top: 16px;
    color: var(--mpt-text);
    font-size: clamp(15px, 1.4vw, 18px);
    line-height: 1.75;
    width: 70%;
    margin-left: auto;
    margin-right: auto;
  
  }

  .mpt-section .mpt-description p {
    margin: 0;
  }

  .mpt-desktop-timeline {
    display: block;
  }

  .mpt-mobile-timeline {
    display: none;
  }

  .mpt-section .mpt-steps-row {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    column-gap: 14px;
    row-gap: 24px;
    align-items: start;
  }

  .mpt-section .mpt-step {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .mpt-section .mpt-top-card {
    width: 100%;
    max-width: 250px;
    min-height: 150px;
    background: #f7f4ef;
    border-radius: 44% 56% 48% 52% / 38% 40% 60% 62%;
    padding: 16px 16px 38px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    box-sizing: border-box;
    transition: transform 0.25s ease;
  }

  .mpt-section .mpt-top-card::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 10px;
    transform: translateX(-50%);
    width: 82%;
    height: 26px;
    border-radius: 999px;
    background: #efe8df;
    z-index: 0;
  }



  .mpt-section .mpt-icon-circle {
    width: 126px;
    height: 126px;
    border-radius: 50%;
    background: #e8edf7;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    box-shadow: inset 0 0 0 1px rgba(36, 19, 13, 0.04);
  }

  .mpt-section .mpt-icon-image {
    width: 88px;
    height: 88px;
    object-fit: contain;
    display: block;
  }

  .mpt-section .mpt-fallback-icon {
    font-size: 40px;
    line-height: 1;
  }

  .mpt-section .mpt-step-title {
    margin: 12px 0 0;
    position: relative;
    z-index: 1;
    color: var(--mpt-heading);
    text-align: center;
    font-size: clamp(18px, 1.5vw, 22px);
    line-height: 1.08;
    font-weight: 800;
    max-width: 190px;
  }

  .mpt-section .mpt-line-wrap {
    width: 100%;
    height: 72px;
    position: relative;
    margin-top: 0;
  }

  .mpt-section .mpt-line {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    height: 5px;
    background: var(--mpt-accent);
  }

  .mpt-section .mpt-dot {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #ffffff;
    border: 5px solid var(--mpt-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    box-sizing: border-box;
  }

  .mpt-section .mpt-dot-inner {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--mpt-accent);
    display: block;
  }

  .mpt-section .mpt-arrow-up,
  .mpt-section .mpt-arrow-down {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    background: var(--mpt-accent);
    z-index: 1;
  }

  .mpt-section .mpt-arrow-up {
    top: 10px;
    height: 22px;
  }

  .mpt-section .mpt-arrow-down {
    bottom: 10px;
    height: 22px;
  }

  .mpt-section .mpt-arrow-up::before,
  .mpt-section .mpt-arrow-down::after {
    content: "";
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    border-left: 7px solid transparent;
    border-right: 7px solid transparent;
  }

  .mpt-section .mpt-arrow-up::before {
    top: -8px;
    border-bottom: 10px solid var(--mpt-accent);
  }

  .mpt-section .mpt-arrow-down::after {
    bottom: -8px;
    border-top: 10px solid var(--mpt-accent);
  }

  .mpt-section .mpt-bubble {
    width: 100%;
    max-width: 250px;
    min-height: 112px;
    background: var(--mpt-soft);
    border-radius: 24px;
    padding: 18px 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    box-sizing: border-box;
    transition: transform 0.25s ease;
  }

  .mpt-section .mpt-step:hover .mpt-bubble {
    transform: translateY(4px);
  }

  .mpt-section .mpt-bubble p {
    margin: 0;
    color: var(--mpt-heading);
    font-size: 15px;
    line-height: 1.55;
    font-weight: 500;
  }

  .mpt-section .mpt-footer {
    margin-top: 38px;
    text-align: center;
  }

  .mpt-section .mpt-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 14px 24px;
    border-radius: 999px;
    background: var(--mpt-accent);
    color: #ffffff;
    text-decoration: none;
    font-size: 15px;
    font-weight: 700;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .mpt-section .mpt-button:hover {
    transform: translateY(-2px);
    opacity: 0.95;
  }

  .mpt-mobile-step {
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr);
    column-gap: 14px;
    align-items: start;
  }

  .mpt-mobile-top {
    position: relative;
    min-height: 100%;
  }

  .mpt-mobile-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    transform: translateX(-50%);
    width: 4px;
    background: var(--mpt-accent);
  }

  .mpt-mobile-dot {
    position: relative;
    z-index: 2;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #ffffff;
    border: 4px solid var(--mpt-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    margin-top: 34px;
  }

  .mpt-mobile-dot-inner {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--mpt-accent);
    display: block;
  }

  .mpt-mobile-content {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  @media screen and (max-width: 1200px) {
    .mpt-section .mpt-steps-row {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      row-gap: 28px;
    }
  }

  @media screen and (max-width: 900px) {
    .mpt-desktop-timeline {
      display: none;
    }

    .mpt-mobile-timeline {
      display: grid;
      row-gap: 22px;
    }
  }

  @media screen and (max-width: 749px) {
    .mpt-section .mpt-container {
      width: min(calc(100% - 24px), var(--mpt-max-width));
    }

    .mpt-section .mpt-header {
      margin-bottom: 28px;
    }

    .mpt-section .mpt-heading {
      font-size: clamp(28px, 8vw, 42px);
    }

    .mpt-section .mpt-top-card,
    .mpt-section .mpt-bubble {
      max-width: 100%;
    }

    .mpt-section .mpt-top-card {
      min-height: 170px;
      padding: 16px 14px 34px;
    }

    .mpt-section .mpt-icon-circle {
      width: 118px;
      height: 118px;
    }

    .mpt-section .mpt-icon-image {
      width: 82px;
      height: 82px;
    }

    .mpt-section .mpt-bubble {
      min-height: auto;
      padding: 18px 16px;
    }
  }
</style>
</section>

{% schema %}
{
  "name": "Manufacturing timeline",
  "tag": "section",
  "class": "section-manufacturing-timeline",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Authentic Himalayan process"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From the Himalayas to Your Dog"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Each chew begins with authentic Himalayan milk and moves through a careful traditional process to create the dense, long-lasting texture dogs love.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Know the process"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Section max width",
      "min": 1000,
      "max": 1800,
      "step": 20,
      "default": 1600
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 20,
      "max": 140,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 20,
      "max": 140,
      "step": 4,
      "default": 72
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#24130d"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description color",
      "default": "#24130d"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#d2632e"
    },
    {
      "type": "color",
      "id": "soft_color",
      "label": "Bubble color",
      "default": "#f1eee9"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Process step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon image"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Fallback icon",
          "default": "collection",
          "options": [
            { "value": "collection", "label": "Collection" },
            { "value": "pasteurization", "label": "Pasteurization" },
            { "value": "aging", "label": "Natural aging" },
            { "value": "cut", "label": "Cut and inspect" },
            { "value": "dry", "label": "Dry" }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Milk rich in nutritional value is collected from free-roaming yaks and cows grazing in the Himalayas."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Manufacturing timeline",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "icon": "collection",
            "title": "Collection",
            "text": "Milk rich in nutritional value is collected from free-roaming yaks and cows grazing in the Himalayas."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "pasteurization",
            "title": "Pasteurization",
            "text": "Milk is pasteurized and processed carefully to create our dense, digestible cheese base."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "aging",
            "title": "Natural Aging",
            "text": "The extracted cheese is aged naturally until it becomes the hard, long-lasting chew dogs love."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "cut",
            "title": "Cleaned, Cut & Inspected",
            "text": "Each chew is cut into different sizes and carefully inspected using food-grade handling methods."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "dry",
            "title": "Store Dried",
            "text": "The chews complete their final drying process before being packed and prepared for shipping."
          }
        }
      ]
    }
  ]
}
{% endschema %} {% endcomment %}


