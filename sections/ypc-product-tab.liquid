      "min": 10,
      "max": 28,
      "step": 1,
      "default": 17
    },
    {
      "type": "range",
      "id": "product_price_size",
      "label": "Recommended product price/link size",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "recommended_product",
      "name": "Recommended product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Choose product"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "YPC Tabs + Products",
      "blocks": [
        {
          "type": "recommended_product"
        },
        {
          "type": "recommended_product"
        }
      ]
    }
  ]
}
{% endschema %}
