    },
    {
      "type": "header",
      "content": "Recommended products"
    },
    {
      "type": "text",
      "id": "reco_heading",
      "label": "Recommendation heading",
      "default": "You may also like..."
    },
    {
      "type": "text",
      "id": "product_link_label",
      "label": "Product link label",
      "default": "Quick view"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f6f1e9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Main text color",
      "default": "#26313a"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text color",
      "default": "#6d7478"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / price color",
      "default": "#d2622e"
    },
    {
      "type": "header",
      "content": "Text sizes"
