<section
  id="ypc-tabs-recos-{{ section.id }}"
  class="ypc-tabs-recos"
  style="
    --ypc-bg: {{ section.settings.bg_color }};
    --ypc-text: {{ section.settings.text_color }};
    --ypc-muted: {{ section.settings.muted_color }};
    --ypc-accent: {{ section.settings.accent_color }};
    --ypc-heading-size: {{ section.settings.heading_size }}px;
    --ypc-body-size: {{ section.settings.body_size }}px;
    --ypc-tab-size: {{ section.settings.tab_size }}px;
    --ypc-reco-heading-size: {{ section.settings.reco_heading_size }}px;
    --ypc-product-title-size: {{ section.settings.product_title_size }}px;
    --ypc-product-price-size: {{ section.settings.product_price_size }}px;
  "
>
  <div class="ypc-tabs-recos__inner">
    <div class="ypc-tabs-recos__left">
      <div class="ypc-tabs-recos__nav" role="tablist">
        <button
          id="ypc-tab-description-{{ section.id }}"
          class="ypc-tabs-recos__tab is-active"
          type="button"
          data-tab="description"
          role="tab"
          aria-selected="true"
          aria-controls="ypc-panel-description-{{ section.id }}"
        >
          <span class="ypc-tabs-recos__tab-icon" aria-hidden="true">
            {% render 'icon', icon: 'information_circle', size: 18 %}
          </span>
          <span class="ypc-tabs-recos__tab-label">{{ section.settings.tab_1_label }}</span>
        </button>

        <button
          id="ypc-tab-feeding-{{ section.id }}"
          class="ypc-tabs-recos__tab"
          type="button"
          data-tab="feeding"
          role="tab"
          aria-selected="false"
          aria-controls="ypc-panel-feeding-{{ section.id }}"
          tabindex="-1"
        >
          <span class="ypc-tabs-recos__tab-icon" aria-hidden="true">
            {% render 'icon', icon: 'shield_checkmark', size: 18 %}
          </span>
          <span class="ypc-tabs-recos__tab-label">{{ section.settings.tab_2_label }}</span>
        </button>

        <button
          id="ypc-tab-shipping-{{ section.id }}"
          class="ypc-tabs-recos__tab"
          type="button"
          data-tab="shipping"
          role="tab"
          aria-selected="false"
          aria-controls="ypc-panel-shipping-{{ section.id }}"
          tabindex="-1"
        >
          <span class="ypc-tabs-recos__tab-icon" aria-hidden="true">
            {% render 'icon', icon: 'airplane', size: 18 %}
          </span>
          <span class="ypc-tabs-recos__tab-label">{{ section.settings.tab_3_label }}</span>
        </button>

        <button
          id="ypc-tab-ingredients-{{ section.id }}"
          class="ypc-tabs-recos__tab"
          type="button"
          data-tab="ingredients"
          role="tab"
          aria-selected="false"
          aria-controls="ypc-panel-ingredients-{{ section.id }}"
          tabindex="-1"
        >
          <span class="ypc-tabs-recos__tab-icon" aria-hidden="true">
            {% render 'icon', icon: 'restaurant', size: 18 %}
          </span>
          <span class="ypc-tabs-recos__tab-label">{{ section.settings.tab_4_label }}</span>
        </button>
      </div>

      <div class="ypc-tabs-recos__content">
        <div
          id="ypc-panel-description-{{ section.id }}"
          class="ypc-tabs-recos__panel is-active"
          data-panel="description"
          role="tabpanel"
          aria-labelledby="ypc-tab-description-{{ section.id }}"
        >
          <h2>{{ section.settings.description_heading }}</h2>
          <div class="rte">
            {% if product.description != blank %}
              {{ product.description }}
            {% else %}
              {{ section.settings.description_fallback }}
            {% endif %}
          </div>
        </div>

        <div
          id="ypc-panel-feeding-{{ section.id }}"
          class="ypc-tabs-recos__panel"
          data-panel="feeding"
          role="tabpanel"
          aria-labelledby="ypc-tab-feeding-{{ section.id }}"
          hidden
        >
          <h2>{{ section.settings.change_heading }}</h2>
          <div class="rte">
            {% if product.metafields.custom.safe_feeding_guidelines != blank %}
              {{ product.metafields.custom.safe_feeding_guidelines | metafield_tag }}
            {% elsif product.metafields.custom.chews_for_change != blank %}
              {{ product.metafields.custom.chews_for_change | metafield_tag }}
            {% else %}
              {{ section.settings.change_fallback }}
            {% endif %}
          </div>
        </div>

        <div
          id="ypc-panel-shipping-{{ section.id }}"
          class="ypc-tabs-recos__panel"
          data-panel="shipping"
          role="tabpanel"
          aria-labelledby="ypc-tab-shipping-{{ section.id }}"
          hidden
        >
          <h2>{{ section.settings.sizing_heading }}</h2>
          <div class="rte">
            {% if product.metafields.custom.shipping != blank %}
              {{ product.metafields.custom.shipping | metafield_tag }}
            {% elsif product.metafields.custom.sizing != blank %}
              {{ product.metafields.custom.sizing | metafield_tag }}
            {% else %}
              {{ section.settings.sizing_fallback }}
            {% endif %}
          </div>
        </div>

        <div
          id="ypc-panel-ingredients-{{ section.id }}"
          class="ypc-tabs-recos__panel"
          data-panel="ingredients"
          role="tabpanel"
          aria-labelledby="ypc-tab-ingredients-{{ section.id }}"
          hidden
        >
          <h2>{{ section.settings.ingredients_heading }}</h2>
          <div class="rte">
            {% if product.metafields.custom.ingredients != blank %}
              {{ product.metafields.custom.ingredients | metafield_tag }}
            {% else %}
              {{ section.settings.ingredients_fallback }}
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    <aside class="ypc-tabs-recos__right">
      <h3 class="ypc-tabs-recos__reco-heading">
        {{ section.settings.reco_heading }}
      </h3>

      <div class="ypc-tabs-recos__products">
        {% for block in section.blocks %}
          {% assign rec_product = block.settings.product %}

          {% if rec_product != blank %}
            <div class="ypc-rec-product" {{ block.shopify_attributes }}>
              <a href="{{ rec_product.url }}" class="ypc-rec-product__image-link">
                {% if rec_product.featured_image %}
                  <img
                    src="{{ rec_product.featured_image | image_url: width: 700 }}"
                    alt="{{ rec_product.featured_image.alt | default: rec_product.title | escape }}"
                    width="{{ rec_product.featured_image.width }}"
                    height="{{ rec_product.featured_image.height }}"
                    loading="lazy"
                    class="ypc-rec-product__image"
                  >
                {% endif %}
              </a>

              <h4 class="ypc-rec-product__title">
                <a href="{{ rec_product.url }}">{{ rec_product.title }}</a>
              </h4>

              <div class="ypc-rec-product__price">
                <span class="ypc-rec-product__price-current">
                  {{ rec_product.price | money }}
                </span>

                {% if rec_product.compare_at_price > rec_product.price %}
                  <span class="ypc-rec-product__price-compare">
                    {{ rec_product.compare_at_price | money }}
                  </span>
                {% endif %}
              </div>

              <a href="{{ rec_product.url }}" class="ypc-rec-product__quick">
                {{ section.settings.product_link_label }}
              </a>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </aside>
  </div>
</section>

<script>
  (function() {
    const section = document.getElementById('ypc-tabs-recos-{{ section.id }}');
    if (!section) return;

    const tabs = section.querySelectorAll('.ypc-tabs-recos__tab');
    const panels = section.querySelectorAll('.ypc-tabs-recos__panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', function(event) {
        event.preventDefault();

        const selectedTab = this.getAttribute('data-tab');

        tabs.forEach((item) => {
          const isSelected = item === this;
          item.classList.toggle('is-active', isSelected);
          item.setAttribute('aria-selected', isSelected ? 'true' : 'false');
          item.setAttribute('tabindex', isSelected ? '0' : '-1');
        });

        panels.forEach((panel) => {
          const isActive = panel.getAttribute('data-panel') === selectedTab;
          panel.classList.toggle('is-active', isActive);
          panel.hidden = !isActive;
        });
      });

      tab.addEventListener('keydown', function(event) {
        if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;

        event.preventDefault();
        const currentIndex = Array.prototype.indexOf.call(tabs, this);
        const direction = event.key === 'ArrowRight' ? 1 : -1;
        const nextIndex = (currentIndex + direction + tabs.length) % tabs.length;
        tabs[nextIndex].focus();
        tabs[nextIndex].click();
      });
    });
  })();
</script>

<style>
  .ypc-tabs-recos,
  .ypc-tabs-recos * {
    box-sizing: border-box;
  }

  .ypc-tabs-recos {
    background: var(--ypc-bg);
    padding: 52px 20px 70px;
  }

  .ypc-tabs-recos__inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
    gap: 42px;
    align-items: start;
  }

  .ypc-tabs-recos__left,
  .ypc-tabs-recos__right {
    min-width: 0;
  }

  .ypc-tabs-recos__nav {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .ypc-tabs-recos__tab {
    appearance: none;
    border: 1px solid rgba(43, 20, 8, 0.16);
    border-radius: 16px;
    background: rgba(255, 250, 243, 0.82);
    color: var(--ypc-muted);
    min-height: 66px;
    padding: 13px 14px;
    font-size: var(--ypc-tab-size);
    line-height: 1.15;
    font-weight: 900;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    cursor: pointer;
    text-align: left;
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
    box-shadow: 0 8px 20px rgba(43, 20, 8, 0.04);
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .ypc-tabs-recos__tab:hover,
  .ypc-tabs-recos__tab.is-active {
    color: #fffaf3;
    border-color: var(--ypc-text);
    background: var(--ypc-text);
  }

  .ypc-tabs-recos__tab:hover {
    transform: translateY(-1px);
  }

  .ypc-tabs-recos__tab-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(225, 102, 16, 0.12);
    color: var(--ypc-accent);
    flex: 0 0 auto;
  }

  .ypc-tabs-recos__tab.is-active .ypc-tabs-recos__tab-icon,
  .ypc-tabs-recos__tab:hover .ypc-tabs-recos__tab-icon {
    background: rgba(255, 250, 243, 0.14);
    color: #fffaf3;
  }

  .ypc-tabs-recos__tab-icon .icon {
    width: 18px;
    height: 18px;
  }

  .ypc-tabs-recos__tab-label {
    overflow-wrap: anywhere;
  }

  .ypc-tabs-recos__content {
    padding-top: 24px;
  }

  .ypc-tabs-recos__panel {
    display: none;
    background: #fffaf3;
    border: 1px solid rgba(43, 20, 8, 0.12);
    border-radius: 22px;
    padding: 34px;
    box-shadow: 0 18px 42px rgba(43, 20, 8, 0.07);
  }

  .ypc-tabs-recos__panel.is-active:not([hidden]) {
    display: block;
  }

  .ypc-tabs-recos__panel h2 {
    margin: 0 0 20px;
    color: var(--ypc-text);
    font-size: var(--ypc-heading-size);
    line-height: 1.05;
    font-weight: 950;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .ypc-tabs-recos .rte {
    color: var(--ypc-text);
    font-size: var(--ypc-body-size);
    line-height: 1.62;
    font-weight: 500;
    max-width: 1000px;
  }

  .ypc-tabs-recos .rte p {
    margin: 0 0 28px;
  }

  .ypc-tabs-recos .rte p:last-child {
    margin-bottom: 0;
  }

  .ypc-tabs-recos .rte strong {
    color: var(--ypc-text);
    font-weight: 900;
  }

  .ypc-tabs-recos .rte ul {
    list-style: square;
    padding-left: 26px;
    margin: 32px 0;
  }

  .ypc-tabs-recos .rte li {
    margin-bottom: 18px;
    padding-left: 8px;
  }

  .ypc-tabs-recos__reco-heading {
    margin: 0 0 36px;
    color: var(--ypc-text);
    font-size: var(--ypc-reco-heading-size);
    line-height: 1;
    font-weight: 900;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

.ypc-tabs-recos__products {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.ypc-rec-product {
  text-align: center;
  background: #fffaf3;
  border: 1px solid rgba(43, 20, 8, 0.12);
  border-radius: 18px;
  padding: 14px;
  box-shadow: 0 10px 28px rgba(43, 20, 8, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.ypc-rec-product:hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 34px rgba(43, 20, 8, 0.1);
}

.ypc-rec-product__image-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 210px;
  background: #ffffff;
  border-radius: 14px;
  overflow: hidden;
  margin-bottom: 14px;
}

.ypc-rec-product__image {
  display: block;
  width: 100%;
  max-width: 190px;
  height: 190px;
  object-fit: contain;
}

.ypc-rec-product__title {
  margin: 0 0 8px;
  font-size: var(--ypc-product-title-size);
  line-height: 1.28;
  font-weight: 800;
  color: var(--ypc-text);
  min-height: 44px;
}

.ypc-rec-product__title a {
  color: inherit;
  text-decoration: none;
}

.ypc-rec-product__price {
  display: flex;
  justify-content: center;
  gap: 8px;
  align-items: center;
  margin-bottom: 10px;
  font-size: var(--ypc-product-price-size);
  font-weight: 850;
}

.ypc-rec-product__price-current {
  color: var(--ypc-accent);
}

.ypc-rec-product__price-compare {
  color: var(--ypc-muted);
  text-decoration: line-through;
}

.ypc-rec-product__quick {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 36px;
  padding: 0 14px;
  border-radius: 999px;
  background: var(--ypc-accent);
  color: #fff;
  font-size: 13px;
  font-weight: 850;
  text-decoration: none;
}

.ypc-rec-product__quick:hover {
  opacity: 0.9;
}
  @media (max-width: 1100px) {
    .ypc-tabs-recos__inner {
      grid-template-columns: 1fr;
      gap: 52px;
    }

    .ypc-tabs-recos__right {
      max-width: 760px;
    }
  }

  @media (max-width: 767px) {
    .ypc-tabs-recos {
      padding: 34px 16px 50px;
    }

    .ypc-tabs-recos__nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .ypc-tabs-recos__tab {
      min-height: 58px;
      padding: 11px 12px;
      font-size: 12px;
      gap: 8px;
    }

    .ypc-tabs-recos__content {
      padding-top: 18px;
    }

    .ypc-tabs-recos__panel {
      border-radius: 18px;
      padding: 24px 18px;
    }

    .ypc-tabs-recos__panel h2 {
      font-size: clamp(24px, 8vw, var(--ypc-heading-size));
    }

    .ypc-tabs-recos__products {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "YPC Tabs + Products",
  "settings": [
    {
      "type": "header",
      "content": "Tab labels"
    },
    {
      "type": "text",
      "id": "tab_1_label",
      "label": "Tab 1 label",
      "default": "Description"
    },
    {
      "type": "text",
      "id": "tab_2_label",
      "label": "Tab 2 label",
      "default": "Safe Feeding"
    },
    {
      "type": "text",
      "id": "tab_3_label",
      "label": "Tab 3 label",
      "default": "Shipping"
    },
    {
      "type": "text",
      "id": "tab_4_label",
      "label": "Tab 4 label",
      "default": "Ingredients"
    },
    {
      "type": "header",
      "content": "Tab headings"
    },
    {
      "type": "text",
      "id": "description_heading",
      "label": "Description heading",
      "default": "The Chew That Calms and Cleans"
    },
    {
      "type": "text",
      "id": "change_heading",
      "label": "Safe feeding heading",
      "default": "Safe Feeding Guidelines"
    },
    {
      "type": "text",
      "id": "sizing_heading",
      "label": "Shipping heading",
      "default": "Shipping and Delivery"
    },
    {
      "type": "text",
      "id": "ingredients_heading",
      "label": "Ingredients heading",
      "default": "Simple Ingredients"
    },
    {
      "type": "header",
      "content": "Fallback content"
    },
    {
      "type": "richtext",
      "id": "description_fallback",
      "label": "Description fallback",
      "default": "<p>Add your product description here.</p>"
    },
    {
      "type": "richtext",
      "id": "change_fallback",
      "label": "Safe feeding fallback",
      "default": "<p>Always supervise your dog during chew time, choose the right size for their weight and chewing style, provide fresh water, and remove any small end pieces.</p>"
    },
    {
      "type": "richtext",
      "id": "sizing_fallback",
      "label": "Shipping fallback",
      "default": "<p>Orders are typically processed within 24-48 hours and shipped with tracking so you can follow your dog's chews from dispatch to delivery.</p>"
    },
    {
      "type": "richtext",
      "id": "ingredients_fallback",
      "label": "Ingredients fallback",
