{% comment %}
  ════════════════════════════════════════════════════════════════════
  DESIGN 2 — "RETAILER'S EDGE" (Data-driven / Margin-focused)
  Prime Pet Food · B2B Wholesale Application Page
  Palette: #d2632e orange · #f1eee9 cream · #fff7ec warm light · #202020 charcoal
  ════════════════════════════════════════════════════════════════════
  Lead with margins, ROI, and the Rawhide vs Yak vs Bully comparison
  reframed for retailers — the data case for switching shelf space.
{% endcomment %}

<!-- ═══ DATA HERO (Split: stats left, pricing card right) ═══ -->
<section class="ws2-hero">
  <div class="ws2-hero__noise"></div>
  <div class="ws2-hero__inner">

    <div class="ws2-hero__left">
      <div class="ws2-hero__badge">
        <span class="ws2-badge__dot"></span>
        {{ section.settings.hero_badge }}
      </div>
      <h1 class="ws2-hero__h1">{{ section.settings.hero_headline }}</h1>
      <p class="ws2-hero__sub">{{ section.settings.hero_subtext }}</p>

      <div class="ws2-hero__metrics">
        <div class="ws2-metric">
          <div class="ws2-metric__big">{{ section.settings.metric_1_num }}</div>
          <div class="ws2-metric__lbl">{{ section.settings.metric_1_label }}</div>
        </div>
        <div class="ws2-metric">
          <div class="ws2-metric__big">{{ section.settings.metric_2_num }}</div>
          <div class="ws2-metric__lbl">{{ section.settings.metric_2_label }}</div>
        </div>
        <div class="ws2-metric">
          <div class="ws2-metric__big">{{ section.settings.metric_3_num }}</div>
          <div class="ws2-metric__lbl">{{ section.settings.metric_3_label }}</div>
        </div>
        <div class="ws2-metric">
          <div class="ws2-metric__big">{{ section.settings.metric_4_num }}</div>
          <div class="ws2-metric__lbl">{{ section.settings.metric_4_label }}</div>
        </div>
      </div>

      <div class="ws2-hero__actions">
        <a href="#ws2-apply" class="ws2-btn ws2-btn--orange">{{ section.settings.hero_cta_primary }}</a>
        <a href="#ws2-compare" class="ws2-btn ws2-btn--ghost">{{ section.settings.hero_cta_secondary }}</a>
      </div>
    </div>

    <div class="ws2-hero__right">
      <div class="ws2-pricecard">
        <div class="ws2-pricecard__head">
          <div class="ws2-pricecard__tag">{{ section.settings.pricecard_tag }}</div>
          <div class="ws2-pricecard__title">{{ section.settings.pricecard_title }}</div>
        </div>

        <div class="ws2-tier ws2-tier--active">
          <div class="ws2-tier__head">
            <div class="ws2-tier__name">{{ section.settings.tier_1_name }}</div>
            <div class="ws2-tier__discount">{{ section.settings.tier_1_discount }}</div>
          </div>
          <div class="ws2-tier__body">{{ section.settings.tier_1_qty }}</div>
        </div>

        <div class="ws2-tier">
          <div class="ws2-tier__head">
            <div class="ws2-tier__name">{{ section.settings.tier_2_name }}</div>
            <div class="ws2-tier__discount">{{ section.settings.tier_2_discount }}</div>
          </div>
          <div class="ws2-tier__body">{{ section.settings.tier_2_qty }}</div>
        </div>

        <div class="ws2-tier">
          <div class="ws2-tier__head">
            <div class="ws2-tier__name">{{ section.settings.tier_3_name }}</div>
            <div class="ws2-tier__discount">{{ section.settings.tier_3_discount }}</div>
          </div>
          <div class="ws2-tier__body">{{ section.settings.tier_3_qty }}</div>
        </div>

        <div class="ws2-pricecard__foot">
          <span>{{ section.settings.pricecard_foot }}</span>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ═══ TRUST BAR ═══ -->
<div class="ws2-trust">
  <div class="ws2-trust__inner">
    {% for i in (1..6) %}
      {%- assign tn = 'trust_' | append: i | append: '_num' -%}
      {%- assign tl = 'trust_' | append: i | append: '_label' -%}
      {%- if section.settings[tl] != blank -%}
        <div class="ws2-trust__item">
          <div class="ws2-trust__num">{{ section.settings[tn] }}</div>
          <div class="ws2-trust__lbl">{{ section.settings[tl] }}</div>
        </div>
      {%- endif -%}
    {% endfor %}
  </div>
</div>

<!-- ═══ THE COMPARISON (Yak vs Rawhide vs Bully — for retailers) ═══ -->
<section class="ws2-compare" id="ws2-compare">
  <div class="ws2-compare__inner">
    <div class="ws2-compare__head">
      <div class="ws2-eyebrow ws2-fade">{{ section.settings.compare_eyebrow }}</div>
      <h2 class="ws2-h2 ws2-fade">{{ section.settings.compare_title }}</h2>
      <p class="ws2-body ws2-fade">{{ section.settings.compare_subtitle }}</p>
    </div>

    <div class="ws2-compare__table ws2-fade">
      <div class="ws2-ctable__head">
        <div class="ws2-ctable__cell ws2-ctable__cell--label">Metric</div>
        <div class="ws2-ctable__cell">Rawhide</div>
        <div class="ws2-ctable__cell ws2-ctable__cell--us">
          <span class="ws2-ctable__usbadge">Us</span>
          Yak Chews
        </div>
        <div class="ws2-ctable__cell">Bully Sticks</div>
      </div>

      {% for i in (1..6) %}
        {%- assign cm = 'compare_' | append: i | append: '_metric' -%}
        {%- assign cr = 'compare_' | append: i | append: '_rawhide' -%}
        {%- assign cy = 'compare_' | append: i | append: '_yak' -%}
        {%- assign cb = 'compare_' | append: i | append: '_bully' -%}
        {%- if section.settings[cm] != blank -%}
          <div class="ws2-ctable__row">
            <div class="ws2-ctable__cell ws2-ctable__cell--label">{{ section.settings[cm] }}</div>
            <div class="ws2-ctable__cell ws2-ctable__cell--bad">
              <span class="ws2-x">✕</span> {{ section.settings[cr] }}
            </div>
            <div class="ws2-ctable__cell ws2-ctable__cell--us ws2-ctable__cell--good">
              <span class="ws2-check">✓</span> {{ section.settings[cy] }}
            </div>
            <div class="ws2-ctable__cell ws2-ctable__cell--bad">
              <span class="ws2-x">✕</span> {{ section.settings[cb] }}
            </div>
          </div>
        {%- endif -%}
      {% endfor %}
    </div>

    <div class="ws2-compare__cta ws2-fade">
      <a href="#ws2-apply" class="ws2-btn ws2-btn--green">{{ section.settings.compare_cta }} →</a>
    </div>
  </div>
</section>

<!-- ═══ PRODUCT CATALOG (5 SKUs — wholesale-ready cases) ═══ -->
<section class="ws2-catalog">
  <div class="ws2-catalog__inner">
    <div class="ws2-catalog__head">
      <div class="ws2-eyebrow ws2-fade">{{ section.settings.catalog_eyebrow }}</div>
      <h2 class="ws2-h2 ws2-fade">{{ section.settings.catalog_title }}</h2>
      <p class="ws2-body ws2-fade">{{ section.settings.catalog_subtitle }}</p>
    </div>

    <div class="ws2-catalog__grid">
      {% for i in (1..5) %}
        {%- assign cn = 'catalog_' | append: i | append: '_name' -%}
        {%- assign cs = 'catalog_' | append: i | append: '_size' -%}
        {%- assign cw = 'catalog_' | append: i | append: '_weight' -%}
        {%- assign cu = 'catalog_' | append: i | append: '_units' -%}
        {%- assign cd = 'catalog_' | append: i | append: '_desc' -%}
        {%- assign cb = 'catalog_' | append: i | append: '_best' -%}
        {%- if section.settings[cn] != blank -%}
          <div class="ws2-sku ws2-fade ws2-d{{ i }}">
            {%- if section.settings[cb] != blank -%}
              <div class="ws2-sku__best">{{ section.settings[cb] }}</div>
            {%- endif -%}
            <div class="ws2-sku__head">
              <div class="ws2-sku__size">{{ section.settings[cs] }}</div>
            </div>
            <h4 class="ws2-sku__name">{{ section.settings[cn] }}</h4>
            <p class="ws2-sku__desc">{{ section.settings[cd] }}</p>
            <div class="ws2-sku__meta">
              <div class="ws2-sku__row">
                <span>Weight</span>
                <strong>{{ section.settings[cw] }}</strong>
              </div>
              <div class="ws2-sku__row">
                <span>Case Pack</span>
                <strong>{{ section.settings[cu] }}</strong>
              </div>
            </div>
          </div>
        {%- endif -%}
      {% endfor %}
    </div>
  </div>
</section>

<!-- ═══ BENEFITS GRID ═══ -->
<section class="ws2-benefits">
  <div class="ws2-benefits__inner">
    <div class="ws2-benefits__head">
      <div class="ws2-eyebrow ws2-eyebrow--light ws2-fade">{{ section.settings.benefits_eyebrow }}</div>
      <h2 class="ws2-h2 ws2-h2--light ws2-fade">{{ section.settings.benefits_title }}</h2>
    </div>

    <div class="ws2-benefits__grid">
      {% for i in (1..6) %}
        {%- assign bi = 'benefit_' | append: i | append: '_icon' -%}
        {%- assign bt = 'benefit_' | append: i | append: '_title' -%}
        {%- assign bp = 'benefit_' | append: i | append: '_text' -%}
        {%- if section.settings[bt] != blank -%}
          <div class="ws2-benefit ws2-fade ws2-d{{ i }}">
            <div class="ws2-benefit__icon">{{ section.settings[bi] }}</div>
            <h3>{{ section.settings[bt] }}</h3>
            <p>{{ section.settings[bp] }}</p>
          </div>
        {%- endif -%}
      {% endfor %}
    </div>
  </div>
</section>

<!-- ═══ HOW IT WORKS — 4 STEPS ═══ -->
<section class="ws2-how">
  <div class="ws2-how__inner">
    <div class="ws2-how__head">
      <div class="ws2-eyebrow ws2-fade">{{ section.settings.how_eyebrow }}</div>
      <h2 class="ws2-h2 ws2-fade">{{ section.settings.how_title }}</h2>
    </div>

    <div class="ws2-how__grid">
      {% for i in (1..4) %}
        {%- assign st = 'step_' | append: i | append: '_title' -%}
        {%- assign sp = 'step_' | append: i | append: '_text' -%}
        {%- if section.settings[st] != blank -%}
          <div class="ws2-step ws2-fade ws2-d{{ i }}">
            <div class="ws2-step__num">{{ i | prepend: '0' }}</div>
            <h4>{{ section.settings[st] }}</h4>
            <p>{{ section.settings[sp] }}</p>
          </div>
        {%- endif -%}
      {% endfor %}
    </div>
  </div>
</section>

<!-- ═══ TESTIMONIAL DUO ═══ -->
<section class="ws2-testi">
  <div class="ws2-testi__inner">
    <div class="ws2-testi__grid">
      {% for i in (1..2) %}
        {%- assign tq = 'testi_' | append: i | append: '_quote' -%}
        {%- assign tn = 'testi_' | append: i | append: '_name' -%}
        {%- assign tr = 'testi_' | append: i | append: '_role' -%}
        {%- assign tm = 'testi_' | append: i | append: '_metric' -%}
        {%- if section.settings[tq] != blank -%}
          <div class="ws2-tcard ws2-fade ws2-d{{ i }}">
            <div class="ws2-tcard__stars">★★★★★</div>
            <blockquote>{{ section.settings[tq] }}</blockquote>
            <div class="ws2-tcard__metric">{{ section.settings[tm] }}</div>
            <div class="ws2-tcard__author">
              <div class="ws2-tcard__av">{{ section.settings[tn] | slice: 0 }}</div>
              <div>
                <div class="ws2-tcard__name">{{ section.settings[tn] }}</div>
                <div class="ws2-tcard__role">{{ section.settings[tr] }}</div>
              </div>
            </div>
          </div>
        {%- endif -%}
      {% endfor %}
    </div>
  </div>
</section>

<!-- ═══ APPLICATION FORM ═══ -->
<section class="ws2-apply" id="ws2-apply">
  <div class="ws2-apply__noise"></div>
  <div class="ws2-apply__inner">

    <div class="ws2-apply__left">
      <div class="ws2-eyebrow ws2-eyebrow--light ws2-fade">{{ section.settings.form_eyebrow }}</div>
      <h2 class="ws2-h2 ws2-h2--light ws2-fade">{{ section.settings.form_title }}</h2>
      <p class="ws2-body ws2-body--light ws2-fade">{{ section.settings.form_subtitle }}</p>

      <div class="ws2-apply__points">
        {% for i in (1..4) %}
          {%- assign pk = 'perk_' | append: i -%}
          {%- if section.settings[pk] != blank -%}
            <div class="ws2-apply__point ws2-fade ws2-d{{ i }}">
              <span class="ws2-apply__chk">✓</span>
              <span>{{ section.settings[pk] }}</span>
            </div>
          {%- endif -%}
        {% endfor %}
      </div>

      <div class="ws2-apply__contact">
        <a href="tel:{{ section.settings.phone }}" class="ws2-pill">📞 {{ section.settings.phone }}</a>
        <a href="https://wa.me/{{ section.settings.whatsapp }}" target="_blank" rel="noopener" class="ws2-pill">💬 WhatsApp</a>
      </div>
    </div>

    <div class="ws2-apply__right">
      {%- if form.posted_successfully? -%}
        <div class="ws2-success">
          <div class="ws2-success__icon">✓</div>
          <h3>You're In</h3>
          <p>Application received. Our wholesale team will review and respond within 24 hours with custom pricing tailored to your store. In the meantime, reach us at <strong>{{ section.settings.phone }}</strong>.</p>
        </div>
      {%- else -%}
        {% form 'contact', id: 'ws2-form' %}
          {%- if form.errors -%}
            <div class="ws2-form__errors">{{ form.errors | default_errors }}</div>
          {%- endif -%}

          <div class="ws2-form">
            <div class="ws2-form__title">{{ section.settings.form_card_title }}</div>

            <div class="ws2-form__row">
              <div class="ws2-form__g">
                <label for="ws2-fn">First Name <em>*</em></label>
                <input id="ws2-fn" type="text" name="contact[first_name]" placeholder="John" required autocomplete="given-name">
              </div>
              <div class="ws2-form__g">
                <label for="ws2-ln">Last Name <em>*</em></label>
                <input id="ws2-ln" type="text" name="contact[last_name]" placeholder="Smith" required autocomplete="family-name">
              </div>
            </div>

            <div class="ws2-form__row">
              <div class="ws2-form__g">
                <label for="ws2-em">Business Email <em>*</em></label>
                <input id="ws2-em" type="email" name="contact[email]" placeholder="john@business.com" required autocomplete="email" value="{{ form.email }}">
              </div>
              <div class="ws2-form__g">
                <label for="ws2-ph">Phone <em>*</em></label>
                <input id="ws2-ph" type="tel" name="contact[phone]" placeholder="+1 (555) 000-0000" required autocomplete="tel">
              </div>
            </div>

            <div class="ws2-form__row ws2-form__row--full">
              <div class="ws2-form__g">
                <label for="ws2-biz">Business Name <em>*</em></label>
                <input id="ws2-biz" type="text" name="contact[business_name]" placeholder="Your Business Name" required>
              </div>
            </div>

            <div class="ws2-form__row">
              <div class="ws2-form__g">
                <label for="ws2-bt">Business Type <em>*</em></label>
                <select id="ws2-bt" name="contact[business_type]" required>
                  <option value="" disabled selected>Select…</option>
                  <option>Pet Store / Boutique</option>
                  <option>Online Retailer</option>
                  <option>Veterinary Clinic</option>
                  <option>Grooming / Daycare</option>
                  <option>Distributor</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="ws2-form__g">
                <label for="ws2-vol">Estimated Monthly Volume</label>
                <select id="ws2-vol" name="contact[monthly_volume]">
                  <option value="" disabled selected>Select volume…</option>
                  <option>1–5 Cases</option>
                  <option>5–15 Cases</option>
                  <option>15–50 Cases</option>
                  <option>50+ Cases</option>
                  <option>Not Sure Yet</option>
                </select>
              </div>
            </div>

            <div class="ws2-form__row">
              <div class="ws2-form__g">
                <label for="ws2-web">Website</label>
                <input id="ws2-web" type="url" name="contact[website]" placeholder="https://yourstore.com">
              </div>
              <div class="ws2-form__g">
                <label for="ws2-reg">State / Region</label>
                <input id="ws2-reg" type="text" name="contact[region]" placeholder="Florida">
              </div>
            </div>

            <div class="ws2-form__row ws2-form__row--full">
              <div class="ws2-form__g">
                <label for="ws2-notes">Anything else?</label>
                <textarea id="ws2-notes" name="contact[body]" rows="3" placeholder="Products of interest, customer base, or questions…"></textarea>
              </div>
            </div>

            <button type="submit" class="ws2-form__submit">{{ section.settings.form_cta }}</button>
            <p class="ws2-form__note">{{ section.settings.form_note }}</p>
          </div>
        {% endform %}
      {%- endif -%}
    </div>

  </div>
</section>

<style>
/* Prime Pet Food B2B Wholesale — cleaned theme
   No green. No dark-brown palette. Built around your live store look:
   orange accents, cream surfaces, white cards, charcoal text. */

.ws2-hero, .ws2-trust, .ws2-compare, .ws2-catalog,
.ws2-benefits, .ws2-how, .ws2-testi, .ws2-apply,
.ws2-hero *, .ws2-trust *, .ws2-compare *, .ws2-catalog *,
.ws2-benefits *, .ws2-how *, .ws2-testi *, .ws2-apply * { box-sizing: border-box; }

.ws2-hero, .ws2-trust, .ws2-compare, .ws2-catalog,
.ws2-benefits, .ws2-how, .ws2-testi, .ws2-apply {
  --ppf-orange: #d2632e;
  --ppf-orange-soft: #e87533;
  --ppf-orange-pale: #fff0df;
  --ppf-cream: #f1eee9;
  --ppf-cream-light: #fff7ec;
  --ppf-card: #ffffff;
  --ppf-ink: #202020;
  --ppf-text: #3c352f;
  --ppf-muted: #746a63;
  --ppf-soft: #9a8f87;
  --ppf-line: #e7d9ca;
  --ppf-line-strong: #dcc9b6;
  --ppf-shadow: 0 22px 55px rgba(32, 32, 32, .08);
  font-family: inherit;
}

/* HERO */
.ws2-hero {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 88% 16%, rgba(210,99,46,.16), transparent 34%),
    linear-gradient(135deg, var(--ppf-cream-light) 0%, var(--ppf-cream) 58%, #fff 100%);
  padding: clamp(64px, 7vw, 104px) 60px clamp(70px, 7vw, 108px);
}
.ws2-hero__noise {
  position: absolute; inset: 0; opacity: .035; pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.55'/%3E%3C/svg%3E");
  background-size: 220px 220px;
}
.ws2-hero::before {
  content: ''; position: absolute; right: -140px; bottom: -170px;
  width: 440px; height: 440px; border-radius: 50%;
  background: rgba(210,99,46,.10); pointer-events: none;
}
.ws2-hero::after {
  content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 7px;
  background: linear-gradient(90deg, var(--ppf-orange), var(--ppf-orange-soft));
}
.ws2-hero__inner {
  position: relative; z-index: 2;
  max-width: 1280px; margin: 0 auto;
  display: grid; grid-template-columns: minmax(0, 1.08fr) minmax(360px, .92fr);
  gap: clamp(36px, 5vw, 72px); align-items: center;
}
.ws2-hero__badge {
  display: inline-flex; align-items: center; gap: 10px;
  background: #fff; border: 1px solid var(--ppf-line);
  padding: 9px 17px; border-radius: 999px;
  font-size: 11px; letter-spacing: 1.9px; text-transform: uppercase;
  color: var(--ppf-orange); font-weight: 800; margin-bottom: 28px;
  box-shadow: 0 10px 30px rgba(32,32,32,.05);
}
.ws2-badge__dot {
  width: 7px; height: 7px; border-radius: 50%; background: var(--ppf-orange);
  box-shadow: 0 0 0 5px rgba(210,99,46,.12);
}
.ws2-hero__h1 {
  font-size: clamp(36px, 4.7vw, 66px);
  font-weight: 900; line-height: .98; letter-spacing: -1.7px;
  color: var(--ppf-ink); margin: 0 0 22px;
  max-width: 780px;
}
.ws2-hero__h1 em { font-style: normal; color: var(--ppf-orange); }
.ws2-hero__sub {
  font-size: clamp(15px, 1.15vw, 18px); line-height: 1.75;
  color: var(--ppf-muted); margin: 0 0 36px; max-width: 560px;
}
.ws2-hero__metrics {
  display: grid; grid-template-columns: repeat(4, 1fr);
  border: 1px solid var(--ppf-line); border-radius: 18px;
  background: rgba(255,255,255,.62); overflow: hidden;
  margin: 0 0 36px; box-shadow: 0 14px 40px rgba(32,32,32,.04);
}
.ws2-metric { padding: 22px 18px; border-right: 1px solid var(--ppf-line); }
.ws2-metric:last-child { border-right: none; }
.ws2-metric__big {
  font-size: clamp(24px, 2.2vw, 34px); font-weight: 900; color: var(--ppf-orange);
  line-height: 1; letter-spacing: -.8px; margin-bottom: 7px;
}
.ws2-metric__lbl {
  font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--ppf-muted); font-weight: 800; line-height: 1.4;
}
.ws2-hero__actions { display: flex; gap: 14px; flex-wrap: wrap; }

/* BUTTONS */
.ws2-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  min-height: 52px; padding: 15px 30px; border-radius: 999px;
  font-size: 12px; font-weight: 900; letter-spacing: 1px; text-transform: uppercase;
  text-decoration: none; border: 1.5px solid transparent; cursor: pointer;
  transition: transform .22s ease, box-shadow .22s ease, background .22s ease, color .22s ease, border-color .22s ease;
  font-family: inherit;
}
.ws2-btn--orange, .ws2-btn--green {
  background: var(--ppf-orange); color: #fff;
  box-shadow: 0 12px 30px rgba(210,99,46,.24);
}
.ws2-btn--orange:hover, .ws2-btn--green:hover {
  background: var(--ppf-orange-soft); color: #fff; transform: translateY(-2px);
  box-shadow: 0 16px 36px rgba(210,99,46,.30);
}
.ws2-btn--ghost {
  background: #fff; color: var(--ppf-ink); border-color: var(--ppf-line-strong);
}
