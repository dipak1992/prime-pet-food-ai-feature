  .ws2-ctable__head .ws2-ctable__cell--us { padding-top: 36px; }
  .ws2-catalog__grid, .ws2-benefits__grid, .ws2-how__grid { grid-template-columns: 1fr; }
  .ws2-testi { padding-left: 20px; padding-right: 20px; }
  .ws2-tcard, .ws2-form { padding: 28px 22px; border-radius: 22px; }
  .ws2-form__row { grid-template-columns: 1fr; }
  .ws2-apply__contact { flex-direction: column; }
  .ws2-pill { justify-content: center; }
}
</style>


<script>
  (function(){
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting) {
          e.target.classList.add('ws2-vis');
          io.unobserve(e.target);
        }
      });
    }, { threshold: .07, rootMargin: '0px 0px -30px 0px' });
    document.querySelectorAll('.ws2-fade').forEach(function(el){ io.observe(el); });
  })();
</script>

