{{ 'prime-roadmap.css' | asset_url | stylesheet_tag }}

<section class="pbl" aria-labelledby="PrimeBreedLandingTitle">
  <div class="pbl__hero">
    <div>
      <p class="pbl__kicker">{{ section.settings.eyebrow }}</p>
      <h1 id="PrimeBreedLandingTitle">{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subheading }}</p>
      <div class="pbl__actions">
        <a href="{{ section.settings.primary_link }}" class="pbl__button pbl__button--primary">{{ section.settings.primary_label }}</a>
        <a href="/pages/how-long-will-this-last-for-my-dog" class="pbl__button pbl__button--secondary">Estimate my dog</a>
      </div>
    </div>
    <aside class="pbl__estimate" aria-label="Breed chew estimate">
      <strong>{{ section.settings.duration }}</strong>
      <span>Typical supervised chew window</span>
      <p>{{ section.settings.estimate_note }}</p>
    </aside>
  </div>

  <div class="pbl__grid" aria-label="Breed buying guidance">
    <article>
      <span>01</span>
      <h2>{{ section.settings.card_1_title }}</h2>
      <p>{{ section.settings.card_1_text }}</p>
    </article>
    <article>
      <span>02</span>
      <h2>{{ section.settings.card_2_title }}</h2>
      <p>{{ section.settings.card_2_text }}</p>
    </article>
    <article>
      <span>03</span>
      <h2>{{ section.settings.card_3_title }}</h2>
      <p>{{ section.settings.card_3_text }}</p>
    </article>
  </div>

  <div class="pbl__links">
    <a href="/blogs/dog-behavior/how-long-do-yak-chews-last">Chew duration guide</a>
    <a href="/blogs/dog-behavior/best-rawhide-alternative">Rawhide alternative guide</a>
    <a href="/pages/my-dog">Open My Dog dashboard</a>
  </div>
</section>

{% schema %}
{
  "name": "Prime Pet Food breed",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Breed-specific yak chew guide" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The right yak chew for your dog." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Choose a rawhide-free Himalayan yak chew by breed, weight, and chewing style." },
    { "type": "text", "id": "duration", "label": "Duration", "default": "45-90 min" },
    { "type": "textarea", "id": "estimate_note", "label": "Estimate note", "default": "Exact duration depends on weight, jaw strength, age, and chew style." },
    { "type": "text", "id": "primary_label", "label": "Primary label", "default": "Shop recommended chews" },
    { "type": "url", "id": "primary_link", "label": "Primary link", "default": "/products/himalayan-yak-chews-for-dogs" },
    { "type": "text", "id": "card_1_title", "label": "Card 1 title", "default": "Size up for safety" },
    { "type": "textarea", "id": "card_1_text", "label": "Card 1 text", "default": "If your dog is between sizes or chews aggressively, choose the larger yak chew." },
    { "type": "text", "id": "card_2_title", "label": "Card 2 title", "default": "Use supervised sessions" },
    { "type": "textarea", "id": "card_2_text", "label": "Card 2 text", "default": "Yak chews are designed for calm-time enrichment with fresh water and supervision." },
    { "type": "text", "id": "card_3_title", "label": "Card 3 title", "default": "Track real duration" },
    { "type": "textarea", "id": "card_3_text", "label": "Card 3 text", "default": "Save your dog's profile and log chew sessions to improve reorder timing." }
  ],
  "presets": [
    { "name": "Prime Pet Food breed" }
  ]
}
{% endschema %}
