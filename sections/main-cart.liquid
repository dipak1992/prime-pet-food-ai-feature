{%- comment -%}theme-check-disable NestedSnippet,TemplateLength{%- endcomment -%}
{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<div
  class="ypc-cart color-{{ section.settings.color_scheme }} isolate gradient {% if cart == empty %} is-empty{% endif %}"
  id="main-cart"
  data-id="{{ section.id }}"
>
  <div class="page-width">
    <div class="ypc-cart__layout">

      <div class="ypc-cart__main" id="main-cart-items">
        <cart-items class="{% if cart == empty %} is-empty{% endif %}">
          <div class="ypc-cart__hero">
            <div class="ypc-cart__hero-copy">
              <h1 class="ypc-cart__title">{{ 'sections.cart.title' | t }}</h1>
              <p class="ypc-cart__subtitle">
                {{ section.settings.cart_subtitle }}
              </p>
            </div>

            <a
              href="{% if settings.cart_continue_shopping_link %}{{ settings.cart_continue_shopping_link }}{% else %}{{ routes.all_products_collection_url }}{% endif %}"
              class="ypc-cart__continue"
            >
              {{ 'general.continue_shopping' | t }}
            </a>
          </div>

          {% render 'cart-chew-personalization', context: 'cart_page' %}

          <div class="cart__warnings">
            <h2 class="cart__empty-text ypc-cart__title ypc-cart__title--empty">Your dog&rsquo;s chew box is waiting.</h2>
            <p class="ypc-cart__subtitle">{{ section.settings.empty_subtitle }}</p>
            <a
              href="{% if settings.cart_continue_shopping_link %}{{ settings.cart_continue_shopping_link }}{% else %}{{ routes.all_products_collection_url }}{% endif %}"
              class="ypc-cart__empty-btn"
            >
              Shop Best Sellers
            </a>
            <a href="/pages/how-long-will-this-last-for-my-dog" class="ypc-cart__empty-secondary">
              Find the Right Chew
            </a>
          </div>

          <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="cart">
            <div class="ypc-cart__headings{% if cart == empty %} hidden{% endif %}">
              <div>{{ 'sections.cart.headings.product' | t }}</div>
              <div>{{ 'sections.cart.headings.quantity' | t }}</div>
              <div class="right">{{ 'sections.cart.headings.total' | t }}</div>
            </div>

            <div class="cart__items" data-id="{{ section.id }}">
              <div class="js-cart-items">
                {%- if cart != empty -%}
                  <div class="ypc-cart-items">
                    {%- for item in cart.items -%}
                      <div
                        class="ypc-cart-item{% if item.parent_relationship.parent != null %} cart-item__nested-line{% endif %}"
                        id="CartItem-{{ item.index | plus: 1 }}"
                        {% if item.parent_relationship.parent != null %}
                          aria-label="{{- 'products.product.nested_label' | t: title: item.product.title, parent_title: item.parent_relationship.parent.title | escape -}}"
                        {% endif %}
                      >
                        <div class="ypc-cart-item__product">
                          <div class="ypc-cart-item__media {% unless item.image %}flex justify-center{% endunless %}">
                            {% if item.image %}
                              <a href="{{ item.url }}" class="cart-item__link" aria-hidden="true" tabindex="-1"> </a>
                              <div class="ypc-cart-item__image-wrap gradient{% if settings.card_image_replace_background %} mix-blend-multiply{% endif %}">
                                <img
                                  src="{{ item.image | image_url: width: 300 }}"
                                  class="ypc-cart-item__image"
                                  alt="{{ item.image.alt | escape }}"
                                  loading="lazy"
                                  fetchpriority="low"
                                  width="150"
                                  height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}"
                                >
                              </div>
                            {% else %}
                              <div class="ypc-cart-item__image-wrap ypc-cart-item__image-wrap--empty">
                                {% render 'icon-no-photo' %}
                              </div>
                            {% endif %}
                          </div>

                          <div class="ypc-cart-item__details">
                            {%- if settings.cart_show_vendor -%}
                              <p class="ypc-cart-item__vendor">{{ item.product.vendor }}</p>
                            {%- endif -%}

                            <a href="{{ item.url }}" class="ypc-cart-item__name">{{ item.product.title | escape }}</a>

                            {%- assign item_inventory = item.variant.inventory_quantity -%}
                            {%- if item.variant.inventory_management == 'shopify' and item_inventory > 0 and item_inventory <= 10 -%}
                              <p class="ypc-cart-item__low-stock">🔥 Only {{ item_inventory }} left</p>
                            {%- endif -%}

                            {%- if item.original_price != item.final_price -%}
                              <div class="ypc-cart-item__unit-prices">
                                <s class="ypc-cart-item__unit-old">
                                  {{- item.original_price | money -}}
                                </s>
                                <strong class="ypc-cart-item__unit-final">
                                  {{ item.final_price | money }}
                                </strong>
                              </div>
                            {%- elsif item.price > 0 or settings.card_show_zero_prices != false -%}
                              <div class="ypc-cart-item__unit-prices">
                                <strong class="ypc-cart-item__unit-final">
                                  {{ item.original_price | money }}
                                </strong>
                              </div>
                            {%- endif -%}

                            {%- if settings.badge_preorder_show_cart and item.product.template_suffix contains 'preorder' -%}
                              <span class="badge badge--preorder badge--bottom-left badge--{{ settings.badge_shape }} mb-1">
                                {{- 'products.product.preorder' | t -}}
                              </span>
                            {%- endif -%}

                            {%- if item.sku != blank -%}
                              <dl class="ypc-cart-item__meta-list">
                                <div class="ypc-cart-item__meta-row">
                                  <dt>{{ 'products.product.sku' | t }}:</dt>
                                  <dd>{{ item.sku }}</dd>
                                </div>
                              </dl>
                            {%- endif -%}

                            {%- if item.product.has_only_default_variant == false
                              or item.properties.size != 0
                              or item.selling_plan_allocation != null
                            -%}
                              <dl class="ypc-cart-item__meta-list">
                                {%- if item.product.has_only_default_variant == false -%}
                                  {%- for option in item.options_with_values -%}
                                    <div class="ypc-cart-item__meta-row">
                                      <dt>{{ option.name }}:</dt>
                                      <dd>{{ option.value }}</dd>
                                    </div>
                                  {%- endfor -%}
                                {%- endif -%}

                                {%- for property in item.properties -%}
                                  {%- assign property_first_char = property.first | slice: 0 -%}
                                  {%- if property.last != blank and property_first_char != '_' -%}
                                    <div class="ypc-cart-item__meta-row">
                                      <dt>{{ property.first }}:</dt>
                                      <dd>
                                        {%- if property.last contains '/uploads/' -%}
                                          <a href="{{ property.last }}" class="link" target="_blank">
                                            {{ property.last | split: '/' | last }}
                                          </a>
                                        {%- else -%}
                                          {{ property.last }}
                                        {%- endif -%}
                                      </dd>
                                    </div>
                                  {%- endif -%}
                                {%- endfor -%}
                              </dl>

                              {%- if item.selling_plan_allocation != null -%}
                                <p class="ypc-cart-item__subscription">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                              {%- endif -%}
                            {%- endif -%}

                            <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                              {%- for discount in item.line_level_discount_allocations -%}
                                <li class="discounts__discount">
                                  {%- render 'icon-discount' -%}
                                  {{ discount.discount_application.title | escape }}
                                </li>
                              {%- endfor -%}
                            </ul>

                            <cart-remove-button
                              id="Remove-mobile-{{ item.index | plus: 1 }}"
                              data-index="{{ item.index | plus: 1 }}"
                              {% assign can_remove = item.instructions.can_remove | default: true %}
                              {% if can_remove == false %}
                                class="hidden"
                              {% endif %}
                            >
                              <a
                                href="{{ item.url_to_remove }}"
                                class="ypc-cart-item__remove ypc-cart-item__remove--details"
                                aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"
                                data-no-instant
                              >
                                {% render 'icon-remove' %}
                                <span>Remove</span>
                              </a>
                            </cart-remove-button>
                          </div>
                        </div>

                        {%- liquid
                          assign has_qty_rules = false
                          if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
                            assign has_qty_rules = true
                          endif

                          assign has_vol_pricing = false
                          if item.variant.quantity_price_breaks.size > 0
                            assign has_vol_pricing = true
                          endif
                        -%}

                        <div class="ypc-cart-item__qty">
                          <quantity-popover>
                            <div class="cart-item__quantity-wrapper quantity-popover-wrapper">
                              <label class="visually-hidden" for="Quantity-{{ item.index | plus: 1 }}">
                                {{ 'products.product.quantity.label' | t }}
                              </label>

                              <div class="quantity-popover-container{% if has_qty_rules or has_vol_pricing %} quantity-popover-container--hover{% endif %}">
                                {%- if has_qty_rules or has_vol_pricing -%}
                                  <button
                                    type="button"
                                    aria-expanded="false"
                                    class="quantity-popover__info-button quantity-popover__info-button--icon-only button button--tertiary small-hide medium-hide no-js-hidden"
                                  >
                                    {% render 'icon-info' %}
                                  </button>
                                {%- endif -%}

                                <quantity-input class="quantity quantity--squidge{% if settings.buttons_radius > 19 %} quantity--squidge-rounded{% endif %} cart-quantity ypc-cart-item__quantity">
                                  {%- assign can_update_quantity = item.instructions.can_update_quantity | default: true -%}
                                  <input
                                    class="quantity__input"
                                    data-quantity-variant-id="{{ item.variant.id }}"
                                    type="number"
                                    name="updates[]"
                                    value="{{ item.quantity }}"
                                    data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                    min="0"
                                    data-min="{{ item.variant.quantity_rule.min }}"
                                    {% if item.variant.quantity_rule.max != null %}
                                      max="{{ item.variant.quantity_rule.max }}"
                                    {% endif %}
                                    step="{{ item.variant.quantity_rule.increment }}"
                                    aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                    id="Quantity-{{ item.index | plus: 1 }}"
                                    data-index="{{ item.index | plus: 1 }}"
                                  >
                                  <label class="visually-hidden" for="Quantity-{{ item.index | plus: 1 }}">
                                    {{ 'products.product.quantity.label' | t }}
                                  </label>

                                  <button class="quantity__button quantity__button-increase tap-target--small no-js-hidden" name="plus" type="button"{% if can_update_quantity == false %} disabled{% endif %}>
                                    <span class="visually-hidden">
                                      {{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}
                                    </span>
                                    {% render 'icon-caret' %}
                                  </button>

                                  <button class="quantity__button quantity__button-decrease tap-target--small no-js-hidden" name="minus" type="button"{% if can_update_quantity == false %} disabled{% endif %}>
                                    <span class="visually-hidden">
                                      {{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}
                                    </span>
                                    {% render 'icon-caret' %}
                                  </button>
                                </quantity-input>
                              </div>

                              <cart-remove-button
                                id="Remove-{{ item.index | plus: 1 }}"
                                data-index="{{ item.index | plus: 1 }}"
                                {% assign can_remove = item.instructions.can_remove | default: true %}
                                {% if can_remove == false %}
                                  class="hidden"
                                {% endif %}
                              >
                                <a
                                  href="{{ item.url_to_remove }}"
                                  class="ypc-cart-item__remove"
                                  aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"
                                  data-no-instant
                                >
                                  {% render 'icon-remove' %}
                                  <span>Remove</span>
                                </a>
                              </cart-remove-button>
                            </div>

                            {%- if has_qty_rules or has_vol_pricing -%}
                              <button
                                type="button"
                                class="quantity-popover__info-button quantity-popover__info-button--icon-with-label button button--tertiary medium-hide large-up-hide"
                                aria-expanded="false"
                              >
                                {% render 'icon-info' %}
                                <span>
                                  {%- if has_vol_pricing -%}
                                    {{ 'products.product.volume_pricing.note' | t }}
                                  {%- elsif has_qty_rules -%}
                                    {{ 'products.product.quantity.note' | t }}
                                  {%- endif -%}
                                </span>
                              </button>
                            {%- endif -%}

                            {%- if has_vol_pricing or has_qty_rules -%}
                              <div class="cart-items__info global-settings-popup quantity-popover__info" tabindex="-1" hidden>
                                {%- if has_qty_rules == false -%}
                                  <span class="volume-pricing-label caption">
                                    {{- 'products.product.volume_pricing.title' | t -}}
                                  </span>
                                {%- endif -%}

                                <div class="quantity__rules caption no-js-hidden">
                                  {%- if item.variant.quantity_rule.increment > 1 -%}
                                    <span class="divider">
                                      {{- 'products.product.quantity.multiples_of' | t: quantity: item.variant.quantity_rule.increment -}}
                                    </span>
                                  {%- endif -%}
                                  {%- if item.variant.quantity_rule.min > 1 -%}
                                    <span class="divider">
                                      {{- 'products.product.quantity.min_of' | t: quantity: item.variant.quantity_rule.min -}}
                                    </span>
                                  {%- endif -%}
                                  {%- if item.variant.quantity_rule.max != null -%}
                                    <span class="divider">
                                      {{- 'products.product.quantity.max_of' | t: quantity: item.variant.quantity_rule.max -}}
                                    </span>
                                  {%- endif -%}
                                </div>

                                <button
                                  class="button-close button button--tertiary large-up-hide"
                                  type="button"
                                  aria-label="{{ 'accessibility.close' | t }}"
                                >
                                  {%- render 'icon-close' -%}
                                </button>

                                {%- if item.variant.quantity_price_breaks.size > 0 -%}
                                  <volume-pricing class="parent-display">
                                    <ul class="list-unstyled">
                                      <li>
                                        <span>{{ item.variant.quantity_rule.min }}+</span>
                                        {%- assign price = item.variant.price | money_with_currency -%}
                                        <span>{{ 'sections.quick_order_list.each_html' | t: money: price }}</span>
                                      </li>
                                      {%- for price_break in item.variant.quantity_price_breaks -%}
                                        <li>
                                          <span>{{- price_break.minimum_quantity -}}<span aria-hidden="true">+</span></span>
                                          {%- assign price = price_break.price | money_with_currency -%}
                                          <span>{{ 'sections.quick_order_list.each_html' | t: money: price }}</span>
                                        </li>
                                      {%- endfor -%}
                                    </ul>
                                  </volume-pricing>
                                {%- endif -%}
                              </div>
                            {%- endif -%}

                            <div class="cart-item__error" id="Line-item-error-{{ item.index | plus: 1 }}" role="alert">
                              <small class="cart-item__error-text"></small>
                              {% render 'icon-error' %}
                            </div>
                          </quantity-popover>
                        </div>

                        <div class="ypc-cart-item__total">
                          {%- render 'loading-spinner' -%}
                          <div class="ypc-cart-item__total-wrap">
                            {%- if item.original_line_price != item.final_line_price -%}
                              <s class="ypc-cart-item__total-old">
                                {{ item.original_line_price | money }}
                              </s>
                              <span class="ypc-cart-item__total-final">
                                {{ item.final_line_price | money }}
                              </span>
                            {%- else -%}
                              <span class="ypc-cart-item__total-final">
                                {{ item.original_line_price | money }}
                              </span>

                              {%- if item.variant.compare_at_price > item.variant.price or item.original_line_price != item.final_line_price -%}
                                {%- if item.variant.compare_at_price > item.variant.price -%}
                                  {%- assign compare_at_total_price = item.variant.compare_at_price | times: item.quantity -%}
                                  <s class="ypc-cart-item__total-old">{{ compare_at_total_price | money }}</s>
                                {%- elsif item.original_line_price != item.final_line_price -%}
                                  <s class="ypc-cart-item__total-old">{{ item.original_line_price | money }}</s>
                                {%- endif -%}
                              {%- endif -%}
                            {%- endif -%}

                            {%- if item.variant.available and item.unit_price_measurement -%}
                              <div class="unit-price caption">
                                <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                                {{ item.unit_price | money }}
                                <span aria-hidden="true">/</span>
                                <span class="visually-hidden">&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span>
                                {%- if item.unit_price_measurement.reference_value != 1 -%}
                                  {{- item.unit_price_measurement.reference_value -}}
                                {%- endif -%}
                                {{ item.unit_price_measurement.reference_unit }}
                              </div>
                            {%- endif -%}
                          </div>
                        </div>
                      </div>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            </div>

            <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
            <p class="visually-hidden" id="shopping-cart-line-item-status" aria-live="polite" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </form>
        </cart-items>
      </div>

      <div class="ypc-cart__summary cart__footer isolate" id="cart-summary">
        <div class="ypc-cart-summary color-{{ section.settings.cart_summary_color_scheme }} isolate gradient">
          {%- liquid
            assign has_subscription_item = false
            for item in cart.items
              if item.selling_plan_allocation != null
                assign has_subscription_item = true
              endif
            endfor
          -%}

          {%- if settings.cart_shipping_bar_show -%}
            <div class="free-shipping-bar-container js-free-shipping-bar ypc-cart-summary__shipping">
              {%- render 'free-shipping-bar' -%}
            </div>
          {%- endif -%}

          <div class="js-subtotal ypc-cart-summary__totals">
            <div>
              {%- if cart.cart_level_discount_applications.size > 0 -%}
                <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                  {%- for discount in cart.cart_level_discount_applications -%}
                    <li class="discounts__discount t5">
                      {%- render 'icon-discount' -%}
                      {{ discount.title | escape }}
                      (-{{ discount.total_allocated_amount | money }})
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>

            <div class="ypc-cart-summary__total-row">
              <h2 class="ypc-cart-summary__label">{{ 'sections.cart.estimated_total' | t }}</h2>
              <p class="ypc-cart-summary__value">{{ cart.total_price | money_with_currency }}</p>
            </div>

            {%- if settings.cart_show_tax_message -%}
              <small class="footer-message caption-large rte ypc-cart-summary__tax">
                {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
                  {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
                {%- elsif cart.taxes_included -%}
                  {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
                {%- elsif shop.shipping_policy.body != blank -%}
                  {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
                {%- else -%}
                  {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
                {%- endif -%}
              </small>
            {%- endif -%}
          </div>

          {%- if cart != empty -%}
            <div class="ypc-cart-summary__confidence" aria-label="Checkout reassurance">
              <span>Guest checkout available. No account required.</span>
              <span>Secure checkout with familiar payment options.</span>
              <span>Free shipping $30+ and 30-day support.</span>
            </div>

            {%- if has_subscription_item -%}
              <div class="ypc-cart-summary__subscription-terms" aria-label="Subscription checkout details">
                <strong>Subscription terms are shown before payment.</strong>
                <span>Skip, pause, or cancel from your account portal before the next renewal.</span>
              </div>
            {%- endif -%}

            <div class="ypc-cart-summary__discount">
              <label class="ypc-cart-summary__discount-label" for="ypc-discount-code">
                Promo / Discount Code
              </label>
              <div class="ypc-cart-summary__discount-row">
                <input
                  type="text"
                  id="ypc-discount-code"
                  class="ypc-cart-summary__discount-input"
                  placeholder="Enter code"
                  autocomplete="off"
                  autocapitalize="characters"
                />
                <button type="button" class="ypc-cart-summary__discount-btn" id="ypc-apply-discount">
                  Apply
                </button>
              </div>
              <p class="ypc-cart-summary__discount-msg" id="ypc-discount-msg" hidden></p>
            </div>
          {%- endif -%}

          <div class="ypc-cart-summary__subscribe">
            <p class="ypc-cart-summary__subscribe-kicker">Subscribe &amp; Save</p>
            <h3>Keep yak chews ready for calm-time routines.</h3>
            <p>Automatic deliveries, flexible schedules, and savings without the subscription anxiety. Skip or cancel anytime.</p>
            <a href="/pages/subscribe-and-save">Start saving 15% today</a>
          </div>

          {%- if settings.cart_show_shipping_calculator -%}
            <custom-accordion class="no-js-hidden">
              <details>
                <summary class="arrow-inset">
                  <span class="summary__title font-medium t4 pl-2 pr-2 flex items-center">
                    {% render 'icon', icon: 'truck' %}
                    {{ 'sections.cart.shipping_calculator.link_title' | t }}
                    {% render 'icon-caret' %}
                  </span>
                </summary>
                <div class="custom-accordion__panel custom-scrollbar pl-2 pr-2">
                  {%- render 'shipping-calculator', id: 'cart' -%}
                </div>
              </details>
            </custom-accordion>
          {%- endif -%}

          {%- if settings.cart_show_cart_note -%}
            <custom-accordion>
              <details>
                <summary class="arrow-inset">
                  <span class="summary__title font-medium t4 pl-2 pr-2 flex items-center">
                    {% render 'icon-note' %}
                    {{ 'sections.cart.note' | t }}
                    {% render 'icon-caret' %}
                  </span>
                </summary>
                <div class="custom-accordion__panel custom-scrollbar pl-2 pr-2">
                  <cart-note class="cart__note field mb-15">
                    <label class="visually-hidden" for="Cart-note">{{ 'sections.cart.note' | t }}</label>
                    <textarea
                      class="text-area field__input"
                      name="note"
                      form="cart"
                      id="Cart-note"
                      placeholder="{{ 'sections.cart.note' | t }}"
                    >{{ cart.note }}</textarea>
                  </cart-note>
                </div>
              </details>
            </custom-accordion>
          {%- endif -%}

          {%- if settings.cart_terms -%}
            <div class="footer-message t4 ypc-cart-summary__terms">
              <input
                type="checkbox"
                class="field__checkbox"
                id="cart-drawer-terms-cart"
                required
                form="cart"
                oninvalid='this.setCustomValidity("{{ 'sections.cart.terms.error' | t }}")'
                onchange="this.setCustomValidity('')"
              />
              <label for="cart-drawer-terms-cart"><span dir="ltr">{{ 'sections.cart.terms.agreement_html' | t: terms: settings.cart_terms }}</span></label>
            </div>
          {%- endif -%}

          <div class="cart__ctas-container ypc-cart-summary__cta-wrap">
            <div class="cart__ctas">
              <noscript>
                <button type="submit" class="cart__update-button button button--secondary" form="cart">
                  {{ 'sections.cart.update' | t }}
                </button>
              </noscript>

              <button
                type="submit"
                id="checkout"
                class="cart__checkout-button lh-1 button-with-icon button-with-icon--right button ypc-cart-summary__checkout"
                name="checkout"
                {% if cart == empty %}
                  disabled
                {% endif %}
                form="cart"
              >
                {% render 'icon-padlock' %}
                {{ 'sections.cart.checkout' | t }}
              </button>
            </div>

            <p class="ypc-cart-summary__checkout-note">Guest checkout. Secure payment. No surprise account step.</p>

            {%- if additional_checkout_buttons -%}
              <div class="cart__dynamic-checkout-buttons additional-checkout-buttons">
                {{ content_for_additional_checkout_buttons }}
              </div>
            {%- endif -%}

            <div class="ypc-cart-summary__social-proof">
              <span class="ypc-cart-summary__stars">★★★★★</span>
              <span class="ypc-cart-summary__proof-text">4.9 · Rated by 2,400+ dog parents</span>
            </div>

            <div class="ypc-cart-summary__payments" aria-label="Accepted payment methods">
              {%- for type in shop.enabled_payment_types -%}
                <span class="ypc-cart-summary__payment-icon">{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</span>
              {%- endfor -%}
            </div>

            <div class="ypc-cart-summary__trust">
              <span>Secure checkout</span>
              <span>Fast delivery</span>
              <span>Easy order help</span>
            </div>

            <nav class="ypc-cart-summary__policies" aria-label="Checkout policy links">
              <a href="/pages/shipping-policy">Shipping</a>
              <a href="/pages/refund-policy">Returns</a>
              <a href="/pages/privacy-policy">Privacy</a>
              <a href="/pages/terms-of-service">Terms</a>
              <a href="/pages/contact">Contact</a>
            </nav>

            <div id="cart-errors"></div>
          </div>
        </div>

        {%- assign scheme1 = settings.color_schemes | first -%}
        {%- if settings.cart_related_show -%}
          <div class="ypc-cart__recommendations cart__recommendations">
            {%- render 'mini-card-list',
              mode: 'related',
              section_id: 'main-cart',
              layout: settings.cart_related_layout,
              make_collapsible_row: false,
              enable_quick_add: settings.enable_quick_add,
              product_list_limit: settings.cart_related_limit,
              block_heading: section.settings.upsell_heading,
              products_per_page: 1,
              color_scheme: settings.cart_related_color_scheme,
              line_color_scheme: scheme1
            -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    function isIE() {
      const ua = window.navigator.userAgent;
      const msie = ua.indexOf('MSIE ');
      const trident = ua.indexOf('Trident/');
      return msie > 0 || trident > 0;
    }

    if (!isIE()) return;
    const cartSubmitInput = document.createElement('input');
    cartSubmitInput.setAttribute('name', 'checkout');
    cartSubmitInput.setAttribute('type', 'hidden');
    document.querySelector('#cart').appendChild(cartSubmitInput);
    document.querySelector('#checkout').addEventListener('click', function () {
      document.querySelector('#cart').submit();
    });
  });
</script>

