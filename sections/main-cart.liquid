    padding: 10px 14px;
    border-radius: 12px;
    background: #f6f1e9;
    border: 1px solid rgba(23, 59, 43, 0.07);
  }

  .ypc-cart-summary__stars {
    color: #f5a623;
    font-size: 15px;
    letter-spacing: 1px;
    line-height: 1;
  }

  .ypc-cart-summary__proof-text {
    color: #3d3a35;
    font-size: 13px;
    font-weight: 700;
    line-height: 1.2;
  }
  /* ── Swipe-to-remove styles (mobile) ── */
  @media (max-width: 989px) {
    .ypc-cart-item {
      position: relative;
      overflow: visible;
      will-change: transform;
    }

    .ypc-cart-item::after {
      content: "Remove";
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: 100px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #e74c3c;
      color: #fff;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.04em;
      border-radius: 0 22px 22px 0;
      opacity: var(--swipe-progress, 0);
      transform: translateX(100%);
      pointer-events: none;
      transition: opacity 0.15s ease;
    }
  }
</style>

<script>
  (function () {
    var btn = document.getElementById('ypc-apply-discount');
    if (!btn) return;
    var input = document.getElementById('ypc-discount-code');
    var msg = document.getElementById('ypc-discount-msg');

    function showMsg(text, type) {
      msg.textContent = text;
      msg.className = 'ypc-cart-summary__discount-msg ypc-cart-summary__discount-msg--' + type;
      msg.hidden = false;
    }

    btn.addEventListener('click', function () {
      var code = (input.value || '').trim();
      if (!code) {
        showMsg('Please enter a discount code.', 'error');
        return;
      }
      btn.disabled = true;
      btn.textContent = 'Applying…';
      msg.hidden = true;

      fetch('/discount/' + encodeURIComponent(code), {
        method: 'GET',
        headers: { 'Accept': 'application/json' }
      }).then(function () {
        /* Shopify applies the discount via cookie on the /discount/ route.
           We then update the cart to reflect the new price. */
        return fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({})
        });
      }).then(function (res) { return res.json(); })
        .then(function (cart) {
          if (cart.cart_level_discount_applications && cart.cart_level_discount_applications.length > 0) {
            showMsg('✓ Discount applied!', 'success');
            setTimeout(function () { window.location.reload(); }, 800);
          } else {
            showMsg('Code applied — refresh to see savings.', 'success');
            setTimeout(function () { window.location.reload(); }, 1200);
          }
        })
        .catch(function () {
          showMsg('Could not apply code. Please try again.', 'error');
          btn.disabled = false;
          btn.textContent = 'Apply';
        });
    });

    input.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') btn.click();
    });
  })();
</script>

