<section class="pch-hero" aria-label="{{ collection.title }} collection">
  <div class="pch-hero__inner">

    <div class="pch-shell pch-hero__content">
      <div class="pch-hero__text">
        <p class="pch-kicker">{{ section.settings.eyebrow | default: 'Premium Himalayan yak chews' }}</p>
        <h1>{{ section.settings.heading | default: collection.title }}</h1>
        {% if section.settings.subheading != blank %}
          <p class="pch-hero__sub">{{ section.settings.subheading }}</p>
        {% elsif collection.description != blank %}
          <p class="pch-hero__sub">{{ collection.description | strip_html | truncate: 180 }}</p>
        {% endif %}
        <div class="pch-hero__pills" aria-label="Key benefits">
          <span>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Rawhide-free
          </span>
          <span>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Lasts 45–90 min avg
          </span>
          <span>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            4 ingredients only
          </span>
          <span>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            10,000+ happy dogs
          </span>
        </div>
      </div>
    </div>

  </div>

  <div class="pch-trust-bar" aria-label="Trust signals">
    <div class="pch-shell pch-trust-bar__inner">
      <div class="pch-trust-bar__item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        <span>Vet-approved ingredients</span>
      </div>
      <div class="pch-trust-bar__divider" aria-hidden="true"></div>
      <div class="pch-trust-bar__item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <span>4.9&#9733; from 500+ reviews</span>
      </div>
      <div class="pch-trust-bar__divider" aria-hidden="true"></div>
      <div class="pch-trust-bar__item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        <span>Free shipping over $50</span>
      </div>
      <div class="pch-trust-bar__divider" aria-hidden="true"></div>
      <div class="pch-trust-bar__item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
        <span>30-day satisfaction guarantee</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* ═══════════════════════════════════════════════════════════════
     PRIME COLLECTION HERO
  ════════════════════════════════════════════════════════════════ */
  .pch-hero {
    --pch-ink: #171512;
    --pch-cream: #fffaf2;
    --pch-clay: #b85f32;
    --pch-clay-dark: #94451f;
    --pch-muted: #5f574e;
    --pch-line: rgba(55, 43, 31, 0.13);
    font-family: var(--prime-font-sans, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif);
  }

  .pch-hero * { box-sizing: border-box; }

  .pch-shell {
    width: min(1160px, calc(100% - 32px));
    margin: 0 auto;
  }

  /* ═══════════════════════════════════════════════════════════════
     HERO LAYOUT
  ════════════════════════════════════════════════════════════════ */
  .pch-hero__inner {
    position: relative;
    min-height: 0;
    display: grid;
    overflow: hidden;
    isolation: isolate;
    background:
      linear-gradient(135deg, rgba(184, 95, 50, 0.08), rgba(255, 250, 242, 0) 48%),
      var(--pch-cream);
    border-bottom: 1px solid var(--pch-line);
  }

  .pch-hero__content {
    padding: 42px 0 34px;
    display: block;
  }

  /* ═══════════════════════════════════════════════════════════════
     HERO TEXT
  ════════════════════════════════════════════════════════════════ */
  .pch-kicker {
    margin: 0 0 10px;
    color: var(--pch-clay);
    font-size: 11px;
    font-weight: 780;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .pch-hero__text h1 {
    margin: 0;
    color: var(--pch-ink);
    font-family: var(--prime-font-display, var(--prime-font-sans, inherit));
    font-size: clamp(32px, 4.2vw, 52px);
    font-weight: 760;
    line-height: 1.04;
    letter-spacing: 0;
    max-width: 760px;
  }

  .pch-hero__sub {
    margin: 14px 0 0;
    color: var(--pch-muted);
    font-size: 16px;
    line-height: 1.6;
    max-width: 660px;
  }

  .pch-hero__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .pch-hero__pills span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 13px;
    border-radius: 999px;
    border: 1px solid rgba(55, 43, 31, 0.12);
    background: #ffffff;
    color: var(--pch-ink);
    font-size: 12px;
    font-weight: 600;
    line-height: 1;
  }

  .pch-hero__pills svg {
    flex-shrink: 0;
    opacity: 0.85;
  }

  /* ═══════════════════════════════════════════════════════════════
     TRUST BAR
  ════════════════════════════════════════════════════════════════ */
  .pch-trust-bar {
    background: #fff;
    border-bottom: 1px solid var(--pch-line);
    padding: 10px 0;
  }

  .pch-trust-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
  }

  .pch-trust-bar__item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    color: var(--pch-ink);
    font-size: 13px;
    font-weight: 600;
  }

  .pch-trust-bar__item svg {
    color: var(--pch-clay);
    flex-shrink: 0;
  }

  .pch-trust-bar__divider {
    width: 1px;
    height: 20px;
    background: var(--pch-line);
    flex-shrink: 0;
  }

  /* ═══════════════════════════════════════════════════════════════
     RESPONSIVE — Tablet
  ════════════════════════════════════════════════════════════════ */
  @media (max-width: 860px) {
    .pch-trust-bar__divider {
      display: none;
    }

    .pch-trust-bar__inner {
      justify-content: flex-start;
      gap: 4px;
    }

    .pch-trust-bar__item {
      padding: 6px 12px;
      font-size: 12px;
    }
  }

  /* ═══════════════════════════════════════════════════════════════
     RESPONSIVE — Mobile
  ════════════════════════════════════════════════════════════════ */
  @media (max-width: 560px) {
    .pch-shell {
      width: calc(100% - 24px);
    }

    .pch-hero__content {
      padding: 32px 0 26px;
    }

    .pch-hero__text h1 {
      font-size: 31px;
    }

    .pch-hero__sub {
      font-size: 15px;
    }

    .pch-trust-bar__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }

    .pch-trust-bar__item {
      padding: 4px 0;
    }
  }
</style>

{% schema %}
{
  "name": "Prime collection hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Premium Himalayan yak chews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (leave blank to use collection title)",
      "info": "Defaults to collection title if empty"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading (leave blank to use collection description)",
      "info": "Defaults to collection description if empty"
    }
  ],
  "presets": [
    {
      "name": "Prime collection hero"
    }
  ]
}
{% endschema %}
