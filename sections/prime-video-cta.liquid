<div class="prime-video-cta">
  <div class="prime-video-cta__inner page-width">
    <div class="prime-video-cta__copy">
      <p class="prime-video-cta__kicker">{{ section.settings.kicker | default: 'Real dogs. Real chew time.' }}</p>
      <h2>{{ section.settings.heading | default: 'Ready to give your dog a better chew?' }}</h2>
      <p>{{ section.settings.subtext | default: 'Choose the 4-ingredient Himalayan yak chew built for longer calm-time enrichment.' }}</p>
    </div>
    <div class="prime-video-cta__conversion">
      <div class="prime-video-cta__actions">
        <a href="{{ section.settings.cta_link | default: '/products/himalayan-yak-chews-for-dogs' }}" class="prime-video-cta__btn prime-video-cta__btn--primary">
          {{ section.settings.cta_text | default: 'Buy Yak Chews' }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        {% if section.settings.secondary_text != blank %}
          <a href="{{ section.settings.secondary_link | default: '/collections/all' }}" class="prime-video-cta__btn prime-video-cta__btn--secondary">
            {{ section.settings.secondary_text }}
          </a>
        {% endif %}
      </div>
      <div class="prime-video-cta__trust" aria-label="Purchase confidence">
        <span>Rawhide-free</span>
        <span>30-day guarantee</span>
        <span>Free shipping $30+</span>
      </div>
    </div>
  </div>
</div>

<style>
  .prime-video-cta {
    background: #fffaf2;
    border-bottom: 1px solid #eadfce;
    border-top: 1px solid #eadfce;
    color: #24130d;
    padding: clamp(28px, 4vw, 46px) 0;
    font-family: var(--prime-font-sans, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif);
  }

  .prime-video-cta * { box-sizing: border-box; }

  .prime-video-cta__inner {
    align-items: center;
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .prime-video-cta__copy {
    max-width: 640px;
  }

  .prime-video-cta__kicker {
    color: #b85f32;
    font-size: 12px;
    font-weight: 850;
    letter-spacing: 0.1em;
    margin: 0 0 8px;
    text-transform: uppercase;
  }

  .prime-video-cta h2 {
    color: #24130d;
    font-size: clamp(24px, 3vw, 34px);
    font-weight: 820;
    letter-spacing: 0;
    line-height: 1.12;
    margin: 0 0 10px;
  }

  .prime-video-cta p {
    color: #6f5a50;
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
  }

  .prime-video-cta__conversion {
    align-items: flex-end;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .prime-video-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: flex-end;
  }

  .prime-video-cta__btn {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    font-size: 13px;
    font-weight: 850;
    gap: 8px;
    justify-content: center;
    letter-spacing: 0.04em;
    min-height: 52px;
    padding: 15px 28px;
    text-decoration: none;
    text-transform: uppercase;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    white-space: nowrap;
  }

  .prime-video-cta__btn:hover {
    box-shadow: 0 10px 24px rgba(184, 95, 50, 0.2);
    transform: translateY(-1px);
  }

  .prime-video-cta__btn--primary {
    background: #b85f32;
    color: #fff;
  }

  .prime-video-cta__btn--primary:hover {
    background: #94451f;
  }

  .prime-video-cta__btn--secondary {
    background: #fff;
    border: 1px solid #eadfce;
    color: #4d3124;
  }

  .prime-video-cta__btn--secondary:hover {
    background: #f6f1e9;
  }

  .prime-video-cta__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .prime-video-cta__trust span {
    display: inline-flex;
    align-items: center;
    background: #f6f1e9;
    border: 1px solid #eadfce;
    border-radius: 999px;
    color: #6f5a50;
    font-size: 12px;
    font-weight: 750;
    padding: 7px 11px;
  }

  @media (max-width: 860px) {
    .prime-video-cta__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .prime-video-cta__copy {
      margin: 0 auto;
    }

    .prime-video-cta__conversion {
      align-items: center;
    }

    .prime-video-cta__actions {
      justify-content: center;
    }

    .prime-video-cta__trust {
      justify-content: center;
    }
  }

  @media (max-width: 560px) {
    .prime-video-cta {
      padding-bottom: 34px;
    }

    .prime-video-cta__btn {
      width: 100%;
    }

    .prime-video-cta__actions {
      align-items: stretch;
      flex-direction: column;
      width: 100%;
    }

    .prime-video-cta__conversion {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Prime Video CTA",
  "tag": "section",
  "class": "section-prime-video-cta",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker text",
      "default": "Real dogs. Real chew time."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to give your dog a better chew?"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Choose the 4-ingredient Himalayan yak chew built for longer calm-time enrichment."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Primary button text",
      "default": "Buy Yak Chews"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary button text",
      "default": "View all chews"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Prime Video CTA"
    }
  ]
}
{% endschema %}
