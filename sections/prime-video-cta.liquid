<div class="prime-video-cta">
  <div class="prime-video-cta__inner page-width">
    <p class="prime-video-cta__kicker">{{ section.settings.kicker | default: 'Ready to try it?' }}</p>
    <h2>{{ section.settings.heading | default: 'Give your dog the chew they deserve.' }}</h2>
    <p>{{ section.settings.subtext | default: 'Join 20,000+ dog parents who switched to safer, longer-lasting enrichment. Free shipping over $30.' }}</p>
    <div class="prime-video-cta__actions">
      <a href="{{ section.settings.cta_link | default: '/products/himalayan-yak-chews-for-dogs' }}" class="prime-video-cta__btn prime-video-cta__btn--primary">
        {{ section.settings.cta_text | default: 'Buy Yak Chews' }}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <a href="{{ section.settings.secondary_link | default: '/collections/all' }}" class="prime-video-cta__btn prime-video-cta__btn--secondary">
        {{ section.settings.secondary_text | default: 'View all chews' }}
      </a>
    </div>
    <div class="prime-video-cta__trust">
      <span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Rawhide-free
      </span>
      <span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        30-day guarantee
      </span>
      <span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Free shipping $30+
      </span>
      <span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        67 min avg chew time
      </span>
    </div>
  </div>
</div>

<style>
  .prime-video-cta {
    background: #1e1a15;
    padding: clamp(52px, 7vw, 80px) 0;
    text-align: center;
    font-family: var(--prime-font-sans, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif);
  }

  .prime-video-cta * { box-sizing: border-box; }

  .prime-video-cta__inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .prime-video-cta__kicker {
    margin: 0 0 12px;
    color: #f4c27d;
    font-size: 12px;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .prime-video-cta h2 {
    margin: 0 0 16px;
    color: #fffaf2;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 760;
    line-height: 1.06;
    letter-spacing: -0.02em;
  }

  .prime-video-cta p {
    margin: 0 auto 32px;
    max-width: 560px;
    color: rgba(255, 250, 242, 0.72);
    font-size: 17px;
    line-height: 1.65;
  }

  .prime-video-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-bottom: 28px;
  }

  .prime-video-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 52px;
    padding: 15px 28px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 780;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }

  .prime-video-cta__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.25);
  }

  .prime-video-cta__btn--primary {
    background: #b85f32;
    color: #fff;
  }

  .prime-video-cta__btn--primary:hover {
    background: #94451f;
  }

  .prime-video-cta__btn--secondary {
    background: rgba(255, 250, 242, 0.1);
    border: 1px solid rgba(255, 250, 242, 0.28);
    color: rgba(255, 250, 242, 0.9);
  }

  .prime-video-cta__btn--secondary:hover {
    background: rgba(255, 250, 242, 0.16);
  }

  .prime-video-cta__trust {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }

  .prime-video-cta__trust span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid rgba(255, 250, 242, 0.18);
    background: rgba(255, 250, 242, 0.07);
    color: rgba(255, 250, 242, 0.8);
    font-size: 13px;
    font-weight: 650;
  }

  .prime-video-cta__trust svg {
    flex-shrink: 0;
    opacity: 0.75;
  }

  @media (max-width: 560px) {
    .prime-video-cta__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .prime-video-cta__btn {
      width: 100%;
      justify-content: center;
    }

    .prime-video-cta__trust span {
      font-size: 12px;
      padding: 7px 12px;
    }
  }
</style>

{% schema %}
{
  "name": "Prime Video CTA",
  "tag": "section",
  "class": "section-prime-video-cta",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker text",
      "default": "Ready to try it?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Give your dog the chew they deserve."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Join 20,000+ dog parents who switched to safer, longer-lasting enrichment. Free shipping over $30."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Primary button text",
      "default": "Buy Yak Chews"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary button text",
      "default": "View all chews"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Prime Video CTA"
    }
  ]
}
{% endschema %}
