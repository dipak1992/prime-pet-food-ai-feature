}
.w-step h4 { font-size: 16px; font-weight: 700; color: #f6f1e9; margin: 0 0 10px; }
.w-step p { font-size: 13px; color: rgba(246,241,233,.38); line-height: 1.65; margin: 0; }

/* TESTIMONIALS */
.w-testi { background: #fff; border-top: 1px solid #e4dfd6; border-bottom: 1px solid #e4dfd6; }
.w-testi__grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; margin-top: 52px; }
.w-tcard { background: #f6f1e9; border: 1.5px solid #e4dfd6; border-radius: 18px; padding: 32px; transition: transform .28s ease, box-shadow .28s ease; }
.w-tcard:hover { transform: translateY(-3px); box-shadow: 0 14px 44px rgba(15,61,46,.08); }
.w-tcard__stars { color: #da803b; font-size: 13px; letter-spacing: 2px; margin-bottom: 14px; }
.w-tcard blockquote { font-size: 15px; font-style: italic; line-height: 1.72; color: #3a3a3a; margin: 0 0 22px; }
.w-tcard blockquote::before { content: '\201C'; }
.w-tcard blockquote::after  { content: '\201D'; }
.w-tcard__author { display: flex; align-items: center; gap: 12px; }
.w-tcard__av { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, #0f3d2e, #da803b); display: flex; align-items: center; justify-content: center; font-size: 15px; font-weight: 700; color: #fff; flex-shrink: 0; }
.w-tcard__name { font-size: 13px; font-weight: 700; color: #111; }
.w-tcard__role { font-size: 12px; color: #999; margin-top: 1px; }

/* FAQ */
.w-faq { background: #f6f1e9; }
.w-faq__grid { display: grid; grid-template-columns: 1fr 1.6fr; gap: 80px; align-items: start; }
.w-faq__left { position: sticky; top: 120px; }
.w-faq__right { display: flex; flex-direction: column; }
.w-faq__item { border-bottom: 1.5px solid #e4dfd6; overflow: hidden; }
.w-faq__q { display: flex; justify-content: space-between; align-items: center; width: 100%; padding: 20px 0; background: none; border: none; cursor: pointer; font-size: 15px; font-weight: 600; color: #1f3d33; text-align: left; gap: 16px; transition: color .22s; }
.w-faq__q:hover { color: #da803b; }
.w-faq__tog { width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid #d0ccc6; display: flex; align-items: center; justify-content: center; font-size: 18px; color: #999; flex-shrink: 0; line-height: 1; transition: all .26s ease; }
.w-faq__item.is-open .w-faq__tog { background: #0f3d2e; border-color: #0f3d2e; color: #f6f1e9; transform: rotate(45deg); }
.w-faq__ans { max-height: 0; overflow: hidden; transition: max-height .36s ease, padding-bottom .36s ease; }
.w-faq__item.is-open .w-faq__ans { max-height: 220px; padding-bottom: 20px; }
.w-faq__ans p { font-size: 14px; line-height: 1.72; color: #767676; margin: 0; }

/* APPLICATION FORM */
.w-apply { position: relative; background: #0f3d2e; padding: 100px 60px; overflow: hidden; }
.w-apply__noise { position: absolute; inset: 0; opacity: .03; pointer-events: none; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); background-size: 200px 200px; }
.w-apply::before { content: ''; position: absolute; top: -30%; right: -5%; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(218,128,59,.1) 0%, transparent 65%); pointer-events: none; }
.w-apply__inner { position: relative; z-index: 2; max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.3fr; gap: 80px; align-items: start; }
.w-perks { list-style: none; padding: 0; margin: 36px 0 0; display: flex; flex-direction: column; gap: 16px; }
.w-perk { display: flex; align-items: center; gap: 14px; }
.w-perk__chk { width: 22px; height: 22px; border-radius: 50%; background: rgba(218,128,59,.14); border: 1px solid rgba(218,128,59,.28); display: flex; align-items: center; justify-content: center; color: #da803b; font-size: 11px; font-weight: 700; flex-shrink: 0; }
.w-perk span:last-child { font-size: 14px; color: rgba(246,241,233,.58); line-height: 1.5; }
.w-apply__contact { display: flex; gap: 12px; margin-top: 40px; flex-wrap: wrap; }
.w-contact-pill { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 600; color: #da803b; text-decoration: none; border: 1.5px solid rgba(218,128,59,.28); border-radius: 999px; padding: 10px 20px; transition: all .25s ease; }
.w-contact-pill:hover { background: rgba(218,128,59,.1); border-color: #da803b; }

/* FORM */
.w-form { background: rgba(246,241,233,.05); border: 1px solid rgba(246,241,233,.08); border-radius: 20px; padding: 40px 36px; }
.w-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
.w-form__row--full { grid-template-columns: 1fr; }
.w-form__g { display: flex; flex-direction: column; gap: 7px; }
.w-form__g label { font-size: 10px; letter-spacing: 1.8px; text-transform: uppercase; font-weight: 700; color: rgba(246,241,233,.38); }
.w-form__g label em { font-style: normal; color: #da803b; }
.w-form__g input,
.w-form__g select,
.w-form__g textarea { font-size: 14px; color: #f6f1e9; background: rgba(246,241,233,.06); border: 1.5px solid rgba(246,241,233,.1); border-radius: 10px; padding: 13px 16px; outline: none; transition: border-color .22s, background .22s; font-family: inherit; }
.w-form__g input::placeholder,
.w-form__g textarea::placeholder { color: rgba(246,241,233,.22); }
.w-form__g input:focus,
.w-form__g select:focus,
.w-form__g textarea:focus { border-color: #da803b; background: rgba(218,128,59,.06); }
.w-form__g select { appearance: none; -webkit-appearance: none; background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%23da803b' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E"); background-repeat: no-repeat; background-position: right 14px center; padding-right: 38px; cursor: pointer; }
.w-form__g select option { background: #0f3d2e; color: #f6f1e9; }
.w-form__g textarea { resize: vertical; min-height: 96px; }
.w-form__submit { margin-top: 22px; width: 100%; background: #da803b; color: #fff; padding: 18px 32px; border-radius: 12px; font-size: 13px; font-weight: 800; letter-spacing: 1.2px; text-transform: uppercase; border: none; cursor: pointer; transition: all .28s ease; display: flex; align-items: center; justify-content: center; gap: 10px; font-family: inherit; }
.w-form__submit:hover { background: #e8914f; transform: translateY(-2px); box-shadow: 0 10px 32px rgba(218,128,59,.35); }
.w-form__note { text-align: center; font-size: 11px; color: rgba(246,241,233,.25); margin-top: 14px; }
.w-form__errors { background: rgba(200,0,0,.1); border: 1px solid rgba(200,0,0,.22); border-radius: 10px; padding: 14px 18px; margin-bottom: 18px; font-size: 13px; color: #ff9999; }

/* SUCCESS */
.w-success { background: rgba(246,241,233,.05); border: 1px solid rgba(246,241,233,.08); border-radius: 20px; padding: 60px 36px; text-align: center; }
.w-success__icon { width: 64px; height: 64px; border-radius: 50%; background: rgba(15,61,46,.4); border: 2px solid rgba(218,128,59,.4); display: flex; align-items: center; justify-content: center; font-size: 26px; color: #da803b; margin: 0 auto 20px; }
.w-success h3 { font-size: 22px; font-weight: 700; color: #f6f1e9; margin: 0 0 12px; }
.w-success p { font-size: 14px; color: rgba(246,241,233,.5); line-height: 1.7; margin: 0; }
.w-success strong { color: #da803b; }

/* FADE ANIMATIONS */
.w-fade { opacity: 0; transform: translateY(24px); transition: opacity .6s ease, transform .6s ease; }
.w-fade.w-vis { opacity: 1; transform: translateY(0); }
.w-s1 { transition-delay: .06s; } .w-s2 { transition-delay: .12s; }
.w-s3 { transition-delay: .18s; } .w-s4 { transition-delay: .24s; }
.w-s5 { transition-delay: .30s; } .w-s6 { transition-delay: .34s; }

/* RESPONSIVE */
@media (max-width: 1080px) {
  .w-hero__inner { grid-template-columns: 1fr; gap: 48px; padding: 80px 36px; }
  .w-hero__right { order: -1; }
  .w-trust__inner { padding: 0 36px; }
  .w-section { padding: 72px 36px; }
  .w-how { padding: 72px 36px; }
  .w-apply { padding: 72px 36px; }
  .w-why__grid { grid-template-columns: repeat(2,1fr); }
  .w-steps { grid-template-columns: repeat(2,1fr); }
  .w-steps::before { display: none; }
  .w-testi__grid { grid-template-columns: repeat(2,1fr); }
  .w-faq__grid { grid-template-columns: 1fr; gap: 44px; }
  .w-faq__left { position: static; }
  .w-apply__inner { grid-template-columns: 1fr; gap: 52px; }
}
@media (max-width: 767px) {
  .w-hero__inner { padding: 64px 20px 80px; }
  .w-hero__h1 { font-size: 28px; }
  .w-hero__stats { gap: 20px; }
  .w-stat__n { font-size: 26px; }
  .w-hero__actions { flex-direction: column; }
  .w-btn { justify-content: center; text-align: center; }
  .w-trust__inner { grid-template-columns: repeat(3,1fr); padding: 0 20px; }
  .w-trust__item:nth-child(4), .w-trust__item:nth-child(5) { display: none; }
  .w-section { padding: 60px 20px; }
  .w-how { padding: 60px 20px; }
  .w-apply { padding: 60px 20px; }
  .w-why__grid { grid-template-columns: 1fr; }
  .w-steps { grid-template-columns: 1fr; }
  .w-testi__grid { grid-template-columns: 1fr; }
  .w-form__row { grid-template-columns: 1fr; }
  .w-form { padding: 28px 20px; }
  .w-apply__contact { flex-direction: column; }
  .w-contact-pill { justify-content: center; }
}
</style>

<script>
(function(){
  document.querySelectorAll('.w-faq__q').forEach(function(btn){
    btn.addEventListener('click',function(){
      var item=this.closest('.w-faq__item'), open=item.classList.contains('is-open');
      document.querySelectorAll('.w-faq__item').forEach(function(i){ i.classList.remove('is-open'); });
      if(!open) item.classList.add('is-open');
    });
  });
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('w-vis'); io.unobserve(e.target); } });
  },{threshold:.07,rootMargin:'0px 0px -30px 0px'});
  document.querySelectorAll('.w-fade').forEach(function(el){ io.observe(el); });
})();
</script>

