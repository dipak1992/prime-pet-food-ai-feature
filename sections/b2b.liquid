{% comment %}
  B2B Wholesale — Prime Pet Food
  Colors: #0f3d2e green · #da803b orange · #f6f1e9 cream · #1f3d33 dark
  Sections: Hero · Trust Bar · Why Partner · How It Works · Testimonials · FAQ · Application Form
{% endcomment %}

<!-- ═══ HERO ═══ -->
<section class="w-hero">
  <div class="w-hero__noise"></div>
  <div class="w-hero__inner">
    <div class="w-hero__left">
      <div class="w-hero__badge">
        <span class="w-badge__dot"></span>
        {{ section.settings.hero_badge }}
      </div>
      <h1 class="w-hero__h1">{{ section.settings.hero_headline }}</h1>
      <p class="w-hero__sub">{{ section.settings.hero_subtext }}</p>
      <div class="w-hero__stats">
        <div class="w-stat">
          <span class="w-stat__n">{{ section.settings.stat_1_num }}</span>
          <span class="w-stat__l">{{ section.settings.stat_1_label }}</span>
        </div>
        <div class="w-stat__div"></div>
        <div class="w-stat">
          <span class="w-stat__n">{{ section.settings.stat_2_num }}</span>
          <span class="w-stat__l">{{ section.settings.stat_2_label }}</span>
        </div>
        <div class="w-stat__div"></div>
        <div class="w-stat">
          <span class="w-stat__n">{{ section.settings.stat_3_num }}</span>
          <span class="w-stat__l">{{ section.settings.stat_3_label }}</span>
        </div>
      </div>
      <div class="w-hero__actions">
        <a href="#w-apply" class="w-btn w-btn--orange">{{ section.settings.hero_cta_primary }}</a>
        <a href="#w-why" class="w-btn w-btn--outline">{{ section.settings.hero_cta_secondary }}</a>
      </div>
    </div>
    <div class="w-hero__right">
      <div class="w-card">
        <div class="w-card__head">
          <div class="w-card__title">Wholesale Benefits</div>
          <div class="w-card__sub">Everything you get as a partner</div>
        </div>
        {% for i in (1..5) %}
          {%- assign ti = 'benefit_' | append: i | append: '_icon' -%}
          {%- assign tt = 'benefit_' | append: i | append: '_title' -%}
          {%- assign tb = 'benefit_' | append: i | append: '_text' -%}
          {%- if section.settings[tt] != blank -%}
            <div class="w-benefit">
              <div class="w-benefit__icon">{{ section.settings[ti] }}</div>
              <div class="w-benefit__body">
                <strong>{{ section.settings[tt] }}</strong>
                <span>{{ section.settings[tb] }}</span>
              </div>
            </div>
          {%- endif -%}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<!-- ═══ TRUST BAR ═══ -->
<div class="w-trust">
  <div class="w-trust__inner">
    {% for i in (1..5) %}
      {%- assign ti = 'trust_icon_' | append: i -%}
      {%- assign tl = 'trust_label_' | append: i -%}
      {%- if section.settings[tl] != blank -%}
        <div class="w-trust__item">
          <span class="w-trust__icon">{{ section.settings[ti] }}</span>
          <span class="w-trust__label">{{ section.settings[tl] }}</span>
        </div>
      {%- endif -%}
    {% endfor %}
  </div>
</div>

<!-- ═══ WHY PARTNER ═══ -->
<section class="w-section w-why" id="w-why">
  <div class="w-section__inner">
    <div class="w-section__head">
      <div class="w-eyebrow w-fade">Why Partner With Us</div>
      <h2 class="w-section__title w-fade">{{ section.settings.why_title }}</h2>
      <p class="w-section__sub w-fade">{{ section.settings.why_subtitle }}</p>
    </div>
    <div class="w-why__grid">
      {% for i in (1..6) %}
        {%- assign wi = 'why_icon_' | append: i -%}
        {%- assign wt = 'why_title_' | append: i -%}
        {%- assign wp = 'why_text_' | append: i -%}
        {%- if section.settings[wt] != blank -%}
          <div class="w-why__card w-fade w-s{{ i }}">
            <div class="w-why__num">0{{ i }}</div>
            <div class="w-why__icon">{{ section.settings[wi] }}</div>
            <h3>{{ section.settings[wt] }}</h3>
            <p>{{ section.settings[wp] }}</p>
          </div>
        {%- endif -%}
      {% endfor %}
    </div>
  </div>
</section>

<!-- ═══ HOW IT WORKS ═══ -->
<section class="w-how" id="w-how">
  <div class="w-how__inner">
    <div class="w-section__head w-section__head--center">
      <div class="w-eyebrow w-eyebrow--light w-fade">The Process</div>
      <h2 class="w-section__title w-section__title--light w-fade">{{ section.settings.how_title }}</h2>
      <p class="w-section__sub w-section__sub--light w-fade">{{ section.settings.how_subtitle }}</p>
    </div>
    <div class="w-steps">
      {% for i in (1..4) %}
        {%- assign sh = 'step_' | append: i | append: '_title' -%}
        {%- assign sp = 'step_' | append: i | append: '_text' -%}
        {%- if section.settings[sh] != blank -%}
          <div class="w-step w-fade w-s{{ i }}">
            <div class="w-step__n">{{ i }}</div>
            <h4>{{ section.settings[sh] }}</h4>
            <p>{{ section.settings[sp] }}</p>
          </div>
        {%- endif -%}
      {% endfor %}
    </div>
  </div>
</section>

<!-- ═══ TESTIMONIALS ═══ -->
<section class="w-section w-testi">
  <div class="w-section__inner">
    <div class="w-section__head">
      <div class="w-eyebrow w-fade">What Partners Say</div>
      <h2 class="w-section__title w-fade">{{ section.settings.testimonials_title }}</h2>
    </div>
    <div class="w-testi__grid">
      {% for i in (1..3) %}
        {%- assign tq = 'testimonial_' | append: i | append: '_quote' -%}
        {%- assign tn = 'testimonial_' | append: i | append: '_name' -%}
        {%- assign tr = 'testimonial_' | append: i | append: '_role' -%}
        {%- if section.settings[tq] != blank -%}
          <div class="w-tcard w-fade w-s{{ i }}">
            <div class="w-tcard__stars">★★★★★</div>
            <blockquote>{{ section.settings[tq] }}</blockquote>
            <div class="w-tcard__author">
              <div class="w-tcard__av">{{ section.settings[tn] | slice: 0 }}</div>
              <div>
                <div class="w-tcard__name">{{ section.settings[tn] }}</div>
                <div class="w-tcard__role">{{ section.settings[tr] }}</div>
              </div>
            </div>
          </div>
        {%- endif -%}
      {% endfor %}
    </div>
  </div>
</section>

<!-- ═══ FAQ ═══ -->
<section class="w-section w-faq" id="w-faq">
  <div class="w-section__inner">
    <div class="w-faq__grid">
      <div class="w-faq__left">
        <div class="w-eyebrow w-fade">Common Questions</div>
        <h2 class="w-section__title w-fade">{{ section.settings.faq_title }}</h2>
        <p class="w-section__sub w-fade">Everything you need to know before applying.</p>
        <a href="#w-apply" class="w-btn w-btn--green w-fade" style="margin-top:32px; display:inline-flex;">Apply Now →</a>
      </div>
      <div class="w-faq__right">
        {% for i in (1..8) %}
          {%- assign fq = 'faq_q_' | append: i -%}
          {%- assign fa = 'faq_a_' | append: i -%}
          {%- if section.settings[fq] != blank -%}
            <div class="w-faq__item">
              <button class="w-faq__q" type="button">
                <span>{{ section.settings[fq] }}</span>
                <span class="w-faq__tog" aria-hidden="true">+</span>
              </button>
              <div class="w-faq__ans"><p>{{ section.settings[fa] }}</p></div>
            </div>
          {%- endif -%}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<!-- ═══ APPLICATION FORM ═══ -->
<section class="w-apply" id="w-apply">
  <div class="w-apply__noise"></div>
  <div class="w-apply__inner">
    <div class="w-apply__left">
      <div class="w-eyebrow w-eyebrow--light w-fade">Wholesale Application</div>
      <h2 class="w-section__title w-section__title--light w-fade">{{ section.settings.form_title }}</h2>
      <p class="w-section__sub w-section__sub--light w-fade">{{ section.settings.form_subtitle }}</p>
      <ul class="w-perks">
        {% for i in (1..4) %}
          {%- assign pk = 'perk_' | append: i -%}
          {%- if section.settings[pk] != blank -%}
            <li class="w-perk w-fade w-s{{ i }}">
              <span class="w-perk__chk">✓</span>
              <span>{{ section.settings[pk] }}</span>
            </li>
          {%- endif -%}
        {% endfor %}
      </ul>
      <div class="w-apply__contact">
        <a href="tel:{{ section.settings.phone }}" class="w-contact-pill">📞 {{ section.settings.phone }}</a>
        <a href="https://wa.me/{{ section.settings.whatsapp }}" class="w-contact-pill" target="_blank" rel="noopener">💬 WhatsApp</a>
      </div>
    </div>
    <div class="w-apply__right">
      {%- if form.posted_successfully? -%}
        <div class="w-success">
          <div class="w-success__icon">✓</div>
          <h3>Application Received!</h3>
          <p>Our wholesale team will review your application and reach out within 24 hours with custom pricing. Call us at <strong>{{ section.settings.phone }}</strong> in the meantime.</p>
        </div>
      {%- else -%}
        {% form 'contact', id: 'w-form' %}
          {%- if form.errors -%}
            <div class="w-form__errors">{{ form.errors | default_errors }}</div>
          {%- endif -%}
          <div class="w-form">
            <div class="w-form__row">
              <div class="w-form__g">
                <label for="wf-fn">First Name <em>*</em></label>
                <input id="wf-fn" type="text" name="contact[first_name]" placeholder="John" required autocomplete="given-name">
              </div>
              <div class="w-form__g">
                <label for="wf-ln">Last Name <em>*</em></label>
                <input id="wf-ln" type="text" name="contact[last_name]" placeholder="Smith" required autocomplete="family-name">
              </div>
            </div>
            <div class="w-form__row">
              <div class="w-form__g">
                <label for="wf-em">Email Address <em>*</em></label>
                <input id="wf-em" type="email" name="contact[email]" placeholder="john@business.com" required autocomplete="email" value="{{ form.email }}">
              </div>
              <div class="w-form__g">
                <label for="wf-ph">Phone Number <em>*</em></label>
                <input id="wf-ph" type="tel" name="contact[phone]" placeholder="+1 (555) 000-0000" required autocomplete="tel">
              </div>
            </div>
            <div class="w-form__row w-form__row--full">
              <div class="w-form__g">
                <label for="wf-biz">Business / Store Name <em>*</em></label>
                <input id="wf-biz" type="text" name="contact[business_name]" placeholder="Your Business Name" required>
              </div>
            </div>
            <div class="w-form__row">
              <div class="w-form__g">
                <label for="wf-bt">Business Type <em>*</em></label>
                <select id="wf-bt" name="contact[business_type]" required>
                  <option value="" disabled selected>Select type…</option>
                  <option>Pet Store / Boutique</option>
                  <option>Online Retailer</option>
                  <option>Veterinary Clinic</option>
                  <option>Dog Grooming / Daycare</option>
                  <option>Distributor</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="w-form__g">
                <label for="wf-vol">Est. Monthly Volume</label>
                <select id="wf-vol" name="contact[monthly_volume]">
                  <option value="" disabled selected>Select volume…</option>
                  <option>1–5 Cases</option>
                  <option>5–15 Cases</option>
                  <option>15–50 Cases</option>
                  <option>50+ Cases</option>
                  <option>Not Sure Yet</option>
                </select>
              </div>
            </div>
            <div class="w-form__row">
              <div class="w-form__g">
                <label for="wf-web">Website</label>
                <input id="wf-web" type="url" name="contact[website]" placeholder="https://yourstore.com">
              </div>
              <div class="w-form__g">
                <label for="wf-reg">State / Region</label>
                <input id="wf-reg" type="text" name="contact[region]" placeholder="Florida">
              </div>
            </div>
            <div class="w-form__row w-form__row--full">
              <div class="w-form__g">
                <label for="wf-src">How Did You Hear About Us?</label>
                <select id="wf-src" name="contact[source]">
                  <option value="" disabled selected>Select…</option>
                  <option>Google Search</option>
                  <option>Social Media</option>
                  <option>Trade Show</option>
                  <option>Referral</option>
                  <option>Other</option>
                </select>
              </div>
            </div>
            <div class="w-form__row w-form__row--full">
              <div class="w-form__g">
                <label for="wf-notes">Additional Notes</label>
                <textarea id="wf-notes" name="contact[body]" rows="4" placeholder="Tell us about your business, which products interest you, or any questions you have…"></textarea>
              </div>
            </div>
            <button type="submit" class="w-form__submit">{{ section.settings.form_cta }}</button>
            <p class="w-form__note">We respond within 24 hours. Your information is kept confidential.</p>
          </div>
        {% endform %}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
.w-hero,.w-trust,.w-section,.w-how,.w-apply,
.w-hero *,.w-trust *,.w-section *,.w-how *,.w-apply * { box-sizing: border-box; }

/* HERO */
.w-hero {
  position: relative;
  background: #0f3d2e;
  min-height: 88vh;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.w-hero__noise {
  position: absolute; inset: 0; opacity: .032; pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 200px 200px;
}
.w-hero::before {
  content: ''; position: absolute; top: -40%; right: -8%;
  width: 680px; height: 680px; border-radius: 50%; pointer-events: none;
  background: radial-gradient(circle, rgba(218,128,59,.13) 0%, transparent 65%);
}
.w-hero::after {
  content: ''; position: absolute; bottom: -20%; left: -4%;
  width: 480px; height: 480px; border-radius: 50%; pointer-events: none;
  background: radial-gradient(circle, rgba(246,241,233,.04) 0%, transparent 65%);
}
.w-hero__inner {
  position: relative; z-index: 2; width: 100%;
  max-width: 1280px; margin: 0 auto; padding: 96px 60px;
  display: grid; grid-template-columns: 1.15fr .85fr;
  gap: 72px; align-items: center;
}
.w-hero__badge {
  display: inline-flex; align-items: center; gap: 10px;
  background: rgba(246,241,233,.07); border: 1px solid rgba(218,128,59,.32);
  padding: 8px 18px; border-radius: 999px;
  font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
  color: #da803b; font-weight: 600; margin-bottom: 28px;
}
.w-badge__dot {
  width: 7px; height: 7px; border-radius: 50%; background: #da803b;
  animation: wPulse 2.2s infinite;
}
@keyframes wPulse {
  0%,100% { opacity: 1; transform: scale(1); }
  50%      { opacity: .4; transform: scale(.85); }
}
.w-hero__h1 {
  font-size: clamp(34px, 4vw, 58px); font-weight: 700;
  color: #f6f1e9; line-height: 1.08; letter-spacing: -.5px; margin: 0 0 20px;
}
.w-hero__h1 em { font-style: normal; color: #da803b; }
.w-hero__sub {
  font-size: 16px; line-height: 1.75; color: rgba(246,241,233,.55);
  margin: 0 0 40px; max-width: 460px;
}
.w-hero__stats { display: flex; align-items: center; gap: 28px; margin-bottom: 44px; }
.w-stat { display: flex; flex-direction: column; gap: 4px; }
.w-stat__n { font-size: 34px; font-weight: 800; color: #f6f1e9; line-height: 1; letter-spacing: -1px; }
.w-stat__l { font-size: 11px; letter-spacing: 1.8px; text-transform: uppercase; color: rgba(246,241,233,.38); font-weight: 500; }
.w-stat__div { width: 1px; height: 36px; background: rgba(246,241,233,.12); }
.w-hero__actions { display: flex; gap: 14px; flex-wrap: wrap; }

/* BUTTONS */
.w-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 15px 32px; border-radius: 12px;
  font-size: 13px; font-weight: 700; letter-spacing: .8px;
  text-transform: uppercase; text-decoration: none; border: none; cursor: pointer;
  transition: all .28s ease;
}
.w-btn--orange { background: #da803b; color: #fff; }
.w-btn--orange:hover { background: #e8914f; transform: translateY(-2px); box-shadow: 0 10px 32px rgba(218,128,59,.35); }
.w-btn--outline { background: transparent; color: rgba(246,241,233,.75); border: 1.5px solid rgba(246,241,233,.2); }
.w-btn--outline:hover { border-color: #da803b; color: #da803b; }
.w-btn--green { background: #0f3d2e; color: #f6f1e9; }
.w-btn--green:hover { background: #174d3a; transform: translateY(-2px); }

/* HERO CARD */
.w-card {
  background: rgba(246,241,233,.06); border: 1px solid rgba(246,241,233,.1);
  border-radius: 20px; padding: 36px 32px;
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
}
.w-card__head { padding-bottom: 18px; border-bottom: 1px solid rgba(246,241,233,.08); margin-bottom: 4px; }
.w-card__title { font-size: 18px; font-weight: 700; color: #f6f1e9; margin-bottom: 3px; }
.w-card__sub { font-size: 12px; color: rgba(246,241,233,.38); }
.w-benefit { display: flex; align-items: flex-start; gap: 14px; padding: 14px 0; border-bottom: 1px solid rgba(246,241,233,.06); }
.w-benefit:last-child { border-bottom: none; }
.w-benefit__icon {
  width: 38px; height: 38px; border-radius: 10px;
  background: rgba(218,128,59,.12); border: 1px solid rgba(218,128,59,.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; flex-shrink: 0;
}
.w-benefit__body { display: flex; flex-direction: column; gap: 2px; padding-top: 1px; }
.w-benefit__body strong { font-size: 13px; font-weight: 700; color: #f6f1e9; }
.w-benefit__body span { font-size: 12px; color: rgba(246,241,233,.48); line-height: 1.45; }

/* TRUST BAR */
.w-trust { background: #f6f1e9; border-bottom: 1px solid #e4dfd6; }
.w-trust__inner { max-width: 1280px; margin: 0 auto; padding: 0 60px; display: grid; grid-template-columns: repeat(5,1fr); }
.w-trust__item { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 7px; padding: 26px 14px; border-right: 1px solid #e4dfd6; text-align: center; }
.w-trust__item:last-child { border-right: none; }
.w-trust__icon { font-size: 22px; }
.w-trust__label { font-size: 11px; letter-spacing: 1.4px; text-transform: uppercase; font-weight: 600; color: #555; line-height: 1.5; }

/* SHARED SECTION */
.w-section { padding: 96px 60px; }
.w-section__inner { max-width: 1280px; margin: 0 auto; }
.w-section__head { margin-bottom: 56px; max-width: 600px; }
.w-section__head--center { max-width: 680px; margin: 0 auto 60px; text-align: center; }
.w-eyebrow { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; font-weight: 700; color: #da803b; margin-bottom: 12px; }
.w-eyebrow--light { color: rgba(218,128,59,.85); }
.w-section__title { font-size: clamp(26px,3vw,40px); font-weight: 700; color: #1f3d33; line-height: 1.18; letter-spacing: -.3px; margin: 0 0 14px; }
.w-section__title--light { color: #f6f1e9; }
.w-section__sub { font-size: 15px; color: #767676; line-height: 1.75; margin: 0; }
.w-section__sub--light { color: rgba(246,241,233,.48); }

/* WHY PARTNER */
.w-why { background: #f6f1e9; }
.w-why__grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
.w-why__card {
  background: #fff; border: 1.5px solid #e4dfd6; border-radius: 18px;
  padding: 36px 28px 32px; position: relative; overflow: hidden;
  transition: transform .3s ease, box-shadow .3s ease, border-color .3s ease; cursor: default;
}
.w-why__card::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, #0f3d2e, #da803b);
  transform: scaleX(0); transform-origin: left; transition: transform .35s ease;
}
.w-why__card:hover { transform: translateY(-4px); box-shadow: 0 18px 56px rgba(15,61,46,.1); border-color: transparent; }
.w-why__card:hover::after { transform: scaleX(1); }
.w-why__num { position: absolute; top: 24px; right: 24px; font-size: 52px; font-weight: 800; color: rgba(15,61,46,.04); line-height: 1; letter-spacing: -2px; pointer-events: none; user-select: none; }
.w-why__icon { width: 52px; height: 52px; border-radius: 14px; background: #f6f1e9; border: 1px solid #e4dfd6; display: flex; align-items: center; justify-content: center; font-size: 22px; margin-bottom: 18px; }
.w-why__card h3 { font-size: 17px; font-weight: 700; color: #1f3d33; margin: 0 0 10px; letter-spacing: -.1px; }
.w-why__card p { font-size: 14px; line-height: 1.7; color: #767676; margin: 0; }

/* HOW IT WORKS */
.w-how { background: #1f3d33; padding: 96px 60px; position: relative; overflow: hidden; }
.w-how::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(218,128,59,.4), transparent); }
.w-how__inner { max-width: 1280px; margin: 0 auto; position: relative; z-index: 2; }
.w-steps { display: grid; grid-template-columns: repeat(4,1fr); position: relative; }
.w-steps::before {
  content: ''; position: absolute; top: 42px; left: 10%; right: 10%; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(218,128,59,.22), rgba(218,128,59,.22), rgba(218,128,59,.22), transparent);
  pointer-events: none;
}
.w-step { padding: 40px 24px; text-align: center; position: relative; }
.w-step__n {
  width: 52px; height: 52px; border-radius: 50%;
  border: 2px solid rgba(218,128,59,.5); background: rgba(218,128,59,.08);
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; font-weight: 800; color: #da803b;
