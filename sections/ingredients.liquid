{% comment %}
  Section: Just 4 Simple Ingredients
  File: sections/ingredients.liquid
  Dynamic: All text, colors, ingredients & nutrition editable from Shopify Theme Editor
{% endcomment %}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
  #shopify-section-{{ section.id }} {
    --ing-bg:              {{ section.settings.bg_color }};
    --ing-eyebrow:         {{ section.settings.eyebrow_color }};
    --ing-heading:         {{ section.settings.heading_color }};
    --ing-subtext:         {{ section.settings.subtext_color }};
    --ing-card-bg:         {{ section.settings.card_bg }};
    --ing-card-border:     {{ section.settings.card_border }};
    --ing-card-title:      {{ section.settings.card_title_color }};
    --ing-card-desc:       {{ section.settings.card_desc_color }};
    --ing-nut-value:       {{ section.settings.nutrition_value_color }};
    --ing-nut-label:       {{ section.settings.nutrition_label_color }};
    --ing-divider:         {{ section.settings.nutrition_divider_color }};
  }

  #shopify-section-{{ section.id }} .ing-section {
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    background: var(--ing-bg);
    overflow: hidden;
  }

  /* ── Title ── */
  #shopify-section-{{ section.id }} .ing-title-wrap {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
    padding: 0 20px;
  }
  #shopify-section-{{ section.id }} .ing-eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--ing-eyebrow);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  #shopify-section-{{ section.id }} .ing-eyebrow::before,
  #shopify-section-{{ section.id }} .ing-eyebrow::after {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--ing-eyebrow);
    display: inline-block;
    opacity: 0.5;
  }
  #shopify-section-{{ section.id }} .ing-heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    color: var(--ing-heading);
    line-height: 1.2;
    margin-bottom: 14px;
  }
  #shopify-section-{{ section.id }} .ing-subtext {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    line-height: 1.75;
    color: var(--ing-subtext);
    margin: 0;
  }

  /* ── Ingredient Cards ── */
  #shopify-section-{{ section.id }} .ing-grid {
    max-width: 760px;
    margin: 44px auto 0;
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
  }
  #shopify-section-{{ section.id }} .ing-card {
    text-align: center;
    flex: 1;
    min-width: 140px;
    max-width: 170px;
    padding: 28px 20px 24px;
    background: var(--ing-card-bg);
    border-radius: 20px;
    border: 1px solid var(--ing-card-border);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    opacity: 0;
    transform: translateY(20px);
    animation: ingFadeUp 0.5s ease forwards;
  }
  {% for block in section.blocks %}
    {% if block.type == 'ingredient' %}
      #shopify-section-{{ section.id }} .ing-card:nth-child({{ forloop.index }}) {
        animation-delay: {{ forloop.index0 | times: 0.1 }}s;
      }
    {% endif %}
  {% endfor %}
  @keyframes ingFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
  #shopify-section-{{ section.id }} .ing-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.18);
  }
  #shopify-section-{{ section.id }} .ing-emoji {
    font-size: 42px;
    margin-bottom: 14px;
    display: block;
    filter: drop-shadow(0 3px 8px rgba(0,0,0,0.15));
  }
  #shopify-section-{{ section.id }} .ing-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 17px;
    font-weight: 700;
    color: var(--ing-card-title);
    margin-bottom: 6px;
  }
  #shopify-section-{{ section.id }} .ing-card-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: var(--ing-card-desc);
    line-height: 1.55;
    margin: 0;
  }

  /* ── Nutrition Bar ── */
  #shopify-section-{{ section.id }} .ing-nutrition {
    max-width: 580px;
    margin: 44px auto 0;
    display: flex;
    gap: 0;
    justify-content: center;
    flex-wrap: wrap;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--ing-divider);
  }
  #shopify-section-{{ section.id }} .ing-nut-item {
    flex: 1;
    min-width: 100px;
    text-align: center;
    padding: 22px 16px;
    background: var(--ing-card-bg);
    border-right: 1px solid var(--ing-divider);
    transition: background 0.25s ease;
  }
  #shopify-section-{{ section.id }} .ing-nut-item:last-child {
    border-right: none;
  }
  #shopify-section-{{ section.id }} .ing-nut-item:hover {
    background: rgba(255,255,255,0.07);
  }
  #shopify-section-{{ section.id }} .ing-nut-value {
    font-family: 'Playfair Display', serif;
    font-size: 30px;
    font-weight: 700;
    color: var(--ing-nut-value);
    line-height: 1;
    margin-bottom: 6px;
  }
  #shopify-section-{{ section.id }} .ing-nut-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--ing-nut-label);
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    #shopify-section-{{ section.id }} .ing-grid {
      gap: 14px;
    }
    #shopify-section-{{ section.id }} .ing-card {
      min-width: 120px;
      padding: 20px 14px;
    }
    #shopify-section-{{ section.id }} .ing-nutrition {
      flex-wrap: wrap;
    }
    #shopify-section-{{ section.id }} .ing-nut-item {
      min-width: 45%;
      border-right: 1px solid var(--ing-divider);
      border-bottom: 1px solid var(--ing-divider);
    }
  }
</style>

<section class="ing-section">

  <!-- Title -->
  <div class="ing-title-wrap">
    {% if section.settings.eyebrow != blank %}
      <div class="ing-eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="ing-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subtext != blank %}
      <p class="ing-subtext">{{ section.settings.subtext }}</p>
    {% endif %}
  </div>

  <!-- Ingredient Cards -->
  {% assign ingredient_blocks = section.blocks | where: "type", "ingredient" %}
  {% if ingredient_blocks.size > 0 %}
    <div class="ing-grid">
      {% for block in ingredient_blocks %}
        <div class="ing-card" {{ block.shopify_attributes }}>
          {% if block.settings.emoji != blank %}
            <span class="ing-emoji">{{ block.settings.emoji }}</span>
          {% endif %}
          {% if block.settings.title != blank %}
            <div class="ing-card-title">{{ block.settings.title }}</div>
          {% endif %}
          {% if block.settings.description != blank %}
            <p class="ing-card-desc">{{ block.settings.description }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% endif %}

  <!-- Nutrition Bar -->
  {% assign nutrition_blocks = section.blocks | where: "type", "nutrition" %}
  {% if nutrition_blocks.size > 0 %}
    <div class="ing-nutrition">
      {% for block in nutrition_blocks %}
        <div class="ing-nut-item" {{ block.shopify_attributes }}>
          <div class="ing-nut-value">{{ block.settings.value }}</div>
          <div class="ing-nut-label">{{ block.settings.label }}</div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

</section>

{% schema %}
{
  "name": "Ingredients",
  "tag": "section",
  "class": "ingredients-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "Radical Transparency"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Just 4 Simple Ingredients"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Description",
      "default": "Nothing artificial. Nothing hidden. Just pure, wholesome nutrition for your dog."
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (px)",
      "min": 20,
      "max": 140,
      "step": 4,
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "min": 20,
      "max": 140,
      "step": 4,
      "default": 64
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1B3028"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#E8B85E"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#FAF5ED"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Description Color",
      "default": "#A89B8A"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#ffffff0d"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card Border Color",
      "default": "#ffffff14"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Ingredient Name Color",
      "default": "#FAF5ED"
    },
    {
      "type": "color",
      "id": "card_desc_color",
      "label": "Ingredient Description Color",
      "default": "#8B7D6B"
    },
    {
      "type": "color",
      "id": "nutrition_value_color",
      "label": "Nutrition % Value Color",
      "default": "#E8B85E"
    },
    {
      "type": "color",
      "id": "nutrition_label_color",
      "label": "Nutrition Label Color",
      "default": "#ffffff73"
    },
    {
      "type": "color",
      "id": "nutrition_divider_color",
      "label": "Nutrition Divider/Border Color",
      "default": "#ffffff14"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient Card",
      "settings": [
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji Icon",
          "default": "🥛",
          "info": "Paste any emoji, e.g. 🥛 🐄 🍋 🧂"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Ingredient Name",
          "default": "Yak Milk"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Short Description",
          "default": "Rich in protein & calcium"
        }
      ]
    },
    {
      "type": "nutrition",
      "name": "Nutrition Stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value (e.g. 52%)",
          "default": "52%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (e.g. Protein)",
          "default": "Protein"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredients",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "emoji": "🥛",
            "title": "Yak Milk",
            "description": "Rich in protein & calcium"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "emoji": "🐄",
            "title": "Cow Milk",
            "description": "For creamy texture"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "emoji": "🍋",
            "title": "Lime Juice",
            "description": "Natural preservative"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "emoji": "🧂",
            "title": "Salt",
            "description": "Just a pinch"
          }
        },
        {
          "type": "nutrition",
          "settings": {
            "value": "52%",
            "label": "Protein"
          }
        },
        {
          "type": "nutrition",
          "settings": {
            "value": "6%",
            "label": "Fat"
          }
        },
        {
          "type": "nutrition",
          "settings": {
            "value": "2%",
            "label": "Fiber"
          }
        },
        {
          "type": "nutrition",
          "settings": {
            "value": "10%",
            "label": "Moisture"
          }
        }
      ]
    }
  ]
}
{% endschema %}
