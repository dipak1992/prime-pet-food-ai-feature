{% liquid
  assign cta_link = section.settings.cta_link | default: '/pages/subscribe-and-save'
%}

<section class="prime-subscribe-strip" aria-labelledby="PrimeSubscribeStripTitle">
  <div class="pss-shell">
    <div class="pss-copy">
      <p class="pss-kicker">{{ section.settings.eyebrow }}</p>
      <h2 id="PrimeSubscribeStripTitle">{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>
    <div class="pss-actions">
      <span>{{ section.settings.offer }}</span>
      <a href="{{ cta_link }}" aria-label="{{ section.settings.cta_label }}">{{ section.settings.cta_label }}</a>
    </div>
  </div>
</section>

<style>
  .prime-subscribe-strip {
    background: #fffaf2;
    color: #21150f;
    font-family: var(--prime-font-sans, var(--font-body-family));
    padding: 24px 0 0;
  }

  .prime-subscribe-strip * {
    box-sizing: border-box;
  }

  .pss-shell {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 22px;
    padding: 22px;
    border: 1px solid rgba(210, 99, 46, 0.18);
    border-radius: 20px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(255, 247, 236, 0.96)),
      #fff7ec;
    box-shadow: 0 16px 34px rgba(43, 20, 8, 0.07);
  }

  .pss-kicker {
    margin: 0 0 6px;
    color: #c75c28;
    font-size: 12px;
    font-weight: 820;
    letter-spacing: var(--prime-kicker-letter-spacing, 0.08em);
    line-height: 1.2;
    text-transform: uppercase;
  }

  .pss-copy h2 {
    margin: 0;
    color: #21150f;
    font-size: 32px;
    line-height: 1.06;
    font-weight: 820;
    letter-spacing: 0;
  }

  .pss-copy p {
    max-width: 680px;
    margin: 8px 0 0;
    color: #6a5547;
    font-size: 15px;
    line-height: 1.6;
    letter-spacing: 0;
  }

  .pss-actions {
    display: grid;
    justify-items: end;
    gap: 10px;
  }

  .pss-actions span {
    color: #21150f;
    font-size: 14px;
    font-weight: 780;
    line-height: 1.25;
    letter-spacing: 0;
    text-align: right;
  }

  .pss-actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 20px;
    border-radius: 999px;
    background: #21150f;
    color: #fffaf2;
    font-size: 13px;
    font-weight: 820;
    letter-spacing: 0;
    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .pss-actions a:hover {
    transform: translateY(-1px);
    background: #3a2115;
  }

  @media (max-width: 720px) {
    .prime-subscribe-strip {
      padding-top: 16px;
    }

    .pss-shell {
      grid-template-columns: 1fr;
      gap: 18px;
      padding: 20px;
      border-radius: 18px;
    }

    .pss-actions {
      justify-items: stretch;
    }

    .pss-actions span {
      text-align: left;
    }

    .pss-actions a {
      width: 100%;
    }

    .pss-copy h2 {
      font-size: 26px;
    }
  }
</style>

{% schema %}
{
  "name": "Prime Subscribe strip",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Subscribe & Save"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Create a calmer chew routine."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Automatic deliveries help you keep yak chews ready for enrichment time without last-minute shopping."
    },
    {
      "type": "text",
      "id": "offer",
      "label": "Offer text",
      "default": "20% off first month, then ongoing savings."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    }
  ],
  "presets": [
    {
      "name": "Prime Subscribe strip"
    }
  ]
}
{% endschema %}
