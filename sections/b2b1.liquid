{% comment %}
  Prime Pet Food — B2B Wholesale Final
  Combined editorial story + retailer-focused conversion design.
  Theme colors: #24130d dark brown, #d2632e orange, #f1eee9 cream, #fff7ec warm cream.
{% endcomment %}

<section class="ppf-b2b-hero" id="ppf-b2b-top">
  <div class="ppf-b2b-hero__bg">
    {%- if section.settings.hero_image != blank -%}
      <img src="{{ section.settings.hero_image | image_url: width: 2200 }}" alt="{{ section.settings.hero_image.alt | escape }}" loading="eager" width="2200" height="1200">
    {%- endif -%}
  </div>
  <div class="ppf-b2b-hero__overlay"></div>

  <div class="ppf-b2b-hero__inner">
    <div class="ppf-b2b-hero__content">
      <div class="ppf-kicker"><span></span>{{ section.settings.hero_kicker }}</div>
      <h1>{{ section.settings.hero_title }}</h1>
      <p>{{ section.settings.hero_text }}</p>
      <div class="ppf-b2b-hero__actions">
        <a href="#ppf-b2b-apply" class="ppf-btn ppf-btn--primary">{{ section.settings.hero_primary }}</a>
        <a href="#ppf-b2b-story" class="ppf-btn ppf-btn--light">{{ section.settings.hero_secondary }}</a>
      </div>
    </div>

    <div class="ppf-b2b-hero__panel">
      <div class="ppf-panel__label">{{ section.settings.panel_label }}</div>
      <h3>{{ section.settings.panel_title }}</h3>
      <div class="ppf-panel__rows">
        <div class="ppf-panel__row"><span>{{ section.settings.panel_1_label }}</span><strong>{{ section.settings.panel_1_value }}</strong></div>
        <div class="ppf-panel__row"><span>{{ section.settings.panel_2_label }}</span><strong>{{ section.settings.panel_2_value }}</strong></div>
        <div class="ppf-panel__row"><span>{{ section.settings.panel_3_label }}</span><strong>{{ section.settings.panel_3_value }}</strong></div>
      </div>
      <a href="#ppf-b2b-apply" class="ppf-panel__link">{{ section.settings.panel_cta }} <span>→</span></a>
    </div>
  </div>

  <div class="ppf-b2b-marquee" aria-hidden="true">
    <div class="ppf-b2b-marquee__track">
      {% for i in (1..7) %}
        {%- assign item = 'marquee_' | append: i -%}
        {%- if section.settings[item] != blank -%}
          <span>{{ section.settings[item] }}</span><i>•</i>
        {%- endif -%}
      {% endfor %}
      {% for i in (1..7) %}
        {%- assign item = 'marquee_' | append: i -%}
        {%- if section.settings[item] != blank -%}
          <span>{{ section.settings[item] }}</span><i>•</i>
        {%- endif -%}
      {% endfor %}
    </div>
  </div>
</section>

<section class="ppf-b2b-stats">
  <div class="ppf-b2b-stats__inner">
    {% for i in (1..4) %}
      {%- assign num = 'stat_' | append: i | append: '_num' -%}
      {%- assign label = 'stat_' | append: i | append: '_label' -%}
      {%- if section.settings[num] != blank -%}
        <div class="ppf-stat-card">
          <strong>{{ section.settings[num] }}</strong>
          <span>{{ section.settings[label] }}</span>
        </div>
      {%- endif -%}
    {% endfor %}
  </div>
</section>

<section class="ppf-b2b-story" id="ppf-b2b-story">
  <div class="ppf-b2b-story__inner">
    <div class="ppf-b2b-story__media">
      <div class="ppf-story-image">
        {%- if section.settings.story_image != blank -%}
          <img src="{{ section.settings.story_image | image_url: width: 1200 }}" alt="{{ section.settings.story_image.alt | escape }}" loading="lazy" width="1200" height="900">
        {%- else -%}
          <div class="ppf-story-image__placeholder">Add a Himalayan sourcing image</div>
        {%- endif -%}
      </div>
      <div class="ppf-story-quote">
        <p>“{{ section.settings.story_quote }}”</p>
        <span>{{ section.settings.story_quote_author }}</span>
      </div>
    </div>

    <div class="ppf-b2b-story__copy">
      <div class="ppf-eyebrow">{{ section.settings.story_kicker }}</div>
      <h2>{{ section.settings.story_title }}</h2>
      <p>{{ section.settings.story_p1 }}</p>
      <p>{{ section.settings.story_p2 }}</p>
      <div class="ppf-story-mini">
        <div><strong>{{ section.settings.story_mini_1_num }}</strong><span>{{ section.settings.story_mini_1_label }}</span></div>
        <div><strong>{{ section.settings.story_mini_2_num }}</strong><span>{{ section.settings.story_mini_2_label }}</span></div>
        <div><strong>{{ section.settings.story_mini_3_num }}</strong><span>{{ section.settings.story_mini_3_label }}</span></div>
      </div>
    </div>
  </div>
</section>

<section class="ppf-b2b-edge" id="ppf-b2b-edge">
  <div class="ppf-b2b-edge__inner">
    <div class="ppf-section-head ppf-section-head--center">
      <div class="ppf-eyebrow">{{ section.settings.edge_kicker }}</div>
      <h2>{{ section.settings.edge_title }}</h2>
      <p>{{ section.settings.edge_text }}</p>
    </div>

    <div class="ppf-edge-grid">
      {% for i in (1..6) %}
        {%- assign icon = 'edge_' | append: i | append: '_icon' -%}
        {%- assign title = 'edge_' | append: i | append: '_title' -%}
        {%- assign text = 'edge_' | append: i | append: '_text' -%}
        {%- if section.settings[title] != blank -%}
          <article class="ppf-edge-card">
            <div class="ppf-edge-card__icon">{{ section.settings[icon] }}</div>
            <h3>{{ section.settings[title] }}</h3>
            <p>{{ section.settings[text] }}</p>
          </article>
        {%- endif -%}
      {% endfor %}
    </div>
  </div>
</section>

<section class="ppf-b2b-compare" id="ppf-b2b-compare">
  <div class="ppf-b2b-compare__inner">
    <div class="ppf-section-head">
      <div class="ppf-eyebrow">{{ section.settings.compare_kicker }}</div>
      <h2>{{ section.settings.compare_title }}</h2>
      <p>{{ section.settings.compare_text }}</p>
    </div>

    <div class="ppf-compare-table" role="table">
      <div class="ppf-compare-row ppf-compare-row--head" role="row">
        <div role="columnheader">Retail Factor</div>
        <div role="columnheader">Standard Chews</div>
        <div role="columnheader" class="is-prime">Prime Yak Chews</div>
      </div>
      {% for i in (1..5) %}
        {%- assign factor = 'compare_' | append: i | append: '_factor' -%}
        {%- assign normal = 'compare_' | append: i | append: '_normal' -%}
        {%- assign prime = 'compare_' | append: i | append: '_prime' -%}
        {%- if section.settings[factor] != blank -%}
          <div class="ppf-compare-row" role="row">
            <div role="cell">{{ section.settings[factor] }}</div>
            <div role="cell" class="is-muted">{{ section.settings[normal] }}</div>
            <div role="cell" class="is-prime">{{ section.settings[prime] }}</div>
          </div>
        {%- endif -%}
      {% endfor %}
    </div>
  </div>
</section>

<section class="ppf-b2b-lineup" id="ppf-b2b-lineup">
  <div class="ppf-b2b-lineup__inner">
    <div class="ppf-section-head ppf-section-head--center">
      <div class="ppf-eyebrow">{{ section.settings.lineup_kicker }}</div>
      <h2>{{ section.settings.lineup_title }}</h2>
      <p>{{ section.settings.lineup_text }}</p>
    </div>

    <div class="ppf-lineup-grid">
      {% for i in (1..5) %}
        {%- assign badge = 'product_' | append: i | append: '_badge' -%}
        {%- assign size = 'product_' | append: i | append: '_size' -%}
        {%- assign name = 'product_' | append: i | append: '_name' -%}
        {%- assign desc = 'product_' | append: i | append: '_desc' -%}
        {%- assign pack = 'product_' | append: i | append: '_pack' -%}
        {%- if section.settings[name] != blank -%}
          <article class="ppf-product-card">
            {%- if section.settings[badge] != blank -%}<div class="ppf-product-card__badge">{{ section.settings[badge] }}</div>{%- endif -%}
            <div class="ppf-product-card__size">{{ section.settings[size] }}</div>
            <h3>{{ section.settings[name] }}</h3>
            <p>{{ section.settings[desc] }}</p>
            <div class="ppf-product-card__pack"><span>Case Pack</span><strong>{{ section.settings[pack] }}</strong></div>
          </article>
        {%- endif -%}
      {% endfor %}
    </div>
  </div>
</section>

<section class="ppf-b2b-process" id="ppf-b2b-process">
  <div class="ppf-b2b-process__inner">
    <div class="ppf-section-head ppf-section-head--center ppf-section-head--light">
      <div class="ppf-eyebrow">{{ section.settings.process_kicker }}</div>
      <h2>{{ section.settings.process_title }}</h2>
      <p>{{ section.settings.process_text }}</p>
    </div>

    <div class="ppf-process-grid">
      {% for i in (1..4) %}
        {%- assign title = 'step_' | append: i | append: '_title' -%}
        {%- assign text = 'step_' | append: i | append: '_text' -%}
        {%- if section.settings[title] != blank -%}
          <div class="ppf-process-step">
            <div class="ppf-process-step__num">0{{ i }}</div>
            <h3>{{ section.settings[title] }}</h3>
            <p>{{ section.settings[text] }}</p>
          </div>
        {%- endif -%}
      {% endfor %}
    </div>
  </div>
</section>

<section class="ppf-b2b-faq" id="ppf-b2b-faq">
  <div class="ppf-b2b-faq__inner">
    <div class="ppf-b2b-faq__intro">
      <div class="ppf-eyebrow">{{ section.settings.faq_kicker }}</div>
      <h2>{{ section.settings.faq_title }}</h2>
      <p>{{ section.settings.faq_text }}</p>
      <a href="#ppf-b2b-apply" class="ppf-btn ppf-btn--primary">{{ section.settings.faq_cta }}</a>
    </div>
    <div class="ppf-faq-list">
      {% for i in (1..6) %}
        {%- assign q = 'faq_' | append: i | append: '_q' -%}
        {%- assign a = 'faq_' | append: i | append: '_a' -%}
        {%- if section.settings[q] != blank -%}
          <div class="ppf-faq-item">
            <button type="button" class="ppf-faq-q" aria-expanded="false">
              <span>{{ section.settings[q] }}</span><i>+</i>
            </button>
            <div class="ppf-faq-a"><p>{{ section.settings[a] }}</p></div>
          </div>
        {%- endif -%}
      {% endfor %}
    </div>
  </div>
</section>

<section class="ppf-b2b-apply" id="ppf-b2b-apply">
  <div class="ppf-b2b-apply__inner">
    <div class="ppf-b2b-apply__copy">
      <div class="ppf-eyebrow">{{ section.settings.form_kicker }}</div>
      <h2>{{ section.settings.form_title }}</h2>
      <p>{{ section.settings.form_text }}</p>
      <div class="ppf-apply-points">
        {% for i in (1..4) %}
          {%- assign perk = 'perk_' | append: i -%}
          {%- if section.settings[perk] != blank -%}
            <div><span>✓</span>{{ section.settings[perk] }}</div>
          {%- endif -%}
        {% endfor %}
      </div>
      <div class="ppf-apply-contact">
        <a href="tel:{{ section.settings.phone }}">{{ section.settings.phone }}</a>
        <a href="https://wa.me/{{ section.settings.whatsapp }}" target="_blank" rel="noopener">WhatsApp</a>
      </div>
    </div>

    <div class="ppf-b2b-apply__formwrap">
      {%- if form.posted_successfully? -%}
        <div class="ppf-success">
          <h3>Application Received</h3>
          <p>Thank you. Our wholesale team will review your details and reach out within 24 hours.</p>
        </div>
      {%- else -%}
        {% form 'contact', id: 'ppf-b2b-form' %}
          {%- if form.errors -%}<div class="ppf-form-errors">{{ form.errors | default_errors }}</div>{%- endif -%}
          <input type="hidden" name="contact[form_type]" value="B2B Wholesale Application">
          <div class="ppf-form-grid">
            <label>First Name <em>*</em><input type="text" name="contact[first_name]" placeholder="John" required autocomplete="given-name"></label>
            <label>Last Name <em>*</em><input type="text" name="contact[last_name]" placeholder="Smith" required autocomplete="family-name"></label>
            <label>Business Email <em>*</em><input type="email" name="contact[email]" placeholder="john@store.com" value="{{ form.email }}" required autocomplete="email"></label>
            <label>Phone <em>*</em><input type="tel" name="contact[phone]" placeholder="+1 (555) 000-0000" required autocomplete="tel"></label>
            <label class="is-full">Business / Store Name <em>*</em><input type="text" name="contact[business_name]" placeholder="Your Business Name" required></label>
            <label>Business Type <em>*</em>
              <select name="contact[business_type]" required>
                <option value="" disabled selected>Select type</option>
                <option>Pet Store / Boutique</option>
                <option>Online Retailer</option>
                <option>Veterinary Clinic</option>
                <option>Grooming / Daycare</option>
                <option>Distributor</option>
                <option>Other</option>
              </select>
            </label>
            <label>Monthly Volume
              <select name="contact[monthly_volume]">
                <option value="" disabled selected>Select volume</option>
                <option>1–5 Cases</option>
                <option>5–15 Cases</option>
                <option>15–50 Cases</option>
                <option>50+ Cases</option>
                <option>Not Sure Yet</option>
              </select>
            </label>
            <label>Website<input type="url" name="contact[website]" placeholder="https://yourstore.com"></label>
            <label>State / Region<input type="text" name="contact[region]" placeholder="Florida"></label>
            <label class="is-full">Tell Us About Your Business<textarea name="contact[body]" rows="4" placeholder="Products of interest, customer base, expected order size, or any questions…"></textarea></label>
          </div>
          <button type="submit" class="ppf-form-submit">{{ section.settings.form_cta }}</button>
          <p class="ppf-form-note">{{ section.settings.form_note }}</p>
        {% endform %}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .ppf-b2b-hero,.ppf-b2b-stats,.ppf-b2b-story,.ppf-b2b-edge,.ppf-b2b-compare,.ppf-b2b-lineup,.ppf-b2b-process,.ppf-b2b-faq,.ppf-b2b-apply,
  .ppf-b2b-hero *,.ppf-b2b-stats *,.ppf-b2b-story *,.ppf-b2b-edge *,.ppf-b2b-compare *,.ppf-b2b-lineup *,.ppf-b2b-process *,.ppf-b2b-faq *,.ppf-b2b-apply *{box-sizing:border-box}
  .ppf-b2b-hero{--dark:#24130d;--brown:#3a2418;--orange:#d2632e;--orange2:#e8783d;--cream:#f1eee9;--warm:#fff7ec;--line:#eadfce;position:relative;min-height:78vh;display:flex;align-items:center;overflow:hidden;background:var(--dark)}
  .ppf-b2b-hero__bg{position:absolute;inset:0;background:linear-gradient(135deg,#3a2418,#24130d)}
  .ppf-b2b-hero__bg img{width:100%;height:100%;object-fit:cover;object-position:center;display:block}
  .ppf-b2b-hero__overlay{position:absolute;inset:0;background:linear-gradient(90deg,rgba(36,19,13,.92) 0%,rgba(36,19,13,.76) 43%,rgba(36,19,13,.36) 100%),linear-gradient(0deg,rgba(36,19,13,.48),rgba(36,19,13,.1))}
  .ppf-b2b-hero__inner{position:relative;z-index:2;width:100%;max-width:1280px;margin:0 auto;padding:98px 56px 118px;display:grid;grid-template-columns:minmax(0,1fr) 380px;gap:56px;align-items:center}
  .ppf-kicker,.ppf-eyebrow{font-size:12px;letter-spacing:2.8px;text-transform:uppercase;font-weight:800;color:#d2632e;margin-bottom:14px}.ppf-kicker{display:flex;gap:12px;align-items:center}.ppf-kicker span{width:38px;height:2px;background:#d2632e;display:inline-block}
  .ppf-b2b-hero h1{font-size:clamp(42px,5.8vw,78px);line-height:1.02;letter-spacing:-1.6px;color:#fff;margin:0 0 22px;max-width:760px;font-weight:850}.ppf-b2b-hero__content p{font-size:17px;line-height:1.75;color:rgba(255,247,236,.8);max-width:580px;margin:0 0 34px}
  .ppf-b2b-hero__actions{display:flex;gap:14px;flex-wrap:wrap}.ppf-btn{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;padding:15px 28px;text-decoration:none;font-size:13px;font-weight:850;letter-spacing:.5px;transition:.25s ease;border:1px solid transparent}.ppf-btn--primary{background:#d2632e;color:#fff}.ppf-btn--primary:hover{background:#e8783d;transform:translateY(-2px);box-shadow:0 14px 36px rgba(210,99,46,.32)}.ppf-btn--light{color:#fff7ec;border-color:rgba(255,247,236,.45);background:rgba(255,255,255,.04)}.ppf-btn--light:hover{border-color:#d2632e;color:#fff;background:rgba(210,99,46,.12)}
  .ppf-b2b-hero__panel{background:rgba(255,247,236,.95);border:1px solid rgba(255,255,255,.6);border-radius:28px;padding:28px;box-shadow:0 28px 80px rgba(0,0,0,.28)}.ppf-panel__label{display:inline-block;background:#d2632e;color:#fff;border-radius:999px;padding:6px 12px;font-size:10px;font-weight:850;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:16px}.ppf-b2b-hero__panel h3{color:#24130d;font-size:25px;line-height:1.15;margin:0 0 22px}.ppf-panel__rows{border-top:1px solid #eadfce}.ppf-panel__row{display:flex;justify-content:space-between;gap:18px;padding:15px 0;border-bottom:1px solid #eadfce}.ppf-panel__row span{color:#7b6256;font-size:13px}.ppf-panel__row strong{color:#24130d;font-size:14px;text-align:right}.ppf-panel__link{display:flex;justify-content:space-between;align-items:center;margin-top:20px;background:#24130d;color:#fff7ec;text-decoration:none;border-radius:16px;padding:15px 18px;font-weight:850;font-size:13px}.ppf-panel__link span{color:#d2632e}
  .ppf-b2b-marquee{position:absolute;z-index:3;left:0;right:0;bottom:0;background:#d2632e;overflow:hidden}.ppf-b2b-marquee__track{display:flex;gap:26px;white-space:nowrap;align-items:center;padding:13px 0;animation:ppfMarquee 36s linear infinite}.ppf-b2b-marquee span{color:#fff;font-size:11px;font-weight:850;letter-spacing:1.4px;text-transform:uppercase}.ppf-b2b-marquee i{color:rgba(255,255,255,.45);font-style:normal}@keyframes ppfMarquee{to{transform:translateX(-50%)}}
  .ppf-b2b-stats{background:#fff7ec;border-bottom:1px solid #eadfce}.ppf-b2b-stats__inner{max-width:1280px;margin:0 auto;padding:0 56px;display:grid;grid-template-columns:repeat(4,1fr)}.ppf-stat-card{padding:30px 20px;text-align:center;border-right:1px solid #eadfce}.ppf-stat-card:last-child{border-right:none}.ppf-stat-card strong{display:block;color:#d2632e;font-size:32px;line-height:1;font-weight:900;margin-bottom:8px}.ppf-stat-card span{font-size:11px;text-transform:uppercase;letter-spacing:1.5px;font-weight:800;color:#6b5348}
  .ppf-b2b-story,.ppf-b2b-edge,.ppf-b2b-compare,.ppf-b2b-lineup,.ppf-b2b-faq{background:#f1eee9}.ppf-b2b-story__inner,.ppf-b2b-edge__inner,.ppf-b2b-compare__inner,.ppf-b2b-lineup__inner,.ppf-b2b-process__inner,.ppf-b2b-faq__inner,.ppf-b2b-apply__inner{max-width:1280px;margin:0 auto;padding:96px 56px}.ppf-b2b-story__inner{display:grid;grid-template-columns:.95fr 1fr;gap:70px;align-items:center}.ppf-story-image{border-radius:0 0 0 0;overflow:hidden;background:#fff7ec;min-height:440px}.ppf-story-image img{width:100%;height:100%;min-height:440px;object-fit:cover;display:block}.ppf-story-image__placeholder{min-height:440px;display:flex;align-items:center;justify-content:center;color:#8a7368}.ppf-story-quote{background:#d2632e;color:#fff;padding:28px 34px}.ppf-story-quote p{margin:0 0 16px;font-size:20px;line-height:1.35;font-weight:850;font-style:italic}.ppf-story-quote span{font-size:12px;opacity:.85}.ppf-b2b-story__copy h2,.ppf-section-head h2,.ppf-b2b-faq__intro h2,.ppf-b2b-apply__copy h2{font-size:clamp(30px,3.6vw,52px);line-height:1.08;color:#24130d;margin:0 0 22px;letter-spacing:-1px}.ppf-b2b-story__copy p,.ppf-section-head p,.ppf-b2b-faq__intro p,.ppf-b2b-apply__copy p{font-size:16px;line-height:1.8;color:#5f4b42;margin:0 0 18px}.ppf-story-mini{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:34px}.ppf-story-mini div{background:rgba(255,247,236,.8);border:1px solid #eadfce;border-radius:10px;padding:24px 16px;text-align:center}.ppf-story-mini strong{display:block;color:#d2632e;font-size:30px;line-height:1;font-weight:900;margin-bottom:10px}.ppf-story-mini span{font-size:12px;color:#5f4b42}
  .ppf-section-head{max-width:680px;margin-bottom:52px}.ppf-section-head--center{text-align:center;margin-left:auto;margin-right:auto}.ppf-edge-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.ppf-edge-card{background:#fff7ec;border:1px solid #eadfce;border-radius:22px;padding:30px;transition:.25s ease}.ppf-edge-card:hover{transform:translateY(-4px);box-shadow:0 20px 60px rgba(36,19,13,.08);border-color:rgba(210,99,46,.45)}.ppf-edge-card__icon{width:54px;height:54px;border-radius:16px;background:rgba(210,99,46,.12);display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:20px}.ppf-edge-card h3,.ppf-product-card h3,.ppf-process-step h3{color:#24130d;font-size:19px;margin:0 0 10px}.ppf-edge-card p,.ppf-product-card p,.ppf-process-step p{font-size:14px;line-height:1.7;color:#6b5348;margin:0}
