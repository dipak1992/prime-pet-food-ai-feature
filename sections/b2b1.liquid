<script>
  (function(){
    document.querySelectorAll('.ppf-faq-q').forEach(function(btn){
      btn.addEventListener('click',function(){
        var item = btn.closest('.ppf-faq-item');
        var open = item.classList.contains('is-open');
        document.querySelectorAll('.ppf-faq-item').forEach(function(el){
          el.classList.remove('is-open');
          var q = el.querySelector('.ppf-faq-q');
          if(q) q.setAttribute('aria-expanded','false');
        });
        if(!open){
          item.classList.add('is-open');
          btn.setAttribute('aria-expanded','true');
        }
      });
    });
  })();
</script>

