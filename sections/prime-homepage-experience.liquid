    align-items: center;
    gap: 6px;
    border: 1px solid rgba(255, 250, 242, 0.28);
    border-radius: 999px;
    background: rgba(255, 250, 242, 0.08);
    color: rgba(255, 250, 242, 0.9);
    font-size: 13px;
    line-height: 1;
    padding: 10px 14px;
  }

  .ph-hero__proof svg {
    flex-shrink: 0;
    opacity: 0.85;
  }

  .ph-hero__micro {
    margin: 14px 0 0;
    color: rgba(255, 250, 242, 0.7);
    font-size: 13px;
    line-height: 1.35;
    font-weight: 650;
  }

  /* ═══════════════════════════════════════════════════════════════
     TRUST BAR
  ════════════════════════════════════════════════════════════════ */
  .ph-trust-bar {
    background: var(--ph-ink);
    padding: 20px 0;
  }

  .ph-trust-bar__inner {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
    text-align: center;
  }

  .ph-trust-bar__stat strong {
    display: block;
    color: #fffaf2;
    font-size: 22px;
    font-weight: 780;
    line-height: 1.2;
  }

  .ph-trust-bar__star {
    color: #fbbf24;
  }

  .ph-trust-bar__stat span {
    display: block;
    margin-top: 4px;
    color: rgba(255, 250, 242, 0.6);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }

  /* ═══════════════════════════════════════════════════════════════
     SECTION SPACING
  ════════════════════════════════════════════════════════════════ */
  .ph-products,
  .ph-outcomes,
  .ph-subscribe,
  .ph-reviews,
  .ph-compare,
  .ph-routine,
  .ph-ingredients,
  .ph-craft,
  .ph-fit,
  .ph-guarantee,
  .ph-faq,
  .ph-close {
    padding: 72px 0;
  }

  .ph-section-head {
    max-width: 720px;
    margin-bottom: 36px;
  }

  .ph-section-head--center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .ph-section-head p:not(.ph-kicker) {
    margin: 14px 0 0;
  }

  #prime-home-shop {
    scroll-margin-top: 120px;
  }

  /* ═══════════════════════════════════════════════════════════════
     OUTCOMES
  ════════════════════════════════════════════════════════════════ */
  .ph-outcomes {
    background: #fff;
  }

  .ph-outcomes__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1fr);
    gap: 46px;
    align-items: start;
  }

  .ph-outcomes__copy {
    position: sticky;
    top: 110px;
  }

  .ph-outcomes__copy p:not(.ph-kicker) {
    margin: 16px 0 0;
  }

  .ph-outcomes__grid {
    display: grid;
    gap: 14px;
  }

  .ph-outcomes__grid article {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    column-gap: 18px;
    row-gap: 8px;
    padding: 22px;
    border: 1px solid var(--ph-line);
    border-radius: var(--ph-radius);
    background: var(--ph-soft);
  }

  .ph-outcomes__grid span {
    grid-row: 1 / span 2;
    display: inline-flex;
    width: 38px;
    height: 38px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #fff;
    color: var(--ph-clay);
    font-size: 13px;
    font-weight: 820;
  }

  .ph-outcomes__grid p {
    margin: 0;
    font-size: 15px;
  }

  .ph-outcomes__icon {
    display: inline-block;
    width: 18px;
    height: 18px;
    margin-left: 6px;
    color: var(--ph-clay);
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
    vertical-align: -2px;
  }

  /* ═══════════════════════════════════════════════════════════════
     PRODUCTS
  ════════════════════════════════════════════════════════════════ */
  .ph-product-grid,
  .ph-fit__grid,
  .ph-reviews__grid,
  .ph-ingredients__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .ph-product-grid {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .ph-ingredients__grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .ph-product-card,
  .ph-review-card,
  .ph-ingredient-card,
  .ph-fit article {
    border: 1px solid var(--ph-line);
    border-radius: var(--ph-radius);
    background: #fff;
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .ph-product-card:hover,
  .ph-review-card:hover,
  .ph-ingredient-card:hover,
  .ph-fit article:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .ph-product-card {
    display: grid;
    grid-template-rows: auto 1fr auto;
    min-height: 100%;
  }

  .ph-product-card > div:not(.ph-product-card__media) {
    padding: 22px 22px 0;
  }

  .ph-product-card__media {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--ph-soft);
  }

  .ph-product-card__media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .ph-product-card__label {
    position: absolute;
    top: 14px;
    left: 14px;
    display: inline-flex;
    min-height: 32px;
    align-items: center;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(255, 250, 242, 0.92);
    color: var(--ph-ink);
    font-size: 12px;
    line-height: 1;
    font-weight: 780;
    box-shadow: 0 8px 20px rgba(23, 21, 18, 0.12);
  }

  .ph-product-card__badge {
    color: var(--ph-clay);
    font-size: 12px;
    line-height: 1.2;
    font-weight: 780;
    text-transform: uppercase;
  }

  .ph-product-card h3 {
    margin-top: 14px;
  }

  .ph-product-card p {
    margin: 12px 0 0;
    font-size: 15px;
  }

  .ph-product-card__fit {
    display: block;
    margin-top: 8px;
    color: var(--ph-muted);
    font-size: 14px;
    font-weight: 720;
  }

  .ph-product-card__best {
    display: block;
    margin-top: 8px;
    color: var(--ph-clay);
    font-size: 12px;
    line-height: 1.35;
    font-weight: 760;
  }

  .ph-product-card__footer {
    align-self: end;
    display: grid;
    gap: 12px;
    margin-top: 0;
    padding: 20px 22px 22px;
  }

  .ph-product-card__buy-meta {
    display: grid;
    gap: 4px;
  }

  .ph-product-card__price {
    color: var(--ph-ink);
    font-size: 20px;
    font-weight: 780;
  }

  .ph-product-card__note {
    color: var(--ph-muted);
    font-size: 12px;
    line-height: 1.35;
    font-weight: 650;
  }

  .ph-product-card button,
  .ph-product-card__link {
    width: 100%;
    min-height: 48px;
    border: 0;
    border-radius: 999px;
    background: var(--ph-ink);
    color: #fff;
    cursor: pointer;
    font: inherit;
    font-size: 13px;
    line-height: 1;
    font-weight: 780;
    text-transform: uppercase;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease;
  }

  .ph-product-card button:hover,
  .ph-product-card__link:hover {
    background: #2d2820;
  }

  .ph-product-card button:disabled {
    cursor: not-allowed;
    background: #9a9188;
  }

  .ph-products__link {
    margin-top: 22px;
    text-align: center;
  }

  .ph-products__link a {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ph-line);
    border-radius: 999px;
    padding: 0 22px;
    font-size: 13px;
    font-weight: 780;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ph-ink);
    background: #fff;
    transition: border-color 0.15s ease;
  }

  .ph-products__link a:hover {
    border-color: var(--ph-clay);
  }

  .ph-confidence {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-top: 18px;
  }

  .ph-confidence span {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 8px 14px;
    border: 1px solid var(--ph-line);
    border-radius: 999px;
    background: #fff;
    color: var(--ph-muted);
    font-size: 13px;
    line-height: 1.2;
    font-weight: 700;
  }

  .ph-size-scale {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 10px;
    align-items: end;
    margin-top: 24px;
    padding: 18px;
    border: 1px solid var(--ph-line);
    border-radius: var(--ph-radius);
    background: #fff;
  }

  .ph-size-scale span {
    display: grid;
    gap: 8px;
    color: var(--ph-muted);
    font-size: 12px;
    font-weight: 760;
    text-align: center;
  }

  .ph-size-scale span::before {
    content: "";
    display: block;
    width: var(--size);
    max-width: 100%;
    height: 12px;
    margin-inline: auto;
    border-radius: 999px;
    background: linear-gradient(90deg, #d8b58a, var(--ph-clay));
  }

  /* ═══════════════════════════════════════════════════════════════
     SUBSCRIBE & SAVE
  ════════════════════════════════════════════════════════════════ */
  .ph-subscribe {
    background: #1f1914;
    color: #fffaf2;
  }

  .ph-subscribe__inner {
    display: grid;
    grid-template-columns: minmax(280px, 0.62fr) minmax(0, 1fr);
    align-items: center;
    gap: 36px;
    padding: 28px;
    border: 1px solid rgba(255, 250, 242, 0.14);
    border-radius: var(--ph-radius);
    background:
      linear-gradient(135deg, rgba(255, 250, 242, 0.08), rgba(255, 250, 242, 0.03)),
      #261c16;
    box-shadow: 0 18px 48px rgba(20, 10, 4, 0.22);
  }

  .ph-subscribe__media {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid rgba(255, 250, 242, 0.22);
    border-radius: var(--ph-radius);
    background: rgba(255, 250, 242, 0.08);
  }

  .ph-subscribe__media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .ph-subscribe__copy {
    display: grid;
    gap: 18px;
    max-width: 700px;
  }

  .ph-subscribe__copy .ph-kicker {
    color: #f4c27d;
  }

  .ph-subscribe__copy h2,
  .ph-subscribe__copy p {
    color: #fffaf2;
  }

  .ph-subscribe__copy p {
    max-width: 560px;
    margin: 0;
    color: rgba(255, 250, 242, 0.8);
  }

  .ph-subscribe__benefits {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 0;
  }

  .ph-subscribe__benefits span {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 8px 14px;
    border: 1px solid rgba(255, 250, 242, 0.2);
    border-radius: 999px;
    background: rgba(255, 250, 242, 0.08);
    color: rgba(255, 250, 242, 0.9);
    font-size: 13px;
    line-height: 1.2;
    font-weight: 680;
  }

  .ph-subscribe__offer {
    display: inline-grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    column-gap: 18px;
    row-gap: 4px;
    width: fit-content;
    padding: 18px 22px;
    border: 1px solid rgba(244, 194, 125, 0.22);
    border-radius: var(--ph-radius);
    background: rgba(255, 250, 242, 0.1);
    color: #fffaf2;
  }

  .ph-subscribe__offer span,
  .ph-subscribe__offer small {
    color: rgba(255, 250, 242, 0.72);
    font-size: 12px;
    line-height: 1.35;
    font-weight: 760;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .ph-subscribe__offer strong {
    grid-row: 1 / span 2;
    color: #f4c27d;
    font-size: 52px;
    line-height: 0.92;
    font-weight: 820;
  }

  .ph-subscribe__cadence {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
    max-width: 520px;
  }

  .ph-subscribe__cadence span {
    position: relative;
    padding: 12px 10px;
    border: 1px solid rgba(244, 194, 125, 0.24);
    border-radius: var(--ph-radius);
    background: rgba(244, 194, 125, 0.09);
    color: rgba(255, 250, 242, 0.9);
    font-size: 12px;
    font-weight: 780;
    text-align: center;
    text-transform: uppercase;
  }

  .ph-subscribe__link {
    color: #f4c27d;
    font-size: 13px;
    line-height: 1;
    font-weight: 780;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* ═══════════════════════════════════════════════════════════════
     REVIEWS
  ════════════════════════════════════════════════════════════════ */
  .ph-reviews {
    background: var(--ph-soft);
  }

  .ph-review-card {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ph-review-card__photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 10px;
    object-fit: cover;
    background: var(--ph-soft);
  }

  .ph-review-card__stars {
    color: #fbbf24;
    font-size: 18px;
    letter-spacing: 2px;
  }

  .ph-review-card blockquote {
    margin: 0;
    padding: 0;
    font-size: 15px;
    line-height: 1.7;
    color: var(--ph-ink);
    font-style: normal;
    flex: 1;
  }

  .ph-review-card footer {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .ph-review-card footer strong {
    font-size: 14px;
    font-weight: 720;
  }

  .ph-review-card__badge {
    display: inline-flex;
    align-items: center;
    padding: 5px 10px;
    border-radius: 999px;
    background: var(--ph-soft);
    border: 1px solid var(--ph-line);
    font-size: 12px;
    color: var(--ph-muted);
    font-weight: 600;
  }

  .ph-reviews__link,
  .ph-ingredients__link,
  .ph-fit__link {
    margin-top: 24px;
    text-align: center;
  }

  .ph-reviews__link a,
  .ph-ingredients__link a,
  .ph-fit__link a {
    color: var(--ph-clay);
    font-size: 13px;
    font-weight: 780;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* ═══════════════════════════════════════════════════════════════
     COMPARE TABLE
  ════════════════════════════════════════════════════════════════ */
  .ph-compare__table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--ph-line);
    border-radius: var(--ph-radius);
    background: #fff;
  }

  .ph-compare__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 15px;
    min-width: 760px;
  }

  .ph-compare__table th,
  .ph-compare__table td {
    padding: 16px 20px;
    text-align: left;
    border-bottom: 1px solid var(--ph-line);
    vertical-align: middle;
  }

  .ph-compare__table thead th {
    background: var(--ph-soft);
    font-size: 13px;
    font-weight: 780;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--ph-muted);
  }

  .ph-compare__table thead th.ph-compare__highlight {
    color: var(--ph-clay);
  }

  .ph-compare__highlight {
    background: rgba(184, 95, 50, 0.04);
  }

  .ph-compare__table td svg {
    vertical-align: middle;
    margin-right: 4px;
  }

  .ph-compare__table tbody tr:last-child td {
    border-bottom: 0;
  }

  .ph-compare__cards {
    display: none;
  }

  .ph-compare__cards article {
    border: 1px solid var(--ph-line);
    border-radius: var(--ph-radius);
    background: #fff;
    padding: 18px;
  }

  .ph-compare__cards strong,
  .ph-compare__cards span {
    display: block;
  }

  .ph-compare__cards strong {
    color: var(--ph-ink);
    font-size: 17px;
    margin-bottom: 10px;
  }

  .ph-compare__cards span {
    color: var(--ph-muted);
    font-size: 14px;
    line-height: 1.45;
  }

  /* ═══════════════════════════════════════════════════════════════
     ROUTINE
  ════════════════════════════════════════════════════════════════ */
  .ph-routine {
    background: var(--ph-soft);
  }

  .ph-routine__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .ph-routine__grid article {
    padding: 28px;
    border: 1px solid var(--ph-line);
    border-radius: var(--ph-radius);
    background: #fff;
  }

  .ph-routine__grid span {
    display: inline-flex;
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--ph-soft);
    color: var(--ph-clay);
    font-size: 13px;
    font-weight: 820;
  }

  .ph-routine__grid h3 {
    margin-top: 18px;
  }

  .ph-routine__grid p {
    margin: 10px 0 0;
    font-size: 15px;
  }

  /* ═══════════════════════════════════════════════════════════════
     INGREDIENTS
  ════════════════════════════════════════════════════════════════ */
  .ph-ingredient-card {
    padding: 0 0 24px;
  }

  .ph-ingredient-card img {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    display: block;
    object-fit: cover;
    background: var(--ph-soft);
  }

  .ph-ingredient-card__num {
    display: inline-block;
    width: 32px;
    height: 32px;
    line-height: 32px;
    text-align: center;
    border-radius: 50%;
    background: var(--ph-soft);
    color: var(--ph-clay);
    font-size: 13px;
    font-weight: 780;
    margin: 20px 24px 0;
  }

  .ph-ingredient-card h3 {
    margin: 16px 24px 0;
    font-size: 19px;
  }

  .ph-ingredient-card p {
    margin: 10px 24px 0;
    font-size: 14px;
    line-height: 1.6;
  }

  .ph-ingredients__badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-top: 32px;
  }

  .ph-ingredients__badges span {
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    border-radius: 999px;
    background: var(--ph-soft);
    border: 1px solid var(--ph-line);
    font-size: 13px;
    font-weight: 650;
    color: var(--ph-ink);
  }

  /* ═══════════════════════════════════════════════════════════════
     CRAFT
  ════════════════════════════════════════════════════════════════ */
  .ph-craft {
    background: #fff;
  }

  .ph-craft__inner {
    display: grid;
    grid-template-columns: minmax(280px, 0.56fr) minmax(0, 1fr);
    gap: 46px;
    align-items: center;
    padding: 34px;
    border: 1px solid var(--ph-line);
    border-radius: var(--ph-radius);
    background:
      linear-gradient(135deg, rgba(248, 241, 231, 0.72), rgba(255, 255, 255, 0.92)),
      #fff;
  }

  .ph-craft__media {
    overflow: hidden;
    aspect-ratio: 1 / 1;
    border-radius: var(--ph-radius);
    background: var(--ph-soft);
  }

  .ph-craft__media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .ph-craft__copy p:not(.ph-kicker) {
    max-width: 640px;
    margin: 18px 0 0;
  }

  .ph-craft__marks {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .ph-craft__marks span {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 8px 14px;
    border: 1px solid var(--ph-line);
    border-radius: 999px;
    background: #fff;
    color: var(--ph-ink);
    font-size: 13px;
    line-height: 1.2;
    font-weight: 720;
  }

  /* ═══════════════════════════════════════════════════════════════
     DOG FIT
  ════════════════════════════════════════════════════════════════ */
  .ph-fit {
    background: var(--ph-soft);
  }

  .ph-fit article img {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    display: block;
    object-fit: cover;
  }

  .ph-fit article div {
    padding: 18px;
  }

  .ph-fit strong,
  .ph-fit span {
    display: block;
  }

  .ph-fit strong {
    font-size: 18px;
    line-height: 1.2;
    font-weight: 760;
  }

  .ph-fit__duration {
    margin-top: 6px;
    color: var(--ph-clay);
    font-size: 13px;
    font-weight: 680;
  }

  /* ═══════════════════════════════════════════════════════════════
     GUARANTEE
  ════════════════════════════════════════════════════════════════ */
  .ph-guarantee {
    background:
      radial-gradient(circle at top, rgba(244, 194, 125, 0.14), transparent 42%),
      linear-gradient(135deg, rgba(23, 21, 18, 0.98), rgba(46, 33, 25, 0.98)),
      var(--ph-ink);
  }

  .ph-guarantee__inner {
    max-width: 980px;
  }

  .ph-guarantee__card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 28px;
    padding: 34px;
    border: 1px solid rgba(255, 250, 242, 0.16);
    border-radius: var(--ph-radius);
    background: rgba(255, 250, 242, 0.07);
    box-shadow: inset 0 1px 0 rgba(255, 250, 242, 0.08), 0 18px 46px rgba(0, 0, 0, 0.18);
  }

  .ph-guarantee__icon {
    display: grid;
    width: 82px;
    height: 82px;
    place-items: center;
    border: 1px solid rgba(244, 194, 125, 0.32);
    border-radius: 999px;
    background: rgba(244, 194, 125, 0.12);
    color: var(--ph-clay);
  }

  .ph-guarantee__copy {
    text-align: left;
  }

  .ph-guarantee .ph-kicker {
    color: #f4c27d;
  }

  .ph-guarantee h2 {
    color: #fffaf2;
  }

  .ph-guarantee p {
    color: rgba(255, 250, 242, 0.75);
    max-width: 540px;
    margin: 12px 0 0;
  }

  .ph-guarantee__pills {
    grid-column: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .ph-guarantee__pills span {
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    border-radius: 999px;
    border: 1px solid rgba(255, 250, 242, 0.2);
    background: rgba(255, 250, 242, 0.08);
    color: rgba(255, 250, 242, 0.88);
    font-size: 13px;
    font-weight: 600;
  }

  /* ═══════════════════════════════════════════════════════════════
     FAQ
  ════════════════════════════════════════════════════════════════ */
  .ph-faq {
    background: var(--ph-soft);
  }

  .ph-faq__inner {
    display: grid;
    grid-template-columns: minmax(260px, 0.42fr) minmax(0, 1fr);
    gap: 42px;
    align-items: start;
  }

  .ph-faq .ph-section-head {
    margin-bottom: 0;
  }

  .ph-faq__list {
    display: grid;
    gap: 12px;
  }

  .ph-faq details {
    border: 1px solid var(--ph-line);
    border-radius: var(--ph-radius);
    background: #fff;
    overflow: hidden;
  }

  .ph-faq summary {
    cursor: pointer;
    padding: 18px 20px;
    color: var(--ph-ink);
    font-size: 16px;
    line-height: 1.35;
    font-weight: 760;
    list-style: none;
  }

  .ph-faq summary::-webkit-details-marker {
    display: none;
  }

  .ph-faq summary::after {
    content: "+";
    float: right;
    color: var(--ph-clay);
    font-weight: 820;
  }

  .ph-faq details[open] summary::after {
    content: "-";
  }

  .ph-faq details p {
    margin: 0;
    padding: 0 20px 20px;
    font-size: 15px;
  }

  /* ═══════════════════════════════════════════════════════════════
     CLOSING CTA
  ════════════════════════════════════════════════════════════════ */
  .ph-close {
    position: relative;
    overflow: hidden;
    text-align: center;
    background:
      linear-gradient(90deg, rgba(23, 21, 18, 0.9), rgba(23, 21, 18, 0.58)),
      var(--ph-close-image) center / cover no-repeat,
      var(--ph-ink);
  }

  .ph-close__inner {
    position: relative;
    max-width: 760px;
    padding: 28px;
    border: 1px solid rgba(255, 250, 242, 0.18);
    border-radius: 24px;
    background: rgba(23, 21, 18, 0.44);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .ph-close .ph-kicker,
  .ph-close h2,
  .ph-close p {
    color: #fffaf2;
  }

  .ph-close p:not(.ph-kicker) {
    max-width: 560px;
    margin: 16px auto 0;
    color: rgba(255, 250, 242, 0.82);
  }

  /* ═══════════════════════════════════════════════════════════════
     RESPONSIVE — Tablet
  ════════════════════════════════════════════════════════════════ */
  @media (max-width: 860px) {
    .prime-homepage h1 {
      font-size: 52px;
    }

    .prime-homepage h2 {
      font-size: 36px;
    }

    .ph-product-grid,
    .ph-fit__grid,
    .ph-reviews__grid,
    .ph-outcomes__inner,
    .ph-faq__inner,
    .ph-craft__inner {
      grid-template-columns: 1fr;
    }

    .ph-product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ph-outcomes__copy {
      position: static;
    }

    .ph-ingredients__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .ph-trust-bar__inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .ph-routine__grid {
      grid-template-columns: 1fr;
    }

    .ph-subscribe {
      background: #1f1914;
    }

    .ph-subscribe__inner {
      grid-template-columns: 1fr;
    }

    .ph-subscribe__media {
      max-width: 520px;
    }

    .ph-subscribe__offer {
      justify-items: start;
      max-width: 360px;
    }

    .ph-guarantee__card {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }

    .ph-guarantee__copy {
      text-align: center;
    }

    .ph-guarantee p {
      margin-left: auto;
      margin-right: auto;
    }

    .ph-guarantee__pills {
      grid-column: auto;
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
    }

    .ph-compare__table {
      font-size: 14px;
    }
  }

  /* ═══════════════════════════════════════════════════════════════
     RESPONSIVE — Mobile
  ════════════════════════════════════════════════════════════════ */
  @media (max-width: 560px) {
    .ph-shell {
      width: min(100% - 24px, 1160px);
    }

    .ph-hero {
      min-height: 52vh;
    }

    .ph-hero__media::after {
      background: linear-gradient(180deg, rgba(19, 16, 12, 0.18) 0%, rgba(19, 16, 12, 0.56) 38%, rgba(19, 16, 12, 0.92) 100%);
    }

    .ph-hero__content {
      padding: 118px 0 36px;
    }

    .prime-homepage h1 {
      font-size: 38px;
      line-height: 1.02;
    }

    .prime-homepage h2 {
      font-size: 28px;
    }

    .prime-homepage p {
      font-size: 16px;
    }

    .ph-actions {
      flex-direction: column;
    }

    .ph-button {
      width: 100%;
    }

    .ph-trust-bar__inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      padding: 8px 0;
    }

    .ph-trust-bar__stat strong {
      font-size: 18px;
    }

    .ph-products,
    .ph-outcomes,
    .ph-subscribe,
    .ph-reviews,
    .ph-compare,
    .ph-routine,
    .ph-ingredients,
    .ph-craft,
    .ph-fit,
    .ph-guarantee,
    .ph-faq,
    .ph-close {
      padding: 52px 0;
    }

    .ph-routine,
    .ph-ingredients,
    .ph-fit,
    .ph-craft,
    .ph-vet {
      display: none !important;
      height: 0 !important;
      margin: 0 !important;
      overflow: hidden !important;
      padding: 0 !important;
    }

    .ph-product-grid {
      grid-template-columns: 1fr;
    }

    .ph-size-scale,
    .ph-subscribe__cadence {
      grid-template-columns: 1fr;
    }

    .ph-ingredients__grid {
      grid-template-columns: 1fr;
    }

    .ph-outcomes__grid article {
      grid-template-columns: 1fr;
    }

    .ph-outcomes__grid span {
      grid-row: auto;
    }

    .ph-craft__inner {
      padding: 22px;
    }

    .ph-subscribe__benefits {
      display: grid;
      grid-template-columns: 1fr;
    }

    .ph-subscribe__benefits span {
      justify-content: center;
    }

    .ph-subscribe__offer {
      grid-template-columns: 1fr;
      max-width: none;
      justify-items: center;
      text-align: center;
      padding: 24px;
    }

    .ph-subscribe__offer strong {
      grid-row: auto;
      font-size: 46px;
    }

    .ph-guarantee__card {
      padding: 26px 20px;
    }

    .ph-routine__grid article {
      padding: 24px;
    }

    .ph-hero__social-badge {
      font-size: 12px;
      padding: 6px 12px;
    }

    .ph-compare__table-wrap {
      display: none;
    }

    .ph-compare__cards {
      display: grid;
      gap: 12px;
    }
  }

  /* ═══════════════════════════════════════════════════════════════
     SCROLL REVEAL ANIMATIONS
  ════════════════════════════════════════════════════════════════ */
  .ph-reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ph-reveal.ph-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger children for grids */
  .ph-reveal.ph-revealed .ph-product-grid > *,
  .ph-reveal.ph-revealed .ph-outcomes__grid > *,
  .ph-reveal.ph-revealed .ph-reviews__grid > *,
  .ph-reveal.ph-revealed .ph-ingredients__grid > *,
  .ph-reveal.ph-revealed .ph-routine__grid > *,
  .ph-reveal.ph-revealed .ph-fit__grid > * {
    animation: ph-stagger-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .ph-reveal.ph-revealed .ph-product-grid > *:nth-child(1),
  .ph-reveal.ph-revealed .ph-outcomes__grid > *:nth-child(1),
  .ph-reveal.ph-revealed .ph-reviews__grid > *:nth-child(1),
  .ph-reveal.ph-revealed .ph-ingredients__grid > *:nth-child(1),
  .ph-reveal.ph-revealed .ph-routine__grid > *:nth-child(1),
  .ph-reveal.ph-revealed .ph-fit__grid > *:nth-child(1) { animation-delay: 0.1s; }

  .ph-reveal.ph-revealed .ph-product-grid > *:nth-child(2),
  .ph-reveal.ph-revealed .ph-outcomes__grid > *:nth-child(2),
  .ph-reveal.ph-revealed .ph-reviews__grid > *:nth-child(2),
  .ph-reveal.ph-revealed .ph-ingredients__grid > *:nth-child(2),
  .ph-reveal.ph-revealed .ph-routine__grid > *:nth-child(2),
  .ph-reveal.ph-revealed .ph-fit__grid > *:nth-child(2) { animation-delay: 0.2s; }

  .ph-reveal.ph-revealed .ph-product-grid > *:nth-child(3),
  .ph-reveal.ph-revealed .ph-outcomes__grid > *:nth-child(3),
  .ph-reveal.ph-revealed .ph-reviews__grid > *:nth-child(3),
  .ph-reveal.ph-revealed .ph-ingredients__grid > *:nth-child(3),
  .ph-reveal.ph-revealed .ph-routine__grid > *:nth-child(3),
  .ph-reveal.ph-revealed .ph-fit__grid > *:nth-child(3) { animation-delay: 0.3s; }

  .ph-reveal.ph-revealed .ph-ingredients__grid > *:nth-child(4) { animation-delay: 0.4s; }

  @keyframes ph-stagger-in {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes ph-hero-drift {
    from { transform: scale(1.03) translate3d(0, 0, 0); }
    to { transform: scale(1.08) translate3d(-1.2%, -0.8%, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ph-hero__media img {
      animation: none;
      transform: none;
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .ph-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .ph-reveal.ph-revealed .ph-product-grid > *,
    .ph-reveal.ph-revealed .ph-outcomes__grid > *,
    .ph-reveal.ph-revealed .ph-reviews__grid > *,
    .ph-reveal.ph-revealed .ph-ingredients__grid > *,
    .ph-reveal.ph-revealed .ph-routine__grid > *,
    .ph-reveal.ph-revealed .ph-fit__grid > * {
      animation: none;
    }
  }

  /* ═══════════════════════════════════════════════════════════════
     STICKY SHOP BAR
  ════════════════════════════════════════════════════════════════ */
  .ph-sticky-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 999;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .ph-sticky-bar.ph-sticky-bar--visible {
    transform: translateY(0);
    pointer-events: auto;
  }

  .ph-sticky-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 14px 20px;
    background: var(--ph-ink);
    border-top: 1px solid rgba(255, 250, 242, 0.12);
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.2);
  }

  .ph-sticky-bar__text {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255, 250, 242, 0.85);
    font-size: 13px;
    font-weight: 650;
  }

  .ph-sticky-bar__text svg {
    color: var(--ph-clay);
    flex-shrink: 0;
  }

  .ph-sticky-bar__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 10px 22px;
    border-radius: 999px;
    background: var(--ph-clay);
    color: #fff;
    font-size: 12px;
    font-weight: 780;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .ph-sticky-bar__btn:hover {
    background: var(--ph-clay-dark);
    transform: translateY(-1px);
  }

  .ph-quiz,
  .ph-subscribe,
  .ph-reviews,
  .ph-compare,
  .ph-routine,
  .ph-ingredients,
  .ph-craft,
  .ph-fit,
  .ph-vet,
  .ph-guarantee,
  .ph-faq,
  .ph-close {
    content-visibility: auto;
    contain-intrinsic-size: auto 760px;
  }

  @media (max-width: 560px) {
    .ph-quiz,
    .ph-subscribe,
    .ph-reviews,
    .ph-compare,
    .ph-routine,
    .ph-ingredients,
    .ph-craft,
    .ph-fit,
    .ph-vet,
    .ph-guarantee,
    .ph-faq,
    .ph-close {
      content-visibility: visible;
      contain-intrinsic-size: none;
    }
  }

  .ph-back-top {
    position: fixed;
    right: 14px;
    bottom: 78px;
    z-index: 998;
    display: none;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 250, 242, 0.24);
    border-radius: 999px;
    background: var(--ph-ink);
    color: #fffaf2;
    box-shadow: 0 10px 26px rgba(23, 21, 18, 0.22);
    font-size: 18px;
    font-weight: 850;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .ph-back-top--visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ═══════════════════════════════════════════════════════════════
     FIND YOUR CHEW QUIZ
  ════════════════════════════════════════════════════════════════ */
  .ph-quiz {
    background: var(--ph-soft);
  }

  .ph-quiz__widget {
    max-width: 680px;
    margin: 0 auto;
    min-height: 320px;
  }

  .ph-quiz__step {
    display: none;
  }

  .ph-quiz__step--active {
    display: block;
    animation: ph-quiz-fade 0.35s ease;
  }

  @keyframes ph-quiz-fade {
    from { opacity: 0; transform: translateX(12px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .ph-quiz__step-label {
    margin: 0 0 8px;
    color: var(--ph-clay);
    font-size: 12px;
    font-weight: 780;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-align: center;
  }

  .ph-quiz__step h3 {
    text-align: center;
    margin-bottom: 24px;
    font-size: 26px;
  }

  .ph-quiz__options {
    display: grid;
    gap: 12px;
  }

  .ph-quiz__option {
    display: grid;
    grid-template-columns: 42px 1fr;
    grid-template-rows: auto auto;
    column-gap: 14px;
    align-items: center;
    padding: 18px 20px;
    border: 1px solid var(--ph-line);
    border-radius: var(--ph-radius);
    background: #fff;
    cursor: pointer;
    text-align: left;
    font: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }

  .ph-quiz__option:hover {
    border-color: var(--ph-clay);
    box-shadow: 0 4px 16px rgba(184, 95, 50, 0.1);
    transform: translateY(-1px);
  }

  .ph-quiz__option--selected {
    border-color: var(--ph-clay);
    background: #fff8f3;
    box-shadow: 0 0 0 2px var(--ph-clay);
    transform: translateY(-1px);
  }

  /* Returning visitor banner */
  .ph-quiz__returning-banner {
    background: linear-gradient(135deg, #fff8f3 0%, #fef3e8 100%);
    border: 1px solid rgba(184, 95, 50, 0.25);
    border-radius: var(--ph-radius);
    padding: 20px 24px;
    margin-bottom: 28px;
    text-align: center;
  }

  .ph-quiz__returning-banner p {
    margin: 0 0 14px;
    font-size: 15px;
    color: var(--ph-ink);
  }

  .ph-quiz__returning-banner strong {
    color: var(--ph-clay);
  }

  .ph-quiz__returning-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .ph-quiz__returning-cta {
    display: inline-block;
    padding: 10px 22px;
    background: var(--ph-clay);
    color: #fff;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .ph-quiz__returning-cta:hover {
    background: #9e4a22;
    color: #fff;
    text-decoration: none;
  }

  .ph-quiz__returning-retake {
    display: inline-block;
    padding: 10px 22px;
    background: transparent;
    color: var(--ph-clay);
    border: 1px solid var(--ph-clay);
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    font: inherit;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .ph-quiz__returning-retake:hover {
    background: var(--ph-clay);
    color: #fff;
  }

  .ph-quiz__option-icon {
    grid-row: 1 / span 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 999px;
    background: var(--ph-soft);
    font-size: 20px;
  }

  .ph-quiz__option-text {
    color: var(--ph-ink);
    font-size: 16px;
    font-weight: 720;
    line-height: 1.3;
  }

  .ph-quiz__option-sub {
    color: var(--ph-muted);
    font-size: 13px;
    line-height: 1.4;
  }

  /* Quiz result */
  .ph-quiz__result-card {
    text-align: center;
    padding: 36px 28px;
    border: 1px solid var(--ph-line);
    border-radius: var(--ph-radius);
    background: #fff;
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.06);
  }

  .ph-quiz__result-badge {
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(184, 95, 50, 0.1);
    color: var(--ph-clay);
    font-size: 12px;
    font-weight: 780;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 16px;
  }

  .ph-quiz__result-title {
    font-size: 32px !important;
    margin-bottom: 12px !important;
  }

  .ph-quiz__result-desc {
    max-width: 480px;
    margin: 0 auto 24px;
    font-size: 16px;
  }

  .ph-quiz__result-stats {
    display: flex;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .ph-quiz__result-stats span {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    color: var(--ph-muted);
  }

  .ph-quiz__result-stats strong {
    color: var(--ph-ink);
    font-size: 20px;
    font-weight: 780;
  }

  .ph-quiz__result-cta {
    margin-bottom: 16px;
  }

  .ph-quiz__email-form {
    display: grid;
    gap: 10px;
    max-width: 420px;
    margin: 0 auto 14px;
  }

  .ph-quiz__email-form label {
    color: var(--ph-muted);
    font-size: 13px;
    font-weight: 680;
  }

  .ph-quiz__email-form div {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 8px;
  }

  .ph-quiz__email-form input {
    min-height: 44px;
    border: 1px solid var(--ph-line);
    border-radius: 999px;
    padding: 0 16px;
    font: inherit;
    font-size: 14px;
  }

  .ph-quiz__email-form button {
    min-height: 44px;
    border: 0;
    border-radius: 999px;
    background: var(--ph-ink);
    color: #fff;
    cursor: pointer;
    font: inherit;
    font-size: 12px;
    font-weight: 780;
    padding: 0 18px;
    text-transform: uppercase;
  }

  .ph-quiz__restart {
    background: none;
    border: none;
    color: var(--ph-muted);
    font: inherit;
    font-size: 14px;
    font-weight: 650;
