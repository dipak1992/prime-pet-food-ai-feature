      <div class="ph-product-grid">
        {% render 'prime-home-product-card',
          product: product,
          variant: small_variant,
          image: small_dog_chew_image,
          image_alt: 'Small dog calmly chewing a small Himalayan yak chew',
          label: 'Small dogs',
          title: 'Small Yak Chew',
          fit: '1-15 lbs',
          text: 'A compact chew for small breeds and lighter chewing sessions.',
          badge: 'Small',
          best_for: 'Chihuahuas, Yorkies, and toy mixes'
        %}

        {% render 'prime-home-product-card',
          product: product,
          variant: medium_variant,
          image: medium_dog_chew_image,
          image_alt: 'Medium dog enjoying a medium Himalayan yak chew',
          label: 'Most popular',
          title: 'Medium Yak Chew',
          fit: '15-35 lbs',
          text: 'The everyday fit for steady chewers who need a reliable calm-time routine.',
          badge: 'Medium &bull; Best seller',
