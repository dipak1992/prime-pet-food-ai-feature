<!-- ═══════════════════════════════════════════════════════════════
     JAVASCRIPT — Quiz logic, scroll animations, sticky bar
════════════════════════════════════════════════════════════════ -->
<script>
(function() {
  'use strict';

  /* ─── SCROLL REVEAL (IntersectionObserver) ─── */
  const homepage = document.querySelector('.prime-homepage');
  const animationsEnabled = homepage && homepage.getAttribute('data-animations') !== 'false';
  const revealEls = document.querySelectorAll('.ph-reveal');

  if (!animationsEnabled) {
    revealEls.forEach(function(el) { el.classList.add('ph-revealed'); });
  } else if ('IntersectionObserver' in window) {
    const revealObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('ph-revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

    revealEls.forEach(function(el) { revealObserver.observe(el); });
  } else {
    revealEls.forEach(function(el) { el.classList.add('ph-revealed'); });
  }

  /* ─── STICKY SHOP BAR ─── */
  const stickyBar = document.getElementById('ph-sticky-bar');
  const productsSection = document.getElementById('prime-home-shop');
  if (stickyBar && productsSection && 'IntersectionObserver' in window) {
    const stickyObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting && entry.boundingClientRect.top < 0) {
          stickyBar.classList.add('ph-sticky-bar--visible');
          stickyBar.setAttribute('aria-hidden', 'false');
        } else {
          stickyBar.classList.remove('ph-sticky-bar--visible');
          stickyBar.setAttribute('aria-hidden', 'true');
        }
      });
    }, { threshold: 0 });

    stickyObserver.observe(productsSection);
  }

  /* ─── MOBILE BACK TO TOP ─── */
  var backTop = document.querySelector('[data-ph-back-top]');
  if (backTop) {
    var ticking = false;
    function updateBackTop() {
      var visible = window.innerWidth <= 560 && window.scrollY > 900;
      backTop.classList.toggle('ph-back-top--visible', visible);
      ticking = false;
    }
    window.addEventListener('scroll', function() {
      if (!ticking) {
        window.requestAnimationFrame(updateBackTop);
        ticking = true;
      }
    }, { passive: true });
    window.addEventListener('resize', updateBackTop);
    backTop.addEventListener('click', function() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
    updateBackTop();
  }

  /* ─── TRUST STAT COUNT-UP ─── */
  var countEls = document.querySelectorAll('[data-ph-count]');
  if (countEls.length && 'IntersectionObserver' in window && animationsEnabled) {
    var countObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var target = Number(el.getAttribute('data-ph-count') || 0);
        var suffix = el.getAttribute('data-ph-suffix') || '';
        var start = performance.now();
        var duration = 900;
        function tick(now) {
          var progress = Math.min((now - start) / duration, 1);
          var eased = 1 - Math.pow(1 - progress, 3);
          var value = Math.round(target * eased);
          el.textContent = value.toLocaleString() + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        countObserver.unobserve(el);
      });
    }, { threshold: 0.6 });
    countEls.forEach(function(el) { countObserver.observe(el); });
  }

  /* ─── FIND YOUR CHEW QUIZ ─── */
  var QUIZ_STORAGE_KEY = 'prime_quiz_result';
  var quizWidget = document.getElementById('ph-quiz-widget');
  if (!quizWidget) return;

  var answers = {};
  var steps = quizWidget.querySelectorAll('.ph-quiz__step');

  var recommendations = {
    small:  { title: 'Small Yak Chew',       duration: '~45 min', link: '/products/himalayan-yak-chews-for-dogs?variant=51744916701504', desc: 'A compact chew perfect for smaller breeds. Dense enough for focused enrichment without being overwhelming.' },
    medium: { title: 'Medium Yak Chew',      duration: '~67 min', link: '/products/himalayan-yak-chews-for-dogs?variant=51744918962496', desc: 'Our most popular size. Ideal for steady chewers who need a reliable calm-time routine.' },
    large:  { title: 'Large Yak Chew',       duration: '~85 min', link: '/products/himalayan-yak-chews-for-dogs?variant=51744918995264', desc: 'Built for bigger jaws and dogs that finish softer treats too quickly. Dense and long-lasting.' },
    xlarge: { title: 'Extra Large Yak Chew', duration: '~95 min', link: '/products/himalayan-yak-chews-for-dogs?variant=51744919028032', desc: 'For large dogs and power chewers who need more chew mass and a longer calm-time routine.' },
    jumbo:  { title: 'Jumbo Yak Chew',       duration: '~110 min', link: '/products/himalayan-yak-chews-for-dogs?variant=51744919060800', desc: 'For giant breeds and serious chewers. The largest Prime chew for supervised enrichment sessions.' }
  };

  function showStep(stepId) {
    steps.forEach(function(s) { s.classList.remove('ph-quiz__step--active'); });
    var target = quizWidget.querySelector('[data-step="' + stepId + '"]');
    if (target) target.classList.add('ph-quiz__step--active');
  }

  function getRecommendation() {
    var size = answers.weight || 'medium';
    var style = answers.chewing || 'moderate';
    if (style === 'aggressive') {
      if (size === 'small') size = 'medium';
      else if (size === 'medium') size = 'large';
      else if (size === 'large') size = 'xlarge';
      else size = 'jumbo';
    }
    return recommendations[size] || recommendations.medium;
  }

  function saveResult(rec) {
    try {
      localStorage.setItem(QUIZ_STORAGE_KEY, JSON.stringify({
        title:    rec.title,
        duration: rec.duration,
        link:     rec.link,
        desc:     rec.desc,
        savedAt:  Date.now()
      }));
    } catch(e) {}
  }

  function loadSavedResult() {
    try {
      var raw = localStorage.getItem(QUIZ_STORAGE_KEY);
      if (!raw) return null;
      var data = JSON.parse(raw);
      // Expire after 90 days
      if (Date.now() - data.savedAt > 90 * 24 * 60 * 60 * 1000) {
        localStorage.removeItem(QUIZ_STORAGE_KEY);
        return null;
      }
      return data;
    } catch(e) { return null; }
  }

  function showReturningBanner(saved) {
    var banner = quizWidget.querySelector('.ph-quiz__returning-banner');
    if (!banner) {
      banner = document.createElement('div');
      banner.className = 'ph-quiz__returning-banner';
      banner.innerHTML =
        '<p>Welcome back! Your last recommendation: <strong>' + saved.title + '</strong></p>' +
        '<div class="ph-quiz__returning-actions">' +
          '<a href="' + saved.link + '" class="ph-quiz__returning-cta">Shop ' + saved.title + ' &rarr;</a>' +
          '<button class="ph-quiz__returning-retake">Retake quiz</button>' +
        '</div>';
      quizWidget.insertBefore(banner, quizWidget.firstChild);
    }
    banner.style.display = 'block';

    banner.querySelector('.ph-quiz__returning-retake').addEventListener('click', function() {
      banner.style.display = 'none';
      try { localStorage.removeItem(QUIZ_STORAGE_KEY); } catch(e) {}
      answers = {};
      showStep('1');
    });
  }

  function showResult() {
    var rec = getRecommendation();
    var profileWeight = { small: 12, medium: 28, large: 48, xlarge: 72, jumbo: 90 }[answers.weight || 'medium'];
    var profileChewStyle = answers.chewing === 'aggressive' ? 'destroyer' : answers.chewing;
    var resultCard = quizWidget.querySelector('.ph-quiz__result-card');
    if (resultCard) {
      resultCard.querySelector('.ph-quiz__result-title').textContent = rec.title;
      resultCard.querySelector('.ph-quiz__result-desc').textContent = rec.desc;
      resultCard.querySelector('.ph-quiz__result-cta').href = rec.link;
      var stats = resultCard.querySelectorAll('.ph-quiz__result-stats strong');
      if (stats[0]) stats[0].textContent = rec.duration;
    }
    if (window.PrimeDogProfile && typeof window.PrimeDogProfile.save === 'function') {
      window.PrimeDogProfile.save({
        breed: 'mixed',
        weight: profileWeight,
        chewStyle: profileChewStyle || 'moderate',
        chewReason: answers.goal || 'calm',
        recommendedProductTitle: rec.title,
        recommendedProductUrl: rec.link,
        source: 'homepage_quiz'
      });
    }
    saveResult(rec);
    showStep('result');
  }

  // Check for returning visitor on load
  var savedResult = loadSavedResult();
  if (savedResult) {
    showReturningBanner(savedResult);
  }

  // Option click handlers
  quizWidget.addEventListener('click', function(e) {
    var option = e.target.closest('.ph-quiz__option');
    if (option) {
      // Visual selected state
      var siblingOptions = option.closest('.ph-quiz__step').querySelectorAll('.ph-quiz__option');
      siblingOptions.forEach(function(o) { o.classList.remove('ph-quiz__option--selected'); });
      option.classList.add('ph-quiz__option--selected');

      var step    = option.closest('.ph-quiz__step');
      var stepNum = step ? step.getAttribute('data-step') : null;
      var answer  = option.getAttribute('data-answer');
      var next    = option.getAttribute('data-next');

      if (stepNum === '1') answers.weight  = answer;
      else if (stepNum === '2') answers.chewing = answer;
      else if (stepNum === '3') answers.goal    = answer;

      // 180 ms delay so user sees the selected state before advancing
      setTimeout(function() {
        if (next === 'result') {
          showResult();
        } else if (next) {
          showStep(next);
        }
      }, 180);
    }

    // Restart
    if (e.target.closest('.ph-quiz__restart')) {
      try { localStorage.removeItem(QUIZ_STORAGE_KEY); } catch(e) {}
      answers = {};
      showStep('1');
    }
  });
})();
</script>

