{% liquid
  assign product = all_products['himalayan-yak-chews-for-dogs']
  assign hero_image = section.settings.hero_image | default: 'prime-calm-dog-yak-chew-hero.jpg' | asset_url
  assign lab_image = 'prime-ugc-labrador-chew-card.jpg' | asset_url
  assign frenchie_image = 'prime-ugc-french-bulldog-chew-card.jpg' | asset_url
  assign golden_image = 'prime-ugc-golden-retriever-chew-card.jpg' | asset_url
  assign shepherd_image = 'prime-ugc-german-shepherd-chew-card.jpg' | asset_url
  assign beagle_image = 'prime-ugc-beagle-chew-card.jpg' | asset_url
  assign poodle_image = 'prime-ugc-poodle-chew-card.jpg' | asset_url
  assign small_dog_chew_image = 'prime-home-small-dog-chew.jpg' | asset_url
  assign medium_dog_chew_image = 'prime-home-medium-dog-chew.jpg' | asset_url
  assign large_dog_chew_image = 'prime-home-large-dog-chew.jpg' | asset_url
  assign subscribe_dog_image = 'prime-home-subscribe-dog-box.jpg' | asset_url
  assign ingredient_yak_milk_image = 'prime-home-ingredient-yak-milk.jpg' | asset_url
  assign ingredient_cow_milk_image = 'prime-home-ingredient-cow-milk.jpg' | asset_url
  assign ingredient_lime_image = 'prime-home-ingredient-lime.jpg' | asset_url
  assign ingredient_salt_image = 'prime-home-ingredient-salt.jpg' | asset_url
  assign founder_image = 'prime-founder.png' | asset_url
  assign calm_cta_image = 'prime-home-calm-cta-bg.jpg' | asset_url

  assign hero_headline = section.settings.hero_headline | default: 'Calmer dogs start with a better chew.'
  assign hero_subtext = section.settings.hero_subtext | default: 'Long-lasting Himalayan yak cheese chews made with 4 simple ingredients. Built for focused chew time, cleaner enrichment, and fewer destroyed shoes.'
  assign trust_stat_1_value = section.settings.trust_stat_1_value | default: '20,000+'
  assign trust_stat_1_label = section.settings.trust_stat_1_label | default: 'Dog parents'
  assign trust_stat_2_value = section.settings.trust_stat_2_value | default: '4'
  assign trust_stat_2_label = section.settings.trust_stat_2_label | default: 'Ingredients only'
  assign trust_stat_3_value = section.settings.trust_stat_3_value | default: '67 min'
  assign trust_stat_3_label = section.settings.trust_stat_3_label | default: 'Avg chew time'
  assign trust_stat_4_value = section.settings.trust_stat_4_value | default: '30-day'
  assign trust_stat_4_label = section.settings.trust_stat_4_label | default: 'Guarantee'

  assign small_variant = nil
  assign medium_variant = nil
  assign large_variant = nil
  assign extra_large_variant = nil
  assign jumbo_variant = nil

  if product != blank
    for variant in product.variants
      if variant.id == 51744916701504
        assign small_variant = variant
      elsif variant.id == 51744918962496
        assign medium_variant = variant
      elsif variant.id == 51744918995264
        assign large_variant = variant
      elsif variant.id == 51744919028032
        assign extra_large_variant = variant
      elsif variant.id == 51744919060800
        assign jumbo_variant = variant
      endif
    endfor
  endif
%}

<section class="prime-homepage" aria-label="Prime Pet Food homepage" data-animations="{{ section.settings.enable_animations }}">

