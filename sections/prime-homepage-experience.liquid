  {% if section.settings.show_quiz %}
  <!-- ═══════════════════════════════════════════════════════════════
       FIND YOUR CHEW — Interactive 3-question quiz
  ════════════════════════════════════════════════════════════════ -->
  <div class="ph-quiz ph-reveal" id="ph-quiz-section">
    <div class="ph-shell">
      <div class="ph-section-head ph-section-head--center">
        <p class="ph-kicker">Not sure which size?</p>
        <h2>Find your dog&rsquo;s perfect chew in 30 seconds.</h2>
        <p>Answer 3 quick questions and we&rsquo;ll recommend the right size, quantity, and routine.</p>
      </div>

      <div class="ph-quiz__widget" id="ph-quiz-widget">
        <!-- Step 1: Dog weight -->
        <div class="ph-quiz__step ph-quiz__step--active" data-step="1">
          <p class="ph-quiz__step-label">Question 1 of 3</p>
          <h3>How much does your dog weigh?</h3>
          <div class="ph-quiz__options">
            <button type="button" class="ph-quiz__option" data-answer="small" data-next="2">
              <span class="ph-quiz__option-icon">🐕</span>
              <span class="ph-quiz__option-text">Under 15 lbs</span>
              <span class="ph-quiz__option-sub">Toy &amp; small breeds</span>
            </button>
            <button type="button" class="ph-quiz__option" data-answer="medium" data-next="2">
              <span class="ph-quiz__option-icon">🐕‍🦺</span>
              <span class="ph-quiz__option-text">15–35 lbs</span>
              <span class="ph-quiz__option-sub">Medium breeds</span>
            </button>
            <button type="button" class="ph-quiz__option" data-answer="large" data-next="2">
              <span class="ph-quiz__option-icon">🦮</span>
              <span class="ph-quiz__option-text">35–55 lbs</span>
              <span class="ph-quiz__option-sub">Large breeds</span>
            </button>
            <button type="button" class="ph-quiz__option" data-answer="xlarge" data-next="2">
              <span class="ph-quiz__option-icon">🐾</span>
              <span class="ph-quiz__option-text">55+ lbs</span>
              <span class="ph-quiz__option-sub">Extra large breeds</span>
            </button>
          </div>
        </div>

        <!-- Step 2: Chewing style -->
        <div class="ph-quiz__step" data-step="2">
          <p class="ph-quiz__step-label">Question 2 of 3</p>
          <h3>How does your dog chew?</h3>
          <div class="ph-quiz__options">
            <button type="button" class="ph-quiz__option" data-answer="gentle" data-next="3">
              <span class="ph-quiz__option-icon">😌</span>
              <span class="ph-quiz__option-text">Gentle nibbler</span>
              <span class="ph-quiz__option-sub">Takes their time, savors it</span>
            </button>
            <button type="button" class="ph-quiz__option" data-answer="moderate" data-next="3">
              <span class="ph-quiz__option-icon">😊</span>
              <span class="ph-quiz__option-text">Steady chewer</span>
              <span class="ph-quiz__option-sub">Consistent pace, focused</span>
            </button>
            <button type="button" class="ph-quiz__option" data-answer="aggressive" data-next="3">
              <span class="ph-quiz__option-icon">💪</span>
              <span class="ph-quiz__option-text">Power chewer</span>
              <span class="ph-quiz__option-sub">Destroys toys quickly</span>
            </button>
          </div>
        </div>

        <!-- Step 3: Goal -->
        <div class="ph-quiz__step" data-step="3">
          <p class="ph-quiz__step-label">Question 3 of 3</p>
          <h3>What&rsquo;s your main goal?</h3>
          <div class="ph-quiz__options">
            <button type="button" class="ph-quiz__option" data-answer="calm" data-next="result">
              <span class="ph-quiz__option-icon">🧘</span>
              <span class="ph-quiz__option-text">Calm &amp; settle</span>
              <span class="ph-quiz__option-sub">Help my dog relax and decompress</span>
            </button>
            <button type="button" class="ph-quiz__option" data-answer="occupy" data-next="result">
              <span class="ph-quiz__option-icon">⏰</span>
              <span class="ph-quiz__option-text">Keep busy</span>
              <span class="ph-quiz__option-sub">Occupy during work calls or crate time</span>
            </button>
            <button type="button" class="ph-quiz__option" data-answer="dental" data-next="result">
              <span class="ph-quiz__option-icon">🦷</span>
              <span class="ph-quiz__option-text">Dental health</span>
              <span class="ph-quiz__option-sub">Natural teeth cleaning while chewing</span>
            </button>
          </div>
        </div>

        <!-- Result -->
        <div class="ph-quiz__step ph-quiz__result" data-step="result">
          <div class="ph-quiz__result-card">
            <div class="ph-quiz__result-badge">Your perfect match</div>
            <h3 class="ph-quiz__result-title">Medium Yak Chew</h3>
            <p class="ph-quiz__result-desc">Based on your answers, we recommend starting with our medium chew for steady, focused enrichment sessions.</p>
            <div class="ph-quiz__result-stats">
              <span><strong>~67 min</strong> avg duration</span>
              <span><strong>4</strong> ingredients</span>
              <span><strong>100%</strong> digestible</span>
            </div>
            <a href="/collections/all" class="ph-button ph-button--primary ph-quiz__result-cta">Shop this size</a>
            {% form 'customer', class: 'ph-quiz__email-form' %}
              <input type="hidden" name="contact[tags]" value="homepage_quiz_recommendation">
              <label for="PrimeQuizEmail-{{ section.id }}">Want us to save this recommendation?</label>
              <div>
                <input id="PrimeQuizEmail-{{ section.id }}" type="email" name="contact[email]" placeholder="Email address" autocomplete="email">
                <button type="submit">Save</button>
              </div>
            {% endform %}
            <button type="button" class="ph-quiz__restart">← Retake quiz</button>
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

