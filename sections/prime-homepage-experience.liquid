    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════
       TRUST BAR — Key stats at a glance
  ════════════════════════════════════════════════════════════════ -->
  <div class="ph-trust-bar" aria-label="Key statistics">
    <div class="ph-shell ph-trust-bar__inner">
      <div class="ph-trust-bar__stat">
        <strong data-ph-count="20000" data-ph-suffix="+">{{ trust_stat_1_value }}</strong>
        <span>{{ trust_stat_1_label }}</span>
      </div>
      <div class="ph-trust-bar__stat">
