      "label": "Heading color",
      "default": "#1f4b3b"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "default": "#6f6f6f"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text color",
      "default": "#5f5f5f"
    },
    {
      "type": "color",
      "id": "card_label_color",
      "label": "Card small label color",
      "default": "#496155"
    },
    {
      "type": "color",
      "id": "side_card_bg",
      "label": "Side card background",
      "default": "#fbfaf8"
    },
    {
      "type": "color",
      "id": "side_card_border",
