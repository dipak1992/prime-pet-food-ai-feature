      "default": "#f9f3e8"
    },
    {
      "type": "color",
      "id": "featured_border",
      "label": "Featured card border",
      "default": "#d6a64d"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#d2632e"
    },
    {
      "type": "color",
      "id": "negative_icon_color",
      "label": "Negative icon color",
      "default": "#7b7b7b"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#d2632e"
    },
    {
      "type": "color",
      "id": "button_hover_bg",
