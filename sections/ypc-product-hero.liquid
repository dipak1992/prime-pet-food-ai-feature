    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 12px 28px rgba(210, 98, 46, 0.25);
  }

  .ypc-cta__text {
    font-weight: 900;
    letter-spacing: 0.4px;
  }

  .ypc-cta__divider {
    opacity: 0.85;
    font-weight: 900;
  }

  .ypc-cta__price,
  .ypc-cta__compare {
    font-size: 16px;
  }

  .ypc-cta__compare {
    font-weight: 750;
    text-decoration: line-through;
    opacity: 0.65;
  }

  .ypc-review-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 24px;
  }

  .ypc-review-card {
    background: #fffaf3;
    border: 1px solid rgba(43, 20, 8, 0.08);
    border-radius: 12px;
    padding: 16px;
    min-height: 130px;
  }

  .ypc-review-card img {
    width: 54px;
    height: 54px;
    border-radius: 999px;
    object-fit: cover;
    border: 2px solid #fff7ed;
    margin-bottom: 10px;
  }

  .ypc-review-card__stars {
    color: #2b1408;
    font-size: 17px;
    letter-spacing: 2px;
    line-height: 1;
    margin-bottom: 12px;
  }

  .ypc-review-card p {
    margin: 0;
    color: #2b1408;
    font-size: 13px;
    line-height: 1.5;
    font-weight: 500;
  }

  .ypc-size-guide-modal {
    position: fixed;
    inset: 0;
    z-index: 999999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ypc-size-guide-modal.is-open {
    display: flex;
  }

  .ypc-size-guide-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(43, 20, 8, 0.58);
  }

  .ypc-size-guide-modal__box {
    position: relative;
    z-index: 2;
    max-width: 820px;
    width: 100%;
    background: #fffaf3;
    border-radius: 18px;
    padding: 18px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.25);
  }

  .ypc-size-guide-modal__x {
    position: absolute;
    top: 10px;
    right: 14px;
    border: none;
    background: #d2622e;
    color: #fff;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    z-index: 3;
  }

  .ypc-size-guide-modal__image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 12px;
  }

  @media (max-width: 990px) {
    .ypc-product-hero__inner {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .ypc-product-hero__media {
      position: static;
      top: auto;
    }

    .ypc-product-hero__content {
      max-width: 100%;
    }

    .ypc-product-hero__main-image-wrap {
      height: min(52vh, 520px);
      min-height: 300px;
    }

    .ypc-review-cards {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    .ypc-product-hero {
      padding: 20px 16px 30px;
    }

    .ypc-product-hero__title {
      font-size: 27px;
    }

    .ypc-product-hero__main-image-wrap {
      height: min(44vh, 400px);
      min-height: 250px;
    }

    .ypc-hero-summary {
      padding: 12px;
      border-radius: 12px;
    }

    .ypc-hero-summary__lead {
      font-size: 12px;
      margin-bottom: 12px;
    }

    .ypc-hero-summary__list {
      grid-template-columns: repeat(2, 1fr);
    }

    .ypc-hero-summary__list li {
      padding: 14px 10px 14px 36px;
      font-size: 10px;
      letter-spacing: var(--prime-kicker-letter-spacing, 0.08em);
    }

    .ypc-hero-summary__list li::before {
      left: 12px;
      font-size: 14px;
    }

    .ypc-product-hero__price {
      font-size: 36px;
    }

    .ypc-profile-recommendation {
      grid-template-columns: 1fr;
    }

    .ypc-profile-recommendation a {
      width: fit-content;
    }

    .ypc-cart-row {
      grid-template-columns: 1fr;
    }

    .ypc-quantity {
      max-width: 170px;
    }

    .ypc-radio {
      grid-template-columns: 20px 1fr auto;
    }

    .ypc-badge {
      display: none;
    }
  }
</style>

