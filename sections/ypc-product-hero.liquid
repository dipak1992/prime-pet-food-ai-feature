{% assign current_variant = product.selected_or_first_available_variant %}
{% assign featured_media = current_variant.featured_media | default: product.featured_media %}

{% liquid
  assign product_title_downcase = product.title | downcase

  assign hero_lead = ''
  assign hero_rating_text = ''
  assign hero_benefit_1 = ''
  assign hero_benefit_2 = ''
  assign hero_benefit_3 = ''
  assign hero_benefit_4 = ''
  assign hero_benefit_5 = ''
  assign hero_benefit_6 = ''

  if product.metafields.custom.hero_lead.value != blank
    assign hero_lead = product.metafields.custom.hero_lead.value
  endif

  if product.metafields.custom.hero_rating_text.value != blank
    assign hero_rating_text = product.metafields.custom.hero_rating_text.value
  endif

  if product.metafields.custom.hero_benefit_1.value != blank
    assign hero_benefit_1 = product.metafields.custom.hero_benefit_1.value
  endif
  if product.metafields.custom.hero_benefit_2.value != blank
    assign hero_benefit_2 = product.metafields.custom.hero_benefit_2.value
  endif
  if product.metafields.custom.hero_benefit_3.value != blank
    assign hero_benefit_3 = product.metafields.custom.hero_benefit_3.value
  endif
  if product.metafields.custom.hero_benefit_4.value != blank
    assign hero_benefit_4 = product.metafields.custom.hero_benefit_4.value
  endif
  if product.metafields.custom.hero_benefit_5.value != blank
    assign hero_benefit_5 = product.metafields.custom.hero_benefit_5.value
  endif
  if product.metafields.custom.hero_benefit_6.value != blank
    assign hero_benefit_6 = product.metafields.custom.hero_benefit_6.value
  endif

  if hero_lead == blank
    assign hero_lead = section.settings.hero_lead
  endif
  if hero_rating_text == blank
    assign hero_rating_text = section.settings.hero_rating_text
  endif
  if hero_benefit_1 == blank
    assign hero_benefit_1 = section.settings.hero_benefit_1
  endif
  if hero_benefit_2 == blank
    assign hero_benefit_2 = section.settings.hero_benefit_2
  endif
  if hero_benefit_3 == blank
    assign hero_benefit_3 = section.settings.hero_benefit_3
  endif
  if hero_benefit_4 == blank
    assign hero_benefit_4 = section.settings.hero_benefit_4
  endif
  if hero_benefit_5 == blank
    assign hero_benefit_5 = section.settings.hero_benefit_5
  endif
  if hero_benefit_6 == blank
    assign hero_benefit_6 = section.settings.hero_benefit_6
  endif

  assign urgency_threshold = section.settings.low_stock_threshold | default: 8
  assign current_urgency_text = section.settings.urgency_fallback_text | default: "Popular size - ships fast while today's batch lasts."
  if current_variant.inventory_management != blank and current_variant.inventory_policy != 'continue' and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= urgency_threshold
    assign current_urgency_text = 'Only ' | append: current_variant.inventory_quantity | append: ' left in this size'
  elsif current_variant.available == false
    assign current_urgency_text = 'This size is currently out of stock'
  endif
%}

<section class="ypc-product-hero">
  <div class="ypc-product-hero__inner">
    <div class="ypc-product-hero__media">
      {% if featured_media %}
        <div class="ypc-product-hero__main-image-wrap">
          <img
            id="ypc-main-image"
            src="{{ featured_media | image_url: width: 900 }}"
            alt="{{ featured_media.alt | default: product.title | escape }}"
            width="{{ featured_media.width }}"
            height="{{ featured_media.height }}"
            loading="eager"
            class="ypc-product-hero__main-image"
          >
        </div>
      {% endif %}

      {% if product.images.size > 0 %}
        <div class="ypc-product-hero__thumb-row" id="ypc-thumb-row">
          {% for image in product.images %}
            <button
              type="button"
              class="ypc-product-hero__thumb {% if image.id == featured_media.id %}is-active{% endif %}"
              data-image-id="{{ image.id }}"
              data-image-url="{{ image | image_url: width: 900 }}"
              data-image-alt="{{ image.alt | default: product.title | escape }}"
              aria-label="View image {{ forloop.index }}"
            >
              <img
                src="{{ image | image_url: width: 140, height: 140 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                width="140"
                height="140"
                loading="lazy"
              >
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="ypc-product-hero__content">
      {% if section.settings.show_vet_badge %}
        <div class="ypc-vet-badge">✦ {{ section.settings.vet_badge_text }}</div>
      {% endif %}

      <h1 class="ypc-product-hero__title">{{ product.title }}</h1>

      {% if section.settings.show_reviews %}
        <div class="ypc-review-row">
          <span class="ypc-review-stars">{{ section.settings.review_stars }}</span>
          <span class="ypc-review-text">{{ section.settings.review_text }}</span>
        </div>
      {% endif %}

      <div class="ypc-hero-summary">
        {% if hero_lead != blank %}
          <p class="ypc-hero-summary__lead">{{ hero_lead }}</p>
        {% endif %}

        <ul class="ypc-hero-summary__list">
          {% if hero_benefit_1 != blank %}<li>{{ hero_benefit_1 }}</li>{% endif %}
          {% if hero_benefit_2 != blank %}<li>{{ hero_benefit_2 }}</li>{% endif %}
          {% if hero_benefit_3 != blank %}<li>{{ hero_benefit_3 }}</li>{% endif %}
          {% if hero_benefit_4 != blank %}<li>{{ hero_benefit_4 }}</li>{% endif %}
          {% if hero_benefit_5 != blank %}<li>{{ hero_benefit_5 }}</li>{% endif %}
          {% if hero_benefit_6 != blank %}<li>{{ hero_benefit_6 }}</li>{% endif %}
        </ul>
      </div>

      {% form 'product', product, id: 'ypc-product-form', class: 'ypc-product-hero__form' %}
        {% unless product.has_only_default_variant %}
          {% for option in product.options_with_values %}
            {% assign option_name_downcase = option.name | downcase %}

            <div class="ypc-product-hero__option">
              <div class="ypc-product-hero__option-header">
                <div class="ypc-product-hero__option-label">Select {{ option.name }}</div>

                {% if option_name_downcase contains 'size' and section.settings.size_guide_image != blank %}
                  <button type="button" class="ypc-size-guide-trigger" id="ypc-size-guide-open">
                    {{ section.settings.size_guide_label }}
                  </button>
                {% endif %}
              </div>

              <div class="ypc-product-hero__options" data-option-position="{{ option.position }}">
                {% for value in option.values %}
                  <button
                    type="button"
                    class="ypc-product-hero__option-btn {% if option.selected_value == value %}is-active{% endif %}"
                    data-value="{{ value | escape }}"
                  >
                    {{ value }}
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        {% endunless %}

        <div class="ypc-size-hint">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Not sure which size?
          <a href="#chew-analyzer" class="ypc-size-hint__link" id="ypc-size-hint-link">Find the right fit for your dog &rarr;</a>
        </div>

        <input type="hidden" name="id" id="ypc-variant-id" value="{{ current_variant.id }}">

        <div class="ypc-product-hero__price-wrap">
          <div class="ypc-product-hero__price-row">
            <div class="ypc-product-hero__price" id="ypc-price">
              {{ current_variant.price | money }}
            </div>

            {% if current_variant.compare_at_price > current_variant.price %}
              <div class="ypc-product-hero__compare-price" id="ypc-compare-price">
                {{ current_variant.compare_at_price | money }}
              </div>

              {% assign save_pct = current_variant.compare_at_price
                | minus: current_variant.price
                | times: 100
                | divided_by: current_variant.compare_at_price
              %}
              <div class="ypc-product-hero__save-badge" id="ypc-save-badge">SAVE {{ save_pct }}%</div>
            {% else %}
              <div class="ypc-product-hero__compare-price" id="ypc-compare-price" style="display:none;"></div>
              <div class="ypc-product-hero__save-badge" id="ypc-save-badge" style="display:none;"></div>
            {% endif %}
          </div>
        </div>

        {% if section.settings.show_info_line %}
          <div class="ypc-info-line">
            <span id="ypc-per-chew">{{ section.settings.per_chew_prefix }}</span>
            <span class="ypc-dot">•</span>
            <span>{{ section.settings.shipping_text }}</span>
            <span class="ypc-dot">•</span>
            <span>Estimated delivery by <strong data-ypc-delivery-date></strong></span>
          </div>
        {% endif %}

        {% if section.settings.show_urgency_signals != false %}
          <div class="ypc-urgency" id="ypc-urgency" aria-live="polite">
            <span class="ypc-urgency__item ypc-urgency__item--stock">
              <span class="ypc-urgency__dot" aria-hidden="true"></span>
              <span id="ypc-urgency-stock">{{ current_urgency_text }}</span>
            </span>
            <span class="ypc-urgency__item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>{{ section.settings.urgency_shipping_text | default: 'Ships quickly from current inventory' }}</span>
            </span>
          </div>
        {% endif %}

        <div class="ypc-conversion-badges" aria-label="Purchase reassurance">
          <span>Safety tested</span>
          <span>$0.22/hour of calm time</span>
          <span>30-day chew duration guarantee</span>
        </div>

        <div class="ypc-profile-recommendation" data-ypc-profile-card hidden>
          <div>
            <span>Your dog profile</span>
            <strong data-ypc-profile-size>Recommended size</strong>
            <p data-ypc-profile-duration>Estimated chew duration based on your saved dog profile.</p>
          </div>
          <a href="/pages/my-dog">View My Dog</a>
        </div>

        {% if product.selling_plan_groups.size > 0 %}
          <div class="ypc-subscription">
            <div class="ypc-sub-toggle">
              <label class="ypc-radio" id="ypc-one-time-card">
                <input type="radio" name="purchase_type" value="one_time" checked>
                <span class="ypc-radio__label">One-time purchase</span>
                <span class="ypc-price-inline" id="ypc-one-time-price">{{ current_variant.price | money }}</span>
              </label>

              <label class="ypc-radio highlight" id="ypc-subscribe-card">
                <input type="radio" name="purchase_type" value="subscription">
                <span class="ypc-radio__label">{{ section.settings.subscribe_label }}</span>
                <span class="ypc-badge" id="ypc-sub-badge">SAVE 15%</span>
                <span class="ypc-price-inline" id="ypc-sub-price"></span>
              </label>
            </div>

            <div class="ypc-frequency" id="ypc-frequency" style="display:none;">
              <select name="selling_plan" id="ypc-selling-plan">
                {% for group in product.selling_plan_groups %}
                  {% for plan in group.selling_plans %}
                    <option
                      value="{{ plan.id }}"
                      data-adjustment-value="{{ plan.price_adjustments[0].value }}"
                      data-adjustment-type="{{ plan.price_adjustments[0].value_type }}"
                    >
                      {{ plan.name }}
                    </option>
                  {% endfor %}
                {% endfor %}
              </select>
            </div>

            <div class="ypc-subscription-proof" aria-label="Subscribe and Save benefits">
              <span>Never run out</span>
              <span>Skip or cancel anytime</span>
              <span>Cancel in 2 clicks</span>
              <span>Built for steady chew routines</span>
            </div>
          </div>
        {% endif %}

        <details class="ypc-guarantee-details">
          <summary>What if my dog does not love it?</summary>
          <p>Try Prime during supervised chew sessions for 30 days. If the size, chew pace, or routine fit is not right, contact us and we will help with a replacement size or a refund.</p>
        </details>

        <div class="ypc-cart-row">
          <div class="ypc-quantity" aria-label="Quantity selector">
            <button type="button" class="ypc-quantity__btn" id="ypc-qty-minus" aria-label="Decrease quantity">−</button>
            <input
              type="number"
              name="quantity"
              id="ypc-quantity-input"
              class="ypc-quantity__input"
              value="1"
              min="1"
              inputmode="numeric"
            >
            <button type="button" class="ypc-quantity__btn" id="ypc-qty-plus" aria-label="Increase quantity">+</button>
          </div>

          <button type="submit" class="ypc-product-hero__cta" id="ypc-add-to-cart-btn">
            <span class="ypc-cta__text">{{ section.settings.cta_text }}</span>
            <span class="ypc-cta__divider">-</span>
            <span class="ypc-cta__price" id="ypc-cta-price">{{ current_variant.price | money }}</span>
            <span class="ypc-cta__compare" id="ypc-cta-compare" style="display:none;"></span>
          </button>
        </div>
      {% endform %}

      {% if section.settings.show_review_cards %}
        <div class="ypc-review-cards">
          <div class="ypc-review-card">
            <img src="{{ 'prime-ugc-golden-retriever-chew-card.jpg' | asset_url }}" alt="Golden Retriever enjoying a Prime yak chew at home" loading="lazy" width="96" height="96">
            <div class="ypc-review-card__stars">★★★★★</div>
            <p>{{ section.settings.review_card_1 }}</p>
          </div>

          <div class="ypc-review-card">
            <img src="{{ 'prime-ugc-labrador-chew-card.jpg' | asset_url }}" alt="Labrador chewing a Prime Himalayan yak chew" loading="lazy" width="96" height="96">
            <div class="ypc-review-card__stars">★★★★★</div>
            <p>{{ section.settings.review_card_2 }}</p>
          </div>

          <div class="ypc-review-card">
            <img src="{{ 'prime-ugc-french-bulldog-chew-card.jpg' | asset_url }}" alt="French Bulldog with a Prime yak chew" loading="lazy" width="96" height="96">
            <div class="ypc-review-card__stars">★★★★★</div>
            <p>{{ section.settings.review_card_3 }}</p>
          </div>
        </div>
      {% endif %}
    </div>
  </div>

  {% if section.settings.size_guide_image != blank %}
    <div class="ypc-size-guide-modal" id="ypc-size-guide-modal" aria-hidden="true">
      <div class="ypc-size-guide-modal__overlay" id="ypc-size-guide-close"></div>

      <div class="ypc-size-guide-modal__box">
        <button type="button" class="ypc-size-guide-modal__x" id="ypc-size-guide-x" aria-label="Close size guide">
          ×
        </button>

        <img
          src="{{ section.settings.size_guide_image | image_url: width: 1400 }}"
          alt="Prime Pet Food yak chew size guide by dog weight"
          width="{{ section.settings.size_guide_image.width }}"
          height="{{ section.settings.size_guide_image.height }}"
          class="ypc-size-guide-modal__image"
          loading="lazy"
        >
      </div>
    </div>
  {% endif %}
</section>

<script>
  (function() {
    const variants = {{ product.variants | json }};
    const variantInventory = {
      {% for variant in product.variants %}
        "{{ variant.id }}": {
          "available": {{ variant.available | json }},
          "inventory_quantity": {{ variant.inventory_quantity | json }},
          "inventory_management": {{ variant.inventory_management | json }},
          "inventory_policy": {{ variant.inventory_policy | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    };
    const mainImage = document.getElementById('ypc-main-image');
    const variantIdInput = document.getElementById('ypc-variant-id');
    const priceEl = document.getElementById('ypc-price');
    const comparePriceEl = document.getElementById('ypc-compare-price');
    const saveBadgeEl = document.getElementById('ypc-save-badge');
    const thumbs = document.querySelectorAll('.ypc-product-hero__thumb');

    const purchaseTypeRadios = document.querySelectorAll("input[name='purchase_type']");
    const frequencyWrap = document.getElementById('ypc-frequency');
    const sellingPlanSelect = document.getElementById('ypc-selling-plan');
    const subPriceEl = document.getElementById('ypc-sub-price');
    const subBadgeEl = document.getElementById('ypc-sub-badge');
    const oneTimePriceEl = document.getElementById('ypc-one-time-price');

    const ctaPriceEl = document.getElementById('ypc-cta-price');
    const ctaCompareEl = document.getElementById('ypc-cta-compare');
    const perChewEl = document.getElementById('ypc-per-chew');
    const deliveryDateEl = document.querySelector('[data-ypc-delivery-date]');
    const urgencyStockEl = document.getElementById('ypc-urgency-stock');

    const qtyInput = document.getElementById('ypc-quantity-input');
    const qtyMinus = document.getElementById('ypc-qty-minus');
    const qtyPlus = document.getElementById('ypc-qty-plus');

    const sizeGuideOpen = document.getElementById('ypc-size-guide-open');
    const sizeGuideModal = document.getElementById('ypc-size-guide-modal');
    const sizeGuideClose = document.getElementById('ypc-size-guide-close');
    const sizeGuideX = document.getElementById('ypc-size-guide-x');

    function getSelectedOptions() {
      const selected = [];
      document.querySelectorAll('.ypc-product-hero__options').forEach((group) => {
        const activeBtn = group.querySelector('.ypc-product-hero__option-btn.is-active');
        selected.push(activeBtn ? activeBtn.dataset.value : null);
      });
      return selected;
    }

    function findVariant(selectedOptions) {
      return variants.find((variant) => {
        return variant.options.every((opt, index) => opt === selectedOptions[index]);
      });
    }

    function getCurrentVariant() {
      return findVariant(getSelectedOptions()) || variants[0];
    }

    function getCurrentPurchaseType() {
      const checked = document.querySelector("input[name='purchase_type']:checked");
      return checked ? checked.value : 'one_time';
    }

    function getSelectedSellingPlanOption() {
      if (!sellingPlanSelect) return null;
      return sellingPlanSelect.options[sellingPlanSelect.selectedIndex] || null;
    }

    function formatMoney(cents) {
      return '$' + (cents / 100).toFixed(2);
    }

    function activateThumb(thumb) {
      thumbs.forEach((t) => t.classList.remove('is-active'));
      if (thumb) {
        thumb.classList.add('is-active');
        thumb.scrollIntoView({
          behavior: 'smooth',
          inline: 'center',
          block: 'nearest'
        });
      }
    }

    function setActiveThumbByVariant(variant) {
      if (!variant || !variant.featured_image) return;

      const variantImageId = String(variant.featured_image.id);
      let matchedThumb = null;

      thumbs.forEach((thumb) => {
        thumb.classList.remove('is-active');
        if (thumb.dataset.imageId === variantImageId) {
          matchedThumb = thumb;
        }
      });

      if (matchedThumb) activateThumb(matchedThumb);
    }

    function slideMainImage(newUrl, newAlt) {
      if (!mainImage || !newUrl) return;
      if (mainImage.src === newUrl) return;

      mainImage.classList.add('is-sliding-out');

      setTimeout(() => {
        mainImage.src = newUrl;
        mainImage.alt = newAlt || '{{ product.title | escape }}';
        mainImage.classList.remove('is-sliding-out');
        mainImage.classList.add('is-sliding-in');
      }, 180);

      setTimeout(() => {
        mainImage.classList.remove('is-sliding-in');
      }, 380);
    }

    function calculateSubscriptionPrice(basePrice, selectedPlanOption) {
      if (!selectedPlanOption) return basePrice;

      const adjustmentValue = parseFloat(selectedPlanOption.dataset.adjustmentValue || 0);
      const adjustmentType = selectedPlanOption.dataset.adjustmentType || 'percentage';

      if (adjustmentType === 'percentage') {
        return Math.round(basePrice * (1 - adjustmentValue / 100));
      }

      if (adjustmentType === 'fixed_amount') {
        return Math.max(0, basePrice - adjustmentValue);
      }

      return basePrice;
    }

    function updateSubscriptionDisplay(variant) {
      if (!variant) return;

      if (oneTimePriceEl) {
        oneTimePriceEl.textContent = formatMoney(variant.price);
      }

      const selectedPlanOption = getSelectedSellingPlanOption();
      const subPrice = calculateSubscriptionPrice(variant.price, selectedPlanOption);

      if (subPriceEl) {
        subPriceEl.textContent = formatMoney(subPrice);
      }

      if (subBadgeEl && selectedPlanOption) {
        const adjustmentValue = parseFloat(selectedPlanOption.dataset.adjustmentValue || 0);
        subBadgeEl.textContent = 'SAVE ' + adjustmentValue + '%';
      }
    }

    function updateMainPriceArea(activePrice, activeComparePrice) {
      if (priceEl) priceEl.textContent = formatMoney(activePrice);

      if (comparePriceEl && saveBadgeEl) {
        if (activeComparePrice && activeComparePrice > activePrice) {
          comparePriceEl.style.display = 'block';
          comparePriceEl.textContent = formatMoney(activeComparePrice);

          const savePct = Math.round(((activeComparePrice - activePrice) * 100) / activeComparePrice);
          saveBadgeEl.style.display = 'block';
          saveBadgeEl.textContent = 'SAVE ' + savePct + '%';
        } else {
          comparePriceEl.style.display = 'none';
          comparePriceEl.textContent = '';
          saveBadgeEl.style.display = 'none';
          saveBadgeEl.textContent = '';
        }
      }
    }

    function updateAddToCartButton(activePrice, activeComparePrice) {
      if (!ctaPriceEl || !ctaCompareEl) return;

      ctaPriceEl.textContent = formatMoney(activePrice);

      if (activeComparePrice && activeComparePrice > activePrice) {
        ctaCompareEl.style.display = 'inline';
        ctaCompareEl.textContent = formatMoney(activeComparePrice);
      } else {
        ctaCompareEl.style.display = 'none';
        ctaCompareEl.textContent = '';
      }
    }

    function updatePerChew(variant, activePrice) {
      if (!perChewEl || !variant) return;

      const piecesOption = variant.options.find(opt => /pc|count|piece|lb/i.test(opt));
      const qty = piecesOption ? parseInt(piecesOption, 10) : 1;

      if (qty && qty > 0) {
        const perChew = activePrice / qty;
        perChewEl.textContent = '$' + (perChew / 100).toFixed(2) + ' per chew';
      } else {
        perChewEl.textContent = '{{ section.settings.per_chew_prefix }}';
      }
    }

    function setDeliveryEstimate() {
      if (!deliveryDateEl) return;
      const estimate = new Date();
      let addedDays = 0;

      while (addedDays < 4) {
        estimate.setDate(estimate.getDate() + 1);
        const day = estimate.getDay();
        if (day !== 0 && day !== 6) addedDays += 1;
      }

      deliveryDateEl.textContent = estimate.toLocaleDateString(undefined, {
        weekday: 'short',
        month: 'short',
        day: 'numeric'
      });
    }

    function updateUrgency(variant) {
      if (!urgencyStockEl || !variant) return;

      const inventory = variantInventory[String(variant.id)] || variant;
      const threshold = {{ section.settings.low_stock_threshold | default: 8 | json }};
      const fallbackText = {{ section.settings.urgency_fallback_text | default: "Popular size - ships fast while today's batch lasts." | json }};
      const inventoryManaged = inventory.inventory_management && inventory.inventory_policy !== 'continue';
      const inventoryQuantity = Number(inventory.inventory_quantity);

      if (inventory.available === false) {
        urgencyStockEl.textContent = 'This size is currently out of stock';
      } else if (inventoryManaged && inventoryQuantity > 0 && inventoryQuantity <= threshold) {
        urgencyStockEl.textContent = 'Only ' + inventoryQuantity + ' left in this size';
      } else {
        urgencyStockEl.textContent = fallbackText;
      }

      document.dispatchEvent(new CustomEvent('ypc:urgency:update', {
        detail: { text: urgencyStockEl.textContent }
      }));
    }

    function updateVariantUI(variant) {
      if (!variant) return;

      if (variantIdInput) variantIdInput.value = variant.id;

      const purchaseType = getCurrentPurchaseType();
      const selectedPlanOption = getSelectedSellingPlanOption();

      let activePrice = variant.price;
      let activeComparePrice = variant.compare_at_price;

      if (purchaseType === 'subscription' && selectedPlanOption) {
        activePrice = calculateSubscriptionPrice(variant.price, selectedPlanOption);
        activeComparePrice = variant.price;
      }

      updateSubscriptionDisplay(variant);
      updateMainPriceArea(activePrice, activeComparePrice);
      updateAddToCartButton(activePrice, activeComparePrice);
      updatePerChew(variant, activePrice);
      updateUrgency(variant);

      if (variant.featured_image && mainImage) {
        const newUrl = variant.featured_image.src + '&width=900';
        slideMainImage(newUrl, variant.featured_image.alt || '{{ product.title | escape }}');
        setActiveThumbByVariant(variant);
      }
    }

    document.querySelectorAll('.ypc-product-hero__option-btn').forEach((button) => {
      button.addEventListener('click', function() {
        const parent = this.closest('.ypc-product-hero__options');
        parent.querySelectorAll('.ypc-product-hero__option-btn').forEach((btn) => btn.classList.remove('is-active'));
        this.classList.add('is-active');
        updateVariantUI(getCurrentVariant());
      });
    });

    function normalizeProfileSize(value) {
      return String(value || '')
        .toLowerCase()
        .replace(/\(.+?\)/g, '')
        .replace(/extra\s+large|xlarge/g, 'xl')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function applyDogProfileRecommendation() {
      if (window.location.search.indexOf('variant=') !== -1) return;
      if (!window.PrimeDogProfile || typeof window.PrimeDogProfile.getRecommendation !== 'function') return;

      const recommendation = window.PrimeDogProfile.getRecommendation();
      const targetSize = normalizeProfileSize(recommendation && (recommendation.variantTitle || recommendation.size));
      if (!targetSize) return;

      const profileCard = document.querySelector('[data-ypc-profile-card]');
      if (profileCard && recommendation) {
        const sizeEl = profileCard.querySelector('[data-ypc-profile-size]');
        const durationEl = profileCard.querySelector('[data-ypc-profile-duration]');
        if (sizeEl) sizeEl.textContent = (recommendation.variantTitle || recommendation.size || 'Prime') + ' Yak Chew';
        if (durationEl) {
          durationEl.textContent = 'Estimated ' + (recommendation.durationRange || (recommendation.duration + ' minutes')) + ' for your saved dog profile.';
        }
        profileCard.hidden = false;
      }

      const sizeGroup = Array.prototype.find.call(document.querySelectorAll('.ypc-product-hero__options'), function(group) {
        const label = group.closest('.ypc-product-hero__option')?.querySelector('.ypc-product-hero__option-label');
        return label && /size/i.test(label.textContent || '');
      });
      if (!sizeGroup) return;

      const matchedButton = Array.prototype.find.call(sizeGroup.querySelectorAll('.ypc-product-hero__option-btn'), function(button) {
        const buttonSize = normalizeProfileSize(button.dataset.value || button.textContent);
        return buttonSize === targetSize || buttonSize.indexOf(targetSize) !== -1 || targetSize.indexOf(buttonSize) !== -1;
      });
      if (!matchedButton || matchedButton.classList.contains('is-active')) return;

      sizeGroup.querySelectorAll('.ypc-product-hero__option-btn').forEach((btn) => btn.classList.remove('is-active'));
      matchedButton.classList.add('is-active');
    }

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', function() {
        activateThumb(this);

        const imageUrl = this.dataset.imageUrl;
        const imageAlt = this.dataset.imageAlt;

        if (mainImage && imageUrl) {
          slideMainImage(imageUrl, imageAlt || '{{ product.title | escape }}');
        }
      });
    });

    if (purchaseTypeRadios.length) {
      purchaseTypeRadios.forEach((radio) => {
        radio.addEventListener('change', function() {
          if (this.value === 'subscription') {
            if (frequencyWrap) frequencyWrap.style.display = 'block';
          } else {
            if (frequencyWrap) frequencyWrap.style.display = 'none';
            if (sellingPlanSelect) sellingPlanSelect.value = sellingPlanSelect.options[0]?.value || '';
          }

          updateVariantUI(getCurrentVariant());
        });
      });
    }

    if (sellingPlanSelect) {
      sellingPlanSelect.addEventListener('change', function() {
        updateVariantUI(getCurrentVariant());
      });
    }

    function applySubscriptionIntent() {
      const params = new URLSearchParams(window.location.search);
      if (params.get('purchase') !== 'subscription') return;
      const subscribeRadio = Array.prototype.find.call(purchaseTypeRadios, function(radio) {
        return radio.value === 'subscription';
      });
      if (!subscribeRadio) return;
      subscribeRadio.checked = true;
      if (frequencyWrap) frequencyWrap.style.display = 'block';
    }

    if (qtyMinus && qtyInput) {
      qtyMinus.addEventListener('click', function() {
        const currentQty = parseInt(qtyInput.value || '1', 10);
        qtyInput.value = Math.max(1, currentQty - 1);
      });
    }

    if (qtyPlus && qtyInput) {
      qtyPlus.addEventListener('click', function() {
        const currentQty = parseInt(qtyInput.value || '1', 10);
        qtyInput.value = currentQty + 1;
      });
    }

    if (qtyInput) {
      qtyInput.addEventListener('change', function() {
        const currentQty = parseInt(qtyInput.value || '1', 10);
        qtyInput.value = Math.max(1, currentQty);
      });
    }

    function openSizeGuide() {
      if (!sizeGuideModal) return;
      sizeGuideModal.classList.add('is-open');
      sizeGuideModal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeSizeGuide() {
      if (!sizeGuideModal) return;
      sizeGuideModal.classList.remove('is-open');
      sizeGuideModal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    if (sizeGuideOpen) sizeGuideOpen.addEventListener('click', openSizeGuide);
    if (sizeGuideClose) sizeGuideClose.addEventListener('click', closeSizeGuide);
    if (sizeGuideX) sizeGuideX.addEventListener('click', closeSizeGuide);

    document.addEventListener('keydown', function(event) {
      if (event.key === 'Escape') closeSizeGuide();
    });

    applyDogProfileRecommendation();
    applySubscriptionIntent();
    setDeliveryEstimate();
    updateVariantUI(getCurrentVariant());
  })();

  /* ─── Size hint smooth scroll ─── */
  var sizeHintLink = document.getElementById('ypc-size-hint-link');
  if (sizeHintLink) {
    sizeHintLink.addEventListener('click', function(e) {
      var target = document.getElementById('chew-analyzer-widget') || document.getElementById('chew-analyzer-section');
      if (target && target._chewAnalyzer) {
        e.preventDefault();
        target._chewAnalyzer.open();
      } else {
        target = document.getElementById('chew-analyzer');
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  }
</script>

