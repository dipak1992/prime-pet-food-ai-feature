{{ 'prime-roadmap.css' | asset_url | stylesheet_tag }}

<section class="plr" aria-labelledby="PrimeLoyaltyTitle">
  <div class="plr__inner">
    <header class="plr__hero">
      <p class="plr__kicker">Prime Pet Food Pack Rewards</p>
      <h1 id="PrimeLoyaltyTitle">Share calmer chew time. Earn better routines.</h1>
      <p>Invite another dog parent into a calmer enrichment routine. They get a better first chew session, and you earn credit toward your next restock.</p>
      <div class="plr__actions">
        <a href="/pages/contact" class="plr__button plr__button--primary">Request referral link</a>
        <a href="/pages/subscribe-and-save" class="plr__button plr__button--secondary">Subscribe &amp; Save</a>
      </div>
    </header>

    <div class="plr__grid">
      <article>
        <span>Refer</span>
        <h2>Give $10, get $10</h2>
        <p>Send a referral link to a friend who wants a safer rawhide-free chew routine. When they order, both households save.</p>
      </article>
      <article>
        <span>Repeat</span>
        <h2>Reward routine builders</h2>
        <p>Subscribers and repeat customers get a clear place to track future rewards, reorder credit, and routine-building perks.</p>
      </article>
      <article>
        <span>Share</span>
        <h2>Community chew reports</h2>
        <p>Log real chew duration in My Dog to help other dog parents choose the right size for their household.</p>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Prime Pet Food rewards",
  "settings": [],
  "presets": [
    { "name": "Prime Pet Food rewards" }
  ]
}
{% endschema %}
