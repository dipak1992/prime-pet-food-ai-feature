<section class="prime-blog-newsletter" aria-labelledby="PrimeBlogNewsletterTitle">
  <div class="pbn-shell">
    <div class="pbn-panel">
      <div class="pbn-copy">
        <p class="pbn-kicker">Prime Pet Food journal</p>
        <h2 id="PrimeBlogNewsletterTitle">Calmer dog care, straight to your inbox.</h2>
        <p>
          Get practical chew guidance, enrichment ideas, and thoughtful Prime Pet Food updates
          for dogs who need more than a quick distraction.
        </p>
      </div>

      {% form 'customer', class: 'pbn-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter, blog_newsletter">

        <div class="pbn-field">
          <label for="PrimeBlogNewsletterEmail-{{ section.id }}">Email address</label>
          <input
            id="PrimeBlogNewsletterEmail-{{ section.id }}"
            type="email"
            name="contact[email]"
            value="{{ form.email }}"
            placeholder="Email address"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            required
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="PrimeBlogNewsletterError-{{ section.id }}"
            {% elsif form.posted_successfully? %}
              aria-describedby="PrimeBlogNewsletterSuccess-{{ section.id }}"
            {% endif %}
          >
          <button type="submit" name="commit">Subscribe</button>
        </div>

        {% if form.errors %}
          <p class="pbn-message pbn-message--error" id="PrimeBlogNewsletterError-{{ section.id }}">
            {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
          </p>
        {% endif %}

        {% if form.posted_successfully? %}
          <p class="pbn-message pbn-message--success" id="PrimeBlogNewsletterSuccess-{{ section.id }}" tabindex="-1">
            Thanks for subscribing. Check your inbox for Prime Pet Food updates.
          </p>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

<style>
  .prime-blog-newsletter {
    background: #fffaf2;
    color: #171512;
    font-family: var(--prime-font-sans, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif);
    padding: 72px 0;
  }

  .prime-blog-newsletter * {
    box-sizing: border-box;
  }

  .pbn-shell {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .pbn-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(340px, 0.72fr);
    gap: 36px;
    align-items: center;
    overflow: hidden;
    border: 1px solid rgba(55, 43, 31, 0.12);
    border-radius: 8px;
    background:
      radial-gradient(circle at 88% 12%, rgba(184, 95, 50, 0.18), transparent 32%),
      linear-gradient(135deg, #f8f1e7 0%, #ffffff 100%);
    padding: clamp(28px, 5vw, 56px);
    box-shadow: 0 24px 70px rgba(52, 42, 32, 0.08);
  }

  .pbn-kicker {
    margin: 0 0 12px;
    color: #b85f32;
    font-size: 12px;
    line-height: 1.25;
    letter-spacing: 0;
    text-transform: uppercase;
    font-weight: 780;
  }

  .pbn-copy h2 {
    max-width: 700px;
    margin: 0;
    color: #171512;
    font-family: var(--prime-font-display, var(--prime-font-sans, inherit));
    font-size: 42px;
    line-height: 1.08;
    font-weight: 735;
    letter-spacing: 0;
  }

  .pbn-copy p:not(.pbn-kicker) {
    max-width: 620px;
    margin: 18px 0 0;
    color: #5f574e;
    font-size: 17px;
    line-height: 1.7;
  }

  .pbn-form {
    width: 100%;
  }

  .pbn-field {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 10px;
    padding: 8px;
    border: 1px solid rgba(55, 43, 31, 0.14);
    border-radius: 999px;
    background: #ffffff;
  }

  .pbn-field label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .pbn-field input {
    width: 100%;
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: #171512;
    font: inherit;
    font-size: 16px;
    line-height: 1.4;
    padding: 13px 16px;
  }

  .pbn-field input::placeholder {
    color: rgba(95, 87, 78, 0.7);
  }

  .pbn-field button {
    min-height: 48px;
    border: 0;
    border-radius: 999px;
    background: #b85f32;
    color: #ffffff;
    cursor: pointer;
    font: inherit;
    font-size: 13px;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
    font-weight: 780;
    padding: 0 22px;
    transition: background 180ms ease, transform 180ms ease;
  }

  .pbn-field button:hover {
    background: #94451f;
    transform: translateY(-1px);
  }

  .pbn-message {
    margin: 12px 0 0;
    font-size: 14px;
    line-height: 1.5;
  }

  .pbn-message--error {
    color: #9f2d20;
  }

  .pbn-message--success {
    color: #276241;
  }

  @media (max-width: 820px) {
    .prime-blog-newsletter {
      padding: 52px 0;
    }

    .pbn-panel {
      grid-template-columns: 1fr;
      gap: 26px;
    }

    .pbn-copy h2 {
      font-size: 34px;
    }
  }

  @media (max-width: 560px) {
    .pbn-shell {
      width: min(100% - 24px, 1120px);
    }

    .pbn-panel {
      padding: 24px;
    }

    .pbn-copy h2 {
      font-size: 30px;
    }

    .pbn-copy p:not(.pbn-kicker) {
      font-size: 16px;
    }

    .pbn-field {
      grid-template-columns: 1fr;
      border-radius: 8px;
      padding: 10px;
    }

    .pbn-field input {
      padding: 12px;
    }

    .pbn-field button {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Prime blog newsletter",
  "tag": "section",
  "class": "section section-prime-blog-newsletter",
  "settings": [],
  "presets": [
    {
      "name": "Prime blog newsletter"
    }
  ]
}
{% endschema %}
