<section class="prime-contact-page" aria-labelledby="PrimeContactTitle">
  <div class="pcp-shell">
    <header class="pcp-hero">
      <p class="pcp-kicker">Contact Prime Pet Food</p>
      <h1 id="PrimeContactTitle">Real support for better chew decisions.</h1>
      <p>
        Questions about sizing, safety, orders, wholesale, or subscriptions? Send a note and
        we will help you choose the next best step. Average response time is 4 business hours
        Monday-Friday, 9am-5pm CT.
      </p>
    </header>

    <div class="pcp-grid">
      <aside class="pcp-support">
        <div class="pcp-note">
          <p class="pcp-kicker">Human help</p>
          <h2>Tell us about your dog.</h2>
          <p>For product questions, include breed, weight, age, and chewing style so we can give more useful guidance.</p>
        </div>

        <div class="pcp-response">
          <strong>Average response</strong>
          <span>4 business hours, Mon-Fri 9am-5pm CT</span>
        </div>

        <div class="pcp-cards">
          <div>
            <strong>Orders</strong>
            <span>Tracking, changes, delivery questions.</span>
          </div>
          <div>
            <strong>Product questions</strong>
            <span>Size, safety, duration, ingredients.</span>
          </div>
          <div>
            <strong>Wholesale</strong>
            <span>Retailer and bulk order support.</span>
          </div>
          <div>
            <strong>Subscription help</strong>
            <span>Billing, cadence, account updates.</span>
          </div>
        </div>

        <div class="pcp-links" aria-label="Helpful links">
          <a href="/pages/faq">FAQ</a>
          <a href="/pages/how-long-will-this-last-for-my-dog">Chew duration estimator</a>
          <a href="/collections/all">Shop yak chews</a>
          <a href="/pages/about-us">Our story</a>
        </div>
      </aside>

      <div class="pcp-form-card">
        {% form 'contact', class: 'pcp-form' %}
          {% if form.posted_successfully? %}
            <div class="pcp-success" tabindex="-1" autofocus>
              Thanks for reaching out. We received your message and will reply as soon as we can.
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="pcp-error" role="alert">
              Please check your email address and try again.
            </div>
          {% endif %}

          <div class="pcp-field pcp-field--half">
            <label for="PrimeContactName">Name</label>
            <input id="PrimeContactName" type="text" name="contact[Name]" autocomplete="name" value="{{ form.name }}" placeholder="Your name">
          </div>

          <div class="pcp-field pcp-field--half">
            <label for="PrimeContactEmail">Email</label>
            <input id="PrimeContactEmail" type="email" name="contact[email]" autocomplete="email" value="{{ form.email }}" placeholder="Email address" required>
          </div>

          <div class="pcp-field">
            <label for="PrimeContactTopic">What can we help with?</label>
            <select id="PrimeContactTopic" name="contact[Topic]" required>
              <option value="">Choose a topic</option>
              <option>Order support</option>
              <option>Product or sizing question</option>
              <option>Safety or digestion question</option>
              <option>Wholesale</option>
              <option>Subscription help</option>
              <option>Other</option>
            </select>
          </div>

          <div class="pcp-field">
            <label for="PrimeContactOrder">Order number, if you have one</label>
            <input id="PrimeContactOrder" type="text" name="contact[Order number]" placeholder="Optional">
          </div>

          <div class="pcp-field">
            <label for="PrimeContactMessage">Message</label>
            <textarea id="PrimeContactMessage" name="contact[body]" rows="6" placeholder="Tell us what is going on. For chew questions, include your dog's breed, weight, age, and chewing style." required>{{ form.body }}</textarea>
          </div>

          <button type="submit">Send message</button>
        {% endform %}
      </div>
    </div>
  </div>
</section>

<style>
  .prime-contact-page {
    background: #fffaf2;
    color: #171512;
    font-family: var(--prime-font-sans, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif);
    padding: 72px 0 86px;
  }

  .prime-contact-page * { box-sizing: border-box; }

  .pcp-shell {
    width: min(1160px, calc(100% - 32px));
    margin: 0 auto;
  }

  .pcp-kicker {
    margin: 0 0 12px;
    color: #b85f32;
    font-size: 12px;
    line-height: 1.25;
    letter-spacing: 0;
    text-transform: uppercase;
    font-weight: 780;
  }

  .pcp-hero {
    max-width: 800px;
    margin-bottom: 46px;
  }

  .pcp-hero h1,
  .pcp-note h2 {
    margin: 0;
    color: #171512;
    font-family: var(--prime-font-display, var(--prime-font-sans, inherit));
    font-size: 58px;
    line-height: 1.04;
    font-weight: 735;
    letter-spacing: 0;
  }

  .pcp-hero p,
  .pcp-note p {
    margin: 18px 0 0;
    color: #5f574e;
    font-size: 18px;
    line-height: 1.72;
  }

  .pcp-grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.8fr) minmax(0, 1.2fr);
    gap: 32px;
    align-items: start;
  }

  .pcp-support,
  .pcp-form-card {
    border: 1px solid rgba(55, 43, 31, 0.12);
    border-radius: 8px;
    background: #fff;
  }

  .pcp-support {
    display: grid;
    gap: 24px;
    padding: 28px;
  }

  .pcp-note h2 {
    font-size: 34px;
  }

  .pcp-note p {
    font-size: 16px;
  }

  .pcp-cards {
    display: grid;
    gap: 10px;
  }

  .pcp-response {
    padding: 16px;
    border: 1px solid rgba(184, 95, 50, 0.22);
    border-radius: 8px;
    background: #fff8f3;
  }

  .pcp-response strong,
  .pcp-response span {
    display: block;
  }

  .pcp-response strong {
    color: #171512;
    font-size: 15px;
    font-weight: 780;
  }

  .pcp-response span {
    margin-top: 4px;
    color: #5f574e;
    font-size: 14px;
    line-height: 1.45;
  }

  .pcp-cards div {
    padding: 16px;
    border-radius: 8px;
    background: #f8f1e7;
  }

  .pcp-cards strong,
  .pcp-cards span {
    display: block;
  }

  .pcp-cards strong {
    color: #171512;
    font-size: 16px;
    line-height: 1.25;
    font-weight: 760;
  }

  .pcp-cards span {
    margin-top: 5px;
    color: #5f574e;
    font-size: 14px;
    line-height: 1.45;
  }

  .pcp-links {
    display: grid;
    gap: 8px;
  }

  .pcp-links a {
    color: #94451f;
    font-size: 15px;
    line-height: 1.4;
    font-weight: 720;
    text-decoration: none;
  }

  .pcp-form-card {
    padding: clamp(24px, 4vw, 40px);
  }

  .pcp-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .pcp-field {
    display: grid;
    gap: 8px;
    grid-column: span 2;
  }

  .pcp-field--half {
    grid-column: span 1;
  }

  .pcp-field label {
    color: #302820;
    font-size: 14px;
    line-height: 1.25;
    font-weight: 720;
  }

  .pcp-field input,
  .pcp-field select,
  .pcp-field textarea {
    width: 100%;
    border: 1px solid rgba(55, 43, 31, 0.16);
    border-radius: 8px;
    background: #fffaf2;
    color: #171512;
    font: inherit;
    font-size: 16px;
    line-height: 1.45;
    padding: 14px;
  }

  .pcp-field textarea {
    resize: vertical;
  }

  .pcp-form button {
    grid-column: span 2;
    min-height: 52px;
    border: 0;
    border-radius: 999px;
    background: #b85f32;
    color: #fff;
    cursor: pointer;
    font: inherit;
    font-size: 13px;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
    font-weight: 780;
    padding: 0 26px;
  }

  .pcp-success,
  .pcp-error {
    grid-column: span 2;
    padding: 14px 16px;
    border-radius: 8px;
    font-size: 15px;
    line-height: 1.5;
  }

  .pcp-success {
    background: #edf7ef;
    color: #276241;
  }

  .pcp-error {
    background: #fff1ee;
    color: #9f2d20;
  }

  @media (max-width: 820px) {
    .prime-contact-page {
      padding: 54px 0 66px;
    }

    .pcp-grid {
      grid-template-columns: 1fr;
    }

    .pcp-hero h1 {
      font-size: 42px;
    }
  }

  @media (max-width: 560px) {
    .pcp-shell {
      width: min(100% - 24px, 1160px);
    }

    .pcp-hero h1 {
      font-size: 36px;
    }

    .pcp-hero p {
      font-size: 16px;
    }

    .pcp-field--half {
      grid-column: span 2;
    }
  }
</style>

{% schema %}
{
  "name": "Prime contact page",
  "tag": "section",
  "class": "section section-prime-contact-page",
  "settings": [],
  "presets": [
    {
      "name": "Prime contact page"
    }
  ]
}
{% endschema %}
