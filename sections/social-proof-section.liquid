{%- comment -%}theme-check-disable SchemaJsonFormat{%- endcomment -%}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_is_empty = true
  assign block_count = 0
  for block in section.blocks
    if block.settings.icon != blank or block.settings.text != blank or block.settings.title != blank or block.settings.image != blank
      assign section_is_empty = false
      assign block_count = block_count | plus: 1
    endif
  endfor
-%}

{%- if request.design_mode or section.settings.hide_when_empty == false or section_is_empty == false -%}
  {%- liquid
    assign columns_desktop = block_count
    assign columns_mobile = section.settings.columns_mobile | plus: 0

    assign show_mobile_slider = false
    if section.settings.mobile_layout == 'carousel'
      assign show_mobile_slider = true
    endif

    assign show_desktop_slider = false

    if settings.animations_reveal_on_scroll and section.index > 3 and section.location != 'header'
      assign animate = true
    else
      assign animate = false
    endif
  -%}

  <div class="social-proof-section color-{{ section.settings.color_scheme }} isolate gradient {{ section.settings.line_separator }} {{ section.settings.visibility }} {%- render 'class-time-of-day-to-show' -%}">
    <div class="icons-with-text section__inner section-content"
         style="padding-top: {{ section.settings.vertical_padding }}rem;padding-bottom: {{ section.settings.vertical_padding }}rem;"
    >
      <slider-component class="slider-mobile-gutter
        {% if show_mobile_slider == false %} page-width{% endif %}
        {% if show_desktop_slider == false %} page-width-desktop{% if section.settings.placement == 'beside' %} md:pl-0 md:pr-0{% endif %}{% endif %}
        {% if show_desktop_slider %} slider-component-desktop{% endif %}
        {% if animate %} scroll-trigger animate--slide-in{% endif %}"
      >
        <ul
            id="Slider-{{ section.id }}"
            class="section-grid grid mb-0 mt-0
            grid--{{ columns_desktop }}-col-desktop
            grid--central-loners
            {% if block_count == 0 %}
              grid--2-col-tablet-down
            {% else %}
              grid--{{ section.settings.columns_mobile }}-col-tablet-down
            {% endif %}
            {% if show_mobile_slider or show_desktop_slider %}
              slider
              {% if show_desktop_slider %} slider--desktop{% endif %}
              {% if show_mobile_slider %} slider--tablet grid--peek{% endif %}
            {% endif %}"
            role="list"
            {% if show_mobile_slider or show_desktop_slider %}tabindex="0"{% endif %}
            aria-label="{{ 'general.slider.name' | t }}"
        >
          {%- for block in section.blocks -%}
            {%- liquid
              if block.settings.title contains "<a " or block.settings.text contains "<a "
                assign content_has_link = true
              else
                assign content_has_link = false
              endif
            -%}
            <li
                id="Slide-{{ section.id }}-{{ forloop.index }}"
                class="icons-with-text__item grid__item pt-0 pb-0
                {% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}
                {% if animate %} scroll-trigger animate--slide-in{% endif %}"
                {{ block.shopify_attributes }}
                {% if animate %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
            >
              <{% if content_has_link == false and block.settings.card_link != blank %}a href="{{ block.settings.card_link }}"{% else %}div{% endif %}
                class="full-unstyled-link
                {% if section.settings.placement == 'beside' %}
                  flex h-full{% if columns_mobile > 1 %} md:justify-center{% else %} justify-center{% endif %} gap-1 md:gap-2
                  {{ section.settings.content_vertical_alignment }}
                {% else %}
                  block text-{{ section.settings.column_alignment }}
                {% endif %}"
              >
                {%- if block.settings.image != blank or block.settings.icon != blank -%}
                  <div class="icons-with-text__icon flex justify-{{ section.settings.column_alignment }}
                        {% if section.settings.placement == 'above' %} mb-05em last-child:mb-0{% endif %}"
                  >
                    {%- if block.settings.image != blank -%}
                      {%- assign image_height = block.settings.image_width | divided_by: block.settings.image.aspect_ratio -%}
                      {% capture sizes %}(max-width: {{ block.settings.image_width | times: 2 }}px) 50vw, {{ block.settings.image_width | times: 2 }}px{% endcapture %}
                      {% capture widths %}{{ block.settings.image_width }}, {{ block.settings.image_width | times: 1.5 | round }}, {{ block.settings.image_width | times: 2 }}{% endcapture %}
                      {{ block.settings.image | image_url: width: 600 | image_tag:
                        widths: widths,
                        height: image_height,
                        width: block.settings.image_width,
                        sizes: sizes
                      }}
                    {%- elsif block.settings.icon != blank -%}
                        {%- liquid
                          if section.settings.placement == 'beside' and section.settings.content_vertical_alignment == 'items-center'
                            assign icon_class = 'flex items-center'
                          else
                            assign icon_class = nil
                          endif
                          render 'standard-blocks', type: 'icon', section_name: 'icons-with-text', block: block, class: icon_class, animate: animate
                        -%}
                    {%- endif -%}
                  </div>
                {%- endif -%}

                {%- if block.settings.title != blank or block.settings.text != blank -%}
                  <div class="icons-with-text__text-wrapper">
                    {%- if block.settings.title != blank -%}
                      <div
                          class="icons-with-text__heading section-content__text rte {{ section.settings.heading_size }}
                            {% if animate %} scroll-trigger animate--slide-in{% endif %}"
                          {% if animate %}
                            data-cascade
                            style="--animation-order: {{ forloop.index | default: 1 }};"
                          {% endif %}
                      >
                        {{ block.settings.title }}
                      </div>
                    {%- endif -%}

                    {%- if block.settings.text != blank -%}
                      {% render 'standard-blocks', type: 'text', section_name: 'icons-with-text', block: block, animate: animate %}
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </{% if content_has_link == false and block.settings.card_link != blank %}a{% else %}div{% endif %}>
            </li>
          {%- endfor -%}
        </ul>
      </slider-component>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Social Proof Section",
  "tag": "section",
  "class": "section section-social-proof",
  "disabled_on": {
    "groups": ["aside"]
